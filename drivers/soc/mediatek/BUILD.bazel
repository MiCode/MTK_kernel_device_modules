define_platform_scpsys_ko("mt6853")
define_platform_scpsys_ko("mt6877")
define_platform_scpsys_ko("mt6886")
define_platform_scpsys_ko("mt6893")
define_platform_scpsys_ko("mt6897")
define_platform_scpsys_ko("mt6899")
define_platform_scpsys_ko("mt6983")
define_platform_scpsys_ko("mt6985")
define_platform_scpsys_ko("mt6989")
define_platform_scpsys_ko("mt6855")

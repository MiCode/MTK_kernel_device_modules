load("//build/bazel_mgk_rules:mgk_ddk_ko.bzl", "define_mgk_ddk_ko")
load("@mgk_info//:kernel_version.bzl","kernel_version")
load("//build/kernel/kleaf:kernel.bzl", "ddk_headers")

package(
    default_visibility = [
        "//visibility:public",
    ],
)

ddk_headers(
    name = "ddk_public_headers",
    hdrs = glob([
        "**/*.h",
    ]),
    includes = ["."],
)

define_mgk_ddk_ko(
    name = "mdp_drv_dummy",

    srcs = ["mdp_drv_dummy.c"],

    hdrs = glob(["**/*.h"]),

    copts = ["-I$(DEVICE_MODULES_PATH)/drivers/gpu/drm/mediatek/dpc"],

)

filegroup(
    name = "ddk_kconfigs",
    srcs = glob([
        "**/Kconfig",
        "drivers/misc/mediatek/mdp/Kconfig",
        "drivers/misc/mediatek/mdp/Kconfig.*",
    ])
)

filegroup(
    name = "ddk_src",
    srcs = glob([
          "**/Makefile",
          "**/Kbuild",
          "**/*.c",
          "**/*.h",
    ]),
)

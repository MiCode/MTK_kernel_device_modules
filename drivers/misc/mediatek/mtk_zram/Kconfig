config MTK_ZRAM
	tristate "MTK zram feature"
	depends on BLOCK && SYSFS && MMU
	depends on CRYPTO_LZ4
	select ZSMALLOC
	help
	  Creates virtual block devices called /dev/block/zramX (X = 0, 1, ...).
	  Pages written to these disks are compressed and stored in memory itself.
	  These disks allow very fast I/O and compression provides good amounts of
	  memory savings.
	  If you are not sure about whether to enable it or not, please set n.

config MTK_ZRAM_ENGINE
	tristate "MTK zram engine feature"
	help
	  MTK proprietary compression engine, which is highly integrated with
	  ZRAM to provide fast and light-loading compression tasks.
	  This is used for the improvement of sw compression over some scenarios.
	  If you are not sure about whether to enable it or not, please set n.

config ZRAM_ENGINE_COMP_FIFO_1_BITS
	int "The entry bits of ZRAM ENGINE Compression FIFO #1 (5-11)"
	range 5 11
	default "8"
	help
	  This will create a fifo with depth of 2^5 ~ 2^11.

config ZRAM_ENGINE_COMP_FIFO_2_BITS
	int "The entry bits of ZRAM ENGINE Compression FIFO #2 (5-11)"
	range 5 11
	default "7"
	help
	  This will create a fifo with depth of 2^5 ~ 2^11.

config ZRAM_ENGINE_DECOMP_FIFO_BITS
	int "The entry bits of ZRAM ENGINE Decompression FIFOs (0-7)"
	range 0 7
	default "3"
	help
	  When setting to 0, the way of waiting for decompression completion
	  will be changed to synchronous mode. Asynchronous mode for others.

config HWCOMP_SUPPORT_NO_DST_COPY
	bool "No extra SW copy to store HW compressed data"
	default y
	help
	  Original zram uses zsmalloc to store compressed data. The flow is to compress
	  SRC page and then copy the compressed data to zsmalloc. Turn on this option will
	  use slab memory to store compressed data directly without the SW copy.

config ZRAM_ENGINE_SW_SIMULATION
	bool "Do SW simulation"
	default n
	help
	  Do SW simulation to verify the correctness of drivers.

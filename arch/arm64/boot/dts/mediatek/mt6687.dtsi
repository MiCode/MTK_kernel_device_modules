#include <dt-bindings/spmi/spmi.h>

&spmi {
	mt6687_mfd: mt6687-mfd {
		compatible = "mediatek,mt6687";
		reg = <0x9 SPMI_USID>;
		mt6687_clkbuf: mt6687-clkbuf {
			compatible = "mediatek,mt6687-clkbuf";
			XO-BBCK1 {
				perms = <0xfffc>;
				xo-id = <0>;
			};
			XO-BBCK2 {
				xo-id = <1>;
			};
			XO-BBCK3 {
				xo-id = <2>;
			};
			XO-BBCK4 {
				xo-id = <3>;
			};
			XO-BBCK5 {
				xo-id = <4>;
			};
			XO-BBCK6 {
				xo-id = <5>;
			};
			XO-RFCK1A {
				xo-id = <6>;
			};
			XO-RFCK1B {
				xo-id = <7>;
			};
			XO-RFCK1C {
				xo-id = <8>;
			};
			XO-RFCK2A {
				xo-id = <9>;
			};
			XO-RFCK2B {
				xo-id = <10>;
			};
			XO-RFCK2C {
				xo-id = <11>;
			};
		};
	};
};

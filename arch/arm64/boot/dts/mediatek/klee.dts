&peak_power_budget {
	compatible = "mediatek,peak_power_budget";

	battery-circult-rdc = <14>;
	battery0-path-rac-t0 = <44>;
	battery0-path-rac-t1 = <44>;
	battery0-path-rac-t2 = <44>;
	battery0-path-rac-t3 = <44>;
	battery0-path-rac-t4 = <44>;
	battery0-path-rac-t5 = <44>;
	battery1-path-rac-t0 = <44>;
	battery1-path-rac-t1 = <44>;
	battery1-path-rac-t2 = <44>;
	battery1-path-rac-t3 = <44>;
	battery1-path-rac-t4 = <44>;
	battery1-path-rac-t5 = <44>;
	battery2-path-rac-t0 = <44>;
	battery2-path-rac-t1 = <44>;
	battery2-path-rac-t2 = <44>;
	battery2-path-rac-t3 = <44>;
	battery2-path-rac-t4 = <44>;
	battery2-path-rac-t5 = <44>;
	battery3-path-rac-t0 = <44>;
	battery3-path-rac-t1 = <44>;
	battery3-path-rac-t2 = <44>;
	battery3-path-rac-t3 = <44>;
	battery3-path-rac-t4 = <44>;
	battery3-path-rac-t5 = <44>;
	max-temperature-stage = <5>;
	temperature-threshold = <50 25 10 0 0xFFFFFFF6>;
	system-ocp = <13000>;
	system-uvlo = <2400>;
	bat-ocv-table-num = <0>;
};

&low_battery_throttling {
	compatible = "mediatek,low_battery_throttling";
	lvsys-thd-enable = <1>;
	vbat-thd-enable = <1>;
	bat0-thd-volts-l = <
		3210 2791 2600
		3307 2835 2600

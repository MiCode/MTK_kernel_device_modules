&i2c5 {
	status = "ok";
	hl7603@77 {
		compatible = "hl7603";
		reg = <0x77>;
		vout_threshold = <3400>;
	};
};

&lk_charger {
	/* charging current */
	usb-charger-current = <500000>;
	ac-charger-current = <1800000>;
	ac-charger-input-current = <2000000>;
	non-std-ac-charger-current = <1500000>;
	charging-host-charger-current = <1500000>;
	ta-ac-charger-current = <1500000>;
	pd-charger-current = <1500000>;
	/* battery temperature protection */
	temp-t4-threshold = <60>;
	temp-t3-threshold = <45>;
	pre-charger-current = <500000>;
	fast-charge-voltage = <3100>;
	//max-charger-voltage = <12000000>;
	shutdown-voltage = <3200>;
	boot-battery-voltage = <3200000>;
};

&pd_cp_manager {
	compatible = "pd_cp_manager";
	fv = <4502>;
	fv_ffc = <4552>;
	fv_ffc_gl = <4572>;
	max_fcc = <17600>;
	max_vbus = <20000>;
	max_ibus = <4400>;
	fcc_low_hyst = <150>;
	fcc_high_hyst = <10>;
	low_tbat = <100>;
	high_tbat = <480>;
	high_vbat = <4400>;
	high_soc = <95>;
	low_fcc = <2000>;
	cv_vbat = <4480>;
	cv_vbat_ffc = <4510>;
	cv_ibat = <1500>;
	//cv_ibat_bypass = <1300>;
	//vbus_low_gap_div = <400>;
	//vbus_high_gap_div = <600>;
	min_pdo_vbus = <8000>;
	max_pdo_vbus = <21000>;
	mt6375_control_gpio = <&pio 77 0x0>;
	lsw_control_gpio = <&pio 26 0x0>;
	support_4_1_mode;
	support_pmic_parachg;
	switch1_1_enter = <2500>;
	switch1_1_exit = <3700>;
	switch2_1_enter = <4200>;
	switch2_1_exit = <6500>;
	pdm_ibus_gap = <600>;
	pdm_bypass_ibus_gap = <2600>;
	adapter_power = <100>;
	fv_hyst = <9>;
};

&mtk_gauge {
	DISABLE_MTKBATTERY = <(1)>;
	FIXED_BATTERY_TEMPERATURE = <25>;

	temperature-t0 = <(50)>;
	/* Battery temperature T0 */
	temperature-t1 = <(25)>;
	/* Battery temperature T1 */
	temperature-t2 = <(10)>;
	/* Battery temperature T2 */
	temperature-t3 = <(0)>;
	/* Battery temperature T3 */
	temperature-t4 = <(-10)>;
	/* Battery temperature T4 */
	temperature-t5 = <(-20)>;
	/* Battery temperature T5 */
	active-table = <(6)>;
	#include "klee_mt6899_battery_table.dtsi"
};

&u2port0{
	mediatek,discth = <0xb>;
	mediatek,rev6 = <3>;
	mediatek,eye-term = <7>;
	mediatek,eye-vrt = <7>;
	mediatek,rx-sqth = <2>;
	mediatek,intr-ofs = "0";
	mediatek,term-ofs = "2";

	mediatek,rev6-host = <3>;
	mediatek,eye-term-host = <7>;
	mediatek,eye-vrt-host = <7>;
	mediatek,host-rx-sqth = <3>;
	mediatek,host-intr-ofs = "0";
	mediatek,host-term-ofs = "0";
};
/* charger end */

/* svp start */
&mtee_svp {
	mtee: MTEE {
		compatible = "mediatek,mtk_svp_on_mtee_support";
	};

	svp: SecureVideoPath {
		compatible = "mediatek,mtk_sec_video_path_support";
	};
};

&mtkheap_page_svp {
	status = "ok";
};

&mtkheap_region_svp {
	status = "ok";
};
/* svp end */


	DISABLE_MTKBATTERY = <(1)>;
	FIXED_BATTERY_TEMPERATURE = <25>;
	#include "klimt_mt6991_battery_table.dtsi"
};
/* charger end */

/* usb typec mux start */
&pio {

	ps_enable: ps_enable {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO207__FUNC_GPIO207>;
			output-high;
		};
	};

	ps_disable: ps_disable {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO207__FUNC_GPIO207>;
			output-low;
		};
	};

};

&mt6379_typec {
	tcpc,en_floatgnd;
	/* 0:16x, 1:128x, 2:512x, 3:1024x */
	wd,wd0_tsleep = <1>;
	/* 0:400us, 1:1ms, 2:2ms, 3:4ms, 4:10ms, 5:40ms, 6:100ms, 7:400ms */
	wd,wd0_tdet = <3>;
	/* example wd0_tsleep = 512x, wd0_tdet = 4ms, wd0 polling time = 512*4ms */

	port {
		tcpc_typec_usb: endpoint {
			remote-endpoint = <&ssusb_mux>;
		};
	};
};

&typec_mux_switch {
	orientation-switch;
	mode-switch;
	accessory;
	port {
		ssusb_mux: endpoint {
			remote-endpoint = <&tcpc_typec_usb>;
		};
	};
};

&ps5170 {
	pinctrl-names = "enable", "disable";
	pinctrl-0 = <&ps_enable>;
	pinctrl-1 = <&ps_disable>;
	status = "disabled";
};

&usb_dp_selector {
	status = "okay";
};
/* usb typec mux end */

/* SI Haptic */
&pio {
	sih_reset_low: sih_reset_reset {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO42__FUNC_GPIO42>;
			drive-strength = <2>;
			bias-disable;
			output-low;
		};
	};
	sih_reset_high: sih_reset_active {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO42__FUNC_GPIO42>;
			drive-strength = <2>;
			bias-disable;
			output-high;
		};
	};
	sih_interrupt: sih_interrupt_active {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO5__FUNC_GPIO5>;
			drive-strength = <2>;
			bias-pull-up;
			input-enable;
		};
	};
};
/* SI Haptic */

&aud_gpio_ap_dmic56_on {
	pins-cmd1-dat {
		pinmux = <PINMUX_GPIO25__FUNC_DMIC2_CLK>;
		input-schmitt-enable;
		bias-disable;
	};
	pins-cmd2-dat {
		pinmux = <PINMUX_GPIO26__FUNC_DMIC2_DAT>;
		input-schmitt-enable;
		bias-disable;
	};
};

&aud_gpio_ap_dmic56_off {
	pins-cmd1-dat {
		pinmux = <PINMUX_GPIO25__FUNC_GPIO25>;
		input-enable;
		bias-pull-down;
	};
	pins-cmd2-dat {
		pinmux = <PINMUX_GPIO26__FUNC_GPIO26>;
		input-enable;
		bias-pull-down;
	};
};

&i2c1 {
    clock-frequency = <400000>;
	status = "ok";
	/* SI Haptic */
	sih6887_haptic:sih6887_haptic@6B{
		compatible = "silicon,sih_haptic_688X";
		reg = <0x6B>;
		reset-gpio = <&pio 42 0>;
		irq-gpio = <&pio 5 0>;
		interrupt=<26 1>;
		pinctrl-names = "sih_reset_reset","sih_reset_active","sih_interrupt_active";
		pinctrl-0 = <&sih_reset_low>;
		pinctrl-1 = <&sih_reset_high>;
		pinctrl-2 = <&sih_interrupt>;
		lra_name = "0809";
		vib_effect_id_boundary = < 10 >;
		vib_effect_max = < 197 >;
		vib_f0_pre = < 1700 >;
		vib_bst_vol_default = < 95 >;
    };
	/* SI Haptic */
};

&pio {
	sia91xx_gpio_L: sia91xx_gpio_L {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO91__FUNC_GPIO91>;
			slew-rate = <1>;
			bias-disable;
		};
	};
	sia91xx_gpio_R: sia91xx_gpio_R {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO174__FUNC_GPIO174>;
			slew-rate = <1>;
			bias-disable;
		};
	};
	sia91xx_irq_gpio_L: sia91xx_irq_gpio_L {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO39__FUNC_GPIO39>;
			bias-pull-up;
			input-enable;
		};
	};
	sia91xx_irq_gpio_R: sia91xx_irq_gpio_R {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO94__FUNC_GPIO94>;
			bias-pull-up;
			input-enable;
		};
	};
};

&odm {
	sia91xx_L: sia91xx@L {
		compatible = "si,sia91xx";
		si,si_pa_type = "sia9187";
		si,si_pa_irq = <&pio 39 0x0>;
		si,si_pa_reset = <&pio 91 0>;
		pinctrl-names = "si_pa_gpio", "si_pa_irq";
		pinctrl-0 = <&sia91xx_gpio_L>;
		pinctrl-1 = <&sia91xx_irq_gpio_L>;
		si,si_pa_disable_pin = <0>;
		spksw-gpio = <&pio 210 0>;
		en_irq_func = <1>;
		channel_num = <0>;
	};
	sia91xx_R: sia91xx@R {
		compatible = "si,sia91xx";
		si,si_pa_type = "sia9187";
		si,si_pa_irq = <&pio 94 0x0>;
		si,si_pa_reset = <&pio 174 0>;
		pinctrl-names = "si_pa_gpio", "si_pa_irq";
		pinctrl-0 = <&sia91xx_gpio_R>;
		pinctrl-1 = <&sia91xx_irq_gpio_R>;
		si,si_pa_disable_pin = <0>;
		en_irq_func = <1>;
		channel_num = <1>;
	};
};

&sound {
	si,sia81xx-max-num = <2>;
	si,is_digital_pa = <1>;
	si,sia81xx-aux-devs = <&sia91xx_i2c_L>, <&sia91xx_i2c_R>;
	si,sia81xx-aux-devs-prefix = "SpkrLeft", "SpkrRight";
};

&i2c0 {
	clock-frequency = <400000>;
	mediatek,use-open-drain;
/*receiver*/
	sia91xx_i2c_L: sia91xx_i2c@L {
		compatible = "si,sia91xx-i2c";
		#sound-dai-cells = <0>;
		reg = <0x6C>;
		si,sipa-dev = <&sia91xx_L>;
		sound-name-prefix = "SpkrLeft";
		status = "okay";
	};
/*speaker*/
	sia91xx_i2c_R: sia91xx_i2c@R {
		compatible = "si,sia91xx-i2c";
		#sound-dai-cells = <0>;
		reg = <0x6D>;
		si,sipa-dev = <&sia91xx_R>;
		sound-name-prefix = "SpkrRight";
		status = "okay";
	};
	
};

&sound {
	mediatek,spk-i2s = <25 24>;
	mediatek,speaker-codec {
		sound-dai = <&sia91xx_i2c_L>,<&sia91xx_i2c_R>;
	};
};

#if 0
&pdc {
	pd_vbus_upper_bound = <12000000>;
};
#endif

&connfem {
	sku {
		hw-names =
			"qm42655_qm45655_2g2a_o12u";	/* [0] QM42655/QM45655, 2G+2A */

		/***************************************************************
		 * [HW][0] QM42655/QM45655, 2G+2A
		 **************************************************************/
		hw-0 {
			using-fems =
				<&qm42655>,
				<&qm45655>;

			layout-flag = <0x00000000>;
			layout =
				<&g_wf0_bt0_qm42655>,
				<&g_wf1_bt1_qm42655>,
				<&a_wf0_qm45655>,
				<&a_wf1_qm45655>;

			common {
				flags {
					fe-ant-cnt = [85];
					fe-conn-dpdt-sp3t = [80];
					fe-conn-spdt = [80];
					fe-bt-wf-usage = [80];
					fe-conn-spdt-2 = [80];
				};
			};

			wifi {
				using-states =
					<&qm42655_rxl>,
					<&qm45655_rxh>;
			};

			bt {
				flags {
					efem-mode = [03]; /* 3:epa_elna, 2:epa, 1:elna, 0:bypass */
					rx-mode = [24]; /* 0x24: G-band RxL */
				};
			};
		};
	};
};


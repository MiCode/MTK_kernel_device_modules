			gpio-num = <96>;
			eint-no = <1>; /* Max to 3, options:{1, 2, 3} */

			port {
				seninf_csi_port_3_in: endpoint@1 {
					remote-endpoint = <&sensor0_out>;
				};
			};
		};
};
#endif

&mt6363_pio {
	camera_pins_cam2_dvdd_0: cam4@0 {
		pins-1 {
			pinmux = <PINMUX_MT6363_GPIO4__FUNC_GPIO4>;
			drive-strengh = <15>;
			output-low;
		};
	};

	camera_pins_cam2_dvdd_1: cam4@1 {
		pins-1 {
			pinmux = <PINMUX_MT6363_GPIO4__FUNC_GPIO4>;
			drive-strengh = <15>;
			output-high;
		};
	};

	camera_pins_cam4_avdd_0: cam4@4 {
		pins-1 {
			pinmux = <PINMUX_MT6363_GPIO7__FUNC_GPIO7>;
			drive-strengh = <15>;
			output-low;
		};
	};
	camera_pins_cam4_avdd_1: cam4@5 {
		pins-1 {
			pinmux = <PINMUX_MT6363_GPIO7__FUNC_GPIO7>;
			drive-strengh = <15>;
			output-high;
		};
	};

	camera_pins_cam4_dvdd_0: cam4@2 {
		pins-1 {
			pinmux = <PINMUX_MT6363_GPIO5__FUNC_GPIO5>;
			drive-strengh = <15>;
			output-low;
		};
	};

	camera_pins_cam4_dvdd_1: cam4@3 {
		pins-1 {
			pinmux = <PINMUX_MT6363_GPIO5__FUNC_GPIO5>;
			drive-strengh = <15>;
			output-high;
		};
	};

	camera_pins_cam4_oisvdd_0: cam4@6 {
		pins-1 {
			pinmux = <PINMUX_MT6363_GPIO6__FUNC_GPIO6>;
			drive-strengh = <15>;
			output-low;
		};
	};
	camera_pins_cam4_oisvdd_1: cam4@7 {
		pins-1 {
			pinmux = <PINMUX_MT6363_GPIO6__FUNC_GPIO6>;
			drive-strengh = <15>;
			output-high;
		};
	};
};

&i2c6 {
	lm3644:lm3644@63 {
		compatible = "mediatek,lm3644";
		reg = <0x63>;
		#cooling-cells = <2>;
		pinctrl-names = "default", "hwen-high", "hwen-low";
		pinctrl-0 = <&lm3644_pins_default>;
		pinctrl-1 = <&lm3644_pins_hwen_high>;
		pinctrl-2 = <&lm3644_pins_hwen_low>;
		status = "okay";
		flash@0{
			reg = <0>;
			type = <0>;
			ct = <0>;
			part = <0>;
			port@0 {
				fl_core_0: endpoint {
					remote-endpoint = <&flashlight_0>;
				};
			};
		};
		flash@1{
			reg = <1>;
			type = <0>;
			ct = <1>;
			part = <0>;
			port@1 {
				fl_core_1: endpoint {
					remote-endpoint = <&flashlight_1>;
				};
			};
		};
	};
};


		pinctrl-1 = <&camera_pins_cam0_mclk_2ma>;
		pinctrl-2 = <&camera_pins_cam0_mclk_4ma>;
		pinctrl-3 = <&camera_pins_cam0_mclk_6ma>;
		pinctrl-4 = <&camera_pins_cam0_mclk_8ma>;
		pinctrl-5 = <&camera_pins_cam0_rst_0>;
		pinctrl-6 = <&camera_pins_cam0_rst_1>;
		pinctrl-7 = <&camera_pins_cam0_scl_ap>;
		pinctrl-8 = <&camera_pins_cam0_scl_scp>;
		pinctrl-9 = <&camera_pins_cam0_sda_ap>;
		pinctrl-10 = <&camera_pins_cam0_sda_scp>;
		pinctrl-11 = <&camera_pins_cam0_oisvdd_0>;
		pinctrl-12 = <&camera_pins_cam0_oisvdd_1>;
		pinctrl-13 = <&camera_pins_cam0_ois_en_0>;
		pinctrl-14 = <&camera_pins_cam0_ois_en_1>;

		avdd-supply =  <&rt5133_ldo5>;  // 2.8V
		avdd1-supply =  <&camera_pin_cam0_avdd1>;  // 1.8V
		dvdd-supply = <&rt5133_ldo7>;  // 1.1v for ov48b
		dvdd1-supply = <&camera_pin_cam0_dvdd>;  // 0.81v for tri cam
		afvdd1-supply = <&rt5133_gpio1>;
		dovdd-supply = <&camera_vcamd_pmu>;  // iovdd 1.8v share
		base-supply = <&rt5133_base>;

		clocks = <&cksys_reg_clk CLK_CKSYS_REG_UNIVPLL_192M_D32>,
			<&cksys_reg_clk CLK_CKSYS_REG_UNIVPLL_192M_D16>,
			<&cksys_reg_clk CLK_CKSYS_REG_F26M_CK_D2>,
			<&cksys_reg_clk CLK_CKSYS_REG_UNIVPLL_192M_D10>,
			<&cksys_reg_clk CLK_CKSYS_REG_UNIVPLL_192M_D8>,
			<&cksys_reg_clk CLK_CKSYS_REG_TCK_26M_MX9>,
			<&cksys_reg_clk CLK_CKSYS_REG_OSC_D10>,
			<&cksys_reg_clk CLK_CKSYS_REG_UNIVPLL_D6_D8>,
			<&cksys_reg_clk CLK_CKSYS_REG_CAMTG1_SEL>;

		clock-names = "6", "12", "13", "19.2", "24", "26", "26_ulposc", "52", "mclk";


		status = "okay";
		port {
			sensor0_out: endpoint {
				remote-endpoint = <&seninf_csi_port_3_in>;
			};
		};
	};

	mtk_camera_eeprom:camera-eeprom0@50 {
		compatible = "mediatek,camera_eeprom";
		reg = <0x50 0 0>;
		names = "imx06c_cust_eeprom",
			"ov48b_mtk_eeprom";
		status = "okay";
	};
#endif
};


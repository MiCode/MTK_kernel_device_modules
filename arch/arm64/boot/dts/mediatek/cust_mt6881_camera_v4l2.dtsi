&rt5133_ldo7 {
	rt5133-ldo1-supply = <&camera_vcamd_pmu>;
};

&rt5133_ldo8 {
	rt5133-ldo1-supply = <&camera_vcamd_pmu>;
};

&odm {
	camera_vcamd_pmu: camera-vcamd-pmu {
		compatible = "regulator-fixed";
		regulator-name = "amera-vcamd-pmu";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		enable-active-high;
		gpio = <&pio 144 0x0>;
	};

	camera_pin_cam0_dvdd:camera-pin-cam0-dvdd {
		compatible = "regulator-fixed";
		regulator-name = "camera-pin-cam0-dvdd";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		enable-active-high;
		gpio = <&pio 32 0x0>;
	};

	camera_pin_cam0_avdd1:camera-pin-cam0-avdd1 {
		compatible = "regulator-fixed";
		regulator-name = "camera-pin-cam0-avdd1";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		enable-active-high;
		gpio = <&pio 33 0x0>;
	};
};

&mtk_composite_v4l2_1 {
	port@0 {
		flashlight_0: endpoint {
			remote-endpoint = <&fl_core_0>;
		};
	};
	port@1 {
		flashlight_1: endpoint {
			remote-endpoint = <&fl_core_1>;
		};
	};
};

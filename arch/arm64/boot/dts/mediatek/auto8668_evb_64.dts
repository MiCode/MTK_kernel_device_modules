&mmc1 {
	compatible = "mediatek,mt8668-mmc";
	vmmc-supply = <&mt6373_vmch_eint_high>;
	vqmmc-supply = <&mt6373_vmc>;
};

#include <auto8668p1_64/cust.dtsi>
#include "mediatek/cust_mt8668_display_interface_EVB.dtsi"
#include "mediatek/cust_mt8668_display_serdes_config.dtsi"
#include "mediatek/cust_mt8668_display_config_main.dtsi"

&rt5133_ldo7 {
	rt5133-ldo1-supply = <&camera_vcamd_pmu>;
};

&rt5133_ldo8 {
	rt5133-ldo1-supply = <&camera_vcamd_pmu>;
};

&odm {
	camera_vcamd_pmu: camera-vcamd-pmu {
		compatible = "regulator-fixed";
		regulator-name = "amera-vcamd-pmu";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		enable-active-high;
		gpio = <&pio 182 0x0>;
	};

	camera_pin_cam0_tof:camera-pin-cam0-tof {
		compatible = "regulator-fixed";
		regulator-name = "camera-pin-cam0-tof";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		enable-active-high;
		gpio = <&pio 184 0x0>;
	};

	camera_pin_cam0_dvdd:camera-pin-cam0-dvdd {
		compatible = "regulator-fixed";
		regulator-name = "camera-pin-cam0-dvdd";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		enable-active-high;
		gpio = <&pio 192 0x0>;
	};

	camera_pin_cam0_avdd1:camera-pin-cam0-avdd1 {
		compatible = "regulator-fixed";
		regulator-name = "camera-pin-cam0-avdd1";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		enable-active-high;
		gpio = <&pio 193 0x0>;
	};

	camera_pin_cam2_dvdd:camera-pin-cam2-dvdd {
		compatible = "regulator-fixed";
		regulator-name = "camera-pin-cam2-dvdd";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		enable-active-high;
		gpio = <&pio 212 0x0>;
	};

	camera_pin_cam4_dvdd:camera-pin-cam4-dvdd {
		compatible = "regulator-fixed";
		regulator-name = "camera-pin-cam4-dvdd";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		enable-active-high;
		gpio = <&pio 215 0x0>;
	};
};

&mtk_composite_v4l2_2 {
	#address-cells = <1>;
	#size-cells = <0>;
	port@0 {
		reg = <0>;
		main_af_endpoint: endpoint {
			remote-endpoint = <&main_af>;
		};
	};
	port@1 {
		reg = <1>;
		main_af_cam1_endpoint: endpoint {
			remote-endpoint = <&main_af_cam1>;
		};
	};
	port@2 {
		reg = <2>;
		main_af_cam2_endpoint: endpoint {
			remote-endpoint = <&main_af_cam2>;
		};
	};
	port@3 {
		reg = <3>;
		main_tof_endpoint: endpoint {
			remote-endpoint = <&main_tof>;
		};
	};
};

&i2c4 {
	status = "okay";
	clock-frequency = <1000000>;

	camera-af-main@c {
		compatible = "mediatek,main_vcm";
		reg = <0x0c 0 0>;
		vin-supply = <&rt5133_gpio1>;
		port {
			main_af: endpoint {
				remote-endpoint = <&main_af_endpoint>;
			};
		};
	};

	sensor0: sensor0@36 {
		compatible = "mediatek,imgsensor";
		sensor-names = "ov48b_mipi_raw",
					"imx06a_mipi_raw",
					"imx06c_mipi_raw";
		reg = <0x36 0 0>;
		maximum-pmic-delay = <4000>;

		#thermal-sensor-cells = <0>;

		pinctrl-names = "mclk_off",
				"mclk_2mA",
				"mclk_4mA",
				"mclk_6mA",
				"mclk_8mA",
				"rst_low",
				"rst_high",
				"scl_ap",
				"scl_scp",
				"sda_ap",
				"sda_scp",
				"oisvdd_off",
				"oisvdd_on",
				"oisen_off",
				"oisen_on";
		pinctrl-0 = <&camera_pins_cam0_mclk_off>;
		pinctrl-1 = <&camera_pins_cam0_mclk_2ma>;
		pinctrl-2 = <&camera_pins_cam0_mclk_4ma>;
		pinctrl-3 = <&camera_pins_cam0_mclk_6ma>;
		pinctrl-4 = <&camera_pins_cam0_mclk_8ma>;
		pinctrl-5 = <&camera_pins_cam0_rst_0>;
		pinctrl-6 = <&camera_pins_cam0_rst_1>;
		pinctrl-7 = <&camera_pins_cam0_scl_ap>;
		pinctrl-8 = <&camera_pins_cam0_scl_scp>;
		pinctrl-9 = <&camera_pins_cam0_sda_ap>;
		pinctrl-10 = <&camera_pins_cam0_sda_scp>;
		pinctrl-11 = <&camera_pins_cam0_oisvdd_0>;
		pinctrl-12 = <&camera_pins_cam0_oisvdd_1>;
		pinctrl-13 = <&camera_pins_cam0_ois_en_0>;
		pinctrl-14 = <&camera_pins_cam0_ois_en_1>;

		avdd-supply =  <&rt5133_ldo5>;  // 2.8V
		avdd1-supply =  <&camera_pin_cam0_avdd1>;  // 1.8V
		dvdd-supply = <&rt5133_ldo7>;  // 1.1v for ov48b
		dvdd1-supply = <&camera_pin_cam0_dvdd>;  // 0.81v for tri cam
		afvdd1-supply = <&rt5133_gpio1>;
		dovdd-supply = <&camera_vcamd_pmu>;  // iovdd 1.8v share
		base-supply = <&rt5133_base>;

		clocks = <&cksys_top_clk CKSYS_TOP_UNIVPLL_192M_D32>,
			<&cksys_top_clk CKSYS_TOP_UNIVPLL_192M_D16>,
			<&cksys_top_clk CKSYS_VLP_F26M_CK_D2>,
			<&cksys_top_clk CKSYS_TOP_UNIVPLL_192M_D10>,
			<&cksys_top_clk CKSYS_TOP_UNIVPLL_192M_D8>,
			<&cksys_top_clk CKSYS_TOP_UNIVPLL_D6_D16>,
			<&cksys_vlp_clk CKSYS_VLP_OSC3>,
			<&cksys_top_clk CKSYS_TOP_UNIVPLL_D6_D8>,
			<&cksys_vlp_clk VLP_CAMTG1_SEL>;

		clock-names = "6", "12", "13", "19.2", "24", "26", "26_ulposc", "52", "mclk";


		status = "okay";
		port {
			sensor0_out: endpoint {
				remote-endpoint = <&seninf_csi_port_3_in>;
			};
		};
	};

	mtk_camera_eeprom:camera-eeprom0@50 {
		compatible = "mediatek,camera_eeprom";
		reg = <0x50 0 0>;
		names = "imx06c_cust_eeprom",
			"ov48b_mtk_eeprom";
		status = "okay";
	};

	camera-tof-main@29 {
		compatible = "mediatek,vl53l4";
		reg = <0x29 0 0>;
		pinctrl-names = "mclk_off",
				"camera_tof_en_off",
				"camera_tof_en_on";
		pinctrl-0 = <&camera_pins_cam0_mclk_off>;
		pinctrl-1 = <&camera_pins_cam0_tofvdd_0>;
		pinctrl-2 = <&camera_pins_cam0_tofvdd_1>;
		vin-supply =  <&camera_pin_cam0_tof>;
		vdd-supply =  <&rt5133_ldo5>;
		port {
			main_tof: endpoint {
				remote-endpoint = <&main_tof_endpoint>;
			};
		};
	};
};

&i2c2 {
	status = "okay";
	clock-frequency = <1000000>;

	sensor1: sensor1@10 {
		compatible = "mediatek,imgsensor";
		sensor-names = "s5k3p9sp_mipi_raw";
		reg = <0x10>;
		maximum-pmic-delay = <4000>;

		#thermal-sensor-cells = <0>;

		pinctrl-names = "mclk_off",
				"mclk_2mA",
				"mclk_4mA",
				"mclk_6mA",
				"mclk_8mA",
				"rst_low",
				"rst_high",
				"scl_ap",
				"scl_scp",
				"sda_ap",
				"sda_scp";
		pinctrl-0 = <&camera_pins_cam1_mclk_off>;
		pinctrl-1 = <&camera_pins_cam1_mclk_2ma>;
		pinctrl-2 = <&camera_pins_cam1_mclk_4ma>;
		pinctrl-3 = <&camera_pins_cam1_mclk_6ma>;
		pinctrl-4 = <&camera_pins_cam1_mclk_8ma>;
		pinctrl-5 = <&camera_pins_cam1_rst_0>;
		pinctrl-6 = <&camera_pins_cam1_rst_1>;
		pinctrl-7 = <&camera_pins_cam1_scl_ap>;
		pinctrl-8 = <&camera_pins_cam1_scl_scp>;
		pinctrl-9 = <&camera_pins_cam1_sda_ap>;
		pinctrl-10 = <&camera_pins_cam1_sda_scp>;

		avdd-supply = <&rt5133_ldo3>;
		dvdd-supply = <&rt5133_gpio3>;
		dovdd-supply = <&camera_vcamd_pmu>;
		base-supply = <&rt5133_base>;

		clocks = <&cksys_top_clk CKSYS_TOP_UNIVPLL_192M_D32>,
			<&cksys_top_clk CKSYS_TOP_UNIVPLL_192M_D16>,
			<&cksys_top_clk CKSYS_VLP_F26M_CK_D2>,
			<&cksys_top_clk CKSYS_TOP_UNIVPLL_192M_D10>,
			<&cksys_top_clk CKSYS_TOP_UNIVPLL_192M_D8>,
			<&cksys_top_clk CKSYS_TOP_UNIVPLL_D6_D16>,
			<&cksys_vlp_clk CKSYS_VLP_OSC3>,
			<&cksys_top_clk CKSYS_TOP_UNIVPLL_D6_D8>,
			<&cksys_vlp_clk VLP_CAMTG0_SEL>;
		clock-names = "6", "12", "13", "19.2", "24", "26", "26_ulposc", "52", "mclk";

		status = "okay";
		port {
			sensor1_out: endpoint {
				remote-endpoint = <&seninf_csi_port_0_in>;
			};
		};
	};

	mtk_camera_eeprom1:camera-eeprom1@50 {
		compatible = "mediatek,camera_eeprom";
		reg = <0x50 0 0>;
		names = "s5k3p9sp_mtk_eeprom";
		status = "okay";
	};
};

&i2c9 {
	status = "okay";
	clock-frequency = <1000000>;

	camera-af-main-two@b {
		compatible = "mediatek,main2_vcm";
		reg = <0x0b>;
		vin-supply = <&rt5133_ldo2>;
		port {

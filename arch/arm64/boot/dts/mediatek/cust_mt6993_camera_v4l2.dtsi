		pinctrl-0 = <&camera_pins_cam4_mclk_off>;
		pinctrl-1 = <&camera_pins_cam4_mclk_2ma>;
		pinctrl-2 = <&camera_pins_cam4_mclk_4ma>;
		pinctrl-3 = <&camera_pins_cam4_mclk_6ma>;
		pinctrl-4 = <&camera_pins_cam4_mclk_8ma>;
		pinctrl-5 = <&camera_pins_cam4_rst_0>;
		pinctrl-6 = <&camera_pins_cam4_rst_1>;
		pinctrl-7 = <&camera_pins_cam4_oisvdd_0>;
		pinctrl-8 = <&camera_pins_cam4_oisvdd_1>;
		pinctrl-9 = <&camera_pins_cam4_avdd_0>;
		pinctrl-10 = <&camera_pins_cam4_avdd_1>;
		pinctrl-11 = <&camera_pins_cam4_oisen_0>;
		pinctrl-12 = <&camera_pins_cam4_oisen_1>;


		afvdd-supply = <&rt5133_ldo2>;
		dvdd-supply = <&camera_pin_cam4_dvdd>;
		dovdd-supply = <&camera_vcamd_pmu>;
		base-supply = <&rt5133_base>;

		clocks = <&cksys_top_clk CKSYS_TOP_UNIVPLL_192M_D32>,
			<&cksys_top_clk CKSYS_TOP_UNIVPLL_192M_D16>,
			<&cksys_top_clk CKSYS_VLP_F26M_CK_D2>,
			<&cksys_top_clk CKSYS_TOP_UNIVPLL_192M_D10>,
			<&cksys_top_clk CKSYS_TOP_UNIVPLL_192M_D8>,
			<&cksys_top_clk CKSYS_TOP_UNIVPLL_D6_D16>,
			<&cksys_top_clk CKSYS_TOP_OSC_D20>,
			<&cksys_top_clk CKSYS_TOP_UNIVPLL_D6_D8>,
			<&cksys_vlp_clk VLP_CAMTG2_SEL>;

		clock-names = "6", "12", "13", "19.2", "24", "26", "26_ulposc", "52", "mclk";


		status = "okay";
		port {
			sensor4_out: endpoint {
				remote-endpoint = <&seninf_csi_port_1_in>;
			};
		};
	};

	mtk_camera_eeprom4:camera-eeprom4@55 {
		compatible = "mediatek,camera_eeprom";
		reg = <0x55 0 0>;
		names = "s5khp9sp_cust_eeprom";
		status = "okay";
	};
};

&thermal_zones {
	camera0: camera0 {
		polling-delay = <0>;
		polling-delay-passive = <0>;
		thermal-sensors = <&sensor0>;
		trips {
			camera0_crit: camera0-crit {
				temperature = <120000>;
				hysteresis = <2000>;
				type = "passive";
			};
		};
	};
	camera1: camera1 {
		polling-delay = <0>;
		polling-delay-passive = <0>;
		thermal-sensors = <&sensor1>;
		trips {
			camera1_crit: camera1-crit {
				temperature = <120000>;
				hysteresis = <2000>;
				type = "passive";
			};
		};
	};
	camera2: camera2 {
		polling-delay = <0>;
		polling-delay-passive = <0>;
		thermal-sensors = <&sensor2>;
		trips {
			camera2_crit: camera2-crit {
				temperature = <120000>;
				hysteresis = <2000>;
				type = "passive";
			};
		};
	};
	camera4: camera4 {
		polling-delay = <0>;
		polling-delay-passive = <0>;
		thermal-sensors = <&sensor4>;
		trips {
			camera4_crit: camera4-crit {
				temperature = <120000>;
				hysteresis = <2000>;
				type = "passive";
			};
		};
	};
};

&adaptor_core {
	power1-supply = <&camera_vcamd_pmu>;
	power2-supply = <&rt5133_ldo7>;
	power3-supply = <&rt5133_ldo1>;
	mux-sel-ctrl-supply = <&rt5133_gpio2>;
};

		pins-cmd-dat {
			pinmux = <PINMUX_GPIO73__FUNC_CMMCLK1>;
			drive-strength = <3>;
		};
	};

	camera_pins_cam0_scl_ap: cam0@2 {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO174__FUNC_SCL4>;
		};
	};
	camera_pins_cam0_scl_scp: cam0@3 {

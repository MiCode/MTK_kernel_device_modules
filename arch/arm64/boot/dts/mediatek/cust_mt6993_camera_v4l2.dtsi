	mtk_camera_eeprom2:camera-eeprom2@54 {
		compatible = "mediatek,camera_eeprom";
		reg = <0x54>;
		names = "s5kjn1_cust_eeprom";
		status = "okay";
	};
};

&i2c7 {
	compatible = "mediatek,mt6991-i3c";
	#address-cells = <3>;
	#size-cells = <0>;
	i3c-scl-hz = <12000000>;
	status = "okay";

	camera-af-main-three@74 {
		compatible = "mediatek,main3_vcm";
		reg = <0x74 0 0>;
		vin-supply = <&rt5133_ldo2>;
		port {
			main_af_cam2: endpoint {
				remote-endpoint = <&main_af_cam2_endpoint>;
			};
		};
	};

	sensor4: sensor4@10 {
		compatible = "mediatek,imgsensor";
		sensor-names = "s5khp9sp_mipi_raw";
		reg = <0x26 0x0216 0x1b730000>;
		assigned-address = <0x26>;
		pre-cfg-addr = <0x10>;
		maximum-pmic-delay = <4000>;

		#thermal-sensor-cells = <0>;

		pinctrl-names = "mclk_off",
				"mclk_2mA",
				"mclk_4mA",
				"mclk_6mA",
				"mclk_8mA",
				"rst_low",
				"rst_high",

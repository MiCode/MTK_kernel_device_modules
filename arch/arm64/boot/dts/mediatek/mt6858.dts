					"TOP_MUX_SENINF",
					"TOP_MUX_SENINF1",
					"TOP_MUX_SENINF2",
					"TOP_MUX_CAMTG",
					"TOP_MUX_CAMTG2",
					"TOP_MUX_CAMTG3",
					"TOP_MUX_CAMTG4",
					"TOP_CLK26M",
					"TOP_UNIVP_192M_D8",
					"TOP_UNIVPLL_D6_D8",
					"TOP_UNIVP_192M_D4",
					"TOP_F26M_CK_D2",
					"TOP_UNIVP_192M_D16",
					"TOP_UNIVP_192M_D32",
					"mmdvfs_clk";

			operating-points-v2 = <&opp_table_cam>;

			reg = <0 0x11d01000 0 0x1000>,
				<0 0x11300400 0 0x100>;
			interrupts = <GIC_SPI 596 IRQ_TYPE_LEVEL_HIGH 0>;
			clocks = <&imp_iic_wrap_s_clk CLK_IMPS_I2C2_I2C>,

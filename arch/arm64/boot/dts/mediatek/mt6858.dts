	smi_larb2: smi-larb2@1f002000 {
		compatible = "mediatek,smi-larb2",
			"mediatek,mt6858-smi-larb", "mediatek,smi-larb";
		reg = <0 0x1f002000 0 0x1000>;
		mediatek,smi-supply = <&smi_mdp_sub_comm0 0>;
		mediatek,larb-id = <2>;
		power-domains = <&scpsys MT6858_POWER_DOMAIN_DIS0_SHUTDOWN>;
		clocks = <&mdpsys_config_clk CLK_MDP_SMI0_SMI>;
		clock-names = "apb";
		is-default-ostdl;
		is-real-time-perm;
		larb-port-real-time-type = <1 1 1 1 1>;

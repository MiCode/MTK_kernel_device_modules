		reg = <0 0x1502f000 0 0x1000>;
		mediatek,smi-supply = <&smi_mdp_sub_comm1 0>;
		mediatek,common-id = <12>;
		power-domains = <&scpsys MT6858_POWER_DOMAIN_ISP_IMG1>;
		clocks = <&imgsys1_clk CLK_IMGSYS1_LARB9_SMI>,
			 <&imgsys1_clk CLK_IMGSYS1_LARB10_SMI>;

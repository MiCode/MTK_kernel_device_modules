		reg = <0 0x1401e000 0 0x1000>;
		mediatek,smi-supply = <&smi_disp_common 0>;
		mediatek,larb-id = <0>;
		init-power-on;
		power-domains = <&scpsys MT6858_POWER_DOMAIN_DIS0_SHUTDOWN>;
		clocks = <&dispsys_config_clk CLK_MM_SMI_COMMON_SMI>;

		afe: mt6858-afe-pcm@11050000 {
			compatible = "mediatek,mt6858-sound";
			reg = <0 0x11050000 0 0x10000>;
			interrupts = <GIC_SPI 407 IRQ_TYPE_LEVEL_HIGH 0>;
			topckgen = <&cksys_reg_clk>;
			apmixedsys = <&apmixedsys_clk>;
			power-domains = <&scpsys MT6858_POWER_DOMAIN_AUDIO>;
			clocks = <&afe_clk CLK_AFE_APLL1_AUDIO>,
				<&afe_clk CLK_AFE_APLL2_AUDIO>,
				<&afe_clk CLK_AFE_APLL_TUNER1_AUDIO>,
				<&afe_clk CLK_AFE_APLL_TUNER2_AUDIO>,
				<&afe_clk CLK_AFE_AUDIO_F26M_AUDIO>,
				<&afe_clk CLK_AFE_AUDIO_HOPPING_AUDIO>,
				<&afe_clk CLK_AFE_DL0_DAC_AUDIO>,
				<&afe_clk CLK_AFE_DL0_DAC_HIRES_AUDIO>,
				<&afe_clk CLK_AFE_DL0_PREDIS_AUDIO>,
				<&afe_clk CLK_AFE_UL0_ADC_AUDIO>,
				<&afe_clk CLK_AFE_UL0_ADC_HIRES_AUDIO>,
				<&afe_clk CLK_AFE_UL1_ADC_AUDIO>,
				<&afe_clk CLK_AFE_UL1_ADC_HIRES_AUDIO>,
				<&cksys_reg_clk CLK_TOP_AUD_1_SEL>,
				<&cksys_reg_clk CLK_TOP_AUD_2_SEL>,
				<&cksys_reg_clk CLK_TOP_AUD_ENGEN1_SEL>,
				<&cksys_reg_clk CLK_TOP_AUD_ENGEN2_SEL>,
				<&cksys_reg_clk CLK_TOP_AUD_INTBUS_SEL>,
				<&cksys_reg_clk CLK_TOP_AUDIO_H_SEL>,
				<&pericfg_ao_clk CLK_PERAO_P_AUDIO0_AUDIO>,
				<&pericfg_ao_clk CLK_PERAO_P_AUDIO1_AUDIO>,
				<&pericfg_ao_clk CLK_PERAO_P_AUDIO2_AUDIO>,
				<&cksys_reg_clk CLK_TOP_APLL1>,
				<&cksys_reg_clk CLK_TOP_APLL1_D2>,
				<&cksys_reg_clk CLK_TOP_APLL1_D4>,
				<&cksys_reg_clk CLK_TOP_APLL2>,
				<&cksys_reg_clk CLK_TOP_APLL2_D2>,
				<&cksys_reg_clk CLK_TOP_APLL2_D4>,
				<&cksys_reg_clk CLK_TOP_APLL_I2SIN1_MCK_SEL>,
				<&cksys_reg_clk CLK_TOP_APLL12_CK_DIV_I2SIN1>,
				<&cksys_reg_clk CLK_TOP_TCK_26M_MX9>;
			clock-names = "afe_apll1_audio",
				"afe_apll2_audio",
				"afe_apll_tuner1_audio",
				"afe_apll_tuner2_audio",
				"afe_audio_f26m_audio",
				"afe_audio_hopping_audio",
				"afe_dl0_dac_audio",
				"afe_dl0_dac_hires_audio",
				"afe_dl0_predis_audio",
				"afe_ul0_adc_audio",
				"afe_ul0_adc_hires_audio",
				"afe_ul1_adc_audio",
				"afe_ul1_adc_hires_audio",
				"clk_top_aud_1_sel",
				"clk_top_aud_2_sel",
				"clk_top_aud_engen1_sel",
				"clk_top_aud_engen2_sel",
				"clk_top_aud_intbus_sel",
				"clk_top_audio_h_sel",
				"perao_p_audio0_audio",
				"perao_p_audio1_audio",
				"perao_p_audio2_audio",
				"apll1_ck",
				"top_apll1_d2",
				"top_apll1_d4",
				"apll2_ck",
				"top_apll2_d2",
				"top_apll2_d4",
				"apll_i2sin1_mck_sel",
				"top_apll12_div_i2sin1",
				"tck_26m_mx9_ck";
			pinctrl-names = "aud-dat-miso0-off",
				"aud-dat-miso0-on",
				"aud-dat-miso1-off",
				"aud-dat-miso1-on",
				"aud-dat-mosi0-off",
				"aud-dat-mosi0-on",
				"aud-dat-mosi1-off",
				"aud-dat-mosi1-on",
				"aud-gpio-i2sin1-off",
				"aud-gpio-i2sin1-on",
				"aud-gpio-i2sout1-off",
				"aud-gpio-i2sout1-on",
				"aud-gpio-ap-dmic-off",
				"aud-gpio-ap-dmic-on",
				"aud-gpio-ap-dmic1-off",
				"aud-gpio-ap-dmic1-on",
				"vow-dat-miso-off",
				"vow-dat-miso-on",
				"vow-clk-miso-off",
				"vow-clk-miso-on",
				"vow-scp-dmic-dat-off",
				"vow-scp-dmic-dat-on",
				"vow-scp-dmic-clk-off",
				"vow-scp-dmic-clk-on";
			pinctrl-0 = <&aud_dat_miso0_off>;
			pinctrl-1 = <&aud_dat_miso0_on>;
			pinctrl-2 = <&aud_dat_miso1_off>;
			pinctrl-3 = <&aud_dat_miso1_on>;
			pinctrl-4 = <&aud_dat_mosi0_off>;
			pinctrl-5 = <&aud_dat_mosi0_on>;
			pinctrl-6 = <&aud_dat_mosi1_off>;
			pinctrl-7 = <&aud_dat_mosi1_on>;
			pinctrl-8 = <&aud_gpio_i2sin1_off>;
			pinctrl-9 = <&aud_gpio_i2sin1_on>;
			pinctrl-10 = <&aud_gpio_i2sout1_off>;
			pinctrl-11 = <&aud_gpio_i2sout1_on>;
			pinctrl-12 = <&aud_gpio_ap_dmic_off>;
			pinctrl-13 = <&aud_gpio_ap_dmic_on>;
			pinctrl-14 = <&aud_gpio_ap_dmic1_off>;
			pinctrl-15 = <&aud_gpio_ap_dmic1_on>;
			pinctrl-16 = <&vow_dat_miso_off>;
			pinctrl-17 = <&vow_dat_miso_on>;
			pinctrl-18 = <&vow_clk_miso_off>;
			pinctrl-19 = <&vow_clk_miso_on>;
			pinctrl-20 = <&vow_scp_dmic_dat_off>;
			pinctrl-21 = <&vow_scp_dmic_dat_on>;
			pinctrl-22 = <&vow_scp_dmic_clk_off>;
			pinctrl-23 = <&vow_scp_dmic_clk_on>;
			/* Only for ETDM in/out 4 */
			etdm-out-ch = <2 2 8>;
			etdm-in-ch = <2 2 8>;
			etdm-out-sync = <0 0 0>; /* 0: disable; 1: enable */
			etdm-in-sync = <1 0 0>; /* 0: disable; 1: enable */
			etdm-ip-mode = <0 0 0>; /* 0: One IP multi-channel 1: Multi-IP 2-channel */
		};

		audio_sram: audio-sram@11060000 {
			compatible = "mediatek,audio_sram";
			reg = <0 0x11060000 0 0x10000>;
			prefer-mode = <0>;
			mode-size = <0x10000 0x10000>;
			block-size = <0x1000>;
		};

		opp_table_disp: opp-table-disp {
			compatible = "operating-points-v2";
			opp-0 {
				opp-hz = /bits/ 64 <229000000>;
				opp-microvolt = <550000>;
			};
			opp-1 {
				opp-hz = /bits/ 64 <344000000>;
				opp-microvolt = <600000>;
			};
			opp-2 {
				opp-hz = /bits/ 64 <458000000>;
				opp-microvolt = <650000>;
			};
			opp-3 {
				opp-hz = /bits/ 64 <594000000>;
				opp-microvolt = <725000>;
			};
		};


		i2c3: i2c@11281000 {
			compatible = "mediatek,mt6991-i2c";
			reg = <0 0x11281000 0 0x1000>,
				<0 0x11300500 0 0x80>;
			interrupts = <GIC_SPI 597 IRQ_TYPE_LEVEL_HIGH 0>;
			clocks = <&imp_iic_wrap_c_clk CLK_IMPC_I2C3_I2C>,
				<&pericfg_ao_clk CLK_PERAO_P_DMA_B_I2C>;
			clock-names = "main", "dma";
			i2c-clock-info = <0x11286e00 0x2>;    /* *reg*  *value* */
			clock-div = <1>;
			scl-gpio-id = <145>;
			sda-gpio-id = <146>;
		};


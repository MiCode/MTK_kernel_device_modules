ST4_LDRO12,ST4_LDRO13,ST4_LDRO14,ST4_LDRO15,ST5_LDRO0,ST5_LDRO1,ST5_LDRO2,ST5_LDRO3,ST5_LDRO4,\
ST5_LDRO5,ST5_LDRO6,ST5_LDRO7,ST5_LDRO8,ST5_LDRO9,ST5_LDRO10,ST5_LDRO11,ST5_LDRO12,ST5_LDRO13,\
ST5_LDRO14,ST5_LDRO15,TOP_LDRO0,TOP_LDRO1,TOP_LDRO2,TOP_LDRO3,TOP_LDRO4,TOP_LDRO5,TOP_LDRO6,\
TOP_LDRO7,TOP_LDRO8,TOP_LDRO9,TOP_LDRO10,TOP_LDRO11,TOP_LDRO12,TOP_LDRO13,TOP_LDRO14,TOP_LDRO15";
			node-43 = "GPUEB_PTP3_Cerr", "ST0,ST1,ST2,ST3,ST4,ST5,TOP";
			node-44 = "GPUEB_PTP3_Ferr", "ST0,ST1,ST2,ST3,ST4,ST5,TOP";
			node-45 = "GPUEB_PTP3_HBVC_VOLT", "gpu_Vc,stack_Vc,gpu_Vt,stack_Vt";
			node-46 = "GPUEB_PTP3_HBVC_VOLT__detail", "ST0_Vt,ST1_Vt,ST2_Vt,ST3_Vt,ST4_Vt,ST5_Vt,TOP_Vt";
			node-47 = "GPUEB_POWER_STATE", "power_state";
			node-48 = "GPUEB_OPP", "pow_restore,desire_sys,desire_opp,virtual_min,cur";
			node-49 = "GPUEB_SLCV2_ITER_TRACE_START", "source,event,context_id,timer,\
sw_info,frame_id,custom,pipeline_stage,RPID,UID";
			node-50 = "GPUEB_SLCV2_ITER_TRACE_END", "source,event,context_id,timer";
			node-51 = "GPUEB_SLCV2_CCMD_PMU_CNT", "DF0,DF1,CH0,CH2,RP_HIT,Z_CLEAN,Z_IRQ";
			node-52 = "GPUEB_SLCV1_POLICY", "current,final";
			node-53 = "GPUEB_GPUFREQ_PRBC_POWER_CURRENT",
				"final_power,spbm_power,spbm_current,ondie_power,ondie_current,\
				avg_power_gpu,avg_power_stack";
			node-54 = "GPUEB_GPUFREQ_PRBC_FREQ_VOLT",
				"hbvc_freq,prbc_freq,avg_freq,ondie_volt";
			node-55 = "GPUEB_GPUFREQ_PRBC_MISC_INFO",
				"limiter,ratio,ratio_irq_count";
		};
	};

	mmqos-wrapper {
			compatible = "mediatek,mt6858-mmqos-wrapper";
	};

	mmqos: interconnect {
		compatible = "mediatek,mt6858-mmqos";
		#mtk-interconnect-cells = <1>;
		mediatek,larbs-supply = <&smi_larb0 &smi_larb1 &smi_larb2
					&smi_larb4  &smi_larb7 &smi_larb9
					&smi_larb11 &smi_larb13 &smi_larb14
					&smi_larb16 &smi_larb17 &smi_larb20>;
		mediatek,commons-supply = <&smi_disp_common>;
		mmqos-state = <0x1c177ed>;
		mmqos-log-level = <0>;
		interconnects = <&dvfsrc MT6873_MASTER_MMSYS &dvfsrc MT6873_SLAVE_DDR_EMI>,
				<&dvfsrc MT6873_MASTER_HRT_MMSYS
				&dvfsrc MT6873_SLAVE_HRT_DDR_EMI>;
		interconnect-names = "icc-bw", "icc-hrt-bw";
		vmmrc-base = <0x1ec00000>;
		vmmrc-mask = <0x2e814>;
		vmmrc-mask-bit = <8>;
		vmmrc-on-table = <0x2e788>;
		vmmrc-off-table = <0x2e7a8>;
		mminfra-base = <0x1e800000>;
		w-hrt-ostdl = <1>;
		r-srt-ostdl = <4>;
		dvfsrc-level-base = <0x1c00f000>;
		required-opps = <&dvfsrc_freq_opp0>,
				<&dvfsrc_freq_opp1>,
				<&dvfsrc_freq_opp2>,
				<&dvfsrc_freq_opp3>,
				<&dvfsrc_freq_opp4>,
				<&dvfsrc_freq_opp5>;
	};

	mminfra-debug@1e827000 {
		compatible = "mediatek,mminfra-debug";
		reg = <0 0x1e827000 0 0x90>;
		power-domains = <&scpsys MT6858_POWER_DOMAIN_MM_INFRA_SHUTDOWN>;
		interrupts = <GIC_SPI 292 IRQ_TYPE_LEVEL_HIGH 0>;
		mminfra-gals-sel = <15 16 17 18 19 20>;
		mminfra-bkrs = <0>;
		bkrs-reg = <0x1e800860>;
		init-clk-on;
		clocks = <&mminfra_config_clk CLK_MMINFRA_GCE_D_GCE>,
				<&mminfra_config_clk CLK_MMINFRA_GCE_M_GCE>,
				<&mminfra_config_clk CLK_MMINFRA_GCE_26M_GCE>;
		clock-names = "clk0", "clk1", "clk2";
	};


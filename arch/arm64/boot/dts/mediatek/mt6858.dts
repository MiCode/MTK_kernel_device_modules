		srclken_rc: srclken-rc@1c00d000 {
			compatible = "mediatek,srclken-rc";
			 reg = <0 0x1c00d000 0 0x100>,
			       <0 0x1c00d100 0 0x700>;

			suspend {
				xo-buf = "BB1";
				perms = <0x0>;
				sub-id = <0>;
			};
			md1 {
				xo-buf = "RF2A";
				sub-id = <1>;
			};
			md2 {
				sub-id = <2>;
			};
			md3 {
				sub-id = <3>;
			};
			mdrf {
				sub-id = <4>;
			};
			gps {
				xo-buf = "BB2/RF1A";
				sub-id = <6>;
			};
			bt {
				xo-buf = "BB2/RF1A";
				sub-id = <7>;
			};
			wf {
				xo-buf = "BB2/RF1A";
				sub-id = <8>;
			};
			mcu {
				xo-buf = "BB2/RF1A";
				sub-id = <9>;
			};
			co-ant {
				sub-id = <10>;
			};
			nfc {
				xo-buf = "BB4";
				sub-id = <11>;
			};
			suspend-rsv {
				sub-id = <12>;
			};
			ufs {
				xo-buf = "BB3";
				sub-id = <13>;
			};
		};

		mtkheap-page-prot {
			compatible = "mediatek,dmaheap-mtk-sec-page";
			heap-name = "mtk_prot_page-uncached";
			trusted-mem-type = <10>;
		};

		mtkheap-region-prot {
			compatible = "mediatek,dmaheap-mtk-sec-region";
			heap-name = "mtk_prot_region";
			trusted-mem-type = <1>;
			region-heap-align-name = "mtk_prot_region-aligned";
			iommus = <&disp_iommu M4U_L0_P0_OVL0_RDMA_HDR>;
		};

		mtkheap_page_svp: mtkheap-page-svp {
			compatible = "mediatek,dmaheap-mtk-sec-page";
			heap-name = "mtk_svp_page-uncached";

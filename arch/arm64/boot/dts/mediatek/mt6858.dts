		i2c0: i2c@11d00000 {
			compatible = "mediatek,mt6991-i2c";
			reg = <0 0x11d00000 0 0x1000>,
				<0 0x11300300 0 0x80>;
			interrupts = <GIC_SPI 594 IRQ_TYPE_LEVEL_HIGH 0>;
			clocks = <&imp_iic_wrap_s_clk CLK_IMPS_I2C0_I2C>,
				<&pericfg_ao_clk CLK_PERAO_P_DMA_B_I2C>;
			clock-names = "main", "dma";
			i2c-clock-info = <0x11d04e00 0x1>;    /* *reg*  *value* */
			clock-div = <1>;
			scl-gpio-id = <139>;
			sda-gpio-id = <140>;
		};

		i2c1: i2c@11280000 {
			compatible = "mediatek,mt6991-i2c";

		vdec@16000000 {
			compatible = "mediatek,vcodec-dec";
			mediatek,platform = "platform:mt6858";
			mediatek,ipm = <1>;
			vp-mode-buf-size-multi = <16384>; // 1024 * 16

			/* for power */
			mediatek,larbs = <&smi_larb4>;
			power-domains = <&scpsys MT6858_POWER_DOMAIN_VDE0>;
			clocks =
				<&vdec_gcon_base_clk CLK_VDE2_VDEC_CKEN>;
			clock-names =
				"CORE_MT_CG_VDEC0";

			/* for memory */
			iommus = <&disp_iommu M4U_L4_P0_HW_VDEC_MC_EXT>,
				<&disp_iommu M4U_L4_P1_HW_VDEC_PP_EXT>,
				<&disp_iommu M4U_L4_P2_HW_VDEC_PRED_RD_EXT>,
				<&disp_iommu M4U_L4_P3_HW_VDEC_PRED_WR_EXT>,
				<&disp_iommu M4U_L4_P4_HW_VDEC_PPWRAP_EXT>,
				<&disp_iommu M4U_L4_P5_HW_VDEC_TILE_EXT>,
				<&disp_iommu M4U_L4_P6_HW_VDEC_VLD_EXT>,
				<&disp_iommu M4U_L4_P7_HW_VDEC_VLD2_EXT>,
				<&disp_iommu M4U_L4_P8_HW_VDEC_AVC_MV_EXT>,
				<&disp_iommu M4U_L4_P9_HW_VDEC_RG_CTRL_DMA_EXT>;

			/* for translation fault callback */
			m4u-ports =
				<M4U_L4_P0_HW_VDEC_MC_EXT>,
				<M4U_L4_P1_HW_VDEC_PP_EXT>,
				<M4U_L4_P2_HW_VDEC_PRED_RD_EXT>,
				<M4U_L4_P3_HW_VDEC_PRED_WR_EXT>,
				<M4U_L4_P4_HW_VDEC_PPWRAP_EXT>,
				<M4U_L4_P5_HW_VDEC_TILE_EXT>,
				<M4U_L4_P6_HW_VDEC_VLD_EXT>,
				<M4U_L4_P7_HW_VDEC_VLD2_EXT>,
				<M4U_L4_P8_HW_VDEC_AVC_MV_EXT>,
				<M4U_L4_P9_HW_VDEC_RG_CTRL_DMA_EXT>,
				<M4U_PORT_L21_VIDEO_UP0>,
				<M4U_PORT_L21_VIDEO_UP0>;
			m4u-port-names =
				"M4U_PORT_VDEC_MC",
				"M4U_PORT_VDEC_PP",
				"M4U_PORT_VDEC_PRED_RD",
				"M4U_PORT_VDEC_PRED_WR",
				"M4U_PORT_VDEC_PPWRAP",
				"M4U_PORT_VDEC_TILE",
				"M4U_PORT_VDEC_VLD",
				"M4U_PORT_VDEC_VLD2",
				"M4U_PORT_VDEC_AVC_MV",
				"M4U_PORT_VDEC_RG_CTRL_DMA",
				"M4U_PORT_VDEC_VIDEO_UP_NOR",
				"M4U_PORT_VDEC_VIDEO_UP_SEC";

			/* dvfs params */
			dvfs-qos-ver = <2>;
			vdec-set-bw-in-min-freq = <1>;
			vdec-mmdvfs-in-vcp = <1>;
			vdec-mmdvfs-in-adaptive = <1>;
			vdec-thermal-hint-mode; /* vdec thermal throttle enable */
			vdec-cpu-hint-mode = <1>;
			throughput-min = <218000000>;
			throughput-normal-max = <546000000>;
			mmqos-supply = <&mmqos>;
			interconnects =
				<&mmqos SLAVE_LARB(4) &mmqos SLAVE_COMMON(0)>,
				<&mmqos SLAVE_LARB(5) &mmqos SLAVE_COMMON(0)>;
			interconnect-names = "path_vdec_r", "path_vdec_w";
			interconnect-num = <2>;
			bandwidth-table = // avg occupy
				<4 0 1300>,
				<4 1 350>; /* larb_id, rw, base_bw*/
		};

		venc@17000000 {
			compatible = "mediatek,vcodec-enc";
			mediatek,platform = "platform:mt6858";
			mediatek,ipm = <2>;
			venc-core-count = <1>;
			reg = <0 0x17020000 0 0x2000>;
			reg-names =
				"VENC_SYS";
			iommus = <&disp_iommu M4U_L7_P0_RC>,
				<&disp_iommu M4U_L7_P1_REC>,
				<&disp_iommu M4U_L7_P2_BSDMA>,
				<&disp_iommu M4U_L7_P3_SV_COMV>,
				<&disp_iommu M4U_L7_P4_RD_COMV>,
				<&disp_iommu M4U_L7_P8_SUB_W_LUMA>,
				<&disp_iommu M4U_L7_P10_CUR_LUMA>,
				<&disp_iommu M4U_L7_P11_CUR_CHROMA>,
				<&disp_iommu M4U_L7_P12_REF_LUMA>,
				<&disp_iommu M4U_L7_P13_REF_CHROMA>,
				<&disp_iommu M4U_L7_P14_SUB_R_LUMA>;
			interconnects =
				<&mmqos SLAVE_LARB(7) &mmqos SLAVE_COMMON(0)>,
				<&mmqos SLAVE_LARB(8) &mmqos SLAVE_COMMON(0)>;
			interconnect-names = "path_venc_smi_mon_r", "path_venc_smi_mon_w";
			interconnect-num = <2>;
			mediatek,larbs = <&smi_larb7>;
			power-domains = <&scpsys MT6858_POWER_DOMAIN_VEN0>;
			clocks = <&venc_gcon_clk CLK_VEN1_CKE1_VENC>;
			clock-names = "MT_CG_VENC0";

			/* for translation fault callback */
			port-arg-num = <3>;
			port-def = <0 M4U_L7_P0_RC 0>,
				<0 M4U_L7_P1_REC 0>,
				<0 M4U_L7_P2_BSDMA 0>,
				<0 M4U_L7_P3_SV_COMV 0>,
				<0 M4U_L7_P4_RD_COMV 0>,
				<0 M4U_L7_P5_JPGENC_Y_RDMA 0>,
				<0 M4U_L7_P6_JPGENC_C_RDMA 0>,
				<0 M4U_L7_P7_JPGENC_Q_TABLE 0>,
				<0 M4U_L7_P8_SUB_W_LUMA 0>,
				<0 M4U_L7_P9_JPGENC_BSDMA 0>,
				<0 M4U_L7_P10_CUR_LUMA 0>,
				<0 M4U_L7_P11_CUR_CHROMA 0>,
				<0 M4U_L7_P12_REF_LUMA 0>,
				<0 M4U_L7_P13_REF_CHROMA 0>,
				<0 M4U_L7_P14_SUB_R_LUMA 0>;
			/* dvfs params */
			dvfs-qos-ver = <1>;
			venc-mmdvfs-in-vcp = <1>;
			venc-mmdvfs-in-adaptive = <1>;
			venc-thermal-hint-mode; /* venc thermal throttle enable */
			venc-cpu-hint-mode = <1>;
			mmqos-supply = <&mmqos>;
			need-smi-monitor = <1>;	  /* enable smi bw monitor in kernel */
			smi-monitor-in-vcp = <1>; /* specify the monitor location, 1 for vcp, 0 for kernel */
			commlarb-id = <6 6 6 6>;		/* Monitor port of <comm0 comm1> */
			common-id = <0>;		/* <DISP_COMM MDP_COMM> */
			monitor-id = <3>;		/* Monitor id of <comm_0 comm_1> */
			bandwidth-table = // avg occupy
				<7 0 566>,
				<7 1 234>; /* larb_id, rw, base_bw*/
		};

		jpgenc@17030000 {
			compatible = "mediatek,mtk-jpgenc";
			mediatek,platform = "platform:mt6858";
			reg = <0 0x17030000 0 0x10000>,
				<0 0x17000000 0 0x10000>;
			interrupts = <GIC_SPI 495 IRQ_TYPE_LEVEL_HIGH 0>;
			clocks = <&venc_gcon_clk CLK_VEN1_CKE2_JPGENC_JPEGENC>,
				 <&mmdvfs_clk CLK_MMDVFS_JPEGENC>;
			clock-names = "jpgenc", "mmdvfs_clk";
			power-domains = <&scpsys  MT6858_POWER_DOMAIN_VEN0>;
			mediatek,larb = <&smi_larb7>;
			dma-ranges = <0x0 0x0 0x0 0x0 0x4 0x0>;
			mmqos-supply = <&mmqos>;
			iommus = <&disp_iommu  M4U_L7_P5_JPGENC_Y_RDMA>,
				 <&disp_iommu M4U_L7_P6_JPGENC_C_RDMA	>,
				 <&disp_iommu M4U_L7_P7_JPGENC_Q_TABLE>,
				 <&disp_iommu M4U_L7_P9_JPGENC_BSDMA>;
			interconnects = <&mmqos MASTER_LARB_PORT(M4U_L7_P5_JPGENC_Y_RDMA)
					&mmqos SLAVE_COMMON(0)>,
				<&mmqos MASTER_LARB_PORT(M4U_L7_P6_JPGENC_C_RDMA)
					&mmqos SLAVE_COMMON(0)>,
				<&mmqos MASTER_LARB_PORT(M4U_L7_P7_JPGENC_Q_TABLE)
					&mmqos SLAVE_COMMON(0)>,
				<&mmqos MASTER_LARB_PORT(M4U_L7_P9_JPGENC_BSDMA)
					&mmqos SLAVE_COMMON(0)>;
			interconnect-names = "path_jpegenc_y_rdma",
				"path_jpegenc_c_rmda",
				"path_jpegenc_q_table",
				"path_jpegenc_bsdma";
			operating-points-v2 = <&opp_table_venc>;
			config-larbaddr;
			qos-enablevcp;
		};

		keypad: kp@1c00e000 {
			compatible = "mediatek,kp";
			/*
			 * factory key type
			 * 0: Keypad IP key
			 * 1: GPIO key
			 * 2: HOME2 key
			 */
			mediatek,factory-key-type = <2>;

	pda: pda@1a0b0000 {
		compatible = "mediatek,camera-pda";
		reg = <0 0x1a0b0000 0 0x1000>;
		dma-ranges = <0x0 0x0 0x0 0x0 0x4 0x0>;
		interrupts = <GIC_SPI 163 IRQ_TYPE_LEVEL_HIGH 0>;

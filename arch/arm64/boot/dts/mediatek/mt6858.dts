	met {
		met_emi: met-emi {
			compatible = "mediatek,met_emi";
			emi-num = <1>;
			dram-num = <2>;
			dramc-ver = <2>;
			slc-ver = <3>;
			/* 0: dram ebg, 1:emi_freq, 2: DRAMC_DCM_CTRL 3:chn_emi_low_effi */
			/* 4: SLC, 5: DRAMC BUS MON trigger, 6: SSPM register write */
			/* 7: EMI_RESUME_DISABLE 8: Disable SLC DCM for BMEN*/
			met-emi-support-list = <0xe1>;
			cen-emi-reg-base = <0x10219000>;
			cen-emi-reg-size = <0x1000>;
			chn-emi-reg-base = <0x10235000 0x10245000>;
			chn-emi-reg-size = <0x1000>;
			dramc-nao-reg-base = <0x10234000 0x10244000>;
			dramc-nao-reg-size = <0x1000>;
			dramc-ao-reg-base = <0x10230000 0x10240000>;
			dramc-ao-reg-size = <0x2000>;
			dramc-ao-bus-mon1 = <0x118>;
			ddrphy-ao-reg-base = <0x10238000 0x10248000>;
			ddrphy-ao-reg-size = <0x2000>;
			ddrphy-ao-misc-cg-ctrl0 = <0x0>;
			ddrphy-ao-misc-cg-ctrl2 = <0xad4>;
			dram-freq-default = <6400>;
			ddr-ratio-default = <8>;
			dram-type-default = <8>;
			slc-pmu-reg-base = <0x10235000 0x10245000>;
			slc-pmu-reg-size = <0x1000>;
			slc-pmu-2nd-reg-base = <0x10359000 0x1035c000>;
			slc-pmu-2nd-reg-size = <0x1000>;
			slc-pmu-ch-num = <1>;

			/* 6993 emipll-con1 is not from apmixedsys */
			apmixedsys-reg-base = <0x1000c000>;
			apmixedsys-reg-size = <0x410>;
			apmixedsys-emipll-con1 = <0x000c>;
		};

		met-res-ram {
			compatible = "mediatek,met_res_ram";
			met-res-ram-sspm {
				size = <0x400000>; /* 4M: only reserve on userdebug/eng load */
				start = <0x0>; /* start addr of reserved ram */
			};
			met-res-ram-mcupm {
				size = <0x400000>; /* 4M: only reserve on userdebug/eng load */
				start = <0x0>; /* start addr of reserved ram */
			};
			met-res-ram-gpueb {
				size = <0x400000>; /* 4M: only reserve on userdebug/eng load */
				start = <0x0>; /* start addr of reserved ram */
			};
		};

		met-config {
			compatible = "mediatek,met_config";
			/* 0: resource ctrl */
			met-config-list = <0x1>;
			sspm-rts-unlimited-enable = <0>;
		};


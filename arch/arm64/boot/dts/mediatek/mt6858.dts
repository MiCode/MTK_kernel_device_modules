			compatible = "mediatek,mt6858-gps";
			reg = <0 0x18c00000 0 0x100000>,
				<0 0x18000000 0 0x100000>,
				<0 0x1c000000 0 0x4>,
				<0 0x1c013058 0 0x4>,
				<0 0x1c013060 0 0x4>,

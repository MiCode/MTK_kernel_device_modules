		};

		fhctl: fhctl@1000ce00 {
			mcupm-supply = <&mcupm>;
			compatible = "mediatek,mt6858-fhctl";
			reg = <0 0x1000ce00 0 0x100>, //AP FHCTL base
				<0 0x1000c000 0 0xe00>, //APMIX base

				<0 0x1000ce00 0 0x100>, //mcupm FHCTL base
				<0 0x1000c000 0 0xe00>; //mcupm pll base

			map0 {
				domain = "top0"; //PLL_GP1
				method = "fhctl-ap";
				mainpll {
					fh-id = <0>;
					perms = <0x1e>;
				};
				msdcpll {
					fh-id = <1>;
					perms = <0x1e>;
				};
				adsppll {
					fh-id = <2>;
					perms = <0x1e>;
				};
				mmpll {
					fh-id = <4>;
					perms = <0x1e>;
				};
				tvdpll {
					fh-id = <5>;
					perms = <0x1e>;
				};
			};

			map1 {
				domain = "top1"; //PLL_GP2
				method = "fhctl-mcupm";
				armpll-ll {
					fh-id = <6>;
				};
				armpll-bl {
					fh-id = <7>;
				};
				ccipll {
					fh-id = <8>;
				};
			};
		};

		lkg: lkg@c57d400 {
			compatible = "mediatek,mtk-lkg";
			reg = <0 0x0c57d400 0 0xc00>;
		};


		ccifdriver:ccifdriver@10209000 {
			compatible = "mediatek,ccci_ccif";
			reg = <0 0x10209000 0 0x1000>, /*AP_CCIF_BASE*/
				<0 0x1020a000 0 0x1000>; /*MD_CCIF_BASE*/
			mediatek,sram-size = <512>;
			/* ccif hw reset version */
			mediatek,ccif-hw-reset-ver = <1>;
			/* ccif hw reset bit */
			mediatek,ccif-hw-reset-bit = <26>;
			/* DTS/GIC_ID: CCIF0 228/260; CCIF0 229/261 */
			interrupts = <GIC_SPI 228 IRQ_TYPE_LEVEL_HIGH 0>,
				<GIC_SPI 229 IRQ_TYPE_LEVEL_HIGH 0>;
			clocks = <&infra_infracfg_ao_reg_clk CLK_INFRACFG_AO_REG_CCIF_AP_CCCI>,
				<&infra_infracfg_ao_reg_clk CLK_INFRACFG_AO_REG_CCIF_MD_CCCI>,
				<&infra_infracfg_ao_reg_clk CLK_INFRACFG_AO_REG_CCIF1_AP_CCCI>,
				<&infra_infracfg_ao_reg_clk CLK_INFRACFG_AO_REG_CCIF1_MD_CCCI>,
				<&infra_infracfg_ao_reg_clk CLK_INFRACFG_AO_REG_CCIF4_MD_CCCI>,
				<&infra_infracfg_ao_reg_clk CLK_INFRACFG_AO_REG_CCIF5_MD_CCCI>;

			clock-names = "infra-ccif-ap",
				"infra-ccif-md",
				"infra-ccif1-ap",
				"infra-ccif1-md",
				"infra-ccif4-md",
				"infra-ccif5-md";
		};

		mddriver:mddriver@d180000 {
			compatible = "mediatek,mddriver";
			/* bit0~3: CLDMA|CCIF|DPMAIF */
			mediatek,mdhif-type = <6>;
			mediatek,ap-plat-info = <6858>;
			mediatek,md-generation = <6299>;
			mediatek,md-sub-version = <0>;
			/* 0x64: epon offset; */
			/* 0x06: once a value[1] exist, means in l2sram */
			/* value[1] not exist means in mddbgsys. the value(6) has no meaningful */
			mediatek,offset-epon-md1 = <0x64 0x06>;
			mediatek,cldma-capability = <10>;
			mediatek,boot-status-value = <0x544300f1>;
			reg = <0 0x0d180000 0 0x2000>; /* l2sram base address */
			mediatek,md-buck-iso-con = <0x1c001f20>;
			load-md-stage = "bl2_ext_load_md";
			mediatek,mdsrc-settle-time = <20>;
			mediatek,ccci-ctrl-mtcmos = <1>;
			/* bit0:srcclkena|bit1:srclken_o1_on|bit2:revert_sequencer */
			/* bit3:md_pll|bit4:dpsw|bit5:topclkgen|bit6:vmodem_ext_iso_en_control */
			mediatek,power-flow-config = <0x40>;
			/* DTS/GIC_ID: MDWDT 491/523; CCIF0 228/260; CCIF0 229/261 */
			interrupts = <GIC_SPI 491 IRQ_TYPE_LEVEL_HIGH  0>,
					 <GIC_SPI 228 IRQ_TYPE_LEVEL_HIGH  0>,
					 <GIC_SPI 229 IRQ_TYPE_LEVEL_HIGH  0>;
			ccci-infracfg = <&infra_infracfg_ao_reg_clk>;
			ccci-topckgen = <&cksys_reg_clk>;
			/* ccci-spmsleep = <&sleep>; */
		};

		ccci_scp:ccci-scp@1023c000 {
			compatible = "mediatek,ccci_md_scp";
			reg = <0 0x1023c000 0 0x1000>, /*AP_CCIF2_BASE*/
			      <0 0x1023d000 0 0x1000>; /*MD_CCIF2_BASE*/
			clocks = <&infra_infracfg_ao_reg_clk CLK_INFRACFG_AO_REG_CCIF2_AP_CCCI>,
				 <&infra_infracfg_ao_reg_clk CLK_INFRACFG_AO_REG_CCIF2_MD_CCCI>;
			clock-names = "infra-ccif2-ap",
				"infra-ccif2-md";
		};

		dpmaif:dpmaif@10014000 {
			compatible = "mediatek,dpmaif";
			reg = <0 0x10014000 0 0x1000>, /*ao_ul*/
				<0 0x1022d000 0 0x1000>, /*pd_ul*/
				<0 0x1022c000 0 0x1000>, /*pd_md_misc*/
				<0 0x1022e000 0 0x1000>; /*sram*/
			/* rxq0 irq: 142 238 270 */
			interrupts = <GIC_SPI 238 IRQ_TYPE_LEVEL_HIGH 0>,
				<GIC_SPI 259 IRQ_TYPE_LEVEL_HIGH 0>; /* rxq1 irq: 163 259 291 */
			mediatek,dpmaif-ver = <3>;
			/*0-napi,1-txbusystop,2-sgio,3-hwchksum,4-lro,5-2rxq,6-rsvmem,7-maxbat,8-udpgro*/
			mediatek,dpmaif-cap = <0x0000004a>;
			mediatek,plat-info = <6858>;
			clocks = <&infra_infracfg_ao_reg_clk CLK_INFRACFG_AO_REG_DPMAIF_MAIN_DPMAIF>,
				<&infra_infracfg_ao_reg_clk CLK_INFRACFG_AO_REG_CLDMA_BCLK_DPMAIF>,
				<&infra_infracfg_ao_reg_clk CLK_INFRACFG_AO_REG_RG_MMW_DPMAIF26M_DPMAIF>;
			clock-names = "infra-dpmaif-clk",
				    "infra-dpmaif-blk-clk",
				    "infra-dpmaif-rg-mmw-clk";
#if 0
			interconnects = <&dvfsrc MT6873_MASTER_NETSYS &dvfsrc MT6873_SLAVE_DDR_EMI>;
			interconnect-names = "icc-mdspd-bw";
			required-opps = <&dvfsrc_freq_opp0>,
					<&dvfsrc_freq_opp1>;
#endif
			net-spd-ver = <2>;
			hw-reset-ver = <1>;
			dpmaif-infracfg = <&infra_infracfg_ao_reg_clk>;
		};


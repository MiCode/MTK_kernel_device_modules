	smi_larb20: smi-larb20@1b00f000 {
		compatible = "mediatek,smi-larb20",
			"mediatek,mt6858-smi-larb", "mediatek,smi-larb";
		reg = <0 0x1b00f000 0 0x1000>;
		mediatek,smi-supply = <&smi_ipe_sub_comm 0>;

		mediatek,larbs = <&smi_larb13>;
		iommus = <&disp_iommu M4U_L13_P12_PDA_0_SMI_PDAI_0>,
			<&disp_iommu M4U_L13_P13_PDA_0_SMI_PDAI_1>,
			<&disp_iommu M4U_L13_P14_PDA_0_SMI_PDAO>;
		interconnects =
			<&mmqos MASTER_LARB_PORT(M4U_L13_P12_PDA_0_SMI_PDAI_0)
				&mmqos SLAVE_COMMON(0)>,
			<&mmqos MASTER_LARB_PORT(M4U_L13_P13_PDA_0_SMI_PDAI_1)
				&mmqos SLAVE_COMMON(0)>,
			<&mmqos MASTER_LARB_PORT(M4U_L13_P14_PDA_0_SMI_PDAO)
				&mmqos SLAVE_COMMON(0)>;

		dcm: dcm@c530000 {
			compatible = "mediatek,mt6858-dcm";
			reg = <0 0xc530000 0 0xc8a0>,
				<0 0x10001000 0 0xa40>,
				<0 0x10022000 0 0x50>,
				<0 0x11031000 0 0x60>,
				<0 0x1c017000 0 0xb0>;

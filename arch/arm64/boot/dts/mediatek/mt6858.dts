				<0 0x10248000 0 0x2000>, /* DDRPHY AO CHB */
				<0 0x10236000 0 0x2000>, /* DDRPHY NAO CHA */
				<0 0x10246000 0 0x2000>, /* DDRPHY NAO CHB */
				<0 0x10006000 0 0x1000>; /* SLEEP BASE */
			mr4-version = <0>;
			mr4-rg = <0x0090 0x0000ffff 0>;
			fmeter-version = <41>;
			use-real-freq = <1>;
			crystal-freq = <87>;
			pll-id = <0x15c4 0x00003fff 0>;

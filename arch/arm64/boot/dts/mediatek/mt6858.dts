		power-domains = <&scpsys MT6858_POWER_DOMAIN_CAM_SUBA>;
		clocks = <&camsys_rawa_clk CLK_CAM_RA_LARBX_SMI>;
		clock-names = "apb";
	};

	smi_larb17: smi-larb17@1a010000 {
		compatible = "mediatek,smi-larb17",
			"mediatek,mt6858-smi-larb", "mediatek,smi-larb";
		reg = <0 0x1a010000 0 0x1000>;
		mediatek,smi-supply = <&smi_cam_sub_comm0 0>;
		mediatek,larb-id = <17>;
		power-domains = <&scpsys MT6858_POWER_DOMAIN_CAM_SUBB>;
		clocks = <&camsys_rawb_clk CLK_CAM_RB_LARBX_SMI>;
		clock-names = "apb";
	};

	smi_larb7: smi-larb7@17010000 {
		compatible = "mediatek,smi-larb7",
			"mediatek,mt6858-smi-larb", "mediatek,smi-larb";
		reg = <0 0x17010000 0 0x1000>;
		mediatek,smi-supply = <&smi_disp_common 0>;
		mediatek,larb-id = <7>;
		power-domains = <&scpsys MT6858_POWER_DOMAIN_VEN0>;
		clocks = <&venc_gcon_clk CLK_VEN1_CKE0_LARB_SMI>;
		clock-names = "apb";
	};

	smi_larb4: smi-larb4@1602e000 {
		compatible = "mediatek,smi-larb4",
			"mediatek,mt6858-smi-larb", "mediatek,smi-larb";
		reg = <0 0x1602e000 0 0x1000>;
		mediatek,smi-supply = <&smi_disp_common 0>;
		mediatek,larb-id = <4>;
		power-domains = <&scpsys MT6858_POWER_DOMAIN_VDE0>;
	};

	smi_dbg: smi-dbg {
		compatible = "mediatek,mtk-smi-dbg";
		mediatek-larb-supply = <&smi_larb0 &smi_larb1 &smi_larb2 &smi_larb9 &smi_larb11
					&smi_larb20 &smi_larb13 &smi_larb14 &smi_larb16 &smi_larb17
					&smi_larb7 &smi_larb4>;
		mediatek-common-supply = <&smi_ssc0_smi_sub_common &smi_ssc1_smi_sub_common
					  &smi_disp_common &smi_mdp_sub_comm0 &smi_mdp_sub_comm1
					  &smi_img_sub_comm0 &smi_ipe_sub_comm &smi_cam_sub_comm0
					  &smi_cam_sub_comm1>;
		dbg-version = <2>;
		hwccf-support;
	};

	mmqos-wrapper {
			compatible = "mediatek,mt6858-mmqos-wrapper";
	};

	mmqos: interconnect {
		compatible = "mediatek,mt6858-mmqos";
		#mtk-interconnect-cells = <1>;
		mediatek,larbs-supply = <&smi_larb0 &smi_larb1 &smi_larb2
					&smi_larb4  &smi_larb7 &smi_larb9
					&smi_larb11 &smi_larb13 &smi_larb14
					&smi_larb16 &smi_larb17 &smi_larb20>;
		mediatek,commons-supply = <&smi_disp_common>;
		mmqos-state = <0x0>;
		mmqos-log-level = <0>;
		interconnects = <&dvfsrc MT6873_MASTER_MMSYS &dvfsrc MT6873_SLAVE_DDR_EMI>,
				<&dvfsrc MT6873_MASTER_HRT_MMSYS
				&dvfsrc MT6873_SLAVE_HRT_DDR_EMI>;
		interconnect-names = "icc-bw", "icc-hrt-bw";
		vmmrc-base = <0x1ec00000>;
		vmmrc-mask = <0x2e814>;
		vmmrc-mask-bit = <8>;
		vmmrc-on-table = <0x2e788>;
		vmmrc-off-table = <0x2e7a8>;
		mminfra-base = <0x1e800000>;
		mediatek,mmqos-met-not-freerun;
	};

	soc {
		compatible = "simple-bus";
		#address-cells = <2>;
		#size-cells = <2>;
		ranges;
		dma-ranges = <0x0 0x0 0x0 0x0 0x10 0x0>;

		topckgen@10000000 {
			compatible = "mediatek,topckgen";
			reg = <0 0x10000000 0 0x1000>;
		};

		infracfg-ao@10001000 {
			compatible = "mediatek,infracfg_ao";
			reg = <0 0x10001000 0 0x1000>;
		};

		infracfg-ao-mem@10002000 {
			compatible = "mediatek,infracfg_ao_mem";
			reg = <0 0x10002000 0 0x1000>;
		};

		iocfg-0@10002000 {
			compatible = "mediatek,iocfg_0";
			reg = <0 0x10002000 0 0x200>;
		};

		iocfg-1@10002200 {
			compatible = "mediatek,iocfg_1";
			reg = <0 0x10002200 0 0x200>;
		};

		iocfg-2@10002400 {
			compatible = "mediatek,iocfg_2";
			reg = <0 0x10002400 0 0x200>;
		};

		iocfg-3@10002600 {
			compatible = "mediatek,iocfg_3";
			reg = <0 0x10002600 0 0x200>;
		};

		iocfg-4@10002800 {
			compatible = "mediatek,iocfg_4";
			reg = <0 0x10002800 0 0x200>;
		};

		iocfg-5@10002a00 {
			compatible = "mediatek,iocfg_5";
			reg = <0 0x10002a00 0 0x200>;
		};

		iocfg-6@10002c00 {
			compatible = "mediatek,iocfg_6";
			reg = <0 0x10002c00 0 0x200>;
		};

		pericfg@10003000 {
			compatible = "mediatek,pericfg";
			reg = <0 0x10003000 0 0x1000>;
		};

		gpio: gpio@10005000 {
			compatible = "mediatek,gpio";
			reg = <0 0x10005000 0 0x1000>;
		};

		pio: pinctrl {
			compatible = "mediatek,mt6858-pinctrl";
			reg = <0 0x10005000 0 0x1000>,
				<0 0x11b20000 0 0x1000>,
				<0 0x11c10000 0 0x1000>,
				<0 0x11d10000 0 0x1000>,
				<0 0x11d30000 0 0x1000>,
				<0 0x11d40000 0 0x1000>,
				<0 0x11e20000 0 0x1000>,
				<0 0x11e30000 0 0x1000>,
				<0 0x11ed0000 0 0x1000>,
				<0 0x11ee0000 0 0x1000>;
			reg-names = "gpio",
				"iocfg_lm",
				"iocfg_rb",
				"iocfg_bm2",
				"iocfg_bm",
				"iocfg_bm1",
				"iocfg_lt",
				"iocfg_lt1",
				"iocfg_rt",
				"iocfg_rt1";
			gpio-controller;
			#gpio-cells = <2>;
			gpio-ranges = <&pio 0 0 197>;
			interrupt-controller;
			#interrupt-cells = <2>;
			mediatek,eint = <&eint>;
		};

		dcm: dcm@c530000 {
			compatible = "mediatek,mt6858-dcm";
			reg = <0 0xc530000 0 0xc8a0>,
				<0 0x10001000 0 0xa40>,
				<0 0x10022000 0 0x50>,
				<0 0x11031000 0 0x60>,
				<0 0x1c017000 0 0xb0>;
			reg-names = "mcusys_par_wrap",
				"infracfg_ao",
				"infra_ao_bcrm",
				"peri_ao_bcrm",
				"vlp_ao_bcrm";
		};

		iobist@10006000 {
			compatible = "mediatek,iobist";
			reg = <0 0x10006000 0 0x1000>;
		};

		sej@1000a000 {
			compatible = "mediatek,sej";
			reg = <0 0x1000a000 0 0x1000>;
		};

		apirq@1000b000 {
			compatible = "mediatek,apirq";
			reg = <0 0x1000b000 0 0x1000>;
		};

		apmixed@1000c000 {
			compatible = "mediatek,apmixed";
			reg = <0 0x1000c000 0 0xe00>;
		};

		fhctl: fhctl@1000ce00 {
			//mcupm-supply = <&mcupm>;
			//compatible = "mediatek,mt6858-fhctl";
			reg = <0 0x1000ce00 0 0x100>, //AP FHCTL base
				<0 0x1000c000 0 0xe00>, //APMIX base

				<0 0x1000ce00 0 0x100>, //mcupm FHCTL base
				<0 0x1000c000 0 0xe00>; //mcupm pll base

			map0 {
				domain = "top0"; //PLL_GP1
				method = "fhctl-ap";
				mainpll {
					fh-id = <0>;
					perms = <0x1e>;
				};
				msdcpll {
					fh-id = <1>;
					perms = <0x1e>;
				};
				adsppll {
					fh-id = <2>;
					perms = <0x1e>;
				};
				mmpll {
					fh-id = <4>;
					perms = <0x1e>;
				};
				tvdpll {
					fh-id = <5>;
					perms = <0x1e>;
				};
			};

			map1 {
				domain = "top1"; //PLL_GP2
				method = "fhctl-ap";
				armpll-ll {
					fh-id = <6>;
				};
				armpll-bl {
					fh-id = <7>;
				};
				ccipll {
					fh-id = <8>;
				};
			};
		};

		lkg: lkg@c57d400 {
			compatible = "mediatek,mtk-lkg";
			reg = <0 0x0c57d400 0 0xc00>;
		};

		performance: performance-controller@c57c010 {
			compatible = "mediatek,cpufreq-hw";
			reg = <0 0x0c57c010 0 0x120>,
					<0 0x0c57c130 0 0x120>;
			reg-names = "performance-domain0",
					"performance-domain1";
			#performance-domain-cells = <1>;
		};

		cpu_mcucfg: mcusys-ao-cfg@c530000 {
			reg = <0 0x0c530000 0 0x10000>; /* 64KB */
		};

		cpu_pll: mcusys-pll1u-top@1000c000 {
			reg = <0 0x1000c000 0 0x1000>; /* 4KB */
		};

		csram_sys: csram-sysram@11bc00 {
			reg = <0 0x0011bc00 0 0x1400>; /* 5KB */
		};

		devapc-ao-mm@1001c000 {
			compatible = "mediatek,devapc_ao_mm";
			reg = <0 0x1001c000 0 0x1000>;
		};

		devapc-ao-infra-peri@10022000 {
			compatible = "mediatek,devapc_ao_infra_peri";
			reg = <0 0x10022000 0 0x1000>;
		};

		devapc-ao-infra-peri@10023000 {
			compatible = "mediatek,devapc_ao_infra_peri";
			reg = <0 0x10023000 0 0x1000>;
		};

		sleep-reg-md@1000f000 {
			compatible = "mediatek,sleep_reg_md";
			reg = <0 0x1000f000 0 0x1000>;
		};

		topmisc@10011000 {
			compatible = "mediatek,topmisc";
			reg = <0 0x10011000 0 0x1000>;
		};

		dvfsrc-top@10012000 {
			compatible = "mediatek,dvfsrc_top";
			reg = <0 0x10012000 0 0x1000>;

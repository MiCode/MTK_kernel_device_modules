		disp_mutex0: disp-mutex0@14001000 {
			compatible = "mediatek,disp_mutex0",
					"mediatek,mt6858-disp-mutex";
			reg = <0 0x14001000 0 0x1000>;
			dispsys-num = <1>;
			interrupts = <GIC_SPI 303 IRQ_TYPE_LEVEL_HIGH 0>;
			clocks = <&dispsys_config_clk CLK_MM_DISP_MUTEX0_DISP>;
		};

		disp_ovl0_2l: disp-ovl0-2l@14002000 {
			compatible = "mediatek,disp_ovl0_2l",
					"mediatek,mt6858-disp-ovl";
			reg = <0 0x14002000 0 0x1000>;
			dma-ranges = <0x0 0x0 0x0 0x0 0x4 0x0>;
			interrupts = <GIC_SPI 302 IRQ_TYPE_LEVEL_HIGH 0>;

			interconnects =

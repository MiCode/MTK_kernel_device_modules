	cam_sub0_bus: syscon@1a00d000 {
		compatible = "mediatek,mt6858-cam_sub0_bus", "syscon";
		reg = <0 0x1a00d000 0 0x1000>;
	};

	aie@1b001000 {
		compatible = "mediatek,mt6858-aie", "mediatek,aie-hw2.0";
		reg = <0 0x1b001000 0 0x1000>;
		interrupts = <GIC_SPI 581 IRQ_TYPE_LEVEL_HIGH 0>;
		power-domains = <&scpsys MT6858_POWER_DOMAIN_ISP_IPE>;
		dma-ranges = <0x0 0x0 0x0 0x0 0x1 0x0>;
		clocks = <&ipesys_clk CLK_IPE_FD>,
				<&ipesys_clk CLK_IPE_LARB20>;
		clock-names = "aie",
					"FDVT_CLK_IPE_LARB20";
		mboxes = <&gce_m 1 0 CMDQ_THR_PRIO_1>,
				 <&gce_m_sec 11 0 CMDQ_THR_PRIO_1>;
		iommus = <&disp_iommu M4U_L20_P0_IPESYS_SMI_FDVT_RDA_0>,
				 <&disp_iommu M4U_L20_P1_IPESYS_SMI_FDVT_RDB_0>,
				 <&disp_iommu M4U_L20_P2_IPESYS_SMI_FDVT_WRA_0>,
				 <&disp_iommu M4U_L20_P3_IPESYS_SMI_FDVT_WRB_0>;
		fdvt_frame_done = <CMDQ_EVENT_IPE_FDVT_DONE>;
		mediatek,larb = <&smi_larb20>;
		interconnects =
				<&mmqos MASTER_LARB_PORT(M4U_L20_P0_IPESYS_SMI_FDVT_RDA_0)
					&mmqos SLAVE_COMMON(0)>,
				<&mmqos MASTER_LARB_PORT(M4U_L20_P1_IPESYS_SMI_FDVT_RDB_0)
					&mmqos SLAVE_COMMON(0)>,
				<&mmqos MASTER_LARB_PORT(M4U_L20_P2_IPESYS_SMI_FDVT_WRA_0)
					&mmqos SLAVE_COMMON(0)>,
				<&mmqos MASTER_LARB_PORT(M4U_L20_P3_IPESYS_SMI_FDVT_WRB_0)
					&mmqos SLAVE_COMMON(0)>;
			interconnect-names =
					"fdvt_qos_rda",
					"fdvt_qos_rdb",
					"fdvt_qos_wra",
					"fdvt_qos_wrb";
		mmqos-supply = <&mmqos>;
		cmdq-supply = <&gce_m_sec>;
	};

	ipe_sub0_bus: syscon@1b00e000 {
		compatible = "mediatek,mt6858-ipe_sub0_bus", "syscon";
		reg = <0 0x1b00e000 0 0x1000>;
	};

	scpsys: power-controller@1c001000 {
		compatible = "mediatek,mt6858-scpsys", "syscon";
		reg = <0 0x1c001000 0 0x1000>;
		#power-domain-cells = <1>;
			clocks = <&cksys_reg_clk CLK_TOP_AUD_INTBUS_SEL>,
				<&cksys_reg_clk CLK_TOP_MMINFRA_SEL>,
				<&cksys_reg_clk CLK_TOP_MMUP_SEL>,
				<&cksys_reg_clk CLK_TOP_IPE_SEL>,
				<&cksys_reg_clk CLK_TOP_VDEC_SEL>,
				<&cksys_reg_clk CLK_TOP_VENC_SEL>,
				<&cksys_reg_clk CLK_TOP_CAM_SEL>,
				<&cksys_reg_clk CLK_TOP_DISP0_SEL>,
				<&cksys_reg_clk CLK_TOP_IMG1_SEL>,
				<&imgsys1_clk CLK_IMGSYS1_LARB9_GENPD>,
				<&imgsys1_clk CLK_IMGSYS1_LARB10_GENPD>,
				<&ipesys_clk CLK_IPE_SMI_SUBCOM_GENPD>,
				<&camsys_main_clk CLK_CAM_M_CAM2MM_GALS_GENPD>,
				<&camsys_main_clk CLK_CAM_M_LARB13_GENPD>,
				<&camsys_main_clk CLK_CAM_M_LARB14_GENPD>,
				<&dispsys_config_clk CLK_MM_SMI_COMMON_GENPD>,
				<&mdpsys_config_clk CLK_MDP_SMI0_GENPD>;
			clock-names = "audio_0",
				"mm_infra_0",
				"mm_proc_0",
				"isp_ipe_0",
				"vde0_0",
				"ven0_0",
				"cam_0",
				"dis0_0",
				"isp_img_0",
				"isp_img-0",
				"isp_img-1",
				"isp_ipe-0",
				"cam_main-0",
				"cam_main-1",
				"cam_main-2",
				"dis0-0",
				"dis0_lp-0";
		infra-infracfg-ao-reg-bus = <&infra_infracfg_ao_reg_clk>;
		ssr-top = <&ssr_top>;
		img-sub0-bus = <&img_sub0_bus>;
		cam-sub1-bus = <&cam_sub1_bus>;
		cam-sub0-bus = <&cam_sub0_bus>;
		ipe-sub0-bus = <&ipe_sub0_bus>;
		vlpcfg-reg-bus = <&vlpcfg_reg_bus>;
		hw-voter-regmap = <&hwv>;
	};

	vlpcfg_reg_bus: syscon@1c00c000 {
		compatible = "mediatek,mt6858-vlpcfg_reg_bus", "syscon";
		reg = <0 0x1c00c000 0 0x1000>;
	};


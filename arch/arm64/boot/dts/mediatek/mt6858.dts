	therm_intf: therm-intf@114000 {
		compatible = "mediatek,therm_intf";
		reg = <0 0x00114000 0 0x400>;
		reg-names = "therm_sram";
	};

	mt6363_temp: mt6363-temp {
		compatible = "mediatek,mt6363-pmic-temp";
		io-channels =
			<&pmic_adc AUXADC_CHIP_TEMP>,
			<&pmic_adc AUXADC_VCORE_TEMP>,
			<&pmic_adc AUXADC_VPROC_TEMP>,
			<&pmic_adc AUXADC_VGPU_TEMP>;
		io-channel-names =
			"pmic6363_ts1",
			"pmic6363_ts2",
			"pmic6363_ts3",
			"pmic6363_ts4";

		#thermal-sensor-cells = <1>;
		nvmem-cells = <&mt6363_thermal_efuse>;
		nvmem-cell-names = "mt6363_e_data";
	};

	mt6369_temp: mt6369-temp {
		compatible = "mediatek,mt6369-pmic-temp";
		io-channels =
			<&mt6369_adc AUXADC_CHIP_TEMP>,
			<&mt6369_adc AUXADC_VCORE_TEMP>,
			<&mt6369_adc AUXADC_VPROC_TEMP>,
			<&mt6369_adc AUXADC_VGPU_TEMP>;
		io-channel-names =
			"pmic6369_ts1",
			"pmic6369_ts2",
			"pmic6369_ts3",
			"pmic6369_ts4";

		#thermal-sensor-cells = <1>;
		nvmem-cells = <&mt6369_thermal_efuse>;
		nvmem-cell-names = "mt6369_e_data";
	};

	thermal_zones: thermal-zones {
		ap_ntc: ap_ntc {
			polling-delay = <0>; /* milliseconds */
			polling-delay-passive = <0>; /* milliseconds */
			thermal-sensors = <&tboard_thermistor1>;

			trips {
				ap_ntc_crit: ap-ntc-crit {
					temperature = <115000>;
					hysteresis = <2000>;
					type = "passive";
				};
			};
		};
		ltepa_ntc: ltepa_ntc {
			polling-delay = <0>; /* milliseconds */
			polling-delay-passive = <0>; /* milliseconds */
			thermal-sensors = <&tboard_thermistor2>;

			trips {
				ltepa_ntc_crit: ltepa-ntc-crit {
					temperature = <115000>;
					hysteresis = <2000>;
					type = "passive";
				};
			};
		};
		nrpa_ntc: nrpa_ntc {
			polling-delay = <0>; /* milliseconds */
			polling-delay-passive = <0>; /* milliseconds */
			thermal-sensors = <&tboard_thermistor3>;

			trips {
				nrpa_ntc_crit: nrpa-ntc-crit {
					temperature = <115000>;
					hysteresis = <2000>;
					type = "passive";
				};
			};
		};
		pmic6363-vio18 {
			polling-delay = <0>; /* milliseconds */
			polling-delay-passive = <0>; /* milliseconds */
			thermal-sensors = <&mt6363_temp 0>;

			trips {
				pmic6363_vio18_crit: pmic6363-vio18-crit {
					temperature = <115000>;
					hysteresis = <2000>;
					type = "passive";
				};
			};
		};
		pmic6363-vs1-vs3 {
			polling-delay = <0>; /* milliseconds */
			polling-delay-passive = <0>; /* milliseconds */
			thermal-sensors = <&mt6363_temp 1>;

			trips {
				pmic6363_vs1_vs3_crit: pmic6363-vs1-vs3-crit {
					temperature = <115000>;
					hysteresis = <2000>;
					type = "passive";
				};
			};
		};
		pmic6363-bk3-bk7 {
			polling-delay = <0>; /* milliseconds */
			polling-delay-passive = <0>; /* milliseconds */
			thermal-sensors = <&mt6363_temp 2>;

			trips {
				pmic6363_bk3_bk7_crit: pmic6363-bk3-bk7-crit {
					temperature = <115000>;
					hysteresis = <2000>;
					type = "passive";
				};
			};
		};
		pmic6363-vs2 {
			polling-delay = <0>; /* milliseconds */
			polling-delay-passive = <0>; /* milliseconds */
			thermal-sensors = <&mt6363_temp 3>;

			trips {
				pmic6363_vs2_crit: pmic6363-vs2-crit {
					temperature = <115000>;
					hysteresis = <2000>;
					type = "passive";
				};
			};
		};
		pmic6369-vpa {
			polling-delay = <0>; /* milliseconds */
			polling-delay-passive = <0>; /* milliseconds */
			thermal-sensors = <&mt6369_temp 0>;

			trips {
				pmic6369_vpa_crit: pmic63639-vpa-crit {
					temperature = <115000>;
					hysteresis = <2000>;
					type = "passive";
				};
			};
		};
		pmic6369-vbk1 {
			polling-delay = <0>; /* milliseconds */
			polling-delay-passive = <0>; /* milliseconds */
			thermal-sensors = <&mt6369_temp 1>;

			trips {
				pmic6369_vbk1_crit: pmic63639-vbk1-crit {
					temperature = <115000>;
					hysteresis = <2000>;
					type = "passive";
				};
			};
		};
		pmic6369-vcn33-1 {
			polling-delay = <0>; /* milliseconds */
			polling-delay-passive = <0>; /* milliseconds */
			thermal-sensors = <&mt6369_temp 2>;

			trips {
				pmic6369_vcn33_1_crit: pmic63639-vcn33-1-crit {
					temperature = <115000>;
					hysteresis = <2000>;
					type = "passive";
				};
			};
		};
		pmic6369-vefuse {
			polling-delay = <0>; /* milliseconds */
			polling-delay-passive = <0>; /* milliseconds */
			thermal-sensors = <&mt6369_temp 3>;

			trips {
				pmic6369_vefuse_crit: pmic63639-vefuse-crit {
					temperature = <115000>;
					hysteresis = <2000>;
					type = "passive";
				};
			};
		};
	};

	connscp: connscp {
		compatible = "mediatek,mt6858-conn_scp";
		scp-shm-size = <0x20000>;

		scp-remap-offset = <0x2100000>; /* offset from connsys pa */
		scp-remap-size = <0x20000>;

		ipi-mbox-size = <64>;
	};

	consys: consys@18000000 {
		compatible = "mediatek,mt6858-6631-consys";
		#thermal-sensor-cells = <0>;
		reg =   <0 0x18000000 0 0x470>, /* 0. 0x1800_0000 conn_infra_rgu_on, sz=0x470 */
			<0 0x10001000 0 0xee4>, /* 1. 0x1000_1000 infracfg_ao, sz=0xee4 */
			<0 0x10005000 0 0xa7c>, /* 2. 0x1000_5000 GPIO, sz=0xa7c */
			<0 0x11ee0000 0 0xa04>, /* 3. 0x11ee_0000 IOCFG_RT, sz=0xa04 */
			<0 0x18001000 0 0x658>, /* 4. 0x1800_1000 conn_infra_cfg_on, sz=0x658 */
			<0 0x18003000 0 0x204>, /* 5. 0x1800_3000 conn_wt_slp_ctl_reg, sz=0x204 */
			<0 0x1800e000 0 0x118>, /* 6. 0x1800_e000 conn_infra_bus_cr_on, sz=0x118*/
			<0 0x18011000 0 0x138>, /* 7. 0x1801_1000 conn_infra_cfg, sz=0x138 */
			<0 0x18012000 0 0x98>,  /* 8. 0x1801_2000 conn_infra_clkgen_top,sz=0x98 */
			<0 0x18020000 0 0x4c>,  /* 9. 0x1802_0000 conn_von_bus_bcrm, sz=0x4c */
			<0 0x18023000 0 0xe28>, /* 10. 0x1802_3000 conn_dbg_ctl, sz=0xe28 */
			<0 0x1803b000 0 0x18>,  /* 11. 0x1803_b000 conn_infra_on_bus_bcrm,sz=0x18 */
			<0 0x18040000 0 0x2c>,  /* 12. 0x1804_0000 conn_therm_ctl, sz=0x2c */
			<0 0x18041000 0 0x140>, /* 13. 0x1804_1000 conn_afe_ctl, sz=0x140 */
			<0 0x18042000 0 0x324>, /* 14. 0x1804_2000 conn_rf_spi_mst_reg, sz=0x324 */
			<0 0x18046000 0 0x324>, /* 15. 0x1804_6000 conn_rf_spi_1_mst_reg, sz=0x324 */
			<0 0x1804b000 0 0x414>, /* 16. 0x1804_b000 conn_infra_bus_cr, sz=0x414 */
			<0 0x1804d000 0 0x41c>, /* 17. 0x1804_d000 conn_infra_off_debug_ctrl_ao */
			<0 0x1804f000 0 0x148>, /* 18. 0x1804_f000 conn_infra_off_bus_bcrm,0x148 */
			<0 0x18053800 0 0x1000>,/* 19. 0x1805_3800 conn_infra_sysram_sw_cr,0x1000*/
			<0 0x18060000 0 0xbf8>, /* 20. 0x1806_0000 conn_host_csr_top, sz=0xbf8 */
			<0 0x18070000 0 0x8004>,/* 21. 0x1807_0000 conn_semaphore, sz=0x8004 */
			<0 0x1c001000 0 0xfd0>, /* 22. 0x1c00_1000 spm, sz=0xfd0 */
			<0 0x1c00a000 0 0x51c>, /* 23. 0x1c00_a000 top_rgu, sz=0x51c */
			<0 0x1803c000 0 0x34>,  /* 24. 0x1803_c000 wf2ap_conn_infra_on_ccif4 */
			<0 0x1803e000 0 0x34>;  /* 25. 0x1803_e000 bgf2ap_conn_infra_on_ccif4 */

		power-domains = <&scpsys MT6858_POWER_DOMAIN_CONN>;
		emi-addr = <0>;
		emi-size = <0x0c00000>;
		ro-bt-emi-size = <0x2e0000>;
		ro-gps-emi-size = <0x0a0000>;
		ro-wifi-emi-size = <0x300000>;
		ro-emi-size = <0x680000>;
		rw-emi-size = <0x480000>;
		emi-alignment = <0x100000>;
		emi-max-addr = <0x90000000>;
		hwid-node = <138>;
		adie-sku = <0 1>;  /* mt6631 = 0 , mt6631 + mt6686 = 1 */
	};

	/* ATF logger */
	atf_logger: atf-logger {
		compatible = "mediatek,tfa_debug";
	};

	connfem: connfem {
		compatible = "mediatek,connfem";
	};

	sound: sound {
		compatible = "mediatek,mt6858-mt6369-sound";
		/* mediatek,snd_audio_dsp = <&snd_audio_dsp>; */
		/* mediatek,headset-codec = <&accdet>; */
		mediatek,platform = <&afe>;
		mediatek,ipm = <1>; /* 0: old version; 1: IPM2.0 */
	};
};

&pio {
	aud_dat_mosi0_off: aud-dat-mosi0-off {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO175__FUNC_GPIO175>;
			input-enable;
			bias-pull-down;
		};
	};
	aud_dat_mosi0_on: aud-dat-mosi0-on {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO175__FUNC_AUD_DAT_MOSI0>;
			input-schmitt-enable;
			bias-disable;
		};
	};
	aud_dat_mosi1_off: aud-dat-mosi1-off {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO176__FUNC_GPIO176>;
			input-enable;
			bias-pull-down;
		};
	};
	aud_dat_mosi1_on: aud-dat-mosi1-on {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO176__FUNC_AUD_DAT_MOSI1>;
			input-schmitt-enable;
			bias-disable;
		};
	};
	aud_dat_miso0_off: aud-dat-miso0-off {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO179__FUNC_GPIO179>;
			input-enable;
			bias-pull-down;
		};
	};
	aud_dat_miso0_on: aud-dat-miso0-on {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO179__FUNC_AUD_DAT_MISO0>;
			input-schmitt-enable;
			bias-disable;
		};
	};
	aud_dat_miso1_off: aud-dat-miso1-off {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO180__FUNC_GPIO180>;
			input-enable;
			bias-disable;
		};
	};
	aud_dat_miso1_on: aud-dat-miso1-on {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO180__FUNC_AUD_DAT_MISO1>;
			input-schmitt-enable;
			bias-disable;
		};
	};
	aud_gpio_i2sin1_off: aud-gpio-i2sin1-off {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO41__FUNC_GPIO41>;
			input-enable;
			bias-pull-down;
		};
		pins-cmd2-dat {
			pinmux = <PINMUX_GPIO42__FUNC_GPIO42>;
			input-enable;
			bias-pull-down;
		};
		pins-cmd3-dat {
			pinmux = <PINMUX_GPIO44__FUNC_GPIO44>;
			input-enable;
			bias-pull-down;
		};
	};
	aud_gpio_i2sin1_on: aud-gpio-i2sin1-on {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO41__FUNC_I2SIN1_BCK>;
			input-schmitt-enable;
			bias-disable;
		};
		pins-cmd2-dat {
			pinmux = <PINMUX_GPIO42__FUNC_I2SIN1_LRCK>;
			input-schmitt-enable;
			bias-disable;
		};
		pins-cmd3-dat {
			pinmux = <PINMUX_GPIO44__FUNC_I2SIN1_DI>;
			input-schmitt-enable;
			bias-disable;
		};
	};
	aud_gpio_i2sout1_off: aud-gpio-i2sout1-off {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO43__FUNC_GPIO43>;
			input-enable;
			bias-pull-down;
		};
	};
	aud_gpio_i2sout1_on: aud-gpio-i2sout1-on {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO43__FUNC_I2SOUT1_DO>;
			input-schmitt-enable;
			bias-disable;
		};
	};
	aud_gpio_ap_dmic_off: aud-gpio-ap-dmic-off {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO1__FUNC_GPIO1>;
			input-enable;
			bias-pull-down;
		};
		pins-cmd2-dat {
			pinmux = <PINMUX_GPIO2__FUNC_GPIO2>;
			input-enable;
			bias-pull-down;
		};
	};
	aud_gpio_ap_dmic_on: aud-gpio-ap-dmic-on {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO1__FUNC_DMIC_CLK>;
			input-schmitt-enable;
			bias-disable;
		};
		pins-cmd2-dat {
			pinmux = <PINMUX_GPIO2__FUNC_DMIC_DAT>;
			input-schmitt-enable;
			bias-disable;
		};
	};
	aud_gpio_ap_dmic1_off: aud-gpio-ap-dmic1-off {
		/* Unused */
	};
	aud_gpio_ap_dmic1_on: aud-gpio-ap-dmic1-on {
		/* Unused */
	};
	vow_dat_miso_off: vow-dat-miso-off {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO179__FUNC_GPIO179>;
			input-enable;
			bias-pull-down;
		};
	};
	vow_dat_miso_on: vow-dat-miso-on {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO179__FUNC_VOW_DAT_MISO>;
			input-schmitt-enable;
			bias-disable;
		};
	};
	vow_clk_miso_off: vow-clk-miso-off {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO180__FUNC_GPIO180>;
			input-enable;
			bias-pull-down;
		};
	};
	vow_clk_miso_on: vow-clk-miso-on {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO180__FUNC_VOW_CLK_MISO>;
			input-schmitt-enable;
			bias-disable;
		};
	};
	vow_scp_dmic_clk_off: vow-scp-dmic-clk-off {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO1__FUNC_GPIO1>;
			input-enable;
			bias-pull-down;
		};
	};
	vow_scp_dmic_clk_on: vow-scp-dmic-clk-on {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO1__FUNC_SCP_DMIC_CLK>;
			input-schmitt-enable;
			bias-disable;
		};
	};
	vow_scp_dmic_dat_off: vow-scp-dmic-dat-off {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO2__FUNC_GPIO2>;
			input-enable;
			bias-pull-down;
		};
	};
	vow_scp_dmic_dat_on: vow-scp-dmic-dat-on {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO2__FUNC_SCP_DMIC_DAT>;
			input-schmitt-enable;
			bias-disable;
		};
	};
};

&mddriver {
	/* for md pmic voltage setting */
	md-vmodem-supply = <&mt6363_vbuck2>;
	md-vmodem = <825000 825000>;
	md-vsram-supply = <&mt6363_vsram_modem>;
	md-vsram = <825000 825000>;
	md-vdigrf-supply = <&mt6363_vbuck1>;
	md-vdigrf = <700000 700000>;
};

&md_auxadc {
	io-channels = <&pmic_adc (ADC_PURES_OPEN_MASK | AUXADC_VIN1)>;
};

#include "mediatek/mt6363.dtsi"
#include "mediatek/mt6369.dtsi"
#include "mediatek/mt6685.dtsi"
#include "mediatek/trusty.dtsi"
#include "mediatek/cust_mt6858_msdc.dtsi"
#include "mediatek/mt6858-clkitg.dtsi"
#include "mediatek/cust_mt6858_connfem.dtsi"
#include "mediatek/mt6858-disable-unused.dtsi"

&spmi {
// PMIC TODO:
#if 0
	pmic: pmic@4 {
		mt6363_dynamic_loading_throttling: mtk-dynamic-loading-throttling {
			compatible = "mediatek,mt6363-dynamic_loading_throttling";
			/* charger: mtk_charger_thread */
			mediatek,charger = <&lk_charger>;
			/* 2000~2900mV, one gear per 100mV */
			uvlo-level = <2400>;
			vbb-uvlo-level = <2500>;
			bob-check-flag = <1>;
			io-channels = <&mt6375_auxadc MT6375_AUXADC_IMP>,
				<&mt6375_auxadc MT6375_AUXADC_IMIX_R>,
				<&mt6375_auxadc MT6375_AUXADC_BATSNS>;
			io-channel-names = "pmic_ptim",
					"pmic_imix_r",
					"pmic_batadc";
			bootmode = <&chosen>;
			// turn on after bring-up
			status = "disabled";
		};
	};
#endif

	mt6319_6: mt6319@6 {
		compatible = "mediatek,mt6319";
		reg = <0x6 SPMI_USID>;

		extbuck-debug {
			compatible = "mediatek,spmi-pmic-debug";
		};
		mt6319_6_regulator: mt6319-6-regulator {
			compatible = "mediatek,mt6315_6-regulator";
			buck-size = <1>;
			buck1-modeset-mask = <0x1>;

			mt6319_6_vbuck1: 6-vbuck1 {
				regulator-compatible = "vbuck1";
				regulator-name = "6_vbuck1";
				regulator-min-microvolt = <300000>;
				regulator-max-microvolt = <1193750>;
				regulator-enable-ramp-delay = <256>;
				regulator-allowed-modes = <0 1 2>;
			};
		};
	};
};

&mt6319_6_vbuck1 {
	regulator-always-on;
};

&mt6363_vbuck1 {
	regulator-always-on;
};

&mt6363_vbuck2 {
	regulator-always-on;
};

&mt6363_vbuck4 {
	regulator-always-on;
};

&mt6363_vbuck5 {
	regulator-always-on;
};

&mt6363_vbuck6 {
	regulator-always-on;
};

&mt6363_vbuck7 {
	regulator-always-on;
};

&mt6363_vm18 {
	regulator-always-on;
};

&mt6363_vcn15 {
	regulator-always-on;
};

&mt6363_vrf12 {
	regulator-always-on;
};

&mt6363_vsram_apu {
	regulator-always-on;
};

&mt6363_vsram_cpub {
	regulator-always-on;
};

&mt6363_vsram_cpul {
	regulator-always-on;
};

&mt6363_vsram_modem {
	regulator-always-on;
};

&mt6363_vsram_cpum {
	regulator-always-on;
};

&mt6363_vsram_digrf {
	regulator-always-on;
};

/* vufs18 is used by DVDD18_IORB(GPIO), so must always on. */
&mt6363_vufs18 {
	regulator-always-on;
};

&mt6363_vufs12 {
	regulator-always-on;
};

&mt6363_va15 {
	/delete-property/ regulator-always-on;
};

&mt6363_vio075 {
	/delete-property/ regulator-always-on;
};

&mt6369_vbuck1 {
	regulator-always-on;
};

&mt6369_vsram_core{
	regulator-always-on;

};

&i2c4 {
	#address-cells = <1>;
	#size-cells = <0>;
	rt6160@75 {
		/* richtek,rt6160-vbb compatbile is for is-existed property */
		compatible = "richtek,rt6160",
			     "richtek,rt6160-vbb";
		reg = <0x75>;
		//enable-gpios = <&gpio26 2 0>;
		regulator-name = "rt6160-buckboost-vbb3";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		regulator-always-on;

		dbg {
			compatible = "richtek,rt6160-dbg";
		};
	};
};

&i2c5 {
	#address-cells = <1>;
	#size-cells = <0>;
	mediatek,fifo-use-polling;
	clock-frequency = <1000000>;

	mt6720: mt6720@34 {
		compatible = "mediatek,mt6720";
		reg = <0x34>;
		status = "okay";
		interrupt-parent = <&pio>;
		interrupts = <118 IRQ_TYPE_LEVEL_LOW>;
		interrupt-controller;
		#interrupt-cells = <1>;
		wakeup-source;

		dbg {
			compatible = "richtek,subpmic-dbg";
			dbg-bus = "I2C";
			dbg-name = "MT6720";
		};

		mt6720_chg: chg {
			compatible = "mediatek,mt6720-charger";
			interrupts = <MT6720_EVT_PWR_RDY>, <MT6720_EVT_DETACH>,
				     <MT6720_EVT_VBUS_OV>, <MT6720_EVT_CHG_TOUT>,
				     <MT6720_EVT_AICC_DONE>, <MT6720_EVT_PE_DONE>,
				     <MT6720_EVT_WDT>, <MT6720_EVT_BATRPO_DONE>,
				     <MT6720_EVT_BC12_DN>, <MT6720_EVT_ADC_VBAT_MON_OV>,
				     <MT6720_EVT_BASE_OTP0>,
				     <MT6720_EVT_BASE_OTP1>, <MT6720_EVT_BASE_OTP2>,
				     <MT6720_EVT_BUS_CHG_RDY>, <MT6720_EVT_CHG_SYSOV>;
			interrupt-names = "fl_pwr_rdy", "fl_detach",
					  "fl_vbus_ov", "fl_chg_tout",
					  "fl_aicc_done", "fl_pe_done",
					  "fl_wdt", "fl_batpro_done",
					  "fl_bc12_dn", "adc_vbat_mon_ov",
					  "otp0", "otp1", "otp2",
					  "fl_bus_chg_rdy", "fl_chg_sysov";
			gauge = <&mtk_gauge>;
			/* mt6720 point VBATMON to VBATMON2, make driver compatible */
			io-channels = <&mt6720_adc MT6720_ADC_VBATMON>,
				      <&mt6720_adc MT6720_ADC_CHGVIN>,
				      <&mt6720_adc MT6720_ADC_USBDP>,
				      <&mt6720_adc MT6720_ADC_VSYS>,
				      <&mt6720_adc MT6720_ADC_VBAT>,
				      <&mt6720_adc MT6720_ADC_IBUS>,
				      <&mt6720_adc MT6720_ADC_IBAT>,
				      <&mt6720_adc MT6720_ADC_USBDM>,
				      <&mt6720_adc MT6720_ADC_TEMPJC>,
				      <&mt6720_adc MT6720_ADC_SBU2>,
				      <&mt6720_adc MT6720_ADC_VBATMON>,
				      <&mt6720_adc MT6720_ADC_ZCV>;
			chgdev-name = "primary_chg";
			chg-tmr = <10>;
			chg-tmr-en;
			/* 0~3, 8s, 40s, 80s, 160s */
			wdt-time = <1>;
			//wdt-en;
			te-en;
			mivr = <4400000>;	/* uV */
			aicr = <500000>;	/* uA */
			ichg = <2000000>;	/* uA */
			ieoc = <150000>;	/* uA */
			cv = <4200000>;		/* uV */
			vrec = <100000>;	/* uV */
			bc12-sel = <MTK_CTD_BY_SUBPMIC>;
			nr-port = <1>;
			boot-mode = <&chosen>;
			phys = <&u2port0 PHY_TYPE_USB2>;
			phy-names = "usb2-phy";
			usb = <&ssusb>;
			//usb-killer-detect;
			enable-fsw-control = <0>; // fsw-control default is enable
			//pmic-uvlo = <&mt6363_dynamic_loading_throttling>;
			otg-supply = <&mt6720_otg_vbus>;
			mt6720_otg_vbus: usb-otg-vbus-regulator {
				regulator-name = "mt6720-usb-otg-vbus";
				regulator-min-microvolt = <4850000>;
				regulator-max-microvolt = <5500000>;
				regulator-min-microamp = <500000>;
				regulator-max-microamp = <2600000>;
			};
		};

		mt6720_div2: div2 {
			compatible = "mediatek,mt6720-div2";
			interrupts = <MT6720_EVT_DIV2_VAC_PD> ,<MT6720_EVT_DIV2_VBUS_PD>,
				     <MT6720_EVT_DIV2_VBAT_OVP>, <MT6720_EVT_DIV2_IBUS_OCP>,
				     <MT6720_EVT_DIV2_IBUS_UCP_RISE>, <MT6720_EVT_DIV2_IBUS_UCP_FALL>,
				     <MT6720_EVT_DIV2_IBUS_OCP_H>, <MT6720_EVT_DIV2_VBUS_LOW_ERR>,
				     <MT6720_EVT_DIV2_VBUS_HIGH_ERR>, <MT6720_EVT_DIV2_VAC_POR>,
				     <MT6720_EVT_DIV2_VBUS_INSERT>, <MT6720_EVT_DIV2_VBAT_INSERT>,
				     <MT6720_EVT_DIV2_WDT>, <MT6720_EVT_DIV2_VAC_UVLO>,
				     <MT6720_EVT_DIV2_VBUS_UVLO>, <MT6720_EVT_DIV2_IBUS_UCP_TO>,
				     <MT6720_EVT_DIV2_CON_SWITCHING>, <MT6720_EVT_DIV2_CFLY_DIAG>;
			interrupt-names = "div2_fl_vac_pd" ,"div2_fl_vbus_pd",
					  "div2_fl_vbat_ovp", "div2_fl_ibus_ocp",
					  "div2_fl_ibus_ucp_rise", "div2_fl_ibus_ucp_fall",
					  "div2_fl_ibus_ocp_h", "div2_fl_vbus_low_err",
					  "div2_fl_vbus_high_err", "div2_fl_vac_por",
					  "div2_fl_vbus_insert", "div2_fl_vbat_insert",
					  "div2_fl_wdt", "div2_fl_vac_uvlo",
					  "div2_fl_vbus_uvlo", "div2_fl_ibus_ucp_to",
					  "div2_fl_con_switching", "div2_fl_cfly_diag";
			io-channels = <&mt6720_adc MT6720_ADC_CHGVIN>,
				      <&mt6720_adc MT6720_ADC_VBAT>,
				      <&mt6720_adc MT6720_ADC_IBUS>,
				      <&mt6720_adc MT6720_ADC_IBAT>,
				      <&mt6720_adc MT6720_ADC_TEMPJC>,
				      <&mt6720_adc MT6720_ADC_DIV2>;
			chgdev-name = "primary_dvchg";
			wdt-dis;
			vbatovp = <4350000>;
			vbusovp = <8900000>;
			ibusocp = <1000000>;
			fsw = <500000>;
			wdt-timer = <0>;
		};

		mt6720_auxadc: auxadc {
			compatible = "mediatek,pmic-auxadc",
				     "mediatek,mt6720-auxadc";
			interrupts = <MT6720_EVT_GM_BM1>;
			interrupt-controller;
			#interrupt-cells = <1>;
			#address-cells = <1>;
			#io-channel-cells = <1>;
			io-channels = <&mt6720_adc MT6720_ADC_VBAT>,
				      <&mt6720_auxadc MT6379_AUXADC_BATSNS_DBG>;
			io-channel-names = "chg_vbat", "auxadc_vbat";
			charger = <&mt6720_chg>;
			gauge = <&mtk_gauge>;
		};

		mtk_gauge: mtk-gauge {
			compatible = "mediatek,mt6720-gauge";
			interrupt-controller;
			#interrupt-cells = <1>;
			#address-cells = <1>;
			bootmode = <&chosen>;
			charger = <&mt6720_chg>;
			io-channels = <&mt6720_auxadc MT6379_AUXADC_BATSNS>,
				      <&mt6720_auxadc MT6379_AUXADC_BATON>,
				      <&mt6720_auxadc MT6379_AUXADC_IMP>,
				      <&mt6720_auxadc MT6379_AUXADC_IMIX_R>,
				      <&mt6720_auxadc MT6379_AUXADC_VREF>,
				      <&mt6720_adc MT6720_ADC_VBATMON>;
			io-channel-names = "bat_volt", "bat_temp", "ptim_bat_volt",
					   "ptim_r", "vref", "adc_vbatmon";
			interrupts-extended = <&mt6720 MT6720_EVT_GM_BM1>,
					      <&mtk_gauge RG_INT_STATUS_FG_BAT_H>,
					      <&mtk_gauge RG_INT_STATUS_FG_BAT_L>,
					      <&mt6720_auxadc RG_INT_STATUS_BAT2_H>,
					      <&mt6720_auxadc RG_INT_STATUS_BAT2_L>,
					      <&mt6720_auxadc RG_INT_STATUS_NAG_C_DLTV>,
					      <&mtk_gauge RG_INT_STATUS_BATON_BAT_IN>,
					      <&mtk_gauge RG_INT_STATUS_BATON_BAT_OUT>,
					      <&mtk_gauge RG_INT_STATUS_FG_ZCV>,
					      <&mtk_gauge RG_INT_STATUS_FG_N_CHARGE_L>,
					      <&mtk_gauge RG_INT_STATUS_FG_IAVG_H>,
					      <&mtk_gauge RG_INT_STATUS_FG_IAVG_L>,
					      <&mt6720_auxadc RG_INT_STATUS_BAT_TEMP_H>,
					      <&mt6720_auxadc RG_INT_STATUS_BAT_TEMP_L>;
			interrupt-names = "GM30_EVT", "COULOMB_H", "COULOMB_L",
					  "VBAT2_H", "VBAT2_L", "NAFG", "BAT_IN", "BAT_OUT", "ZCV",
					  "FG_N_CHARGE_L", "FG_IAVG_H", "FG_IAVG_L", "BAT_TMP_H",
					  "BAT_TMP_L";
			nvmem-cells = <&fg_init>, <&fg_soc>;
			nvmem-cell-names = "initialization", "state-of-charge";
		};

		mt6720_adc: mt6720-adc {
			compatible = "mediatek,mt6720-adc";
			#io-channel-cells = <1>;
		};

		mt6720-ufcs {
			compatible = "mediatek,mt6720-ufcs";
			interrupts = <MT6720_EVT_DPDM_UFCS>;
		};

		mt6720_lbat_service: lbat-service {
			compatible = "mediatek,mt6720-lbat-service";
			interrupts-extended = <&mt6720_auxadc RG_INT_STATUS_BAT_H>,
					      <&mt6720_auxadc RG_INT_STATUS_BAT_L>;
			interrupt-names = "bat_h", "bat_l";
			resistance-ratio = <4 1>;
		};

		mt6720_batoc_throttle: mtk-battery-oc-throttling {
			compatible = "mediatek,mt6720-battery-oc-throttling";
			interrupts-extended = <&mtk_gauge RG_INT_STATUS_FG_CUR_H>,
					      <&mtk_gauge RG_INT_STATUS_FG_CUR_L>;
			interrupt-names = "fg_cur_h", "fg_cur_l";
			oc-thd = <6000 7000 8000>;
		};

		mt6720_typec: mt6720-tcpc {
			compatible = "mediatek,mt6720-tcpc";
			interrupts = <MT6720_EVT_TYPEC_PD>;
			interrupt-names = "pd_evt";
			/* tcpc_device's name */
			tcpc,name = "type_c_port0";
			/* 0: Unknown, 1: SNK, 2: SRC, 3: DRP, 4: Try.SRC, 5: Try.SNK */
			tcpc,role-def = <5>;
			/* 0: Default, 1: 1.5, 2: 3.0 */
			tcpc,rp-level = <1>;
			/* 0: Never, 1: Always, 2: EMarkOnly, 3: StartOnly */
			tcpc,vconn-supply = <1>;
			io-channels = <&mt6720_adc MT6720_ADC_SBU1>,
				      <&mt6720_adc MT6720_ADC_SBU2>;
			charger = <&mt6720_chg>;
			boot-mode = <&chosen>;
			tcpc,en-wd;
			// tcpc,en-wd-dual-port;
			tcpc,en-ctd;
			/* hw not support fod */
			//tcpc,en-fod;
			tcpc,en-typec-otp;
			// tcpc,en-floatgnd;
			wd,sbu-calib-init = <1200>;	/* mV */
			wd,sbu-pl-bound = <200>;	/* mV */
			wd,sbu-pl-lbound-c2c = <1100>;	/* mV */
			wd,sbu-pl-ubound-c2c = <2600>;	/* mV */
			wd,sbu-ph-auddev = <100>;	/* mV */
			wd,sbu-ph-lbound = <888>;	/* mV */
			wd,sbu-ph-lbound1-c2c = <2850>;	/* mV */
			wd,sbu-ph-ubound1-c2c = <3150>;	/* mV */
			wd,sbu-ph-ubound2-c2c = <3800>;	/* mV */
			wd,sbu-aud-ubound = <1600>;	/* mV */
			/* 0:16x, 1:128x, 2:512x, 3:1024x */
			wd,wd0-tsleep = <1>;
			/* 0:400us, 1:1ms, 2:2ms, 3:4ms, 4:10ms, 5:40ms, 6:100ms, 7:400ms */
			wd,wd0-tdet = <3>;
			/* example wd0-tsleep = 512x, wd0-tdet = 4ms, wd0 polling time = 512*4ms */
			pd-data {
				pd,vid = <0x29cf>;
				pd,pid = <0x6720>;
				pd,source-cap-ext = /bits/ 8 <0xcf 0x29 0x20 0x67
							      0x00 0x00 0x00 0x00
							      0x00 0x00 0x00 0x00
							      0x00 0x00 0x00 0x00
							      0x00 0x00 0x00 0x00
							      0x00 0x00 0x01 0x07
							      0x00>;
				pd,sink-cap-ext = /bits/ 8 <0xcf 0x29 0x20 0x67
							    0x00 0x00 0x00 0x00
							    0x00 0x00 0x01 0x00
							    0x00 0x00 0x00 0x00
							    0x01 0x0b 0x01 0x0a
							    0x0a 0x00 0x00 0x00>;
				pd,mfrs = "RichtekTCPC";

				/*
				 *	VSAFE5V = 0, MAX_POWER = 1, CUSTOM = 2,
				 *	MAX_POWER_LV = 0x21, MAX_POWER_LVIC = 0x31
				 *	MAX_POWER_HV = 0x41, MAX_POWER_HVIC = 0x51
				 */
				pd,charging-policy = <0x31>;

				pd,source-pdo-size = <1>;
				pd,source-pdo-data = <0x00019096>; /* 5V, 1500 mA */
				pd,sink-pdo-size = <1>;
				pd,sink-pdo-data = <0x000190c8>;

				/*
				 * No DP, host + device
				 *	pd,id-vdo-size = <6>;
				 *	pd,id-vdo-data = <0xd14029cf 0x0 0x63790000
							  0x61000000 0x0 0x41000000>;
				 * With DP Sink capability
				 *	pd,id-vdo-size = <6>;
				 *	pd,id-vdo-data = <0xd54029cf 0x0 0x63790000
							  0x61000000 0x0 0x41000000>;
				 */

				pd,id-vdo-size = <6>;
				pd,id-vdo-data = <0xd14029cf 0x0 0x67200000
						  0x61000000 0x0 0x41000000>;

				bat,nr = <1>;
				bat-info0 {
					bat,vid = <0x29cf>;
					bat,pid = <0x6720>;
					bat,mfrs = "bat1";
					bat,design-cap = <3000>;
				};
			};
			dpm-caps {
				local-dr-power;
				local-dr-data;
				// local-ext-power;
				local-usb-comm;
				// local-usb-suspend;
				// local-high-cap;
				// local-give-back;
				local-no-suspend;

				/* With DP Source capability */
				attempt-enter-dp-mode;
				// attempt-discover-cable;
				// attempt-discover-id;
				// attempt-discover-svids;

				/* 0: disable, 1: prefer-snk, 2: prefer-src */
				pr-check = <0>;
				// pr-reject-as-source;
				// pr-reject-as-sink;
				// pr-check-gp-source;
				// pr-check-gp-sink;

				/* 0: disable, 1: prefer-ufp, 2: prefer-dfp */
				dr-check = <0>;
				// dr-reject-as-dfp;
				// dr-reject-as-ufp;
			};
			displayport {
				/* connection type = "both", "ufp-d", "dfp-d" */
				1st-connection = "dfp-d";
				2nd-connection = "dfp-d";
				// usbr20-not-used;
				typec,receptacle;
				ufp-d {
					// pin-assignment,mode-c;
					// pin-assignment,mode-d;
					// pin-assignment,mode-e;
				};
				dfp-d {
					pin-assignment,mode-c;
					pin-assignment,mode-d;
					pin-assignment,mode-e;
				};
			};
		};
	};

	rt6160@75 {
		/* richtek,rt6160-vbb compatbile is for is-existed property */
		compatible = "richtek,rt6160",
			     "richtek,rt6160-vbb";
		reg = <0x75>;
		//enable-gpios = <&gpio26 2 0>;
		regulator-name = "rt6160-buckboost";
		regulator-min-microvolt = <2025000>;
		regulator-max-microvolt = <5200000>;
		regulator-always-on;

		dbg {
			compatible = "richtek,rt6160-dbg";
		};
	};

	rt5133: rt5133@18 {
		status = "ok";
		compatible = "richtek,rt5133";
		reg = <0x18>;
		wakeup-source;
		interrupts-extended = <&pio 18 IRQ_TYPE_EDGE_FALLING>;
		enable-gpio = <&pio 7 0x0>;
		gpio-supply = <&rt5133_ldo1>;
		gpio-controller;
		#gpio-cells = <2>;
		regulators {
			rt5133_base: BASE {
				regulator-name = "rt5133,base";
				oc-shutdown-all = <0>;
				pgb-shutdown-all = <0>;
			};
			rt5133_ldo1: LDO1 {
				regulator-name = "rt5133-ldo1";
				regulator-min-microvolt = <2800000>;
				regulator-max-microvolt = <2800000>;
				regulator-active-discharge;
				oc-ptsel = <1>;
				pgb-ptsel = <1>;
				soft-start-time-sel = <1>;
			};
			rt5133_ldo2: LDO2 {
				regulator-name = "rt5133-ldo2";
				regulator-min-microvolt = <1800000>;
				regulator-max-microvolt = <3200000>;
				regulator-active-discharge;
				oc-ptsel = <1>;
				pgb-ptsel = <1>;
				soft-start-time-sel = <1>;
			};
			rt5133_ldo3: LDO3 {
				regulator-name = "rt5133-ldo3";
				regulator-min-microvolt = <1700000>;
				regulator-max-microvolt = <3000000>;
				regulator-active-discharge;
				oc-ptsel = <1>;
				pgb-ptsel = <1>;
				soft-start-time-sel = <1>;
			};
			rt5133_ldo4: LDO4 {
				regulator-name = "rt5133-ldo4";
				regulator-min-microvolt = <1700000>;
				regulator-max-microvolt = <3000000>;
				regulator-active-discharge;
				oc-ptsel = <1>;
				pgb-ptsel = <1>;
				soft-start-time-sel = <1>;
			};
			rt5133_ldo5: LDO5 {
				regulator-name = "rt5133-ldo5";
				regulator-min-microvolt = <1700000>;
				regulator-max-microvolt = <3000000>;
				regulator-active-discharge;
				oc-ptsel = <1>;
				pgb-ptsel = <1>;
				soft-start-time-sel = <1>;
			};
			rt5133_ldo6: LDO6 {
				regulator-name = "rt5133-ldo6";
				regulator-min-microvolt = <1700000>;
				regulator-max-microvolt = <3000000>;
				regulator-active-discharge;
				oc-ptsel = <1>;
				pgb-ptsel = <1>;
				soft-start-time-sel = <1>;
			};
			rt5133_ldo7: LDO7 {
				regulator-name = "rt5133-ldo7";
				regulator-min-microvolt = <900000>;
				regulator-max-microvolt = <1200000>;
				regulator-active-discharge;
				oc-ptsel = <1>;
				pgb-ptsel = <1>;
				soft-start-time-sel = <1>;
			};
			rt5133_ldo8: LDO8 {
				regulator-name = "rt5133-ldo8";
				regulator-min-microvolt = <855000>;
				regulator-max-microvolt = <1200000>;
				regulator-active-discharge;
				oc-ptsel = <1>;
				pgb-ptsel = <1>;
				soft-start-time-sel = <1>;
			};
		};
	};
};

&i2c6 {
	gate_ic: gate-ic@11 {
		compatible = "mediatek,gate-ic-i2c";
		gate-power-gpios = <&pio 130 0>;
		reg = <0x11>;
		id = <6>;
		status = "okay";
	};
};

&mt6685_rtc {
	status = "okay";
};

#include "mediatek/bat_setting/mt6858_battery_prop.dtsi"

/delete-node/ &mt6363_vbuck1_sshub;
/delete-node/ &mt6363_vbuck2_sshub;
/delete-node/ &mt6363_vbuck4_sshub;
/delete-node/ &mt6369_vmch;
/delete-node/ &mt6369_vmch_eint_low;
/delete-node/ &mt6369_vdigrf;

// PMIC TODO:

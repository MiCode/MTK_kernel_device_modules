			dma-ranges = <0x0 0x0 0x0 0x0 0x1 0x0>;
			interrupts = <GIC_SPI 151 IRQ_TYPE_LEVEL_HIGH 0>;
			mediatek,larb = <&smi_larb13>;
		};

		afe: mt6858-afe-pcm@11050000 {

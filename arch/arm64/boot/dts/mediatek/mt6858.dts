		seninf_top:seninf_top@1a004000 {
			compatible = "mediatek,seninf_top";
			reg = <0 0x1a004000 0 0x1000>;
	#if 0
			interrupts = <GIC_SPI 251 IRQ_TYPE_LEVEL_LOW>;
	#endif

			mediatek,platform = "mt6858";
			mediatek,seninf_max_num = "8";
			power-domains = <&scpsys MT6858_POWER_DOMAIN_CAM_MAIN>,
					<&scpsys MT6858_POWER_DOMAIN_CSI_RX>;
			clocks = <&camsys_main_clk CLK_CAM_M_SENINF_CAM>,
					<&cksys_reg_clk CLK_TOP_SENINF_SEL>,
					<&cksys_reg_clk CLK_TOP_SENINF1_SEL>,
					<&cksys_reg_clk CLK_TOP_SENINF2_SEL>,
					<&vlp_cksys_top_clk CLK_VLP_TOP_CAMTG0_SEL>,
					<&vlp_cksys_top_clk CLK_VLP_TOP_CAMTG1_SEL>,
					<&vlp_cksys_top_clk CLK_VLP_TOP_CAMTG2_SEL>,
					<&vlp_cksys_top_clk CLK_VLP_TOP_CAMTG3_SEL>,
					<&cksys_reg_clk CLK_TOP_TCK_26M_MX9>,
					<&cksys_reg_clk CLK_TOP_UNIVPLL_192M_D8>,
					<&cksys_reg_clk CLK_TOP_UNIVPLL_D6_D8>,
					<&cksys_reg_clk CLK_TOP_UNIVPLL_192M_D4>,
					<&cksys_reg_clk CLK_TOP_F26M_CK_D2>,
					<&cksys_reg_clk CLK_TOP_UNIVPLL_192M_D16>,
					<&cksys_reg_clk CLK_TOP_UNIVPLL_192M_D32>,
					<&mmdvfs_clk CLK_MMDVFS_CAM>;

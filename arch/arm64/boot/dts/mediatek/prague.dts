&thermal_zones {
	FAN_therm: FAN_therm {
		polling-delay = <0>; /* milliseconds */
		polling-delay-passive = <0>; /* milliseconds */
		thermal-sensors = <&tboard_thermistor4>;

		trips {
			FAN_therm_crit: FAN-therm-crit {
				temperature = <119000>;
				hysteresis = <2000>;
				type = "passive";
			};
		};
	};
	wifi_therm: wifi_therm {
		polling-delay = <0>; /* milliseconds */
		polling-delay-passive = <0>; /* milliseconds */
		thermal-sensors = <&tboard_thermistor5>;

		trips {
			wifi_therm_crit: wifi-therm-crit {
				temperature = <119000>;
				hysteresis = <2000>;
				type = "passive";
			};
		};
	};
	X7_therm: X7_therm {
		polling-delay = <0>; /* milliseconds */
		polling-delay-passive = <0>; /* milliseconds */
		thermal-sensors = <&tboard_thermistor6>;

		trips {
			X7_therm_crit: X7-therm-crit {
				temperature = <119000>;
				hysteresis = <2000>;
				type = "passive";
			};
		};
	};
	flash_therm: flash_therm {
		polling-delay = <0>; /* milliseconds */
		polling-delay-passive = <0>; /* milliseconds */
		thermal-sensors = <&tboard_thermistor7>;

		trips {
			flash_therm_crit: flash-therm-crit {
				temperature = <119000>;
				hysteresis = <2000>;
				type = "passive";
			};
		};
	};
	quiet_therm: quiet_therm {
		polling-delay = <0>; /* milliseconds */
		polling-delay-passive = <0>; /* milliseconds */
		thermal-sensors = <&tboard_thermistor8>;

		trips {
			quiet_therm_crit: quiet-therm-crit {
				temperature = <119000>;
				hysteresis = <2000>;
				type = "passive";
			};
		};
	};
	charger1_therm: charger1_therm {
		polling-delay = <0>; /* milliseconds */
		polling-delay-passive = <0>; /* milliseconds */
		thermal-sensors = <&tboard_thermistor9>;

		trips {
			charger1_therm_crit: charger1-therm-crit {
				temperature = <119000>;
				hysteresis = <2000>;
				type = "passive";
			};
		};
	};
	display_therm: display_therm {
		polling-delay = <0>; /* milliseconds */
		polling-delay-passive = <0>; /* milliseconds */
		thermal-sensors = <&tboard_thermistor10>;

		trips {
			display_therm_crit: display-therm-crit {
				temperature = <119000>;
				hysteresis = <2000>;
				type = "passive";
			};
		};
	};
};

&peak_power_budget {
			compatible = "mediatek,peak_power_budget";
			bootmode = <&chosen>;
			gauge = <&mtk_gauge>;

			soc-max-level = <3>;
			soc-max-tb-num = <2>;
			soc-hpt-volt-tb0-lv0 = <1>;
			soc-hpt-volt-tb0-lv1 = <1>;
			soc-hpt-volt-tb0-lv2 = <0>;
			soc-hpt-volt-tb0-lv3 = <0>;

			soc-hpt-volt-tb1-lv0 = <1>;
			soc-hpt-volt-tb1-lv1 = <1>;
			soc-hpt-volt-tb1-lv2 = <0>;
			soc-hpt-volt-tb1-lv3 = <0>;
};

&low_battery_throttling {
			compatible = "mediatek,low_battery_throttling";
			lvsys-thd-enable = <1>;
			vbat-thd-enable = <0>;

			lvsys-thd-volt-l-size = <2>;
			lvsys-thd-volt-h-size = <2>;
			lvsys-thd-volt-l = <3200 2600
					3200 2600
					3200 2600
					3200 2600>;
			lvsys-thd-volt-h = <3300 2900
					3300 2900
					3300 2900
					3300 2900>;

			temperature-stage-threshold = <25 10 0>;

			bat0-aging-threshold = <500 1000>;
			bat0-aging-volts-t0 =  <0 0>;
			bat0-aging-volts-t1 =  <0 0>;
			bat0-aging-volts-t2 =  <0 0>;
			bat0-aging-volts-t3 =  <0 0>;
			bat1-aging-threshold = <500 1000>;
			bat1-aging-volts-t0 =  <0 0>;
			bat1-aging-volts-t1 =  <0 0>;
			bat1-aging-volts-t2 =  <0 0>;
			bat1-aging-volts-t3 =  <0 0>;

			lvsys-aging-threshold = <500 1000>;
			lvsys-aging-volts-t0 =  <0 0>;
			lvsys-aging-volts-t1 =  <0 0>;
			lvsys-aging-volts-t2 =  <0 0>;
			lvsys-aging-volts-t3 =  <0 0>;

			pt-shutdown-enable = <0>;

			throttle-level = <0 1 2>,
							<0 1 3>,
							<0 1 3>,
							<0 4 5>;

			bootmode = <&chosen>;
			gauge = <&mtk_gauge>;
			lbat-thl-enable-pct0 = <30 30 30 30>;

			nvmem-cells =<&fab_info>;
			nvmem-cell-names = "fab_info";
};

&cpu_power_throttling {
			compatible = "mediatek,cpu-power-throttling";
			bootmode = <&chosen>;
			lbat-max-level = <5>;
			lbat-max-tb-num = <3>;

			lbat-limit-freq-lv1 = < 2400000 2800000 3050000>;
			lbat-limit-freq-lv2 = < 2100000 2100000 2100000>;
			lbat-limit-freq-lv3 = < 2100000 1800000 1800000>;
			lbat-limit-freq-lv4 = < 2400000 2400000 3050000>;
			lbat-limit-freq-lv5 = < 2100000 1800000 1800000>;

			lbat-limit-freq-tb1-lv1 = < 2400000 2800000 3050000>;
			lbat-limit-freq-tb1-lv2 = < 2100000 2100000 2100000>;
			lbat-limit-freq-tb1-lv3 = < 2100000 1800000 1800000>;
			lbat-limit-freq-tb1-lv4 = < 2400000 2400000 3050000>;
			lbat-limit-freq-tb1-lv5 = < 2100000 1800000 1800000>;

			lbat-limit-freq-tb2-lv1 = < 2400000 2800000 3050000>;
			lbat-limit-freq-tb2-lv2 = < 2100000 2100000 2100000>;
			lbat-limit-freq-tb2-lv3 = < 2100000 1800000 1800000>;
			lbat-limit-freq-tb2-lv4 = < 2400000 2400000 3050000>;
			lbat-limit-freq-tb2-lv5 = < 2100000 1800000 1800000>;

			oc-max-level = <2>;
			oc-limit-freq-lv1 = < 2147483647  2147483647 2147483647>;
			oc-limit-freq-lv2 = < 2147483647  2147483647 2147483647>;

			soc-max-level = <3>;
			soc-core-active-lv1 = < 1 1 1 1 1 1 1 1 >;
			soc-core-active-lv2 = < 1 1 1 1 1 1 1 1 >;
			soc-core-active-lv3 = < 1 1 1 1 1 1 1 1 >;
			soc-limit-freq-lv1 = < 2147483647  2147483647 2147483647>;
			soc-limit-freq-lv2 = < 2100000 2100000 2100000>;
			soc-limit-freq-lv3 = < 2100000 1800000 1800000>;

			soc-limit-cmep-lv1 = <0>;
			soc-limit-cmep-lv2 = <0>;
			soc-limit-cmep-lv3 = <0>;

			mpmm-enable = <1>;
			mpmm-gear = <0>;

			bootup-throttle-level = <1 1 2>, //boot temperature stage 0
						<2 2 2>, //boot temperature stage 1
						<2 2 2>; //boot temperature stage 2
			bootup-temperature-stage-threshold = <0 (-10)>;
			bootup-voltage-threshold = <3700 3500>;
			bootup-delay-release-time = <10>;
			limit-freq-bootmode0-lv1 = <2200000 2800000 3000000>;
			limit-freq-bootmode0-lv2 = <2200000 2200000 2200000>;

			nvmem-cells =<&fab_info>;
			nvmem-cell-names = "fab_info";
};

&gpu_power_throttling {
			compatible = "mediatek,gpu-power-throttling";
			bootmode = <&chosen>;
			lbat-max-level = <5>;
			lbat-max-tb-num = <3>;

			lbat-limit-freq-lv1 = <702000>;
			lbat-limit-freq-lv2 = <702000>;
			lbat-limit-freq-lv3 = <702000>;
			lbat-limit-freq-lv4 = <702000>;
			lbat-limit-freq-lv5 = <702000>;

			lbat-limit-freq-tb1-lv1 = <702000>;
			lbat-limit-freq-tb1-lv2 = <702000>;
			lbat-limit-freq-tb1-lv3 = <702000>;
			lbat-limit-freq-tb1-lv4 = <702000>;
			lbat-limit-freq-tb1-lv5 = <702000>;

			lbat-limit-freq-tb2-lv1 = <702000>;
			lbat-limit-freq-tb2-lv2 = <702000>;
			lbat-limit-freq-tb2-lv3 = <702000>;
			lbat-limit-freq-tb2-lv4 = <702000>;
			lbat-limit-freq-tb2-lv5 = <702000>;

			oc-max-level = <2>;
			oc-limit-freq-lv1 = <2147483647>;
			oc-limit-freq-lv2 = <2147483647>;

			soc-max-level = <3>;
			soc-limit-freq-lv1 = <2147483647>;
			soc-limit-freq-lv2 = <806000>;
			soc-limit-freq-lv3 = <806000>;

			nvmem-cells =<&fab_info>;
			nvmem-cell-names = "fab_info";

			bootup-delay-release-time = <20>;
};

&apu_power_throttling {
			compatible = "mediatek,apu-power-throttling";
			lbat-max-level = <5>;
			lbat-max-tb-num = <3>;

			lbat-limit-opp-lv1 = <7>;
			lbat-limit-opp-lv2 = <7>;
			lbat-limit-opp-lv3 = <7>;
			lbat-limit-opp-lv4 = <8>;
			lbat-limit-opp-lv5 = <9>;

			lbat-limit-opp-tb1-lv1 = <7>;
			lbat-limit-opp-tb1-lv2 = <7>;
			lbat-limit-opp-tb1-lv3 = <7>;
			lbat-limit-opp-tb1-lv4 = <8>;
			lbat-limit-opp-tb1-lv5 = <9>;

			lbat-limit-opp-tb2-lv1 = <7>;
			lbat-limit-opp-tb2-lv2 = <7>;
			lbat-limit-opp-tb2-lv3 = <7>;
			lbat-limit-opp-tb2-lv4 = <8>;
			lbat-limit-opp-tb2-lv5 = <9>;

			oc-max-level = <2>;
			oc-limit-opp-lv1 = <0>;
			oc-limit-opp-lv2 = <0>;

			soc-max-level = <3>;
			soc-limit-opp-lv1 = <0>;
			soc-limit-opp-lv2 = <7>;
			soc-limit-opp-lv3 = <9>;

			nvmem-cells =<&fab_info>;
			nvmem-cell-names = "fab_info";
};

&md_power_throttling {
			compatible = "mediatek,md-power-throttling";
			lbat-dedicate-volts = <3400 3200 3000 2800>;
			lbat-max-level = <3>;
			lbat-reduce-tx-lv1 = <0>;
			lbat-reduce-tx-lv2 = <2>;
			lbat-reduce-tx-lv3 = <2>;

			oc-max-level = <2>;
			oc-reduce-tx-lv1 = <0>;
			oc-reduce-tx-lv2 = <0>;

			soc-max-level = <3>;
			soc-reduce-tx-lv1 = <0>;
			soc-reduce-tx-lv2 = <0>;
			soc-reduce-tx-lv3 = <0>;

			lbat-dedicate-temperature = <25 10 0>;
};

&bp_thl {
			compatible = "mediatek,mtk-bp-thl";
			max-throttle-level = <3>;
			soc-throttle-level = <0 1 2 2>, //temperature stage 0
							<0 1 2 2>, //temperature stage 1
							<0 1 2 2>, //temperature stage 2
							<0 1 3 3>; //temperature stage 3

			soc-max-stage = <3>;
			soc-limit-threshold = <30 7 3>;

			temperature-max-stage = <3>;
			temperature-stage-threshold = <25 10 0>;

			md-thl-enable;

			nvmem-cells =<&fab_info>;
			nvmem-cell-names = "fab_info";
};

&mt6379_typec {
	tcpc,rp-level = <0>;
	tcpc,en_floatgnd;
	/* 0:16x, 1:128x, 2:512x, 3:1024x */
	wd,wd0_tsleep = <1>;
	/* 0:400us, 1:1ms, 2:2ms, 3:4ms, 4:10ms, 5:40ms, 6:100ms, 7:400ms */
	wd,wd0_tdet = <3>;
	/* example wd0_tsleep = 512x, wd0_tdet = 4ms, wd0 polling time = 512*4ms */
	port {
		tcpc_typec_usb: endpoint {
			remote-endpoint = <&ssusb_mux>;
		};
	};

	pd-data {
		pd,source-cap-ext = /bits/ 8 <0xcf 0x29 0x79 0x63
						0x00 0x00 0x00 0x00
						0x00 0x00 0x00 0x00
						0x00 0x00 0x00 0x00
						0x00 0x00 0x00 0x00
						0x00 0x00 0x01 0x05
						0x00>;
		pd,charging-policy = <0x2>;
		pd,source-pdo-data = <0x00019064>; /* 5V, 1000 mA */
		pd,sink-pdo-size = <3>;
		pd,sink-pdo-data = <0x0001912c 0x0002d12c 0xc1902464>;
		pd,support-direct-cap-change;
		pd,support-quick-revchg;
	};
};

&typec_mux_switch {
	orientation-switch;
	mode-switch;
	accessory;
	port {
		ssusb_mux: endpoint {
			remote-endpoint = <&tcpc_typec_usb>;
		};
	};
};

&ps5170 {
	pinctrl-names = "enable", "disable";
	pinctrl-0 = <&ps_enable>;
	pinctrl-1 = <&ps_disable>;
	status = "disable";
};

&usb_dp_selector {
	status = "okay";
};
/* usb typec mux end */

&mt6661keys {
	pinctrl-names = "kpcol0_mode";
	pinctrl-0 = <&kpcol0_pins_gpio_mode>;
	home2 {
		linux,keycodes = <115>;
		wakeup-source;
	};
};

&pio {
	kpcol0_pins_gpio_mode: gpio-mode {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO40__FUNC_GPIO40>;
			input-enable;
		};
	};
};

&connfem {
	sku {
		hw-names =
			"vc536421_qm45655_ps_prague";	/* [0] VC536421/QM45655, 2G+2A, BT/Wi-Fi AntSwap */

		/***************************************************************
		 * [HW][0] VC536421/QM45655, 2G+2A, BT/Wi-Fi AntSwap
		 **************************************************************/
		hw-0 {
			using-fems =
				<&vc536421>,
				<&qm45655>;

			layout-flag = <0x00000000>;
			layout =
				<&g_wf0_bt0_vc536421>,
				<&g_wf1_bt1_vc536421>,
				<&a_wf0_qm45655>,
				<&a_wf1_qm45655>;

			common {
				flags {
					fe-ant-cnt = [85];
					fe-conn-dpdt-sp3t = [80];
					fe-conn-spdt = [80];
					fe-bt-wf-usage = [80];
					fe-conn-spdt-2 = [80];
				};
			};

			wifi {
				using-states =
					<&vc536421_rxh>,
					<&qm45655_rxl_rxh>;
			};

			bt {
				flags {
					efem-mode = [03]; /* 3:epa_elna, 2:epa, 1:elna, 0:bypass */
					rx-mode = [20]; /* 0x20: G-band RxH */
				};
			};
		};
	};
};


&i2c0 {
/*
	spk1: speaker_amp@5c {
		compatible = "richtek,rt5512";
		#sound-dai-cells = <0>;
		reg = <0x5c>;
		status = "okay";
		sound-name-prefix = "Left";
	};

	spk2: speaker_amp@5d {
		compatible = "richtek,rt5512";
		#sound-dai-cells = <0>;
		reg = <0x5d>;
		status = "okay";
		sound-name-prefix = "Right";
	};
*/
       clock-frequency = <400000>;
       spk1: speaker_amp@34 {
               status = "okay";
               compatible = "tfa,tfa98xx";
               #sound-dai-cells = <0>;
               reg = <0x34>;
               reset-gpio = <&pio 106 0>;
               spk-sw-gpio = <&pio 192 0>;
               reset-polarity=<0>;
               irq-gpio = <&pio 138 0>;
       };

       spk2: speaker_amp@36 {
               status = "okay";
               compatible = "tfa,tfa98xx";
               #sound-dai-cells = <0>;
               reg = <0x36>;
               reset-gpio = <&pio 176 0>;
               reset-polarity=<0>;
               irq-gpio = <&pio 107 0>;
       };
};

&sound {
	mediatek,spk-i2s = <25 24>;
	mediatek,speaker-codec {
		sound-dai = <&spk1>, <&spk2>;
	};
};

/* usb typec mux end */
&pio {
	awinic_reset_low: awinic_reset_reset {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO49__FUNC_GPIO49>;
			drive-strength = <2>;
			bias-disable;
			output-low;
		};
	};
	awinic_reset_high: awinic_reset_active {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO49__FUNC_GPIO49>;
			drive-strength = <2>;
			bias-disable;
			output-high;
		};
	};
	awinic_interrupt: awinic_interrupt_active {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO231__FUNC_GPIO231>;
			drive-strength = <2>;
			bias-pull-up;
			input-enable;
		};
	};
};

&aud_gpio_ap_dmic1_on {
	pins-cmd3-dat {
		pinmux = <PINMUX_GPIO12__FUNC_DMIC1_CLK>;
		input-schmitt-enable;
		drive-strength = <2>;
		bias-disable;
		};
	pins-cmd4-dat {
		pinmux = <PINMUX_GPIO13__FUNC_DMIC1_DAT>;
		input-schmitt-enable;
		bias-disable;
		};
};

&aud_gpio_ap_dmic2_on{
	pins-cmd1-dat {
		pinmux = <PINMUX_GPIO46__FUNC_DMIC2_CLK>;
		input-schmitt-enable;
		drive-strength = <1>;
		bias-disable;
	};
	pins-cmd2-dat {
		pinmux = <PINMUX_GPIO47__FUNC_DMIC2_DAT>;
		input-schmitt-enable;
		bias-disable;
	};
};

&i2c1 {
	clock-frequency = <400000>;
	haptic_hv_r@5A {
		compatible = "awinic,haptic_hv";
		reg = <0x5A>;
		#sound-dai-cells = <0>;
		sound-name-prefix = "HAPTIC_SPK";
		irq-gpio = <&pio 231 1>;
		reset-gpio = <&pio 49 1>;
		pinctrl-names = "awinic_reset_reset","awinic_reset_active","awinic_interrupt_active";
		pinctrl-0 = <&awinic_reset_low>;
		pinctrl-1 = <&awinic_reset_high>;
		pinctrl-2 = <&awinic_interrupt>;
		f0_pre = < 1700 >;
		mode = /bits/ 8 < 5 >;
/***************************** aw8693x ******************************/
		aw8693x_f0_cali_percent = /bits/ 8 < 15 >;
		aw8693x_gain_bypass = /bits/ 8 < 1 >;
		aw8693x_uvlo_vol_default = /bits/ 8 < 0 >;
		aw8693x_cont_smart_loop = /bits/ 8 < 0 >;
		aw8693x_cont_drv1_lvl = /bits/ 8 < 0x7F >;
		aw8693x_cont_drv2_lvl = /bits/ 8 < 0x38 >;
		aw8693x_cont_lra_vrms = < 1200 >;
		aw8693x_cont_drv_width = /bits/ 8 <0x8A>;
		aw8693x_cont_drv1_time = /bits/ 8 < 0x04 >;
		aw8693x_cont_drv2_time = /bits/ 8 < 0x14 >;
		aw8693x_cont_track_margin = /bits/ 8 < 0x0F >;
		aw8693x_cont_brk_gain = /bits/ 8 < 0x08 >;
		aw8693x_cont_brk_time = /bits/ 8 < 0x08 >;
		aw8693x_duration_time = /bits/ 8 < 20 30 60 >;
		aw8693x_d2s_gain = /bits/ 8 < 0x07 >;
		aw8693x_algo_d2s_gain = /bits/ 8 < 0x01 >;
		aw8693x_drv_width = /bits/ 8 < 0x6A >;
		aw8693x_trig_config = /bits/ 8 < 0 0 0 1 0 2 0 0
						 0 0 0 1 0 2 0 0
						 0 0 0 1 0 2 0 0 >;
		aw8693x_bst_vol_default = < 8500 >;
		aw8693x_is_enabled_track_en;
		aw8693x_vib_effect_max = < 197 >; /*vib_effect_max must bigger than vib_effect_id*/
		/* aw8693x_is_enabled_auto_bst; */
		/* aw8693x_is_enabled_one_wire; */
	};
};


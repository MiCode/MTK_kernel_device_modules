&lk_charger {
	non-std-ac-charger-current = <1000000>;
	ac-charger-current = <1600000>;
	ac-charger-input-current = <2000000>;
	/* battery temperature protection */
	temp-t4-threshold = <58>;
	temp-t3-threshold = <45>;
	temp-t1-threshold = <(-10)>;
	boot-battery-voltage-max = <3650000>;
	boot-battery-voltage = <3200000>;
	pre-charger-current = <650000>;
	boot-voltage-level = <3000 3100 3200 3200 3400>;
	ta-capability-level = <1900 1350 850 500 0>;
	extrem-boot-battery-voltage = <2850000>;
	fast-charge-voltage = <2800000>;
	show-anime-voltage = <3000000>;
};

&pd_cp_manager {
		compatible = "pd_cp_manager";
		fv = <4502>;
		fv_ffc = <4552>;
		max_fcc = <17600>;
		max_vbus = <20000>;
		max_ibus = <4400>;
		fcc_low_hyst = <150>;
		fcc_high_hyst = <10>;
		low_tbat = <100>;
		high_tbat = <480>;
		high_vbat = <4400>;
		high_soc = <95>;
		low_fcc = <2000>;
		cv_vbat = <4480>;
		cv_vbat_ffc = <4510>;
		cv_ibat = <2000>;
		min_pdo_vbus = <8000>;
		max_pdo_vbus = <21000>;
		mt6375_control_gpio = <&pio 19 0x0>;
		support_4_1_mode;
		support_pmic_parachg;
		switch1_1_enter = <2500>;
		switch1_1_exit = <3700>;
		switch2_1_enter = <4200>;
		switch2_1_exit = <6500>;
		pdm_ibus_gap = <0>;
		pdm_bypass_ibus_gap = <2600>;
		adapter_power = <100>;
		fv_hyst = <9>;
		support_pchg_policy;
};

&mtk_gauge {
	disable-mtkbattery = <(1)>;
	FIXED_BATTERY_TEMPERATURE = <(25)>;
};

&mt6379_eusb2_repeater {
	mediatek,discth = <0xf>;
	mediatek,equalization = <0x4>;
	mediatek,intr-ofs = "2";
	mediatek,pre-emphasis = <0x5>;
	mediatek,rx-sqth = <0x1>;
	mediatek,term-ofs = "4";
	mediatek,vrt-sel = <0x2>;

	mediatek,host-discth = <0xd>;
	mediatek,host-equalization = <0x4>;
	mediatek,host-intr-ofs = "0";
	mediatek,host-pre-emphasis = <0x2>;
	mediatek,host-rx-sqth = <0x5>;
	mediatek,host-term-ofs = "0";
	mediatek,host-vrt-sel = <0x1>;
	status = "okay";
};
/* charger end */

/* svp start */
&mtee_svp {
	mtee: MTEE {
		compatible = "mediatek,mtk_svp_on_mtee_support";
	};

	svp: SecureVideoPath {
		compatible = "mediatek,mtk_sec_video_path_support";
	};
};

&mtkheap_page_svp {
	status = "ok";
};

&mtkheap_page_tee {
	status = "ok";
};
/* svp end */


&pio {
	codec_en_off: codec-en-off {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO9__FUNC_GPIO9>;
			input-enable;
			bias-pull-down;
		};
	};
	codec_en_on: codec-en-on {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO9__FUNC_GPIO9>;
			output-high;
		};
	};
};

&pio {
	accdet_pins_eint_as_int: accdet-eint {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO11__FUNC_GPIO11>;
			bias-pull-up;
			input-enable;
		};
	};
};

&mmlsys2_config {
	dl-enable;
};

&disp_dpc {
	vidle-mask = <0x11>;
};

&mt6661_6_buck1 {
	regulator-always-on;
};

&mt6661_6_buck5 {
	regulator-always-on;
};

&mt6661_5_lnc0_10 {
	regulator-always-on;
	regulator-min-microvolt = <1800000>;
	regulator-max-microvolt = <1800000>;
};

&mt6661_6_ln60_7 {
	regulator-always-on;
};

/* charger start */
&i2c8 {
	status = "ok";
	hl7603_2@76 {
		compatible = "hl7603_2";
		reg = <0x76>;
		vout_threshold = <3450>;
		enable_toff_fast;
	};
	hl7603_3@77 {
		compatible = "hl7603_3";
		reg = <0x77>;
		vout_threshold = <3450>;
		enable_toff_fast;
	};
};

&i2c9 {
	clock-frequency = <400000>;
	status = "okay";
	bq28z610@55 {
	compatible = "bq28z610";
	reg = <0x55>;
	enable_shutdown_delay;
	normal_shutdown_vbat_1s = <3400>;
	critical_shutdown_vbat_1s = <3340>;
	report_full_rsoc_1s = <9700>;
	soc_gap_1s = <2>;
	//slave_connect_gpio = <&pio 75 0x1>;
	soc_decimal_rate = <
		0  38
		10 35
		20 33
		30 33
		40 33
		50 33
		60 33
		70 30
		80 25
		90 20
		95 10 >;

    dynamic_shutdown_voltage_support_v2;
    dod_temp_range = <
        (-200)  (-61)
        (-60)   (-1)
        0        99
        100      600>;
    dod_shutdown_voltage_0 = <
        0     89    2500    2600    2650
        90    168   2600    2650    2700
        169   451   2700    2750    2800
        452   1050  2750    2800    2850
        1051  5000  2850    2900    2950 >;
    dod_shutdown_voltage_1 = <
        0     89    2500    2600    2650
        90    168   2600    2650    2700
        169   451   2700    2750    2800
        452   1050  2850    2900    2950
        1051  5000  2950    3000    3050 >;
    dod_shutdown_voltage_2 = <
        0     89    2600    2650    2650
        90    168   2800    2850    2850
        169   451   2900    2950    2950
        452   1050  3000    3050    3050
        1051  5000  3060    3110    3110 >;
    dod_shutdown_voltage_3 = <
        0     89    2800    2850    2850
        90    168   2970    3020    3020
        169   451   3070    3120    3120
        452   1050  3150    3200    3200
        1051  5000  3200    3250    3250 >;

    cycle_temp_range = <
        (-200)	(-61)
        (-60)	(-1)
        0	99
        100	600>;
    cycle_shutdown_voltage_0 = <
        0     400    2500    2600    2650
        401   800    2600    2650    2700
        801   1200   2700    2750    2800
        1201  5000   2750    2800    2850 >;
    cycle_shutdown_voltage_1 = <
        0     400    2500    2600    2650
        401   800    2600    2650    2700
        801   1200   2700    2750    2800
        1201  5000   2850    2900    2950 >;
    cycle_shutdown_voltage_2 = <
        0     400    2600    2650    2650
        401   800    2800    2850    2850
        801   1200   2900    2950    2950
        1201  5000   3000    3050    3050 >;
    cycle_shutdown_voltage_3 = <
        0     400    2800    2850    2850
        401   800    2970    3020    3020
        801   1200   3070    3120    3120
        1201  5000   3150    3200    3200 >;
    };
};

&i2c13 {
	clock-frequency = <400000>;
	status = "okay";
	sc858x-charger@6E{
		compatible = "sc,sc858x-standalone";
		reg = <0x6E>;
		sc,sc858x,irq-gpio = <&pio 27 IRQ_TYPE_EDGE_FALLING>;

		sc,sc858x,bat-ovp-disable = <0>;
		sc,sc858x,bat-ovp-threshold = <11>;/*4450 + val * 25*/
		sc,sc858x,usb-ovp-threshold = <15>;/*11000 + val * 1000; 15:7.5*/
		sc,sc858x,wpc-ovp-threshold = <11>;/*11000 + val * 1000*/
		sc,sc858x,bus-ovp-threshold = <9>;/*15000 + val * 800*/
		sc,sc858x,out-ovp-threshold = <1>;/*4800 + val * 200*/
		sc,sc858x,bus-ocp-disable = <0>;
		sc,sc858x,bus-ocp-threshold = <15>;/*2500 + val * 125*/
		sc,sc858x,bus-ucp-fall-dg = <1>;/*0:8us 1:5ms 2:20ms 3:50ms*/
		sc,sc858x,pmid2out-ovp-threshold = <2>;/*200 + val * 100*/
		sc,sc858x,pmid2out-uvp-threshold = <7>;/*100 + val * 50*/
		sc,sc858x,fsw-set = <7>;/*180 + val * 60*/
		sc,sc858x,acdrv-hi-en = <1>;/*0:5V, 1:9V*/
		sc,sc858x,ss-timeout = <5>;/*0:dis 3:320ms 4:1.28s 5:5.12s 6:20.48s 7:81.92s*/
		sc,sc858x,wd-timeout = <0>;/*0:dis 1:0.2s 2:0.5s 3:1s 4:5s 5:30s*/
		sc,sc858x,mode = <1>;/*0:(4:1 chg) 1:(2:1 chg) 2:(1:1 chg) 4:(1:4 con) 5:(1:2 con) 6:(1:1 con)*/
		sc,sc858x,tsbat-flt-disable = <1>;
		sc,sc858x,tshut-disable = <1>;
		sc,sc858x,wpc-ovp-disable = <0>;
		sc,sc858x,usb-ovp-disable = <0>;
		sc,sc858x,bus-ovp-disable = <0>;
		sc,sc858x,out-ovp-disable = <0>;
		sc,sc858x,sense-r-mohm = <1>;/*0:1m  1:2m*/
	};
};

&mt6661_4_ldc0_3 {

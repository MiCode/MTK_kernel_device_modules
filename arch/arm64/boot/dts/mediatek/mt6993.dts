		wifi_cooler: wifi-cooler {
			compatible = "mediatek,wifi-level-cooler";
			#cooling-cells = <2>;
		};

		charger_cooler: charger-cooler {
			compatible = "mediatek,mt6379-charger-cooler";
			#cooling-cells = <2>;
		};

		backlight_cooler: backlight-cooler {
			compatible = "mediatek,backlight-cooler";
			backlight-names = "lcd-backlight";
			#cooling-cells = <2>;
		};

		fan_cooler: fan-cooler {
			compatible = "mediatek,fan-cooler";
			#cooling-cells = <2>;
			status = "disabled";
		};

		therm_intf: therm-intf@114000 {
			compatible = "mediatek,therm_intf";
			reg = <0 0x00114000 0 0x400>,
				<0 0x05393120 0 0x37f>;
			reg-names = "therm_sram",
				"therm_cputcm";
			boot-core-ctrl = <1>;
			boot-sensor = "ap_ntc";
			boot-trip-temp = <57500>;
			boot-release-temp = <52500>;
			boot-core-num = <4>;
			interconnects = <&dvfsrc MT6873_MASTER_MCU_4 &dvfsrc MT6873_SLAVE_DDR_EMI>;
			interconnect-names = "icc-thermal";
		};

		mt6661_5_temp: mt6661-5-temp {
			compatible = "mediatek,mt6661-5-pmic-temp";
			io-channels =
				<&mt6661_5_auxadc AUXADC_THR1>,
				<&mt6661_5_auxadc AUXADC_THR2>,
				<&mt6661_5_auxadc AUXADC_THR3>,
				<&mt6661_5_auxadc AUXADC_THR4>;
			io-channel-names =
				"pmic6661_5_ts1",
				"pmic6661_5_ts2",
				"pmic6661_5_ts3",
				"pmic6661_5_ts4";

			#thermal-sensor-cells = <1>;
			nvmem-cells = <&mt6661_5_thermal_efuse>;
			nvmem-cell-names = "mt6661-5-e-data";
		};

		mt6661_6_temp: mt6661-6-temp {
			compatible = "mediatek,mt6661-6-pmic-temp";
			io-channels =
				<&mt6661_6_auxadc AUXADC_THR1>,
				<&mt6661_6_auxadc AUXADC_THR2>,
				<&mt6661_6_auxadc AUXADC_THR3>,
				<&mt6661_6_auxadc AUXADC_THR4>;
			io-channel-names =
				"pmic6661_6_ts1",
				"pmic6661_6_ts2",
				"pmic6661_6_ts3",
				"pmic6661_6_ts4";

			#thermal-sensor-cells = <1>;
			nvmem-cells = <&mt6661_6_thermal_efuse>;
			nvmem-cell-names = "mt6661-6-e-data";
		};

		thermal_zones: thermal-zones {
			soc_max: soc_max {
				polling-delay = <0>; /* milliseconds */
				polling-delay-passive = <0>; /* milliseconds */

		disp_postmask1: disp-postmask1@3e5d0000 {
			compatible = "mediatek,disp_postmask1",
						"mediatek,mt6991-disp-postmask";
			reg = <0 0x3e5d0000 0 0x1000>;
			clocks = <&disp0b_dispsys_config_clk MM0B_DISP_POSTMASK0_DISP>;
			mediatek,larb = <&smi_larb32>;
			mediatek,smi-id = <32>;
			mtk,smmu-shared = <&mm_smmu_disp>;
			mtk,smmu-shared-sec = <&mm_smmu_hdcp_disp>;
		};

		soc_smmu: iommu@14900000 {
			compatible = "arm,smmu-v3", "mtk,smmu-v700", "mediatek,mt6993-soc-smmu";
			reg = <0 0x14900000 0 0x1e0000>,
			      <0 0x14ae0000 0 0x10000>;
			interrupts = <GIC_SPI 829 IRQ_TYPE_EDGE_RISING 0>;
			interrupt-names = "combined";
			#iommu-cells = <1>;
			mediatek,axslc;
			//dma-coherent;
			mtk,tcu-qos = <5>;
			mtk,slc-gid = <7>;
			mtk,trans-granule = <&mtk_smmu_granule>;

			iommu-groups {
				soc_iommu_group_0: soc-iommu-group-common {
					label = "soc_common";
					#address-cells = <2>;
					#size-cells = <2>;
					mtk,iommu-dma-range = <0x0 0x0 0x4 0x0>;
					mtk,smmu-mode = "dma";
				};
			};
		};

		scp: scp@1d000000 {
			compatible = "mediatek,scp";
			status = "okay";
			reg = <0 0x1d000000 0 0x400000>, /* tcm */
				<0 0x1df24000 0 0x1000>, /* cfg */
				<0 0x1df21000 0 0x1000>, /* clk*/
				<0 0x1df30000 0 0x1000>, /* cfg core0 */
				<0 0x1df40000 0 0x1000>, /* cfg core1 */
				<0 0x1df90000 0 0x1000>, /* bus tracker */
				<0 0x1df60000 0 0x1000>, /* l1c, need to check! */
				<0 0x1df2a000 0 0x4>, /* cfg_sec */
				<0 0x1dfa0000 0 0x100>, /* mbox0 base */
				<0 0x1dfa0100 0 0x4>, /* mbox0 set */
				<0 0x1dfa010c 0 0x4>, /* mbox0 clr */
				<0 0x1df2a020 0 0x4>, /* mbox0 init */
				<0 0x1dfb0000 0 0x100>, /* mbox1 base */
				<0 0x1dfb0100 0 0x4>, /* mbox1 set */
				<0 0x1dfb010c 0 0x4>, /* mbox1 clr */
				<0 0x1df2a024 0 0x4>, /* mbox1 init */
				<0 0x1dfc0000 0 0x100>, /* mbox2 base */
				<0 0x1dfc0100 0 0x4>, /* mbox2 set */
				<0 0x1dfc010c 0 0x4>, /* mbox2 clr */
				<0 0x1df2a028 0 0x4>, /* mbox2 init */
				<0 0x1dfd0000 0 0x100>, /* mbox3 base */
				<0 0x1dfd0100 0 0x4>, /* mbox3 set */
				<0 0x1dfd010c 0 0x4>, /* mbox3 clr */
				<0 0x1df2a02c 0 0x4>, /* mbox3 init */
				<0 0x1dfe0000 0 0x100>, /* mbox4 base */
				<0 0x1dfe0100 0 0x4>, /* mbox4 set */
				<0 0x1dfe010c 0 0x4>, /* mbox4 clr */
				<0 0x1df2a030 0 0x4>, /* mbox4 init */
				<0 0x1df50000 0 0x1000>, /* cfg ap */
				<0 0x1dff0000 0 0x100>, /* mbox5 base */
				<0 0x1dff0100 0 0x4>, /* mbox5 set */
				<0 0x1dff010c 0 0x4>, /* mbox5 clr */
				<0 0x1df2a034 0 0x4>; /* mbox5 init */

			reg-names = "scp_sram_base", /* 0 */
					"scp_cfgreg",
					"scp_clkreg",
					"scp_cfgreg_core0",
					"scp_cfgreg_core1",
					"scp_bus_tracker", /* 5 */
					"scp_l1creg",
					"scp_cfgreg_sec",
					"mbox0_base",
					"mbox0_set",
					"mbox0_clr", /* 10 */
					"mbox0_init",
					"mbox1_base",
					"mbox1_set",
					"mbox1_clr",
					"mbox1_init", /* 15 */
					"mbox2_base",
					"mbox2_set",
					"mbox2_clr",
					"mbox2_init",
					"mbox3_base", /* 20 */
					"mbox3_set",
					"mbox3_clr",
					"mbox3_init",
					"mbox4_base",
					"mbox4_set", /* 25 */
					"mbox4_clr",
					"mbox4_init",
					"scp_cfgreg_ap", /* 28, kernel code align*/
					"mbox5_base",
					"mbox5_set",
					"mbox5_clr",
					"mbox5_init";

			interrupts = <GIC_SPI 432 IRQ_TYPE_LEVEL_HIGH 0>,
					<GIC_SPI 433 IRQ_TYPE_LEVEL_HIGH 0>,
					<GIC_SPI 440 IRQ_TYPE_LEVEL_HIGH 0>,
					<GIC_SPI 522 IRQ_TYPE_LEVEL_HIGH 0>,
					<GIC_SPI 523 IRQ_TYPE_LEVEL_HIGH 0>,
					<GIC_SPI 524 IRQ_TYPE_LEVEL_HIGH 0>,
					<GIC_SPI 525 IRQ_TYPE_LEVEL_HIGH 0>,
					<GIC_SPI 526 IRQ_TYPE_LEVEL_HIGH 0>;

			interrupt-names = "ipc0",
					"ipc1",
					"mbox0",
					"mbox1",
					"mbox2",
					"mbox3",
					"mbox4",
					"mbox5";

			mbox-attr =
			<0x0>, /* mbox0 */
			<0x0>, /* mbox1 */
			<0x0>, /* mbox2 */
			<0x0>, /* mbox3 */
			<0x0>, /* mbox4 */
			<0x0>; /* mbox5 */

			core-0 = "enable";
			scp-hwvoter = "enable";
			scp-sram-size = <0x00400000>;
			scp-dram-size = <0x300000>; /* scp dram image size */
			scp-cache-dump-buf-size = <0x000c4000>;
			scp-reg-dump-buf-size = <0x00003c00>;
			scp-tbuf-dump-buf-size = <0x00000400>;

			core-nums = <2>;	/* core number */
			twohart = <1>;		/* two hart arch */
			mbox-count = <5>;
			/* id, mbox, send_size*/
			send-table =
			< 0 0  11>,/* IPI_OUT_AUDIO_VOW_1 */
			<14 0  1>,/* IPI_OUT_DVFS_SET_FREQ_1 */
			<15 0  2>,/* IPI_OUT_C_SLEEP_1 */
			<16 0  1>,/* IPI_OUT_TEST_1 */
			<18 0  2>,/* IPI_OUT_SCPCTL_1 */
			<46 0  1>,/* IPI_OUT_SCP_PM_NOTIFY_1 */
			//<24 0  6>,/* IPI_OUT_SCP_MPOOL_1 */
			<17 1  6>,/* IPI_OUT_LOGGER_CTRL */
			<29 1 16>,/* IPI_OUT_SENSOR_CTRL */
			<31 1  7>,/* IPI_OUT_SENSOR_NOTIFY */
			< 4 2  1>,/* IPI_OUT_DVFS_SET_FREQ_0 */
			< 5 2  2>,/* IPI_OUT_C_SLEEP_0 */
			< 6 2  1>,/* IPI_OUT_TEST_0 */
			//<11 2  6>,/* IPI_OUT_SCP_MPOOL_0 */
			<33 2  16>,/* IPI_OUT_SCP_CONNSYS */
			< 3 3  4>,/* IPI_OUT_APCCCI_0 */
			<37 3  1>,/* IPI_OUT_SCP_AOD */
			<26 3  9>,/* IPI_OUT_AUDIO_ULTRA_SND_0 */
			<35 3  8>,/* IPI_OUT_C_SCP_HWVOTER_DEBUG */
			<45 3  1>,/* IPI_OUT_SCP_PM_NOTIFY_0 */
			<47 3  2>,/* IPI_PIN_HOST_SCP_CHRE */
			<48 3  2>,/* IPI_PIN_SCP_HOST_CHRE */
			<39 4  4>,/* IPI_OUT_AOV_SCP */
			<43 4  4>;/* IPI_OUT_NPU_SCP */

			#recv-cells-mode = <1>;
			/* mode 0 or no defined #recv-cells-mode => 4 elements : id, mbox,
			* recv_size, recv_opt
			*/
			/* mode 1 => 7 elements : id, mbox, recv_size, recv_opt, lock, buf_full_opt,
			* cb_ctx_opt
			*/
			recv-table =
			< 1 0  2 0 0 0 0>,/* IPI_IN_AUDIO_VOW_ACK_1 */
			< 2 0 26 0 0 0 0>,/* IPI_IN_AUDIO_VOW_1 */
			<36 0  1 0 0 0 0>,/* IPI_IN_AUDIO_ACDDET_1 */
			<15 0  1 1 0 0 0>,/* IPI_OUT_C_SLEEP_1 */
			<22 0  1 0 0 0 0>,/* IPI_IN_SCP_READY_1 */
			//<25 0 6 0 0 0 0>,/* IPI_IN_SCP_MPOOL_1 */
			<21 1  6 0 0 0 0>,/* IPI_IN_LOGGER_CTRL */
			<30 1  2 0 0 0 0>,/* IPI_IN_SENSOR_CTRL */
			<32 1  7 0 0 0 0>,/* IPI_IN_SENSOR_NOTIFY */
			<49 1  2 0 0 0 0>,/* IPI_IN_KASAN_CHECK */
			< 5 2  1 1 0 0 0>,/* IPI_OUT_C_SLEEP_0 */
			< 8 2 10 0 0 0 0>,/* IPI_IN_SCP_ERROR_INFO_0 */
			//<12 2  6 0 0 0 0>,/* IPI_IN_SCP_MPOOL_0 */
			<34 2 16 0 0 0 0>,/* IPI_IN_SCP_CONNSYS */
			< 7 3  2 0 0 0 0>,/* IPI_IN_APCCCI_0 */
			<38 3  1 0 0 0 0>,/* IPI_IN_SCP_AOD */
			<28 3  5 0 0 0 0>,/* IPI_IN_AUDIO_ULTRA_SND_0 */
			<27 3  2 0 0 0 0>,/* IPI_IN_AUDIO_ULTRA_SND_ACK_0 */
			<35 3  4 1 0 0 0>,/* IPI_OUT_C_SCP_HWVOTER_DEBUG */
			<47 3  2 1 0 0 0>,/* IPI_PIN_HOST_SCP_CHRE ack slot */
			<48 3  2 0 0 0 1>,/* IPI_PIN_SCP_HOST_CHRE msg slot */
			<40 4  4 0 0 0 0>,/* IPI_IN_SCP_AOV */
			<44 4  4 0 0 0 0>;/* IPI_IN_SCP_NPU */

			//legacy_table =	<11>, /* out_id_0 IPI_OUT_SCP_MPOOL_0 */
			//		<24>, /* out_id_1 IPI_OUT_SCP_MPOOL_1 */
			//		<12>, /* in_id_0 IPI_IN_SCP_MPOOL_0 */
			//		<12>, /* in_id_1 IPI_IN_SCP_MPOOL_0 */
			//		<6>, /* out_size */
			//		<6>; /* in_size */

			/* feature, frequecy, coreid */
			scp-feature-tbl = < 0 40 1>,	/* vow */
					< 1   0 0>,	/* sensor */
					< 2  26 0>,	/* flp */
					< 3   0 0>,	/* rtos */
					< 4 200 1>,	/* speaker */
					< 5   0 0>,	/* vcore */
					< 6 135 1>,	/* barge in */
					< 7  10 1>,	/* vow dump */
					< 8  80 1>,	/* vow vendor M */
					< 9  43 1>,	/* vow vendor A */
					<10  22 1>,	/* vow vendor G */
					<11  20 1>,	/* vow dual mic */
					<12 100 1>,	/* vow dual mic barge in */
					<13 200 0>;	/* ultrasound */

			scp-dram-region = "enable";   /* enable scp dram region manage */
			scp-protect = "enable";   /* enable scp protections */
			secure-dump = "enable";   /* enable dump via secure world*/
			scp-pm-notify = "enable";
			scp-thermal-wq = "disable";
			scp-low-pwr-dbg = "enable";
			scp-cfgreg-ap-en = "enable";
			scp-read-infra-irq-status = "enable";
			scp-scpsys-regmap = "enable";
			scp-bus-tracker-ver = <0x2>;
			scp-tracker-timeout-bugon = "enable";
			scp-mbrain = "enable";
			scp-recovery-wfi-detect = <0x2>; /* version 2 */
			scp-ipi-timeout-bugon = "enable";
			scp-task-monitor-dbg = "enable";
			scp-asan = "disable";
			scp-asan-size = <0x200000>;
			vscp-aging = "disable";

			//scp_aovmem_key = "mediatek,scp_aov_reserved";
			scp-mem-key = "mediatek,reserve-memory-scp_share";

			/* feature ID, size, alignment */
			scp-mem-tbl = <0 0x0 0x0>, /* secure dump, its size is in secure-dump-size */
				<1 0xca700 0x0>, /* vow */
				<2 0x100000 0x0>, /* sensor main*/
				<3 0x180000 0x0>, /* logger */
				<4 0x19000 0x0>, /* audio */
				<5 0xa000 0x0>, /* vow bargein */
				<7 0x1a000 0x0>, /* ultrasound*/
				<8 0x10000 0x0>, /* sensor supper*/
				<9 0x2000 0x0>, /* sensor share buffer tx */
				<10 0x2000 0x0>, /* sensor share buffer rx */
				<11 0x100 0x0>, /* sensor custom cmd tx */
				<12 0x100 0x0>, /* sensor custom cmd rx */
				<13 0x780000 0x0>, /* aov */
				<15 0x0 0x0>, /* aod, real size is {aod-scp-mem-tbl} */
				<17 0x8000 0x0>, /* scp chre from */
				<18 0x8000 0x0>, /* scp chre to */
				<19 0x200 0x0>,  /* low power debug */
				<21 0x1800 0x0>; /* task monitor debug */

			scp-resource-dump = "enable";   /* enable dump scp related resource */
			/* regulator */
			scp-supply-num = <1>;	/* total number of scp related regulator */
			vscp0-supply = <&mt6661_5_buck6>;

			/* dump register */
			/* cell means register info (address,size), not total reg num */
			scp-resource-reg-dump-cell = <2>;
			scp-resource-reg-dump = <0x1df2c220 0x4>,
				<0x1df2b004 0x4>,
				<0x1df2b114 0x4>;
			/* scp fmeter dump */
			scp-clk-fmeter-dump = "disable";
			scp-u1-id = <59>;
			scp-u2-id = <60>;

			scp-infracfg = <&infracfg_ao_clk>;

			/* awake timeout count plt setting */
			awake-timeout = <10000>; /* 100 ms */
		};

		apu_smmu: iommu@4c000000 {
			compatible = "arm,smmu-v3", "mtk,smmu-v700", "mediatek,mt6993-apu-smmu";
			reg = <0 0x4c000000 0 0x1e0000>,
			      <0 0x4c1e0000 0 0x10000>;
			interrupts = <GIC_SPI 782 IRQ_TYPE_EDGE_RISING 0>;
			interrupt-names = "combined";
			#iommu-cells = <1>;
			tcu-prefetch = <2>;
			mediatek,axslc;
			//dma-coherent;
			ssid-enable = <1>;
			mtk,tcu-qos = <5>;
			mtk,stash-mode = <3>;
			//mtk,power-awake;
			mtk,slc-gid = <7>;
			mtk,trans-granule = <&mtk_smmu_granule>;

			iommu-groups {
				apu_iommu_group_0: apu-iommu-group-code {
					label = "apu_code";
					mtk,iommu-dma-range = <
						0x0 0x40000000 0x0 0x0c000000
						0x0 0x50000000 0x0 0xb0000000>;
					mtk,smmu-mode = "dma";
				};
				apu_iommu_group_1: apu-iommu-group-data {
					label = "apu_data";
					mtk,iommu-dma-range = <0x1 0x00000000 0xe 0xf0000000>;
					mtk,smmu-mode = "dma";
				};
				apu_iommu_group_2: apu-iommu-group-share {
					label = "apu_share";
					mtk,iommu-dma-range = <
						0x0 0x20000000 0x0 0x10180000
						0x0 0x30400000 0x0 0x0fc00000>;
					mtk,smmu-mode = "dma";
				};
				apu_iommu_group_3: apu-iommu-group-vlm {
					label = "apu_vlm";
					mtk,iommu-dma-range = <0xf 0xf0000000 0x0 0x0ff80000>;
					mtk,smmu-mode = "dma";
				};
			};
		};

		mm_smmu: iommu@30800000 {
			compatible = "arm,smmu-v3", "mtk,smmu-v700", "mediatek,mt6993-mm-smmu";
			reg = <0 0x30800000 0 0x1e0000>,
			      <0 0x309e0000 0 0x10000>;
			interrupts = <GIC_SPI 479 IRQ_TYPE_EDGE_RISING 0>;
			interrupt-names = "combined";
			#iommu-cells = <1>;
			tcu-prefetch = <2>;
			mediatek,axslc;
			//dma-coherent;
			ssid-enable = <1>;
			mtk,tcu-qos = <5>;
			mtk,stash-mode = <3>;
			mtk,smmu-ela;
			mtk,power-awake;
			mtk,slc-gid = <8>;
			mtk,trans-granule = <&mtk_smmu_granule>;

			iommu-groups {
				mm_iommu_group_0: mm-iommu-group-common {
					label = "mm_common";
					#address-cells = <2>;
					#size-cells = <2>;
					mtk,iommu-dma-range = <
						0x0 0x0 0x0 0xfe000000
						0x0 0xfffff000 0x3 0x00001000>;
					mtk,smmu-mode = "dma";
				};
				mm_iommu_group_1: mm-iommu-group-hfrp {
					label = "mm_hfrp";
					#address-cells = <2>;
					#size-cells = <2>;
					mtk,iommu-dma-range = <0x1 0x40000000 0x0 0x80000000>;
					mtk,smmu-mode = "dma";
				};
				mm_iommu_group_2: mm-iommu-group-2 {
					label = "mm_gce_d";
					#address-cells = <2>;
					#size-cells = <2>;
					mtk,iommu-dma-range = <
						0x0 0x0 0x0 0xfe000000
						0x0 0xfffff000 0x3 0x00001000>;
					mtk,smmu-mode = "dma";
				};
				mm_iommu_group_3: mm-iommu-group-3 {
					label = "mm_gce_m";
					#address-cells = <2>;
					#size-cells = <2>;
					mtk,iommu-dma-range = <
						0x0 0x0 0x0 0xfe000000
						0x0 0xfffff000 0x3 0x00001000>;
					mtk,smmu-mode = "dma";
				};
			};
		};

		jpgdec0: jpgdec0@39270000 {
			compatible = "mediatek,jpgdec";
			core-num = <3>;
			reg = <0 0x39270000 0 0x10000>,
				<0 0x39280000 0 0x10000>,
				<0 0x39290000 0 0x10000>,
				<0 0x39200000 0 0x10000>,
				<0 0x39220000 0 0x10000>;
			interrupts = <GIC_SPI 491 IRQ_TYPE_LEVEL_HIGH 0>,
				<GIC_SPI 492 IRQ_TYPE_LEVEL_HIGH 0>,
				<GIC_SPI 496 IRQ_TYPE_LEVEL_HIGH 0>;
			mediatek,larbs = <&smi_larb42>;
			mediatek-larb-supply = <&smi_larb42>;
			operating-points-v2 = <&opp_table_venc_mdp>;
			clocks = <&venc_gcon_mdp_clk VEN_MDP_CKE4_JPGDEC_CKE4_JPGDEC_JPGDEC>,
				<&venc_gcon_mdp_clk VEN_MDP_CKE5_JPGDEC_C1_CKE5_JPGDEC_C1_JPGDEC>,
				<&venc_gcon_mdp_clk VEN_MDP_CKE6_JPGDEC_C2_CKE6_JPGDEC_C2_JPGDEC>,
				<&mmdvfs_mux MMDVFS_USER_JPEGDEC>;
			clock-names = "MT_CG_VENC_JPGDEC",
				"MT_CG_VENC_JPGDEC_C1",
				"MT_CG_VENC_JPGDEC_C2",
				"mmdvfs_clk";
			dvfs-opp-level = <5>;
			ccf-one-step;
			mtk,smmu-shared = <&mm_smmu_codec>;
			jpeg-set-axdomain-base-idx = <4>;
			jpeg-set-axdomain = <0xd>;
			larb-port = <MTK_M4U_TO_PORT(SMMU_L42_P8_JPGDEC_WDMA_0)>,
				 <MTK_M4U_TO_PORT(SMMU_L42_P9_JPGDEC_BSDMA_0)>,
				 <MTK_M4U_TO_PORT(SMMU_L42_P10_JPGDEC_HUFF_OFFSET_0)>,
				 <MTK_M4U_TO_PORT(SMMU_L42_P11_JPGDEC_WDMA_1)>,
				 <MTK_M4U_TO_PORT(SMMU_L42_P12_JPGDEC_BSDMA_1)>,
				 <MTK_M4U_TO_PORT(SMMU_L42_P13_JPGDEC_HUFF_OFFSET_1)>,
				 <MTK_M4U_TO_PORT(SMMU_L42_P14_JPGDEC_WDMA_2)>,
				 <MTK_M4U_TO_PORT(SMMU_L42_P15_JPGDEC_BSDMA_2)>,
				 <MTK_M4U_TO_PORT(SMMU_L42_P16_JPGDEC_HUFF_OFFSET_2)>;
			interconnects = <&mmqos MASTER_LARB_PORT(SMMU_L42_P8_JPGDEC_WDMA_0)
						&mmqos SLAVE_COMMON(0)>,
					<&mmqos MASTER_LARB_PORT(SMMU_L42_P9_JPGDEC_BSDMA_0)
						&mmqos SLAVE_COMMON(0)>,
					<&mmqos MASTER_LARB_PORT(SMMU_L42_P10_JPGDEC_HUFF_OFFSET_0)
						&mmqos SLAVE_COMMON(0)>,
					<&mmqos MASTER_LARB_PORT(SMMU_L42_P11_JPGDEC_WDMA_1)
						&mmqos SLAVE_COMMON(0)>,
					<&mmqos MASTER_LARB_PORT(SMMU_L42_P12_JPGDEC_BSDMA_1)
						&mmqos SLAVE_COMMON(0)>,
					<&mmqos MASTER_LARB_PORT(SMMU_L42_P13_JPGDEC_HUFF_OFFSET_1)
						&mmqos SLAVE_COMMON(0)>,
					<&mmqos MASTER_LARB_PORT(SMMU_L42_P14_JPGDEC_WDMA_2)
						&mmqos SLAVE_COMMON(0)>,
					<&mmqos MASTER_LARB_PORT(SMMU_L42_P15_JPGDEC_BSDMA_2)
						&mmqos SLAVE_COMMON(0)>,
					<&mmqos MASTER_LARB_PORT(SMMU_L42_P16_JPGDEC_HUFF_OFFSET_2)
						&mmqos SLAVE_COMMON(0)>;
			interconnect-names = "path_jpegdec0_wdma",
						"path_jpegdec0_bsdma",
						"path_jpegdec0_huff_offset",
						"path_jpegdec1_wdma",
						"path_jpegdec1_bsdma",
						"path_jpegdec1_huff_offset",
						"path_jpegdec2_wdma",
						"path_jpegdec2_bsdma",
						"path_jpegdec2_huff_offset";
			mmqos-16-level;
			jpeg-set-resource = <3>;
		};

		gpu_smmu: iommu@48600000 {
			#iommu-cells = <1>;
			compatible = "arm,smmu-v3", "mtk,smmu-v700", "mediatek,mt6993-gpu-smmu";
			reg = <0 0x48600000 0 0x1e0000>,
			      <0 0x487e0000 0 0x10000>;
			interrupts = <GIC_SPI 741 IRQ_TYPE_LEVEL_HIGH 0>;
			interrupt-names = "combined";
			interrupt-disable = <1>;
			/* global mpam: partid, pmg */
			mtk,gmpam-cfg = <5 0>;
			/* ste mpam: sid, partid, pmg */
			mtk,mpam-cfg = <1 5 0>,
				       <2 5 0>;
			//dma-coherent;
			mtk,tcu-qos = <5>;
			mtk,trans-granule = <&mtk_smmu_granule>;
		};

		jpgenc0: jpgenc@39230000 {
			compatible = "mediatek,mtk-jpgenc";
			mediatek,platform = "platform:mt6993";
			reg = <0 0x39230000 0 0x10000>,
				<0 0x39200000 0 0x10000>,
				<0 0x39220000 0 0x10000>;
			interrupts = <GIC_SPI 490 IRQ_TYPE_LEVEL_HIGH 0>;
			clocks = <&venc_gcon_mdp_clk VEN_MDP_CKE2_JPGENC_CKE2_JPGENC>,
				 <&mmdvfs_mux MMDVFS_USER_JPEGENC>;
			clock-names = "jpgenc", "mmdvfs_clk";
			//power-domains = <&hfrpsys  MT6991_POWER_DOMAIN_VEN0>;
			mtk,smmu-shared = <&mm_smmu_codec>;
			//mtk,smmu-shared = <&mm_smmu_hfrp>;
			mediatek,larb = <&smi_larb42>;
			operating-points-v2 = <&opp_table_venc_mdp>;
			mmqos-supply = <&mmqos>;
			ports =
				<SMMU_L42_P0_JPGENC_Y_RDMA>,
				<SMMU_L42_P1_JPGENC_C_RDMA>,
				<SMMU_L42_P2_JPGENC_BS>,
				<SMMU_L42_P3_JPGENC_Q_TABLE>;
			interconnects = <&mmqos MASTER_LARB_PORT(SMMU_L42_P0_JPGENC_Y_RDMA)
							&mmqos SLAVE_COMMON(0)>,
						<&mmqos MASTER_LARB_PORT(SMMU_L42_P1_JPGENC_C_RDMA)
							&mmqos SLAVE_COMMON(0)>,
						<&mmqos MASTER_LARB_PORT(SMMU_L42_P3_JPGENC_Q_TABLE)
							&mmqos SLAVE_COMMON(0)>,
						<&mmqos MASTER_LARB_PORT(SMMU_L42_P2_JPGENC_BS)
							&mmqos SLAVE_COMMON(0)>;
			interconnect-names = "path_jpegenc_y_rdma",
					"path_jpegenc_c_rmda",
					"path_jpegenc_q_table",
					"path_jpegenc_bsdma";
			axdomain = <224>;
			clock-set = <832000000>;
			ccf-one-step;
			need-resource-set = <1>;
			mmqos-level;
			yuv422-bw = <2867000>;
			yuv420-bw = <4096000>;
		};

		jpgenc1: jpgenc@39240000 {
			compatible = "mediatek,mtk-jpgenc_c1";
			mediatek,platform = "platform:mt6993";
			reg = <0 0x39240000 0 0x10000>,
				<0 0x39200000 0 0x10000>,
				<0 0x39220000 0 0x10000>;

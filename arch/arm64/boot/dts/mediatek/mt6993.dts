		pins-cmd3-dat {
			pinmux = <PINMUX_GPIO110__FUNC_I2SIN4_DATA0>;
			input-schmitt-enable;
			bias-disable;
		};
	};
	aud_gpio_i2sout4_off: aud-gpio-i2sout4-off {

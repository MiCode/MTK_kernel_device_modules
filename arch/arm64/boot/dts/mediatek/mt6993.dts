	logstore: logstore {
		enabled = <1>;
		pmic-register = <0xa0d>;
		/*
		if not, means default(3M: 2M(logstoe) + 1M(mrdump));
		version = C_LOG_STORE_EXPDB_SIZE(preloader) + 1M(bootprof) + 1M(mrdump)
		version < MRDUMP_CONFIG_EXPDB_OFFSET_LIMIT
		note: To modify the version value, modify the C_LOG_STORE_EXPDB_SIZE(mt6991/print.h) at the same time.
		*/
		version = "12582912";
	};

	memory@80000000 {
		device_type = "memory";
		reg = <0 0x80000000 0 0x80000000>;
	};

	odm: odm {
		compatible = "simple-bus";
		/* reserved for overlay by odm */
	};

	reserved_memory: reserved-memory {
		/*TODO: add reserved memory node here*/
		#address-cells = <2>;
		#size-cells = <2>;
		ranges;

		mkp_mem: mkp-kernel-code-protection-memory {
			compatible = "mkp-kernel-protection";
			size = <0 0x10000>;
			alloc-ranges = <0 0x80000000 0 0x10000>;
		};

		dpmaif_resv_cache_mem: ccci-dpmaif-cache-memory {
			compatible = "mediatek,dpmaif-resv-cache-mem";
			size = <0 0x00210000>; /* 2162688 Bytes for 2rxq */
			alignment = <0 0x10000>;
			alloc-ranges = <0 0x40000000 0 0xf0000000>;
		};

		dpmaif_resv_nocache_mem: ccci-dpmaif-nocache-memory {
			compatible = "mediatek,dpmaif-resv-nocache-mem";
			no-map;
			size = <0 0x0050000>; /* 327680 Bytes */
			alignment = <0 0x10000>;
			alloc-ranges = <0 0x40000000 0 0xf0000000>;
		};

		ssmr_cma_mem: ssmr-reserved-cma-memory {
			compatible = "shared-dma-pool";
			reusable;
			size = <0 0x10000000>;
			alignment = <0 0x1000000>;
		};

	};

	memory_ssmr_features: memory-ssmr-features {
		compatible = "mediatek,memory-ssmr-features";
		svp-region-based-size = <0 0x6000000>;
		tui-size = <0 0x4000000>;
		wfd-region-based-size = <0 0x2000000>;
		prot-region-based-size = <0 0x2000000>;
		sapu-data-shm-size = <0 0x0>;
	};

	ssmr: ssmr {
		compatible = "mediatek,trusted_mem";
		memory-region = <&ssmr_cma_mem>;
	};

	ffa: memory-ffa-enabled {
		compatible = "mediatek,memory-ffa-enabled";
	};

	page_based_v2: page-based-v2-enabled {
		compatible = "mediatek,page-based-v2-enabled";
		pre-alloc-prot-page-num = <0x40>;
	};

	sel2: hafnium-bypass-cma-enabled {
		compatible = "mediatek,hafnium-bypass-cma-enabled";
	};

	clkitg: clkitg {
		compatible = "simple-bus";
		#address-cells = <1>;
		#size-cells = <0>;
	};

	disable_unused: disable-unused {
		compatible = "simple-bus";
		#address-cells = <1>;
		#size-cells = <0>;
	};

	clkchk {
		compatible = "mediatek,mt6993-clkchk";
		hwv-regmap = <&ap_hwv>;
		mm-hwv-regmap = <&mm_hwv>;
		interrupts = <GIC_SPI 936 IRQ_TYPE_LEVEL_HIGH 0>,
			<GIC_SPI 583 IRQ_TYPE_LEVEL_HIGH 0>;
		interrupt-names = "hwv_irq", "hfrp_hwv_irq";
	};

	pdchk {
		compatible = "mediatek,mt6993-pdchk";
	};

	clocks {
		compatible = "clk-ftrace";
		clk_null: clk-null {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <0>;
		};
		clk32k: clk32k {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <32000>;
		};
		clksq: clksq {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <26000000>;
		};
		clk26m: clk26m {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <26000000>;
		};
		clk208m: clk208m {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <208000000>;
		};
		ulposc: ulposc {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <520000000>;
		};
		ulposc3: ulposc3 {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <26000000>;
		};
	};

	clksqr: syscon@13930000 {
		compatible = "mediatek,mt6993-clksq_ctrl", "syscon";
		reg = <0 0x13930000 0 0x60>;
	};

	cksys_top_ckmtr: syscon@1c211000 {
		compatible = "mediatek,mt6993-cksys_top_ckmtr", "syscon";
		reg = <0 0x1c211000 0 0x20>;
	};
	cksys_mm_ckmtr: syscon@10041000 {
		compatible = "mediatek,mt6993-cksys_mm_ckmtr", "syscon";
		reg = <0 0x10041000 0 0x20>;
	};
	cksys_vlp_ckmtr: syscon@1c201000 {
		compatible = "mediatek,mt6993-cksys_vlp_ckmtr", "syscon";
		reg = <0 0x1c201000 0 0x20>;
	};

	ap_hwv: syscon@1c040000 {
		compatible = "mediatek,mt6993-ap_hwv", "syscon";
		reg = <0 0x1c040000 0 0x74900>;
	};

	mm_hwv: syscon@31c00000 {
		compatible = "mediatek,mt6993-mm_hwv", "syscon";
		reg = <0 0x31c00000 0 0x74900>;
	};

	ccipll_pll_ctrl_clk: syscon@5080000 {
		compatible = "mediatek,mt6993-ccipll_pll_ctrl", "syscon";
		reg = <0 0x5080000 0 0x1000>;
		#clock-cells = <1>;
	};

	ptppll_pll_ctrl_clk: syscon@5084000 {
		compatible = "mediatek,mt6993-ptppll_pll_ctrl", "syscon";
		reg = <0 0x5084000 0 0x1000>;
		#clock-cells = <1>;
	};

	cksys_mm_clk: clock-controller@10040000 {
		compatible = "mediatek,mt6993-cksys_mm", "syscon";
		reg = <0 0x10040000 0 0x1000>;
		hw-voter-regmap = <&ap_hwv>;
		mm-hw-ccf-regmap = <&mm_hwv>;
		#clock-cells = <1>;
	};

	mainpll2_ctrl_clk: clock-controller@10043000 {
		compatible = "mediatek,mt6993-mainpll2_ctrl", "syscon";
		reg = <0 0x10043000 0 0x0100>;
		#clock-cells = <1>;
	};

	univpll2_ctrl_clk: clock-controller@10043100 {
		compatible = "mediatek,mt6993-univpll2_ctrl", "syscon";
		reg = <0 0x10043100 0 0x0100>;
		#clock-cells = <1>;
	};

	mmpll_ctrl_clk: clock-controller@10043200 {
		compatible = "mediatek,mt6993-mmpll_ctrl", "syscon";
		reg = <0 0x10043200 0 0x0100>;
		#clock-cells = <1>;
	};

	imgpll_ctrl_clk: clock-controller@10043300 {
		compatible = "mediatek,mt6993-imgpll_ctrl", "syscon";
		reg = <0 0x10043300 0 0x0100>;
		#clock-cells = <1>;
	};

	tvdpll_ctrl_clk: clock-controller@10043400 {
		compatible = "mediatek,mt6993-tvdpll_ctrl", "syscon";
		reg = <0 0x10043400 0 0x1000>;
		#clock-cells = <1>;
	};

	imp_iic_wrap_e_clk: clock-controller@12650000 {
		compatible = "mediatek,mt6993-imp_iic_wrap_e", "syscon";

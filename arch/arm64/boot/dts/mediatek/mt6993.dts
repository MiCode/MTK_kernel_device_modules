				"camsys_rawa_camtg_cgpdn",
				"camsys_rawa_cam_26m_cgpdn";
			mediatek,smmu-dma-axid =
				<SMMU_L16_P0_CAM2_RAW_R_0_P0_16_U0>,
				<SMMU_L16_P1_CAM2_RAW_R_0_P1_16_U0>,
				<SMMU_L16_P2_CAM2_RAW_R_0_P2_16_U0>,
				<SMMU_L16_P3_CAM2_RAW_R_0_P3_16_U0>,
				<SMMU_L16_P4_CAM2_RAW_R_0_P4_16_U0>,
				<SMMU_L16_P5_CAM2_RAW_R_0_P5_16_U0>,
				<SMMU_L16_P6_CAM2_RAW_R_0_P6_16_U0>,
				<SMMU_L16_P7_CAM2_RAW_R_0_P7_16_U0>,
				<SMMU_L16_P10_CAM2_RAW_W_0_P0_16_U0>,
				<SMMU_L16_P11_CAM2_RAW_W_0_P1_16_U0>,

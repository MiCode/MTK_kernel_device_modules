			pinmux = <PINMUX_GPIO102__FUNC_GPIO102>;
			input-enable;
			bias-pull-down;
		};
		pins-cmd2-dat {
			pinmux = <PINMUX_GPIO103__FUNC_GPIO103>;
			input-enable;
			bias-pull-down;
		};
	};
	aud_dat_miso_only_on: aud-dat-miso-only-on {

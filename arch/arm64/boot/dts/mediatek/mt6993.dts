		disp_dpc: disp-dpc@3eff0000 {
			compatible = "mediatek,mt6993-disp-dpc-v3";
			drm-supply = <&dispsys_config>;
			vdisp-supply = <&vdisp_ctrl>;
			reg =
				<0 0x3eff0000 0 0x2000>,
				<0 0x31b501b8 0 0x4>,             // hfrp rtff pwr con
				<0 0x31bd0070 0 0x4>,             // hfrp DISP_SW_VOTE_SET
				<0 0x31bd0074 0 0x4>,             // hfrp DISP_SW_VOTE_CLR
				<0 0x31bd0078 0 0x4>,             // hfrp DISP_GENERAL_CTRL_SET
				<0 0x31bd007c 0 0x4>,             // hfrp DISP_GENERAL_CTRL_CLR
				<0 0x31a912b4 0 0x4>,             // hfrp_dvfsrc_disp_debug_sta_6
				<0 0x31b50068 0 0x4>,             // hfrp sub pm DISP_VCORE bit29, or 0x31b50068 bit31
				<0 0x3e800100 0 0x10>;            // VDISP_AO_CG_CON0
			reg-names =
				"DPC_BASE",
				"rtff_pwr_con",
				"disp_sw_vote_set",
				"disp_sw_vote_clr",
				"vcore_mode_set",
				"vcore_mode_clr",
				"vdisp_dvfsrc",
				"disp_vcore_pwr_chk",
				"vdisp_ao_cg_con";
			interrupts =
				<GIC_SPI 450 IRQ_TYPE_LEVEL_HIGH 0>; // DISP_VDISP_AO_MERGE_IRQ_BIT
			vidle-mask = <0x0>;
			debug-irq = <0x1>;
			mminfra-pwr-idx = <MMINFRA_MT6993_PWR_MM2>;
			mminfra-pwr-type = <MMINFRA_MT6993_TYPE_DISP>;
			event-vote-hwccf = /bits/ 16 <CMDQ_SYNC_TOKEN_DPC_VOTE_HWCCF>;
			operating-points-v2 = <&opp_table_disp>, <&opp_table_disp_b0>;
			clocks = <&disp_vdisp_ao_config_clk VDISP_AO_DISP_DPC_DISP>,
				 <&disp_vdisp_ao_config_clk VDISP_AO_DISP_BUS_DISP>,
				 <&disp_vdisp_ao_config_clk VDISP_AO_CONFIG_DISP>;
		};


		apu_top_3: apu-top-3 {
			compatible = "mt6993,apu_top_3";
			reg = <0 0x19020000 0 0x1000>;
			reg-names = "apu_rcx";
			apu-cdev-enable;
			apu-sw-throttle-enable;
		};

		apu_top_cti: apu-top-cti {
			compatible = "mt6993,apu_top_cti";
			reg = <0 0xd034000 0 0x1000>;
			cti-out-stop = <0x0 0x0>;
			cti-out-start = <0x1 0x1>;
		};

		apusys_rv: apusys-rv@19090000 {
			compatible = "mediatek,mt6993-apusys_rv";
			status = "okay";

			reg = <0 0x19090000 0 0x1000>,
				<0 0x4c200000 0 0x100000>,
				<0 0x19091000 0 0x10>,
				<0 0x19080000 0 0x10000>,
				<0 0x19052000 0 0x1000>;

			reg-names = "apu_rv_wrap",
				"apu_mbox",
				"apu_wdt",
				"md32_cache_dump",
				"apu_rpc";

			mtk,iommu-group = <&apu_iommu_group_2>;
			iommus = <&apu_smmu 9>;

			interrupts = <GIC_SPI 784 IRQ_TYPE_LEVEL_HIGH 0>,
				<GIC_SPI 763 IRQ_TYPE_LEVEL_HIGH 0>,
				<GIC_SPI 764 IRQ_TYPE_LEVEL_HIGH 0>,
				<GIC_SPI 779 IRQ_TYPE_LEVEL_HIGH 0>;

			interrupt-names = "apu_wdt",
				"mbox0_irq",
				"mbox1_irq",
				"ce_exp_irq";

			up-tcm-sz = <0x80000>;
			up-code-buf-sz = <0x100000>;
			ramdump-sz = <0xf4000>;
			regdump-sz = <0x1000>;
			tbufdump-sz = <0x400>;
			up-coredump-buf-sz = <0x1d0000>;
			ce-coredump-buf-sz = <0x010000>;
			regdump-buf-sz = <0x22000>;
			mdla-coredump-buf-sz = <0x0>;
			mvpu-coredump-buf-sz = <0x0>;
			mvpu-sec-coredump-buf-sz = <0x0>;

			apu-ctrl {
				compatible = "mediatek,apu-ctrl-rpmsg";
				mtk,rpmsg-name = "apu-ctrl-rpmsg";
			};

			apu-top-rpmsg {
				compatible = "mediatek,aputop-rpmsg";
				mtk,rpmsg-name = "apu_top_3_rpmsg";
			};

			apu-mdw-rpmsg {
				compatible = "mediatek,apu-mdw-rpmsg";
				mtk,rpmsg-name = "apu-mdw-rpmsg";
			};

			apu-apummu {
				compatible = "mediatek,apu-apummu-rpmsg";
				mtk,rpmsg-name = "apu-apummu-rpmsg";
			};

			apu-apummu-rx {
				compatible = "mediatek,apu-apummu-rx";
				mtk,rpmsg-name = "apu-apummu-rx";
			};

			apu-edma {
				compatible = "mediatek,apu-edma-rpmsg";
				mtk,rpmsg-name = "apu-edma-rpmsg";
			};

			edma-rx {
				compatible = "mediatek,edma-rx-rpmsg";
				mtk,rpmsg-name = "edma-rx-rpmsg";
			};

			apu-mnoc {
				compatible = "mediatek,apu-mnoc-rpmsg";
				mtk,rpmsg-name = "apu-mnoc-rpmsg";
			};

			mdla-tx-rpmsg {
				compatible = "mediatek,mdla-tx-rpmsg";
				mtk,rpmsg-name = "mdla-tx-rpmsg";
			};

			mdla-rx-rpmsg {
				compatible = "mediatek,mdla-rx-rpmsg";
				mtk,rpmsg-name = "mdla-rx-rpmsg";
			};

			mvpu-tx-rpmsg {
				compatible = "mediatek,mvpu-tx-rpmsg";
				mtk,rpmsg-name = "mvpu-tx-rpmsg";
			};

			mvpu-rx-rpmsg {
				compatible = "mediatek,mvpu-rx-rpmsg";
				mtk,rpmsg-name = "mvpu-rx-rpmsg";
			};

			aps-tx-rpmsg {
				compatible = "mediatek,aps-tx-rpmsg";
				mtk,rpmsg-name = "aps-tx-rpmsg";
			};

			aps-rx-rpmsg {
				compatible = "mediatek,aps-rx-rpmsg";
				mtk,rpmsg-name = "aps-rx-rpmsg";
			};

			sapu-lock-rpmsg {
				compatible = "mediatek,apu-lock-rv-rpmsg";
				mtk,rpmsg-name = "apu-lock-rv-rpmsg";
			};

			apu-scp-mdw-rpmsg {
				compatible = "mediatek,apu-scp-mdw-rpmsg";
				mtk,rpmsg-name = "apu-scp-mdw-rpmsg";
			};

			apu-scp-np-recover-rpmsg {
				compatible = "mediatek,apu-scp-np-recover-rpmsg";
				mtk,rpmsg-name = "apu-scp-np-recover-rpmsg";
			};

			apu-ipi-ut-rpmsg {
				compatible = "mediatek,apu-ipi-ut-rpmsg";
				mtk,rpmsg-name = "apu-ipi-ut-rpmsg";
			};

			rv-bsp-rx-rpmsg {
				compatible = "mediatek,rv-bsp-rx-rpmsg";
				mtk,rpmsg-name = "rv-bsp-rx-rpmsg";
			};

			apu-hds-tx-rpmsg {
				compatible = "mediatek,apu-hds-tx-rpmsg";
				mtk,rpmsg-name = "apu-hds-tx-rpmsg";
			};

			apu-hds-rx-rpmsg {
				compatible = "mediatek,apu-hds-rx-rpmsg";
				mtk,rpmsg-name = "apu-hds-rx-rpmsg";
			};
		};

		apusys_hw_logger: apusys-hw-logger@19094000 {
			compatible = "mediatek,mt6993-apusys_hw_logger";
			status = "okay";

			reg = <0 0x19094000 0 0x1000>,
				 <0 0x4c200000 0 0x2000>;

			reg-names = "apu_logtop",
					"apu_mbox";
			interrupts = <GIC_SPI 783 IRQ_TYPE_EDGE_RISING 0>;
			interrupt-names = "apu_logtop";

			mtk,iommu-group = <&apu_iommu_group_2>;
			iommus = <&apu_smmu 12>;

			log-buf-sz = <0x300000>;
			interrupt-lbc-sz = <0x60000>;
		};


	usb0cfg_ao_clk: clock-controller@167a0000 {
		compatible = "mediatek,mt6993-usb0cfg_ao", "syscon";
		reg = <0 0x167a0000 0 0x35c>;
		#clock-cells = <1>;
	};

	ufs0cfg_ao_clk: clock-controller@16840000 {
		compatible = "mediatek,mt6993-ufs0cfg_ao", "syscon", "simple-mfd";
		reg = <0 0x16840000 0 0x1000>;
		#clock-cells = <1>;

		ufs0cfgao_rst: reset-controller {
			compatible = "ti,syscon-reset";
			#reset-cells = <1>;

			ti,reset-bits = <
				/* ufs mphy/ufschi/crypto/unipro reset */
				/* 0: mphy */
				0x48   3 0x4c   3 0 0
				(ASSERT_SET | DEASSERT_SET | STATUS_NONE)
				/* 1: unipro */
				0x148  0 0x14c  0 0 0
				(ASSERT_SET | DEASSERT_SET | STATUS_NONE)
				/* 2: ufs-crypto */
				0x148  1 0x14c  1 0 0
				(ASSERT_SET | DEASSERT_SET | STATUS_NONE)
				/* 3: ufshci */
				0x148  2 0x14c  2 0 0
				(ASSERT_SET | DEASSERT_SET | STATUS_NONE)
				>;
		};
	};

	ufs1cfg_ao_clk: clock-controller@168c0000 {
		compatible = "mediatek,mt6993-ufs1cfg_ao", "syscon", "simple-mfd";
		reg = <0 0x168c0000 0 0x1000>;
		#clock-cells = <1>;

		ufs1cfgao_rst: reset-controller {
			compatible = "ti,syscon-reset";
			#reset-cells = <1>;

			ti,reset-bits = <
				/* ufs mphy/ufschi/crypto/unipro reset */
				/* 0: mphy */
				0x48   3 0x4c   3 0 0
				(ASSERT_SET | DEASSERT_SET | STATUS_NONE)
				/* 1: unipro */
				0x148  0 0x14c  0 0 0
				(ASSERT_SET | DEASSERT_SET | STATUS_NONE)
				/* 2: ufs-crypto */
				0x148  1 0x14c  1 0 0
				(ASSERT_SET | DEASSERT_SET | STATUS_NONE)
				/* 3: ufshci */
				0x148  2 0x14c  2 0 0
				(ASSERT_SET | DEASSERT_SET | STATUS_NONE)
				>;
		};
	};

	pextp0cfg_ao_clk: clock-controller@169b0000 {
		compatible = "mediatek,mt6993-pextp0cfg_ao", "syscon", "simple-mfd";
		reg = <0 0x169b0000 0 0x1000>;
		#clock-cells = <1>;

		pextp0ao_rst: reset-controller {
			compatible = "ti,syscon-reset";
			#reset-cells = <1>;

			ti,reset-bits = <
				/* 0: PCIe0 MAC reset */
				0x8  0 0xc  0 0 0
				(ASSERT_SET | DEASSERT_SET | STATUS_NONE)
				/* 1: PCIe0 PHY reset */
				0x8  1 0xc  1 0 0
				(ASSERT_SET | DEASSERT_SET | STATUS_NONE)
				>;
		};
	};

	pextp1cfg_ao_clk: clock-controller@169e0000 {
		compatible = "mediatek,mt6993-pextp1cfg_ao", "syscon", "simple-mfd";
		reg = <0 0x169e0000 0 0x1000>;
		#clock-cells = <1>;

		pextp1ao_rst: reset-controller {
			compatible = "ti,syscon-reset";
			#reset-cells = <1>;

			ti,reset-bits = <
				/* 0: PCIe1 MAC reset */
				0x8  0 0xc  0 0 0
				(ASSERT_SET | DEASSERT_SET | STATUS_NONE)
				/* 1: PCIe1 PHY reset */
				0x8  1 0xc  1 0 0
				(ASSERT_SET | DEASSERT_SET | STATUS_NONE)
				>;
		};
	};


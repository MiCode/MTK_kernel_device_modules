				<0 0x1432d000 0 0x1000>, /* apinfra_io_east pd */
				<0 0x14386000 0 0x1000>, /* apinfra_io_east_intf pd */
				<0 0x10693000 0 0x1000>, /* apinfra_big4 pd */
				<0 0x102f3000 0 0x1000>, /* apinfra_dramc pd */
				<0 0x11004000 0 0x1000>, /* apinfra_emi pd */
				<0 0x10438000 0 0x1000>, /* apinfra_nemi pd */
				<0 0x10538000 0 0x1000>, /* apinfra_semi pd */
				<0 0x14130000 0 0x1000>, /* apinfra_mem pd */
				<0 0x14131000 0 0x1000>, /* apinfra_mem_ctrl pd */
				<0 0x140c0000 0 0x1000>, /* apinfra_mem_intf pd */
				<0 0x142f4000 0 0x1000>, /* apinfra_int pd */
				<0 0x14800000 0 0x1000>, /* apinfra_mmu pd */
				<0 0x140e0000 0 0x1000>, /* apinfra_hash pd */
				<0 0x140e1000 0 0x1000>, /* apinfra_hash_ctrl pd */
				<0 0x180a4000 0 0x1000>, /* ssr pd */
				<0 0x16670000 0 0x1000>, /* peri pd */
				<0 0x1c032000 0 0x1000>, /* vlp pd */
				<0 0x1a019000 0 0x1000>, /* adsp pd */
				<0 0x30040000 0 0x1000>, /* mminfra pd */
				<0 0x31ad5000 0 0x1000>, /* mmup pd */
				<0 0x4b890000 0 0x1000>, /* gpu pd */
				<0 0x4b8b0000 0 0x1000>, /* gpu1 pd */
				<0 0x101c4000 0 0x1000>, /* apinfra_io ao */
				<0 0x101c0000 0 0x1000>, /* apinfra_io_ctrl ao */
				<0 0x14000000 0 0x1000>, /* apinfra_io_intf ao */
				<0 0x14310000 0 0x1000>, /* apinfra_io_east ao */
				/* <0 0x14380000 0 0x1000>,  apinfra_io_east_intf ao (no use) */
				<0 0x10680000 0 0x1000>, /* apinfra_big4 ao */
				<0 0x102e0000 0 0x1000>, /* apinfra_dramc ao  */
				/* <0 0x11000000 0 0x1000>,  apinfra_emi ao (no use) */
				<0 0x141f0000 0 0x1000>, /* apinfra_mem ao */
				<0 0x141f4000 0 0x1000>, /* apinfra_mem_ctrl ao */
				<0 0x14020000 0 0x1000>, /* apinfra_mem_intf ao */
				<0 0x14040000 0 0x1000>, /* apinfra_int ao */
				<0 0x14060000 0 0x1000>, /* apinfra_mmu ao */
				<0 0x14080000 0 0x1000>, /* apinfra_hash ao */
				<0 0x14084000 0 0x1000>, /* apinfra_hash_ctrl ao */
				<0 0x180a0000 0 0x1000>, /* ssr ao */
				<0 0x16660000 0 0x1000>, /* peri ao */
				<0 0x1c550000 0 0x1000>, /* vlp ao */
				<0 0x1a340000 0 0x1000>, /* adsp ao */
				<0 0x30050000 0 0x1000>, /* mminfra ao */
				<0 0x31ad0000 0 0x1000>, /* mmup ao */
				<0 0x4b880000 0 0x1000>, /* gpu ao */
				<0 0x14411000 0 0x1000>, /* infracfg */
				<0 0x10033000 0 0x1000>, /* swp */
				<0 0x0010c000 0 0x1000>; /* sramrom */
			interrupts = <GIC_SPI 865 IRQ_TYPE_LEVEL_HIGH 0>, /* apinfra_io irq */
				<GIC_SPI 866 IRQ_TYPE_LEVEL_HIGH 0>, /* apinfra_io_ctrl irq */
				<GIC_SPI 864 IRQ_TYPE_LEVEL_HIGH 0>, /* apinfra_io_intf irq */
				<GIC_SPI 861 IRQ_TYPE_LEVEL_HIGH 0>, /* apinfra_io_east, apinfra_io_east_intf irq */
				<GIC_SPI 862 IRQ_TYPE_LEVEL_HIGH 0>, /* apinfra_big4 irq */
				<GIC_SPI 867 IRQ_TYPE_LEVEL_HIGH 0>, /* apinfra_dramc irq */
				/* <GIC_SPI 1073 IRQ_TYPE_LEVEL_HIGH 0>, apinfra_emi_infra irq (fake) */
				<GIC_SPI 832 IRQ_TYPE_LEVEL_HIGH 0>, /* apinfra_mem irq */
				<GIC_SPI 833 IRQ_TYPE_LEVEL_HIGH 0>, /* apinfra_mem_ctrl irq */
				<GIC_SPI 834 IRQ_TYPE_LEVEL_HIGH 0>, /* apinfra_mem_intf irq */
				<GIC_SPI 863 IRQ_TYPE_LEVEL_HIGH 0>, /* apinfra_int irq */
				<GIC_SPI 831 IRQ_TYPE_LEVEL_HIGH 0>, /* apinfra_mmu irq */
				<2 7 IRQ_TYPE_LEVEL_HIGH 0>, /* apinfra_hash irq */
				<2 8 IRQ_TYPE_LEVEL_HIGH 0>, /* apinfra_hash_ctrl irq */
				<2 94 IRQ_TYPE_LEVEL_HIGH 0>, /* ssr irq */
				<GIC_SPI 279 IRQ_TYPE_EDGE_RISING 0>, /* peri irq */
				<GIC_SPI 806 IRQ_TYPE_LEVEL_HIGH 0>, /* vlp irq */
				<GIC_SPI 546 IRQ_TYPE_LEVEL_HIGH 0>, /* adsp irq */
				<GIC_SPI 480 IRQ_TYPE_LEVEL_HIGH 0>, /* mminfra irq */
				<GIC_SPI 566 IRQ_TYPE_LEVEL_HIGH 0>, /* mmup irq */
				<GIC_SPI 738 IRQ_TYPE_LEVEL_HIGH 0>; /* gpu irq */
			exception {
				excep1 {
					excep-name = "debugsys";
					excep-type = <0>;
					slave-type = <0>;
					reg-base = <0x14411000>;
				};
			};
		};

                infracfg_ao_clk: syscon@10001000 {

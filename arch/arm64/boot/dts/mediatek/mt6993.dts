	};
	vow_scp_dmic_clk_on: vow-scp-dmic-clk-on {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO180__FUNC_SCP_DMIC_CLK>;
			input-schmitt-enable;
			bias-disable;
		};
		pins-cmd2-dat {
			pinmux = <PINMUX_GPIO12__FUNC_SCP_DMIC1_CLK>;
			input-schmitt-enable;
			bias-disable;
		};
	};
	aud_gpio_ext_hp_amp_on: aud-gpio-ext-hp-amp-on {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO196__FUNC_GPIO196>;
			slew-rate = <1>;
			output-high;
		};
	};
	aud_gpio_ext_hp_amp_off: aud-gpio-ext-hp-amp-off {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO196__FUNC_GPIO196>;
			slew-rate = <1>;
			output-low;
		};
	};

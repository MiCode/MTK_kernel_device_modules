						&smi_larb46 &smi_larb14 &smi_larb17 &smi_larb29
						&smi_larb25 &smi_larb44 &smi_larb19 &smi_larb27
						&smi_larb30 &smi_larb7 &smi_larb8 &smi_larb24
						&smi_larb47 &smi_larb42 &smi_larb41 &smi_larb4
						&smi_larb5 &smi_larb6>;
		mediatek,commons-supply = <&smi_disp_common>, <&smi_mdp_common>;
		mmqos-state = <0xd3f42d>;
		mmqos-log-level = <0>;
		interconnects = <&dvfsrc MT6873_MASTER_MMSYS &dvfsrc MT6873_SLAVE_DDR_EMI>,
				<&dvfsrc MT6873_MASTER_HRT_MMSYS
				 &dvfsrc MT6873_SLAVE_HRT_DDR_EMI>;
		interconnect-names = "icc-bw", "icc-hrt-bw";
		vmmrc-base = <0x31ae0000>;
		vmmrc-range = <0x1200>;
		vmmrc-mask = <0x10b0>;
		vmmrc-on-table = <0xff0>;
		mminfra-base = <0x30000000>;
		hfrp-base = <0x31bd0000>;
		mmpc-cam-hw-bw = <0x5c>;
		mmpc-cam-hw-bw-hrt = <0x29c>;
		mmpc-total-mmqos-bw = <0x53c>;
		mmpc-total-pmqos-bw = <0x59c>;
		mmpc-total-slb-bw = <0x10c8>;
		mmpc-sw-en-all-on = <0xfffffff>;
		mmpc-cam-hw-emi-bw-hrt = <0xf00>;
		mmpc-total-emi-pmqos-bw = <0xfd0>;
		mmpc-total-current-mmqos-bw = <0xd8c>;
		mmpc-total-current-pmqos-bw = <0xdec>;
		mmpc-total-current-slb-bw = <0xdec>;
		mmqos-sram-base = <0x00113400>;

		r-hrt-ostdl = <2>;
		w-hrt-ostdl = <3>;
		r-srt-ostdl = <1>;
		w-srt-ostdl = <2>;
		bwl-hrt-r-margin = <100>;
		bwl-hrt-w-margin = <100>;
		bwl-srt-r-margin = <100>;
		bwl-srt-w-margin = <100>;
	};

	dbg-error-flag {
		compatible = "mediatek,dbg-error-flag";
		mediatek,error-flag = <&soc_dbg_error_flag>,
					<&vlp_dbg_error_flag>;
	};

	bw-regulator {
		compatible = "mediatek,bw-regulator";
		mediatek,bw-regulator = <&apinfra_m4_bw_regulator>,
					 <&apinfra_m6_bw_regulator>,
					 <&apinfra_m7_bw_regulator>,
					 <&emiinfra_m6_bw_regulator>,
					 <&emiinfra_m7_bw_regulator>,
					 <&sub_emiinfra_m6_bw_regulator>,
					 <&sub_emiinfra_m7_bw_regulator>,
					 <&chinfra_cha_axi_bw_regulator>,
					 <&chinfra_chb_axi_bw_regulator>,
					 <&chinfra_chc_axi_bw_regulator>,
					 <&chinfra_chd_axi_bw_regulator>,
					 <&chinfra_cha_ace_bw_regulator>,
					 <&chinfra_chb_ace_bw_regulator>,
					 <&chinfra_chc_ace_bw_regulator>,
					 <&chinfra_chd_ace_bw_regulator>,
					 <&chinfra_cha_tcu_ace_bw_regulator>;
	};

	ela {
		compatible = "mediatek,ela";
		mediatek,ela = <&apinfra_ela>;
	};

	cti {
		compatible = "mediatek,cti";
		mediatek,cti = <&apinfra_mem_cti>,
				<&emi_infra_cti>,
				<&chinfra_cti>,
				<&apu_top_cti>,
				<&mfgsys_cti>;
	};

	soc {
		compatible = "simple-bus";
		#address-cells = <2>;
		#size-cells = <2>;
		ranges;
		dma-ranges = <0x0 0x0 0x0 0x0 0x10 0x0>;

		fhctl: fhctl@1c2130c0 {
			gpueb-supply = <&gpueb>;
			compatible = "mediatek,mt6993-fhctl";
			reg = <0 0x1c2130c0 0 0x040>, //mainpll FHCTL base
				<0 0x1c213000 0 0x0c0>, //mainpll PLL base
				<0 0x1c2131c0 0 0x040>, //univpll FHCTL base
				<0 0x1c213100 0 0x0c0>, //univpll PLL base
				<0 0x1c2132c0 0 0x040>, //msdcpll FHCTL base
				<0 0x1c213200 0 0x0c0>, //msdcpll PLL base
				<0 0x100430c0 0 0x040>, //mainpll2 FHCTL base
				<0 0x10043000 0 0x0c0>, //mainpll2 PLL base
				<0 0x100431c0 0 0x040>, //univpll2 FHCTL base
				<0 0x10043100 0 0x0c0>, //univpll2 PLL base
				<0 0x100432c0 0 0x040>, //mmpll FHCTL base
				<0 0x10043200 0 0x0c0>, //mmpll PLL base
				<0 0x100434c0 0 0x040>, //tvdpll FHCTL base
				<0 0x10043400 0 0x0c0>, //tvdpll PLL base

				<0 0x4b810100 0 0x030>, //GPU0 HP_EN
				<0 0x4b810000 0 0x100>, //GPU APMIX
				<0 0x4b810500 0 0x030>,
				<0 0x4b810400 0 0x100>;

			map0 {
				domain = "top0";
				method = "fhctl-ap";
				mainpll {
					fh-id = <0>;
					perms = <0x1e>;
				};
			};

			map1 {
				domain = "top1";
				method = "fhctl-ap";
				univpll {
					fh-id = <0>;
					perms = <0x1e>;
				};
			};

			map2 {
				domain = "top2";
				method = "fhctl-ap";
				msdcpll {
					fh-id = <0>;
					perms = <0x1e>;
				};
			};

			map3 {
				domain = "top3";
				method = "fhctl-ap";
				mainpll2 {
					fh-id = <0>;
					perms = <0x1e>;
				};
			};

			map4 {
				domain = "top4";
				method = "fhctl-ap";
				univpll2 {
					fh-id = <0>;
					perms = <0x1e>;
				};
			};

			map5 {
				domain = "top5";
				method = "fhctl-ap";
				mmpll {
					fh-id = <0>;
					perms = <0x1e>;
				};
			};

			map7 {
				domain = "top7";
				method = "fhctl-ap";
				tvdpll {
					fh-id = <0>;
					perms = <0x1e>;
				};
			};

			map8 {
				domain = "gpu0";
				method = "fhctl-gpueb";
				mfgpll {
					fh-id = <0>;
				};
			};

			map9 {
				domain = "gpu1";
				method = "fhctl-gpueb";
				mfgpll-sc {
					fh-id = <0>;
				};
			};
		};

		dfd_mcu: dfd-mcu {
			compatible = "mediatek,dfd_mcu";
			enabled = <1>;
			hw-version = <35>;
			sw-version = <1>;
			dfd-timeout = <0x2710>;
			dump-to-dramc-channel = <1>;
			enable-dramc-hub-mode = <1>;
			buf-addr-align = <0x1000000>;
			buf-addr-max = <0xffffffff>;
			buf-length = <0x380000>;
			nr-max-core = <8>;
			nr-big-core = <4>;
			nr-rs-entry-little = <16>;
			nr-rs-entry-big = <32>;
			nr-header-row = <4>;
			chip-id-offset = <0x38>;
			check-pattern-offset = <0x20>;
			bypass-check-dfd-status = <1>; /* This property allows bypassing DFD status check */
			dfd-disable-efuse = <25 22>;
			/* dfd-disable-efuse = <(-1) (-1)>; */
			efuse-sec-ctrl = <27 0 6>;
			dfd_cache: dfd-cache {
				enabled = <1>;
				/* dfd-timeout = <0x3a980>; */ /* 120 sec for full cache dump */
				/* dfd-timeout = <0x1d4c0>; */ /* 60 sec for full cache dump */
				dfd-timeout = <0xc000>; /* 24.6 sec */
				/* buf-length = <0x2000000>; */ /* for full cache dump */
				buf-length = <0x380000>;
				tap-en = <0x0>; /* for all SRAM dump */
				/* tap-en = <0x0f1fffff>; *//* for all SRAM dump */
				tap-en2 = <0x000000f0>; /* for CPU EB_mst/slv/dfd_log and GIC SRAM dump */
			};
		};

		lkg: lkg@51c1400 {
			compatible = "mediatek,mtk-lkg";
			reg = <0 0x051c1400 0 0xc00>;
		};

		performance: performance-controller@51c0010 {
			compatible = "mediatek,cpufreq-hw";
			reg = <0 0x051c0010 0 0x120>,
					<0 0x051c0130 0 0x120>,
					<0 0x051c0250 0 0x120>;
			reg-names = "performance-domain0",
						"performance-domain1",
						"performance-domain2";
			#performance-domain-cells = <1>;
		};

		csram_sys: csram-sysram@11bc00 {
			reg = <0 0x0011bc00 0 0x1400>; /* 5KB */
		};

		curve_adj: curve-adjust@51c5838 {
			reg = <0 0x051c5838 0 0x280>;
		};

		apdma: dma-controller@16520000 {
			compatible = "mediatek,mt6985-uart-dma";
			reg = <0 0x16520000 0 0x80>,
				<0 0x16520080 0 0x80>,
				<0 0x16530000 0 0x80>,
				<0 0x16530080 0 0x80>,
				<0 0x16540000 0 0x80>,
				<0 0x16540080 0 0x80>,
				<0 0x16550000 0 0x80>,
				<0 0x16550080 0 0x80>;
			interrupts =    <GIC_SPI 314 IRQ_TYPE_LEVEL_HIGH 0>,
					<GIC_SPI 315 IRQ_TYPE_LEVEL_HIGH 0>,
					<GIC_SPI 551 IRQ_TYPE_LEVEL_HIGH 0>,
					<GIC_SPI 552 IRQ_TYPE_LEVEL_HIGH 0>,
					<GIC_SPI 553 IRQ_TYPE_LEVEL_HIGH 0>,
					<GIC_SPI 554 IRQ_TYPE_LEVEL_HIGH 0>,
					<GIC_SPI 555 IRQ_TYPE_LEVEL_HIGH 0>,
					<GIC_SPI 556 IRQ_TYPE_LEVEL_HIGH 0>;
			clocks = <&pericfg_ao_clk PERAO_U_AP_DMA_X32W_BCLK_UART>;
			clock-names = "apdma";
			dma-requests = <8>;
			support-hub = <0xc0>;  /*bit 0~7 to ch 0~7*/
			#dma-cells = <1>;
			wakeup-irq-support = <1>;
		};

		ccu_rproc: ccu_rproc@3c080000 {
			#address-cells = <2>;
			#size-cells = <2>;
			compatible = "mediatek,ccu_rproc";
			reg = <0 0x3c080000 0 0x4000>;
			interrupts = <GIC_SPI 665 IRQ_TYPE_LEVEL_HIGH 0>;
			mediatek,larbs = <&smi_larb30>;
			clocks =
				<&mm_pd_clk CLK_PD_CAM_VCORE_CAM_VCORE>,
				<&mm_pd_clk CLK_PD_CAM_MAIN_CAM_MAIN>,
				<&mm_pd_clk CLK_PD_CAM_CCU_CCU>,
				<&cksys_mm_clk CKSYS_MM_CCUSYS_SEL>,
				<&cksys_mm_clk CKSYS_MM_CCUTM_SEL>,
				<&ccu_main_clk CCU2MM0_GALS_CON_CCU>,
				<&ccu_main_clk CCU_LARB19_CON_CCU>,
				<&ccu_main_clk CCU2INFRA_GALS_CON_CCU>,
				<&ccu_main_clk CCUSYS_CCU0_CON_CCU>,
				<&cam_main_r1a_clk CAM_M_CAM_CAM_MAIN>,
				<&cam_vcore_r1a_clk CAM_V_R1A_26M_CAM_VCORE>,
				<&cam_vcore_r1a_clk CAM_V_R1A_SUB_COMM1_CAM_VCORE>,
				<&cam_vcore_r1a_clk CAM_V_R1A_X60_GALS_CAM_VCORE>,
				<&cam_vcore_r1a_clk CAM_V_R1A_X90_GALS_CAM_VCORE>,
				<&cam_vcore_r1a_clk CAM_V_R1A_TX90_GALS_CAM_VCORE>,
				<&cam_vcore_r1a_clk CAM_V_R1A_TX13_GALS_CAM_VCORE>;
			clock-names =
				"PD_CAM_VCORE",
				"PD_CAM_MAIN",
				"PD_CCU",
				"MM_CCUSYS",
				"MM_CCUTM",
				"CCU2MM0_GALS",
				"CCU_LARB",
				"CCU_INFRA",
				"CCUSYS_CCU0",
				"CAM_MAIN",
				"VCORE_26M",
				"VCORE_SUBCOMM1",
				"VCORE_X60_GAL",
				"VCORE_X90_GAL",
				"VCORE_TX90_GAL",
				"VCORE_TX13_GAL";
			mediatek,ccu_rproc1 = <&ccu_rproc1>;
			mtk,smmu-shared = <&mm_smmu_ccu_inst>;
			mmqos-supply = <&mmqos>;
			interconnects =
			<&mmqos MASTER_LARB_PORT(SMMU_L30_P1_CAM_TOP_0_CCUO)
				&mmqos SLAVE_COMMON(0)>,
			<&mmqos MASTER_LARB_PORT(SMMU_L30_P0_CAM_TOP_0_CCUI)
				&mmqos SLAVE_COMMON(0)>;
			interconnect-names =
				"ccu_o",
				"ccu_i";
			secured = "yes";
			ccu_version = <82>;
			ccu_sramSize = <0x00010000>;
			ccu_sramOffset = <0x00040000>;
			ccu_dramSize = <0x00200000>;
			ccu_dramAddr = <0xc0000000>;
			ccu_emiRegion = <20>;
			ccu-exch-base = <0x3c0b0000>;
			systick-freq = <1000000000>;
			ccu-cores = <1>;
			compact-ipc = <0>;
			ccu-mbext = <1>;
			ccu-mbext-int = <0>;
		};

		ccu_rproc1: ccu_rproc1@3c180000 {
			#address-cells = <2>;
			#size-cells = <2>;
			compatible = "mediatek,ccu_rproc1";
			reg = <0 0x3c180000 0 0x4000>;
			mtk,smmu-shared = <&mm_smmu_ccu_data_protected>;
			mmqos-supply = <&mmqos>;
			interconnects =
			<&mmqos MASTER_LARB_PORT(SMMU_L30_P3_CAM_TOP_1_CCUO)
				&mmqos SLAVE_COMMON(0)>,
			<&mmqos MASTER_LARB_PORT(SMMU_L30_P2_CAM_TOP_1_CCUI)
				&mmqos SLAVE_COMMON(0)>;
			interconnect-names =
				"ccu_o",
				"ccu_i";
			ccu-exch-base = <0x3c1b0000>;
			systick-freq = <1000000000>;
			ccu-cores = <1>;
			compact-ipc = <0>;
		};

		uart0: serial@16000000 {
			compatible = "mediatek,mt6577-uart";
			reg = <0 0x16000000 0 0x1000>;
			interrupts = <GIC_SPI 325 IRQ_TYPE_LEVEL_HIGH 0>;
			clocks = <&clk26m>, <&pericfg_ao_clk PERAO_U_UART0_BCLK_UART>;
			clock-names = "baud", "bus";
			dmas = <&apdma 0 &apdma 1>;
			dma-names = "tx", "rx";
			uart-line = <0>;
		};

		uart1: serial@16010000 {
			compatible = "mediatek,mt6577-uart";
			reg = <0 0x16010000 0 0x1000>;
			interrupts = <GIC_SPI 326 IRQ_TYPE_LEVEL_HIGH 0>;
			clocks = <&clk26m>, <&pericfg_ao_clk PERAO_U_UART1_BCLK_UART>;
			clock-names = "baud", "bus";
			dmas = <&apdma 2 &apdma 3>;
			dma-names = "tx", "rx";
			uart-line = <1>;
		};

		uart2: serial@16020000 {
			compatible = "mediatek,mt6577-uart";
			reg = <0 0x16020000 0 0x1000>;
			interrupts = <GIC_SPI 327 IRQ_TYPE_LEVEL_HIGH 0>;
			clocks = <&clk26m>, <&pericfg_ao_clk PERAO_U_UART2_BCLK_UART>;
			clock-names = "baud", "bus";
			dmas = <&apdma 4 &apdma 5>;
			dma-names = "tx", "rx";
			uart-line = <2>;
		};

		uart3: serial@16030000 {
			compatible = "mediatek,mt6985-uart";
			reg = <0 0x16030000 0 0x1000>;
			interrupts = <GIC_SPI 328 IRQ_TYPE_LEVEL_HIGH 0>,
					<GIC_SPI 582 IRQ_TYPE_LEVEL_HIGH 0>;    /*uart3 wakeup irq*/
			clocks = <&clk208m>, <&pericfg_ao_clk PERAO_U_UART3_BCLK_UART>;
			clock-names = "baud", "bus";
			dmas = <&apdma 6 &apdma 7>;
			dma-names = "tx", "rx";
			peri-clock-con = <0x16640020 0xf 0x8>;    /*UART ClOCK SEL*/
			peri-wakeup = <0x16640050 0x2 0x2 0x1>;   /*reg* mask* val* toggal*/
			peri-wakeup-sta = <0x16640054>;
			peri-reset = <0x16640000>;
			peri-reset-set = <0x16640004 0x400000 0x400000>;	/*reg* mask* val*/
			peri-reset-clr = <0x16640008 0x400000 0x400000>;	/*reg* mask* val*/
			uart-line = <3>;
			hub-baud = <24000000>;
			wakeup-irq-support = <1>;
			rtff-support = <1>;
		};

		i2c0: i2c@12950000 {
			compatible = "mediatek,mt6991-i2c";
			reg = <0 0x12950000 0 0x20000>,
				<0 0x16370000 0 0x10000>;
			interrupts = <GIC_SPI 373 IRQ_TYPE_LEVEL_HIGH 0>;
			clocks = <&imp_iic_wrap_s_clk IMPS_I2C0_I2C>,
				<&pericfg_ao_clk PERAO_U_AP_DMA_X32W_BCLK_I2C>;
			clock-names = "main", "dma";
			i2c-clock-info = <0x129d0e00 0x1>;    /* *reg*  *value* */
			clock-div = <1>;
			scl-gpio-id = <112>;
			sda-gpio-id = <113>;
		};

		i2c1: i2c@13950000 {
			compatible = "mediatek,mt6991-i2c";
			reg = <0 0x13950000 0 0x80000>,
				<0 0x16380000 0 0x10000>;
			interrupts = <GIC_SPI 374 IRQ_TYPE_LEVEL_HIGH 0>;
			clocks = <&imp_iic_wrap_n_clk IMPN_I2C1_I2C>,
				<&pericfg_ao_clk PERAO_U_AP_DMA_X32W_BCLK_I2C>;
			clock-names = "main", "dma";
			i2c-clock-info = <0x13a50e00 0x1>;    /* *reg*  *value* */
			clock-div = <1>;
			scl-gpio-id = <196>;
			sda-gpio-id = <197>;
		};

		i2c2: i2c@123d0000 {
			compatible = "mediatek,mt6991-i2c";
			reg = <0 0x123d0000 0 0x80000>,
				<0 0x16390000 0 0x30000>;
			interrupts = <GIC_SPI 375 IRQ_TYPE_LEVEL_HIGH 0>;
			clocks = <&imp_iic_wrap_e_clk IMPE_I2C2_I2C>,
				<&pericfg_ao_clk PERAO_U_AP_DMA_X32W_BCLK_I2C>;
			clock-names = "main", "dma";
			i2c-clock-info = <0x12650e00 0x2>;    /* *reg*  *value* */
			clock-div = <1>;
			scl-gpio-id = <172>;
			sda-gpio-id = <173>;
		};

		i2c3: i2c@12970000 {
			compatible = "mediatek,mt6991-i2c";
			reg = <0 0x12970000 0 0x20000>,
				<0 0x163c0000 0 0x10000>;
			interrupts = <GIC_SPI 376 IRQ_TYPE_LEVEL_HIGH 0>;
			clocks = <&imp_iic_wrap_s_clk IMPS_I2C3_I2C>,
				<&pericfg_ao_clk PERAO_U_AP_DMA_X32W_BCLK_I2C>;
			clock-names = "main", "dma";
			i2c-clock-info = <0x129d0e00 0x2>;    /* *reg*  *value* */
			clock-div = <1>;
			scl-gpio-id = <70>;
			sda-gpio-id = <71>;
		};

		i2c4: i2c@12450000 {
			compatible = "mediatek,mt6991-i2c";
			reg = <0 0x12450000 0 0x80000>,
				<0 0x163d0000 0 0x30000>;
			interrupts = <GIC_SPI 377 IRQ_TYPE_LEVEL_HIGH 0>;
			clocks = <&imp_iic_wrap_e_clk IMPE_I2C4_I2C>,
				<&pericfg_ao_clk PERAO_U_AP_DMA_X32W_BCLK_I2C>;
			clock-names = "main", "dma";
			i2c-clock-info = <0x12650e00 0x4>;    /* *reg*  *value* */
			clock-div = <1>;
			scl-gpio-id = <174>;
			sda-gpio-id = <175>;
		};

		i2c5: i2c@12350000 {
			compatible = "mediatek,mt6991-i2c";
			reg = <0 0x12350000 0 0x80000>,
				<0 0x16400000 0 0x10000>;
			interrupts = <GIC_SPI 378 IRQ_TYPE_LEVEL_HIGH 0>;
			clocks = <&imp_iic_wrap_e_clk IMPE_I2C5_I2C>,
				<&pericfg_ao_clk PERAO_U_AP_DMA_X32W_BCLK_I2C>;
			clock-names = "main", "dma";
			i2c-clock-info = <0x12650e00 0x1>;    /* *reg*  *value* */
			clock-div = <1>;
			scl-gpio-id = <178>;
			sda-gpio-id = <179>;
		};

		i2c6: i2c@12990000 {
			compatible = "mediatek,mt6991-i2c";
			reg = <0 0x12990000 0 0x20000>,
				<0 0x16410000 0 0x10000>;
			interrupts = <GIC_SPI 379 IRQ_TYPE_LEVEL_HIGH 0>;
			clocks = <&imp_iic_wrap_s_clk IMPS_I2C6_I2C>,
				<&pericfg_ao_clk PERAO_U_AP_DMA_X32W_BCLK_I2C>;
			clock-names = "main", "dma";
			i2c-clock-info = <0x129d0e00 0x4>;    /* *reg*  *value* */
			clock-div = <1>;
			#address-cells = <1>;
			#size-cells = <0>;
			scl-gpio-id = <114>;
			sda-gpio-id = <115>;
		};

		i2c7: i2c@124d0000 {
			compatible = "mediatek,mt6991-i2c";
			reg = <0 0x124d0000 0 0x80000>,
				<0 0x16420000 0 0x30000>;
			interrupts = <GIC_SPI 380 IRQ_TYPE_LEVEL_HIGH 0>;
			clocks = <&imp_iic_wrap_e_clk IMPE_I2C7_I2C>,
				<&pericfg_ao_clk PERAO_U_AP_DMA_X32W_BCLK_I2C>;
			clock-names = "main", "dma";

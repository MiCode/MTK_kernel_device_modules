		disp_oddmr0: disp-oddmr0@3e410000 {
			compatible = "mediatek,disp_oddmr0",
				"mediatek,mt6993-disp-oddmr";
			reg = <0 0x3e410000 0 0x20000>;
			clocks = <&dispsys_config_clk MM0_DISP_ODDMR0_DISP>;
			// dmr od dbi
			mediatek,oddmr-slc = <1 0 1>;
			mediatek,oddmr-slc-gid = <68 69 70>;
			mediatek,larb-oddmr-dmrr = <0>;
			mediatek,larb-oddmr-dbir = <1>;
			mediatek,larb-oddmr-odr = <2>;
			mediatek,larb-oddmr-odw = <3>;
			mediatek,larb-oddmr-dmrr-stash = <4>;
			mediatek,larb-oddmr-dbir-stash = <5>;
			mediatek,larb-oddmr-odr-stash = <6>;
			mediatek,larb-oddmr-odw-stash = <7>;
			mediatek,larb = <&smi_larb32 SMMU_L32_P2_DISP_ODDMR0_DMRR>,
					<&smi_larb32 SMMU_L32_P3_DISP_ODDMR0_DBIR>,
					<&smi_larb32 SMMU_L32_P4_DISP_ODDMR0_ODR>,
					<&smi_larb32 SMMU_L32_P5_DISP_ODDMR0_ODW>,
					<&smi_larb32 SMMU_L32_P7_DISP_ODDMR0_DMRR_STASH>,
					<&smi_larb32 SMMU_L32_P8_DISP_ODDMR0_DBIR_STASH>,
					<&smi_larb32 SMMU_L32_P9_DISP_ODDMR0_ODR_STASH>,
					<&smi_larb32 SMMU_L32_P10_DISP_ODDMR0_ODW_STASH>;
			mtk,smmu-shared = <&mm_smmu_disp>;
			interconnects =
				<&mmqos MASTER_LARB_PORT(SMMU_L32_P2_DISP_ODDMR0_DMRR)
						&mmqos SLAVE_COMMON(1)>,
				<&mmqos MASTER_LARB_PORT(SMMU_L32_P3_DISP_ODDMR0_DBIR)
						&mmqos SLAVE_COMMON(1)>,
				<&mmqos MASTER_LARB_PORT(SMMU_L32_P4_DISP_ODDMR0_ODR)
						&mmqos SLAVE_COMMON(1)>,
				<&mmqos MASTER_LARB_PORT(SMMU_L32_P5_DISP_ODDMR0_ODW)
						&mmqos SLAVE_COMMON(1)>,
				<&mmqos MASTER_LARB_PORT(SMMU_L32_P2_DISP_ODDMR0_DMRR)
						&mmqos SLAVE_COMMON(1)>,
				<&mmqos MASTER_LARB_PORT(SMMU_L32_P3_DISP_ODDMR0_DBIR)
						&mmqos SLAVE_COMMON(1)>,
				<&mmqos MASTER_LARB_PORT(SMMU_L32_P4_DISP_ODDMR0_ODR)
						&mmqos SLAVE_COMMON(1)>,
				<&mmqos MASTER_LARB_PORT(SMMU_L32_P5_DISP_ODDMR0_ODW)
						&mmqos SLAVE_COMMON(1)>,
				<&mmqos MASTER_LARB_PORT(SMMU_L32_P7_DISP_ODDMR0_DMRR_STASH)
						&mmqos SLAVE_COMMON(1)>,
				<&mmqos MASTER_LARB_PORT(SMMU_L32_P8_DISP_ODDMR0_DBIR_STASH)
						&mmqos SLAVE_COMMON(1)>,
				<&mmqos MASTER_LARB_PORT(SMMU_L32_P9_DISP_ODDMR0_ODR_STASH)
						&mmqos SLAVE_COMMON(1)>,
				<&mmqos MASTER_LARB_PORT(SMMU_L32_P10_DISP_ODDMR0_ODW_STASH)
						&mmqos SLAVE_COMMON(1)>;
			interconnect-names = "DDP_COMPONENT_ODDMR0_DMRR",
						"DDP_COMPONENT_ODDMR0_DBIR",
						"DDP_COMPONENT_ODDMR0_ODR",
						"DDP_COMPONENT_ODDMR0_ODW",
						"DDP_COMPONENT_ODDMR0_DMRR_HRT",
						"DDP_COMPONENT_ODDMR0_DBIR_HRT",
						"DDP_COMPONENT_ODDMR0_ODR_HRT",
						"DDP_COMPONENT_ODDMR0_ODW_HRT",
						"DDP_COMPONENT_ODDMR0_DMRR_STASH",
						"DDP_COMPONENT_ODDMR0_DBIR_STASH",
						"DDP_COMPONENT_ODDMR0_ODR_STASH",
						"DDP_COMPONENT_ODDMR0_ODW_STASH";
		};


		low_battery_throttling: low-battery-throttling {
			compatible = "mediatek,low_battery_throttling";
			lvsys-thd-enable = <1>;
			vbat-thd-enable = <0>;
			lbat-max-tb-num = <3>;
			bat0-thd-volts-tb0-l = <
				3200 3100 3000
				3100 3000 2500
				3100 3000 2500
				3100 3000 2500>;
			bat0-thd-volts-tb0-h = <
				3300 3200 3100
				3200 3100 3000
				3200 3100 3000
				3200 3100 3000>;
			bat0-thd-volts-tb1-l = <
				3290 3210 3060
				3360 3210 3060

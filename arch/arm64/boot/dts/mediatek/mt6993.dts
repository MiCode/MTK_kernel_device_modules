	vdisp_ctrl: vdisp-ctrl@0 {
		compatible = "mediatek,mt6993-vdisp-ctrl-v3";
		drm-supply = <&dispsys_config>;
		pwr-handle = <&disp_pwr_dev>;
		bringup-stage = <0>;
		disp-pd-id = <0>;
		operating-points-v2 = <&opp_table_disp>, <&opp_table_disp_b0>;
		clocks =
			<&mmdvfs_mux MMDVFS_USER_DISP>;
		clock-names =
			"mmdvfs_clk";
		mmdvfs-clock-names = "mmdvfs_clk";
		#clock-cells = <1>;
		reg =
			<0 0x3ee00400 0 0x4>,             /* VDISP_AO_DUMMY0 */
			<0 0x3eb00000 0 0x114>;           /* AGING_BASE */
		reg-names =
			"vdisp_ao_dummy",
			"aging_base";
		mediatek,vcp-supply = <&vcp>;
		nvmem-cells = <&vdisp_efuse0 &vdisp_efuse1 &vdisp_efuse2
			&vdisp_efuse3 &vdisp_efuse4>;
		nvmem-cell-names =
			"vdisp-data0", "vdisp-data1", "vdisp-data2",
			"vdisp-data3", "vdisp-data4";
	};

	efuse: efuse@10160000 {
		compatible = "mediatek,devinfo";
		#address-cells = <1>;
		#size-cells = <1>;

		u3_phy_data1: u3-phy-data1@1b8 {
			reg = <0x1b8 0x4>;
		};

		u3_phy_data2: u3-phy-data2@1bc {
			reg = <0x1bc 0x4>;
		};

		u3_phy_data3: u3-phy-data3@1c0 {
			reg = <0x1c0 0x4>;
		};

		u3_phy_data4: u3-phy-data4@1c4 {
			reg = <0x1c4 0x4>;
		};

		u2_phy_data1: u2-phy-data1@1cc {
			reg = <0x1cc 0x4>;
		};

		lvts_e_data1: data1@338 {
			reg = <0x338 0x10>;
		};

		lvts_e_data2: data2@2d4 {
			reg = <0x2d4 0x1c>;
		};

		lvts_e_data3: data3@300 {
			reg = <0x300 0x4>;
		};

		lvts_e_data4: data4@2f0 {
			reg = <0x2f0 0xc>;
		};

		lvts_e_data5: data5@364 {
			reg = <0x364 0x4>;
		};

		lvts_e_data6: data6@2fc {
			reg = <0x2fc 0x4>;
		};

		lvts_e_data7: data7@308 {
			reg = <0x308 0x8>;
		};

		lvts_e_data8: data8@350 {
			reg = <0x350 0x14>;
		};
		lvts_e_data9: data8@43c {
			reg = <0x43c 0x8>;
		};

		csi_efuse0: csi-data0@1d0 {
			reg = <0x1d0 0x4>;
		};
		csi_efuse1: csi-data1@1d4 {
			reg = <0x1d4 0x4>;
		};
		csi_efuse2: csi-data2@1d8 {
			reg = <0x1d8 0x4>;
		};
		csi_efuse3: csi-data3@1dc {
			reg = <0x1dc 0x4>;
		};
		csi_efuse4: csi-data4@140 {
			reg = <0x140 0x4>;
		};
		csi_efuse5: csi-data5@144 {
			reg = <0x144 0x4>;
		};

		pcie0_calibration: pcie0@154 {
			reg = <0x154 0x8>;
		};

		pcie1_calibration: pcie1@314 {
			reg = <0x314 0xc>;
		};

		pcie_efuse_version: pcie@234 {
			reg = <0x234 0x4>;
		};

		vdisp_efuse0: vdisp-data0@4c0 {
			reg = <0x4c0 0x4>;
		};
		vdisp_efuse1: vdisp-data1@4cc {
			reg = <0x4cc 0x4>;
		};
		vdisp_efuse2: vdisp-data2@4d0 {
			reg = <0x4d0 0x4>;
		};
		vdisp_efuse3: vdisp-data3@4d4 {
			reg = <0x4d4 0x4>;
		};
		vdisp_efuse4: vdisp-data4@4d8 {
			reg = <0x4d8 0x4>;
		};

		fab_info: fab-info@c8 {
			reg = <0xc8 0x4>;
		};

		efuse_segment: segment@78 {
			reg = <0x78 0x4>;
		};

		isp_efuse_data: isp-efuse-data@23c {
			reg = <0x23c 0x4>;
		};
	};

	cpuhvfs: cpuhvfs@51c1400 {
		compatible = "mediatek,cpufreq-hybrid";
		reg = <0 0x051c1400 0 0xc00>,
			<0 0x051c0000 0 0x1400>,
			<0 0x051c37b8 0 0x800>,
			<0 0x051c1f40 0 0xc0>;
		reg-names = "USRAM", "CSRAM", "ESRAM";
		cslog-range = <0x03d0>, <0x0fa0>;
		tbl-off = <4>, <76>, <148>, <220>;

		/* csram sysram base */
		csram-sys-base = <&csram_sys>;

		/* curve adjustment */
		curve-adj-base = <&curve_adj>;

		/* wl support */
		// wl-support = <1>;

		/* leakage info */
		// nvmem-cells = <&lkginfo>;
		// nvmem-cell-names = "lkginfo";
	};

	pf_ctrl: pf-ctrl {
		compatible = "mediatek,pf-ctrl";
		version = <1>;
	};

	eas_info: eas-info {
		compatible = "mediatek,eas-info";
		csram-base = <0x051c0000>;
		share-buck = <2>;
		/* EAS_5_5 : 550, EAS_5_5_1 : 551, EAS_6_1 : 600, EAS_6_5 : 650, EAS_6_12 : 612 */
		version = <612>;
	};

	vip_engine: vip-engine {
		compatible = "mediatek,vip-engine";
		vip-enable = <1>;
	};

	perf_tracker_info: perf-tracker-info {
		compatible = "mediatek,perf-tracker-info";
		/* C, E, U F, U V */
		cdfv-tcm-base = <0x051c0000>;
		cdfv-tcm-base-len = <0x1400>;
		u-tcm-base = <0x05390620>;
		u-tcm-base-len = <0xa4>;
		stall-tcm-base = <0x053927c0>;
		stall-tcm-base-len = <0x20>;
		u-affo = <0x94>;
		u-bmonio = <0x30>;
		u-uffo = <0x484>;
		u-ucfo = <0x480>;
		cpu-stall-ratio-offset = <0x0>;
		perf-tracker-status-offset = <0x12e0>;
		u-volt-3-cluster = <0x514>;
		is-percore-need-to-check = <1>;
	};


	flt: flt@539d850 {
		compatible = "mediatek,flt";
		reg = <0 0x539d850 0 0x6d0>;
		mode = <4>;
		version = <0x1000>;
	};

	dfg_info: dfg-info@539283c {
		compatible = "mediatek,dfg-info";
		dfg-support = <1>;
		reg = <0 0x0539283c 0 0x1>, /*tcm sram base, get value from EB*/
			<0 0x0539283d 0 0x1>, /*get value from EB BCPU*/
			<0 0x0539283e 0 0x1>, /*get value from EB MCPU*/
			<0 0x0539283f 0 0x1>, /*get value from EB LCPU*/
			<0 0x05392840 0 0x1>; /*tcm sram base, pass value to EB*/

		reg-names = "dfg_sram_base",
			"dfg_bcpu_base",
			"dfg_mcpu_base",
			"dfg_lcpu_base",
			"dfg_crtl_base";
	};

	cmep: cmep@5392827 {
		compatible = "mediatek,cmep";
		reg = <0 0x5392827 0 0x1>, /*low battery status*/
			<0 0x539285c 0 0x4>; /*SWPT freq limit BCPU*/
	};

	nfc:nfc {
	};

	subpmic_pmu_eint: subpmic-pmu-eint {

	};

	mgm: mgm {
		compatible = "arm,physical-memory-group-manager";
	};

	aod_scp: aod-scp {
		compatible = "mediatek,aod_scp";
		status = "disabled";
		aod-scp-pic = <1>; /* prepare digit raw data for MTK internal use */
		aod-scp-mem-tbl = <15 0x4010000 0x1000>; /* replace {scp/scp-mem-tbl/#aod} */

		/* backup modules*/
		dsi0 = <&dsi0 0x1000>;
		dsc0 = <&disp_dsc_wrap0 0x1000>;
		mipitx0 = <&mipi_tx_config0 0x1000>;
		spr0 = <&disp_spr0 0x1000>;
		oddmr0 = <&disp_oddmr0 0x2000>;
	};

	aiste: aiste {
		compatible = "mediatek,aiste";
	};

	ged: ged {
		compatible = "mediatek,ged";
                gpufreq-supply = <&gpufreq>;
	};

	rt5133_eint: rt5133-eint {
	};

	gpufreq_wrapper: gpufreq-wrapper {
			compatible = "mediatek,gpufreq_wrapper";
			gpufreq-version = <2>;
			dual-buck = <1>;
			gpueb-support = <1>;
			gpufreq-bringup = <0>;
			ghpm-supply = <&ghpm>;
	};

	gpupdma: gpupdma@48540000 {
		compatible = "mediatek,gpupdma";
		reg =
			<0 0x48540000 0 0x1000>,
			<0 0x48540000 0 0x2000>,
			<0 0x48543000 0 0x100>,
			<0 0x4b808530 0 0x10>,
			<0 0x4b808100 0 0x10>,
			<0 0x124860 0 0x48>;
		ringbuf-page-order = <2>;
		config-mode = <1>;
		concurrent-contexts = /bits/ 8 <0x4>;
		extended-pbha-bits = /bits/ 8 <0x8>;
	};

	connscp: connscp {
		compatible = "mediatek,mt6993-conn_scp";

		/* batching */
		report-region-idx = <3>;
		report-buf-addr = <0>;
		report-buf-size = <0>;
		batch-region-idx = <9>;

		ipi-mbox-size = <64>;

		/* dfd */
		dfd-region-idx = <4>;
		dfd-cmd-addr = <0>;
		dfd-cmd-size = <0>;
		dfd-value-addr = <0>;
		dfd-value-size = <0>;
		dfd-value-region-size = <0x3000>;
	};

	connsys_emi_config: connsys-emi-config {
		/* emi layout settings */
		emi-alignment = <0x1000000>;
		emi-min-addr = <0x80000000>;
		emi-max-addr = <0xf0000000>;

		/* EMI Layout */
		/* idx - region size */
		emi-layout-region =
			<0 0x00c00000>, /* 6653 WiFi MCU */
			<1 0x003c0000>, /* Connsys RO */
			<2 0x00085000>, /* Connsys RW */
			<3 0x0004b000>, /* SCP batching data */
			<4 0x00012000>, /* SCP DFD dump */
			<5 0x0000e000>, /* Reserved for alignment */
			<6 0x00040000>, /* Connsys shared data */
			<7 0x00140000>, /* GPS_EMI */
			<8 0x002fa000>, /* MNL/MPE BIN data */
			<9 0x000d6000>, /* Connsys/SCP shared */
			<10 0x00100000>, /* WF MISC */
			<11 0x01900000>; /* WFDMA1 */

		/* block_name start_idx end_idx mapping */
		emi-alloc-block =
			<0 0 0>,
			<1 9 0>,
			<10 10 0>,
			<11 11 0>;

		emi-alloc-block-name =
			"consys_wifi_emi",
			"consys_emi",
			"shared-dma-pool_wifi-misc-reserve-memory_dma",
			"shared-dma-pool_wifi-reserve-memory_dma";

		/* mpu region */
		/* start_idx end_idx MPU_id */
		emi-mpu-region =
			<0 0 62>,
			<1 1 44>,
			<2 5 45>,
			<6 11 47>,
			<8 9 46>;

		/* emi region to atf: start_idx end_idx */
		emi-region-to-atf = <1 7>;
		gps-emi-to-atf = <7 7>;
	};

	connv3: connv3 {
		compatible = "mediatek,mt6993-connv3";
		/* BT, WIFI, GPS, FM */
		radio-support = "wifi", "bt", "md";
		/* radio-off-mode: 0 means turn off pmic when all radio off */
		radio-off-mode = <0>;
		co-clock = <0>;
		ext-32k-ticks = <32768>;
		/* pmic-uvlo-level: 0: skip, 1: 2.0V, 2: 2.1V, 3: 2.2V */
		pmic-uvlo-level = <1>;
		/* pmic-rising-uvlo-level: 0: skip, 1: 2.6V, 2: 2.7V, ..., 8: 3.3V */
		pmic-rising-uvlo-level = <1>;
		pinctrl-names = "connsys-pin-pmic-en-default",
			"connsys-pin-pmic-en-set",
			"connsys-pin-pmic-en-clr",
			"connsys-pin-pmic-faultb-default",
			"connsys-pin-pmic-faultb-enable",
			"connsys-combo-gpio-init",
			"connsys-combo-gpio-pre-on",
			"connsys-combo-gpio-on",
			"connsys-pin-dfd-init",
			"connsys-pin-dfd-trigger",
			"connsys-pin-dfd-release",
			"connsys-pin-por-reset-trigger",
			"connsys-pin-por-reset-done";
		pinctrl-0 = <&connsys_pin_pmic_en_default>;
		pinctrl-1 = <&connsys_pin_pmic_en_set>;
		pinctrl-2 = <&connsys_pin_pmic_en_clr>;
		pinctrl-3 = <&connsys_pin_pmic_faultb_default>;
		pinctrl-4 = <&connsys_pin_pmic_faultb_enable>;
		pinctrl-5 = <&connsys_combo_gpio_init>;
		pinctrl-6 = <&connsys_combo_gpio_pre_on>;
		pinctrl-7 = <&connsys_combo_gpio_on>;
		pinctrl-8 = <&connsys_pin_dfd_init>;
		pinctrl-9 = <&connsys_pin_dfd_trigger>;
		pinctrl-10 = <&connsys_pin_dfd_release>;
		pinctrl-11 = <&connsys_pin_por_reset_trigger>;
		pinctrl-12 = <&connsys_pin_por_reset_done>;
		interrupt-parent = <&pio>;
		mt6376-gpio = <&pio 65 0>,
				<&pio 251 0>;
		interrupts = <65 IRQ_TYPE_EDGE_FALLING>;
		io-channels = <&mt6661_6_auxadc (ADC_PURES_OPEN_MASK | AUXADC_AGPIO3)>;
		io-channel-names = "mt6661_6_aio3";
	};

	mtk_leds: mtk-leds {
		compatible = "mediatek,i2c-leds";
		gate-ic-supply = <&gate_ic>;
		backlight {
			label = "lcd-backlight";
			max-brightness = <2047>;
			min-brightness = <4>;
			max-hw-brightness = <2047>;
			led-mode = <6>;
			gate-enable = <1>;
			pwm-config = <0 1 0 0 0>;
			reg-bat-percent-pt = <1>;
			bl-bat-pt-percent = <100 100 100 67 67 67>;
		};
	};

//slv0_tcm_base:0x05320000
//SLV_ADDR_WL:0x7E860
//SLV0_ADDR_WL :0x05320000+0x7E860=0x539e860
//MT6991 wlc reg = <0 0x0c2bf090 0 0x10>, /*tcm sram base*/
	wl_info: wl-info@539e860 {
		compatible = "mediatek,wl-info";
		wl-support = <1>;
		reg = <0 0x0539e860 0 0x10>, /*tcm sram base*/
			<0 0x051c2000 0 0x13b8>; /*tcm wl-base sram*/
		reg-names = "wl_sram_base",
			"wl_tbl_base";
	};

	dpt_info: dpt-info@538f820 {
		compatible = "mediatek,dpt-info";
		dpt-v2-support = <0>;
		reg = <0 0x538f820 0 0x5dc>;
	};

	collab_type_0: collab-type-0-info@5392828 {
		compatible = "mediatek,dpt-info";
		reg = <0 0x5392828 0 0x4>,
			<0 0x53927b8 0 0x4>,
			<0 0x51c12f4 0 0x8>,
			<0 0x51c12fc 0 0x8>,
			<0 0x53927c0 0 0x32>;
		reg-names = "COEF2_LTIME", "COEF1_LTIME", "COFE2_S", "COEF1_S", "CPU_S";
	};


	firmware: firmware {
		scmi: scmi {
			compatible = "arm,scmi";
			mboxes = <&tinysys_mbox 0>, <&tinysys_mbox 1>;
			shmem = <&scmi_tx_shmem>, <&scmi_rx_shmem>;
			mbox-names = "tx", "rx";
			#address-cells = <1>;
			#size-cells = <0>;

			scmi_tinysys: protocol@80 {
				reg = <0x80>;
				scmi-qos = <1>;
				scmi-dispplatdbg = <2>;
				scmi-met = <3>;
				scmi-apmcupm = <4>;
				scmi-mminfra = <5>;
				scmi-gpupm = <6>;
				scmi-plt = <7>;
				scmi-smi = <8>;
				scmi-cm = <9>;
				scmi-slbc = <10>;
				scmi-ssc = <11>;
				scmi-ise = <12>;
				scmi-spbm = <13>;
				scmi-aiste = <14>;
			};
		};

		android: android {
			compatible = "android,firmware";
			hardware = "mt6993";
		};
	};

	mcupm: mcupm {
		compatible = "mediatek,mcupms_v0";
		#address-cells = <2>;
		#size-cells = <2>;
		ranges;

		mcupm-mst-mbox@5160000 {
			device_type = "mcupm_mbox";
			enabled = <1>;
			reg = <0 0x051cf600 0 0xa00>,
					<0 0x05166004 0 0x4>,
					<0 0x05166018 0 0x4>,
					<0 0x05166000 0 0x4>,
					<0 0x05166010 0 0x4>;
			reg-names = "mbox_base",
						"mbox_set",
						"mbox_clr",
						"mbox_send",
						"mbox_recv";

			interrupts = <GIC_SPI 70 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 71 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 72 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 73 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 74 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 75 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 76 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 77 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 78 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 79 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 80 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 81 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 82 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 83 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 84 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 85 IRQ_TYPE_LEVEL_HIGH 0>;
			interrupt-names = "mbox0",
						  "mbox1",
						  "mbox2",
						  "mbox3",
						  "mbox4",
						  "mbox5",
						  "mbox6",
						  "mbox7",
						  "mbox8",
						  "mbox9",
						  "mbox10",
						  "mbox11",
						  "mbox12",
						  "mbox13",
						  "mbox14",
						  "mbox15";

			/* chan_id, pin_id, send_size, offset */
			send-table =
				<0 0 4 0>, /* PLATFORM */
				<1 1 4 0>,
				<2 2 9 0>,
				<3 3 3 0>,
				<4 4 3 0>,
				<5 5 1 0>,
				<6 6 4 0>,
				<7 7 4 0>,
				<8 8 4 0>,
				<9 9 4 0>,
				<10 10 4 0>,
				<11 11 4 0>,
				<12 12 4 0>,
				<13 13 4 0>,
				<14 14 4 0>,
				<15 15 4 0>;

			/* chan_id, pin_id, recv_size, recv_opt, cb_ctx_opt, offset */
			recv-table =
				<0 0 1 0 0 20>, /* PLATFORM */
				<1 1 4 0 0 20>,
				<2 2 1 0 0 20>,
				<3 3 1 0 0 20>,
				<4 4 1 0 0 20>,
				<5 5 4 0 0 20>,
				<6 6 1 1 0 20>,
				<7 7 1 0 0 20>,
				<8 8 1 0 0 20>,
				<9 9 4 0 0 20>,
				<10 10 1 0 0 20>,
				<11 11 1 0 0 20>,
				<12 12 1 0 0 20>,
				<13 13 1 0 0 20>,
				<14 14 1 0 0 20>,
				<15 15 1 0 0 20>;
		};

		mcupm-slv0-mbox@5310000 {
			device_type = "mcupm_mbox";
			enabled = <1>;
			reg = <0 0x0539f600 0 0xa00>,
					<0 0x05316004 0 0x4>,
					<0 0x05316018 0 0x4>,
					<0 0x05316000 0 0x4>,
					<0 0x05316010 0 0x4>;
			reg-names = "mbox_base",
						"mbox_set",
						"mbox_clr",
						"mbox_send",
						"mbox_recv";

			interrupts = <GIC_SPI 87 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 88 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 89 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 90 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 91 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 92 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 93 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 94 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 95 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 96 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 97 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 98 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 99 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 100 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 101 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 102 IRQ_TYPE_LEVEL_HIGH 0>;
			interrupt-names = "mbox0",
						  "mbox1",
						  "mbox2",
						  "mbox3",
						  "mbox4",
						  "mbox5",
						  "mbox6",
						  "mbox7",
						  "mbox8",
						  "mbox9",
						  "mbox10",
						  "mbox11",
						  "mbox12",
						  "mbox13",
						  "mbox14",
						  "mbox15";

			/* chan_id, pin_id, send_size, offset */
			send-table =
				<0 0 4 0>, /* PLATFORM */
				<1 1 4 0>,
				<2 2 9 0>,
				<3 3 3 0>,
				<4 4 3 0>,
				<5 5 1 0>,
				<6 6 4 0>,
				<7 7 4 0>,
				<8 8 4 0>,
				<9 9 4 0>,
				<10 10 4 0>,
				<11 11 4 0>,
				<12 12 4 0>,
				<13 13 4 0>,
				<14 14 4 0>,
				<15 15 4 0>;

			/* chan_id, pin_id, recv_size, recv_opt, cb_ctx_opt, offset */
			recv-table =
				<0 0 1 0 0 20>, /* PLATFORM */
				<1 1 4 0 0 20>,
				<2 2 1 0 0 20>,
				<3 3 1 0 0 20>,
				<4 4 1 0 0 20>,
				<5 5 4 0 0 20>,
				<6 6 1 1 0 20>,
				<7 7 1 0 0 20>,
				<8 8 1 0 0 20>,
				<9 9 4 0 0 20>,
				<10 10 1 0 0 20>,
				<11 11 1 0 0 20>,
				<12 12 1 0 0 20>,
				<13 13 1 0 0 20>,
				<14 14 1 0 0 20>,
				<15 15 1 0 0 20>;
		};
	};

	cpuqos_v3: cpuqos-v3@5390620 {
		compatible = "mediatek,cpuqos-v3";
		reg = <0 0x05390620 0 0x400>;
		enable = <1>;
		ram-base = <2>;
	};

        sspm: sspm@1ce00000 {
		compatible = "mediatek,sspm";
		reg = <0 0x1ce00000 0 0x64000>,
			<0 0x1cf00000 0 0x10000>,
			<0 0x1cee0000 0 0x80>;

		reg-names = "sspm_base",
				"cfgreg",
				"mbox_share";

		interrupts = <GIC_SPI 574 IRQ_TYPE_LEVEL_HIGH 0>;

		interrupt-names = "ipc";
		sspm-res-ram-start = <0x0>;
		sspm-res-ram-size = <0x110000>; /* 1M + 64K, shared mem size*/
		/* mediatek,fake-sspm = <1>; */

		/*  reserved memory ID need to align sspm_resrvedmem_define.h */
		/* <reserved memory ID, size> */
		sspm-mem-tbl = <0 0x100100>, /* logger */
				<1 0x0>, /* pwarp */
				<2 0x0>, /* pmic */
				<3 0x1800>, /* upd */
				<4 0x1000>, /* qos */
				<5 0x2000>, /* swpm */
				<6 0x9000>, /* smi */
				<7 0x1000>, /* gpu */
				<8 0x1000>; /* slbc */

		sspm-share-region-base = <0x60000>; /* 384K */
		sspm-share-region-size = <0x3800>; /* 14K */
	};

	ssram1@1ceb0000 {
		compatible = "mmio-sram_1";
		reg = <0x0 0x1ceb0000 0x0 0x80>;

		#address-cells = <1>;
		#size-cells = <1>;
		ranges = <0 0x0 0x1ceb0000 0x80>;

		scmi_tx_shmem: tiny-mbox@0 {
			compatible = "arm,scmi-shmem";
			reg = <0x0 0x80>;
		};
	};

	ssram2@1cec0000 {
		compatible = "mmio-sram_2";
		reg = <0x0 0x1cec0000 0x0 0x80>;

		#address-cells = <1>;
		#size-cells = <1>;
		ranges = <0 0x0 0x1cec0000 0x80>;

		scmi_rx_shmem: tiny-mbox@1 {
			compatible = "arm,scmi-shmem";
			reg = <0x0 0x80>;
		};
	};

	tinysys_mbox: tinysys-mbox@1ceb1000 {
		compatible = "mediatek,tinysys_mbox";
		reg = <0 0x1ceb1000 0 0x1000>,
			  <0 0x1cec1000 0 0x1000>;
		/* for profiling */
		shmem = <&scmi_tx_shmem>, <&scmi_rx_shmem>;
		interrupts = <GIC_SPI 425 IRQ_TYPE_LEVEL_HIGH 0>,
			     <GIC_SPI 426 IRQ_TYPE_LEVEL_HIGH 0>;
		#mbox-cells = <1>;
		/* for secure mode */
		/* secure-sspm-mbox-clr = <1>; */
		secure-sspm-md2spm-clr = <1>;
	};

	sleep@1c004000 {
		compatible = "mediatek,sleep";
		reg = <0 0x1c004000 0 0xa000>;
		interrupts = <GIC_SPI 821 IRQ_TYPE_LEVEL_HIGH 0>;
		sleep-debug {
			compatible = "mediatek,sleep-debug";
			interrupts = <GIC_SPI 808 IRQ_TYPE_LEVEL_HIGH 0>;
			interrupt-names = "spm-dbg-ack-chk";
		};
	};

	pbus@1c001000 {
		compatible = "mediatek,pbus";
		reg = <0 0x1c001000 0 0x0310>,
			<0 0x1c001000 0 0x0310>;
		interrupts = <GIC_SPI 602 IRQ_TYPE_LEVEL_HIGH 0>,
			<GIC_SPI 603 IRQ_TYPE_LEVEL_HIGH 0>;
		interrupt-names = "pbus-vlp-irq",
			"pbus-vcore-irq";
	};

	swpm: swpm {
		compatible = "mediatek,mtk-swpm";
		pmu-support = <0>;
		pmu-boundary-num = <0>;
		pmu-dsu-support = <0>;
		pmu-dsu-type = <11>;
		pmu-ai-support = <0>;
	};

	wla: wla@11031000 {
		compatible = "mediatek,wla";
		reg = <0 0x11031000 0 0x1000>;
		wla-enable = <1>;
		ddren-force-on = <0>;

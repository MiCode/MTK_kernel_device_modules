		mmdebug: mmdebug-vcp {
			compatible = "mediatek,mmdebug-vcp";
			vcp-supply = <&vcp>;
		};

		mmdvfs_mux: mmdvfs-mux {
			compatible = "mediatek,mtk-mmdvfs-mux";
			#clock-cells = <1>;
			mediatek,mmdvfs-muxs = <MMDVFS_MUX_CAM>, <MMDVFS_MUX_CAMTM>, <MMDVFS_MUX_VDE>,
				<MMDVFS_MUX_IMG>, <MMDVFS_MUX_IPE>, <MMDVFS_MUX_DIS>, <MMDVFS_MUX_MDP>,
				<MMDVFS_MUX_SMI>, <MMDVFS_MUX_VEN>, <MMDVFS_MUX_VEN_MDP>;
			mediatek,mmdvfs-mux-names = "mux-cam", "mux-camtm", "mux-vde", "mux-img", "mux-ipe",
				"mux-dis", "mux-mdp", "mux-smi", "mux-ven", "mux-ven-mdp";
			mediatek,mmdvfs-opp-table = <&opp_table_cam>, <&opp_table_camtm>, <&opp_table_vdec>,
				<&opp_table_img>, <&opp_table_ipe>, <&opp_table_disp>, <&opp_table_disp>,
				<&opp_table_mminfra>, <&opp_table_venc>, <&opp_table_venc_mdp>;
			mediatek,mmdvfs-opp-table-b0 = <&opp_table_cam>, <&opp_table_camtm>, <&opp_table_vdec>,
				<&opp_table_img>, <&opp_table_ipe>, <&opp_table_disp_b0>, <&opp_table_disp_b0>,
				<&opp_table_mminfra>, <&opp_table_venc>, <&opp_table_venc_mdp>;
			mediatek,vcore-level =	/bits/ 8 <1 2 3 4 5 6>; //mapping to mmdvfs vcore dfs level
			mediatek,step-idx = /bits/ 8 <MMDVFS_VCP_CAM>;
			mediatek,dpsw-thres = <2>;
			mediatek,mmup-sram;
			mmdebug-supply = <&mmdebug>;
			vcp-supply = <&vcp>;
		};

		mmdvfs_debug: mmdvfs-debug {
			compatible = "mediatek,mmdvfs-debug";
			vcore-supply	= <&mt6667_13_buck1>;
			vmm-supply	= <&mt6667_7_buck3>;
			vdisp-supply	= <&mt6661_6_buck4>;
			mux-base	= <0x10040000>;
			mux-offset	= /bits/ 16 <0x0010 0x0020 0x0030 0x0040 0x0060 0x0330 0x0270>;
			fmeter-id	= /bits/ 8 <116 117 109 110 111 112 113 105 107 108 106 126>;
			fmeter-type	= /bits/ 8 < 6 6 6 6 6 6 6 6 6 6 6 6>;
			mediatek,dpsw-thres = <2>;
			mediatek,met-freerun;
			mmdvfs-mux-supply = <&mmdvfs_mux>;
		};

		mmdvfs-debug-user {
			compatible = "mediatek,mmdvfs-debug-user";
			clocks = <&mmdvfs_mux MMDVFS_AP_CAM>, <&mmdvfs_mux MMDVFS_AP_CAMTM>,
				 <&mmdvfs_mux MMDVFS_AP_VDE>, <&mmdvfs_mux MMDVFS_AP_IMG>, <&mmdvfs_mux MMDVFS_AP_IPE>,
				 <&mmdvfs_mux MMDVFS_AP_DIS>, <&mmdvfs_mux MMDVFS_AP_MML>,
				 <&mmdvfs_mux MMDVFS_AP_SMI>, <&mmdvfs_mux MMDVFS_AP_VEN>, <&mmdvfs_mux MMDVFS_AP_MDP>;
			clock-names = "cam", "camtm", "vde", "img", "ipe", "dis", "mml", "smi", "ven", "mdp";
			mediatek,step-idx = /bits/ 8 <7 0 6 2>;
			mediatek,clk-freerun = <0xffffff>; // 1: freerun without voting high
		};

		u3fpgaphy: u3fpgaphy {
			compatible = "mediatek,fpga-u3phy";
			mediatek,ippc = <0x16753e00>;
			#address-cells = <2>;
			#size-cells = <2>;
			fpga-i2c-physical-base = <0x123d0000>;
			fpga-i2c-clock = <0x12650e00 0x2>;
			status = "disabled";

			u3fpgaport0: u3fpgaport0 {
				chip-id= <0xa60931a>;
				port = <0>;
				pclk_phase = <23>;
				#phy-cells = <1>;
			};
		};

		adaptor_core: adaptor-core@0 {
			compatible = "mediatek,adaptor_core";
			status = "okay";
		};

		seninf_top: seninf-top@3a400000 {
			compatible = "mediatek,seninf-core";
			#address-cells = <2>;
			#size-cells = <2>;
			ranges;

			cam-main-csi-afifo-addr = <0x3a0107dc>;

			hwccf-apply;
			reg = <0 0x3a400000 0 0x1000>,
				<0 0x3a401000 0 0x1000>,
				<0 0x3a402000 0 0x1000>,
				<0 0x138b0000 0 0x1000>;

			reg-names = "seninf-top",
				"seninf-async-top",
				"seninf-tm",
				"csi-top-0";

			normal-cam-rdy-msk-grp-id-start = <0>;
			normal-cam-rdy-msk-grp-id-end = <8>;

			//interrupts = <GIC_SPI 502 IRQ_TYPE_LEVEL_HIGH 0>;

			/* for sentest adjust isp clk used */
			operating-points-v2 = <&opp_table_cam>;

			/* for clock scaling bind vcore */
			dvfsrc-vcore-supply = <&dvfsrc_vcore>;
			/*
			 * description phy dvfs step <[0] [1]>, <[2] [3]>, <[4]>, <[5] [6]>
			 * step: 0-N, or modification by dvfs table. (N: step maximum)
			 * [0]: cphy-4d1c
			 * [1]: cphy-2d1c
			 * [2]: dphy-4d1c
			 * [3]: dphy-2d1c
			 * [4]: step-csi-clk
			 * [5]: step-voltage-4d1c (lowest)
			 * [6]: step-voltage-2d1c (lowest)
			 */
			cdphy-dvfs-step0 = <8000 5400>, <9000 9000>, <312>, <575000 575000>;
			cdphy-dvfs-step1 = <8000 6000>, <9000 9000>, <364>, <600000 600000>;
			cdphy-dvfs-step2 = <8000 7280>, <9000 9000>, <416>, <650000 650000>;
			cdphy-dvfs-step3 = <8000 8000>, <9000 9000>, <499>, <725000 725000>;

			clocks = <&cam_main_r1a_clk CAM_M_SENINF_CAM_MAIN>,
				<&cam_main_r1a_clk CAM_M_CAM_CAM_MAIN>,
				<&cam_main_r1a_clk CAM_M_CAMTG_CAM_MAIN>,
				<&cksys_mm_clk CKSYS_MM_SENINF0_SEL>,
				<&cksys_mm_clk CKSYS_MM_SENINF1_SEL>,
				<&cksys_mm_clk CKSYS_MM_SENINF2_SEL>,
				<&cksys_mm_clk CKSYS_MM_SENINF3_SEL>,
				<&cksys_mm_clk CKSYS_MM_SENINF4_SEL>,
				<&cksys_mm_clk CKSYS_MM_SENINF5_SEL>,
				<&cksys_mm_clk CKSYS_MM_CAMTM_SEL>,

				<&cksys_top_clk CKSYS_TOP_OSC_D4>,
				<&cksys_mm_clk CKSYS_MM_UNIVPLL2_D4_D2>,
				<&cksys_mm_clk CKSYS_MM_MAINPLL2_D6>,
				<&cksys_mm_clk CKSYS_MM_UNIVPLL2_D6>,
				<&cksys_mm_clk CKSYS_MM_UNIVPLL2_D5>,

				/* for power domain hw ccf */
				//<&mm_pd_clk CLK_PD_CAM_MAIN_CAM_MAIN>,
				<&mm_pd_clk CLK_PD_CSI_BS_RX_SENINF>,

				/* for adjust isp clk node */
				<&mmdvfs_mux MMDVFS_USER_CAM>;

			clock-names = "clk_cam_seninf",
				"clk_cam_cam",
				"clk_cam_camtg",
				 "clk_top_seninf",
				 "clk_top_seninf1",
				 "clk_top_seninf2",
				 "clk_top_seninf3",
				 "clk_top_seninf4",
				 "clk_top_seninf5",
				 "clk_top_camtm",
				 "clk_top_aov_step0",
				 "clk_top_ap_step0",
				 "clk_top_ap_step1",
				 "clk_top_ap_step2",
				 "clk_top_ap_step3",
				 //"clk_hw_ccf_cam_main",
				 "clk_hw_ccf_csi_bs",
				 "mmdvfs_mux";

			csi-top {
				#address-cells = <2>;
				#size-cells = <2>;
				ranges;

				seninf_csi_0: seninf-csi@13880000 {
					compatible = "mediatek,seninf-csi";
					reg = <0 0x13880000 0 0xf00>,
						<0 0x13881000 0 0x1000>,
						<0 0x13882000 0 0x1000>,
						<0 0x13883000 0 0x1000>,
						<0 0x13884000 0 0x1000>,
						<0 0x13885000 0 0x1000>,
						<0 0x13886000 0 0x1000>,
						<0 0x13887000 0 0x1000>;

					reg-names = "seninf-csi-rxana-csia",
						"seninf-csi-rxana-csib",
						"seninf-csi-dphy",
						"seninf-csi-cphy",
						"seninf-csi-mac-top",
						"seninf-csi-mac-csia",
						"seninf-csi-mac-csib",
						"seninf-csi-mac-sw-ppi";

					csi-port = <0>;
					connect-to-seninf-async = <0>;
				};

				seninf_csi_1: seninf-csi@13888000 {
					compatible = "mediatek,seninf-csi";
					reg = <0 0x13888000 0 0xf00>,
						<0 0x13889000 0 0x1000>,
						<0 0x1388a000 0 0x1000>,
						<0 0x1388b000 0 0x1000>,
						<0 0x1388c000 0 0x1000>,

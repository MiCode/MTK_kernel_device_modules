		mminfra_util: mminfra-util {
			compatible = "mediatek,mminfra-util";
			mminfra-mtcmos-num = <MMINFRA_MT6993_PWR_NR>; /* mm0/mm1/mm_ao/mm2 */
			mminfra-type-num = <MMINFRA_MT6993_TYPE_NR>;
			mminfra-type0-pwr = <MMINFRA_MT6993_PWR_MM2>; /* cg_link to mm2*/
			mminfra-mtcmos-voter = <55 55 55 55>;
			mminfra-mtcmos-data = <1 2 0 3>;
			mm-mtcmos-base = <0x31b5009c 0x31b500a0 0x31b500a4 0x31b500a8>; /* mm0/mm1/mm_ao/mm2 */
			mm-mtcmos-mask = <0xc0000000 0xc0000000 0xc0000000 0xc0000000>; /* mm0/mm1/mm_ao/mm2*/
			mediatek,vcp-supply = <&vcp>;
		};

		mminfra_debug: mminfra-debug@30070000 {
			compatible = "mediatek,mminfra-debug";
			reg = <0 0x30070000 0 0x104>;
			power-domains;
			interrupts = <GIC_SPI 481 IRQ_TYPE_LEVEL_HIGH 0>;
			mminfra-bkrs = <0>;
			init-clk-on;
			//mminfra-gals-sel = <5 9 10 14 15 16 17 18 19 28>;
			//bkrs-reg = <0x1e800250>;
			//vlp-base = <0x1c000000>;
			//spm-base = <0x1c001000>;
			mm-voter-base = <0x31a80130>;
			mm-mtcmos-base = <0x31b5009c>;
			mm-mtcmos-mask = <0xc0000000>;
			//mminfra-ao-base;
			bypass-devapc-excep;
			mm-devapc-vio-sta-base = <0x30040000>;
			mmup-gipc-in-set = <0x31bd0028>;
			mediatek,vcp-supply = <&vcp>;
			mediatek,mminfra-supply = <&mminfra_util>;
			mminfra-api-pwr-ctrl;
			mminfra-api-pwr-idx = <MMINFRA_MT6993_PWR_MM2>;
			vcp-gipc;
			no-sleep-pd-cb;
			skip-apsrc;
			mm-no-scmi;
			mm-no-cg-ctrl;
			mm-pwr-ver = <3>;
			/* <mm0 mm1 mm_ao mm2> */
			mm-cfg-base = <0x30000000 0x30a00000 0x30080000 0x30b00000>;
			mm-dbg-out-sel-nr = <32 4 0 8>;
			mmpc-src-ctrl-v2;
			mmpc-src-ctrl-base = <0x31b51000>;
			mmpc-src-ctrl-fsm = <0x18 0x38 0x58 0x78 0x98 0xb8 0xd8 0x1d8 0x1f8>;
			mmpc-src-ctrl-hw = <0x1c 0x3c 0x5c 0x7c 0x9c 0xbc 0xdc 0x1dc 0x1fc>;
			mm-proc-mtcmos-base = <0x1c00d04c>;
			mm-proc-mtcmos-mask = <0x80000000>;
		};

		gce: gce@30100000 {
			compatible = "mediatek,mt6993-gce";
			reg = <0 0x30100000 0 0x80000>;
			interrupts = <GIC_SPI 485 IRQ_TYPE_LEVEL_HIGH 0>;
			interrupt-names = "mtk_cmdq";
			#mbox-cells = <3>;
			#gce-event-cells = <1>;
			#gce-subsys-cells = <2>;
			default-tokens = /bits/ 16 <CMDQ_SYNC_TOKEN_GPR_SET_0>,
					/bits/ 16 <CMDQ_SYNC_TOKEN_GPR_SET_1>,
					/bits/ 16 <CMDQ_SYNC_TOKEN_GPR_SET_2>,
					/bits/ 16 <CMDQ_SYNC_TOKEN_GPR_SET_3>,
					/bits/ 16 <CMDQ_SYNC_TOKEN_GPR_SET_4>,
					/bits/ 16 <CMDQ_SYNC_RESOURCE_WROT0>,
					/bits/ 16 <CMDQ_SYNC_RESOURCE_WROT1>,
					/bits/ 16 <CMDQ_SYNC_TOKEN_PREBUILT_MDP_LOCK>,
					/bits/ 16 <CMDQ_SYNC_TOKEN_PREBUILT_MML_LOCK>,
					/bits/ 16 <CMDQ_SYNC_TOKEN_PREBUILT_DISP_LOCK>,
					/bits/ 16 <CMDQ_SYNC_TOKEN_DPC_VOTE_HWCCF>,
					/bits/ 16 <CMDQ_SYNC_TOKEN_MML_MML_STOP>,
					/bits/ 16 <CMDQ_SYNC_TOKEN_MML_DISP_DONE_EVENT>;
			mboxes = <&gce 13 0 CMDQ_THR_PRIO_HIGHEST>;
			mediatek,smi = <&smi_mdp_common &smi_sram_sub_comm4>;
			mtk,smmu-shared = <&mm_smmu_gce_d>;
			mtk,iommu-dma-axid = <SMMU_L62_GCE_D>;
			gce-hwid = <0>;
			dma-mask-bit = <35>;
			cmdq-dbg-type = <0x4>;
			poll-sleep-bit32;
			gce-wla-vote;
			ddr-urgent;
			cmdq-print-debug = <1>;
			mediatek,mminfra-supply = <&mminfra_util>;
			mminfra-all-on-pwr-idx = <MMINFRA_MT6993_PWR_MM2>;
			smmu-tbu = <2>;
			axid = <0x1801>;
			cmdq-dump-buf-size = <1>;
			cmdq-dump-hw-trace = <1>;
			hw-trace-built-in;
			hw-trace-disable = <16 17 18 19>;
			gce-fast-mtcmos;
			ao-ctrl-by-mminfra;
			cmdq-mmp-thread-exec = <0x20030859>;
		};

		gce_sec: gce-mbox-sec@30100000 {

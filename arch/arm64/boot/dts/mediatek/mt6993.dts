		omc-lite-sync-token =
			/bits/ 16 <CMDQ_SYNC_TOKEN_IMGSYS_OMC_LITE>;
		mae-sync-token =
			/bits/ 16 <CMDQ_SYNC_TOKEN_IMGSYS_MAE>;
		dpe-sync-token =
			/bits/ 16 <CMDQ_SYNC_TOKEN_IMGSYS_DPE>;
		dfp-sync-token =
			/bits/ 16 <CMDQ_SYNC_TOKEN_IMGSYS_DFP>;
		adl-sync-token =
			/bits/ 16 <CMDQ_SYNC_TOKEN_IMGSYS_ADL>;
		wpe-depth-sync-token =

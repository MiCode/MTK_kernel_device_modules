			mask = /bits/ 64 <0x0000000fffffffff>;
			mtk,iommu-group = <&apu_iommu_group_2>;
			iommus = <&apu_smmu 0x13>;
		};

		mtk_apu_mem_share_coherent: mtk-apu-mem-share-coherent {
			#address-cells = <2>;
			#size-cells = <2>;
			compatible = "mediatek, apu_mem_share_coherent";

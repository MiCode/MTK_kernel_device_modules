		pmic-ecid {
			compatible = "mediatek,mt6661-4-efuse";
			mt6661-4-ecid {
				ecid = /bits/ 16 <0 0 0 0>;
				slvid = <4>;
			};
			mt6661-3-ecid {
				ecid = /bits/ 16 <0 0 0 0>;
				slvid = <3>;
			};
			mt6661-5-ecid {
				ecid = /bits/ 16 <0 0 0 0>;
				slvid = <5>;
			};
			mt6661-6-ecid {
				ecid = /bits/ 16 <0 0 0 0>;
				slvid = <6>;
			};
			mt6667-7-ecid {
				ecid =  /bits/ 16 <0 0 0 0>;
				slvid = <7>;
			};
			mt6667-8-ecid {
				ecid =  /bits/ 16 <0 0 0 0>;
				slvid = <8>;
			};
			mt6667-12-ecid {
				ecid =  /bits/ 16 <0 0 0 0>;
				slvid = <12>;
			};
			mt6667-13-ecid {
				ecid =  /bits/ 16 <0 0 0 0>;
				slvid = <13>;
			};
			mt6687-9-ecid {
				ecid =  /bits/ 16 <0 0 0 0>;
				slvid = <9>;
			};
		};

		mm_fake_eng: mm-fake-engine@30030000 {
			compatible = "mediatek,mm-fake-engine";
			reg = <0 0x30030000 0 0x10000>;
			power-domain = <MT6993_SMI_PD_MMINFRA0>;
			#fake-engine-cells = <1>;
			fake-engines = <&mm_fake_eng 0x0>,
				<&mm_fake_eng 0x1000>,
				<&mm_fake_eng 0x2000>,
				<&mm_fake_eng 0x3000>;
			fake-engine-names = "MMINFRA_DISP0_FAKE_ENG_REG0",
				"MMINFRA_DISP1_FAKE_ENG_REG0",
				"MMINFRA_MDP0_FAKE_ENG_REG0",
				"MMINFRA_MDP1_FAKE_ENG_REG0";
			smi-monitor-comm0 = <0x30020000>;
			smi-monitor-comm1 = <0x30021000>;
			mtk,smmu-shared = <&mm_smmu_cam>;
		};


				<REG_UPDATE_DONE_SEL0>, <REG_UPDATE_DONE_SEL1>,
				<REG_UPDATE_DONE_SEL2>, <REG_UPDATE_DONE_SEL3>,
				<REG_UPDATE_DONE_SEL4>, <REG_UPDATE_DONE_SEL5>,
				<REG_UPDATE_DONE_SEL6>, <REG_UPDATE_DONE_SEL7>;

			gce-event-sel-offset = /bits/ 16 <GCE_FRAME_DONE_SEL0>;
			gce-merged-event = /bits/ 16 <CMDQ_EVENT_MML2_GCE_FRAME_DONE_0>;
			gce-event-sels = /bits/ 16 <
				MML2_DLO0 MML_EVENT_SEL_DLO0
				MML2_RDMA1 MML_EVENT_SEL_RDMA1
				MML2_RROT0 MML_EVENT_SEL_RROT0
				MML2_RROT1 MML_EVENT_SEL_RROT1
				MML2_WROT0 MML_EVENT_SEL_WROT0
				MML2_WROT1 MML_EVENT_SEL_WROT1>;

			/* as dl component */
			dli0-dl-relay = /bits/ 16 <MML_DLI_ASYNC0_SIZE>;
			dli1-dl-relay = /bits/ 16 <MML_DLI_ASYNC1_SIZE>;
			dli2-dl-relay = /bits/ 16 <MML_DLI_ASYNC2_SIZE>;
			dli3-dl-relay = /bits/ 16 <MML_DLI_ASYNC3_SIZE>;
			dli4-dl-relay = /bits/ 16 <MML_DLI_ASYNC4_SIZE>;
			dlo0-dl-relay = /bits/ 16 <MML_DLO_ASYNC0_SIZE>;
			dlo1-dl-relay = /bits/ 16 <MML_DLO_ASYNC1_SIZE>;
			dlo2-dl-relay = /bits/ 16 <MML_DLO_ASYNC2_SIZE>;
			dlo3-dl-relay = /bits/ 16 <MML_DLO_ASYNC3_SIZE>;
			dlo4-dl-relay = /bits/ 16 <MML_DLO_ASYNC4_SIZE>;
			dlo5-dl-relay = /bits/ 16 <MML_DLO_ASYNC5_SIZE>;

			/* couple mode events */
			event-ir-mml-ready = /bits/ 16 <CMDQ_SYNC_TOKEN_MML_IR_MML_READY>;
			event-ir-disp-ready = /bits/ 16 <CMDQ_SYNC_TOKEN_MML_IR_DISP_READY>;
			event-ir-mml-stop = /bits/ 16 <CMDQ_SYNC_TOKEN_MML_MML_STOP>;
			event-racing-pipe0 = /bits/ 16 <CMDQ_SYNC_TOKEN_MML_PIPE0>;
			event-racing-pipe1 = /bits/ 16 <CMDQ_SYNC_TOKEN_MML_PIPE1>;
			event-racing-pipe1-next = /bits/ 16 <CMDQ_SYNC_TOKEN_MML_PIPE1_NEXT>;

			clocks = <&mml2_mmlsys_config_clk MML2_APB_BUS_MML>,
				<&mml2_mmlsys_config_clk MML2_APB_DB_MML>,
				<&mml2_mmlsys_config_clk MML2_MDP_DLI_ASYNC0_MML>,
				<&mml2_mmlsys_config_clk MML2_MDP_DLI_ASYNC1_MML>,
				<&mml2_mmlsys_config_clk MML2_MDP_DLI_ASYNC2_MML>,
				<&mml2_mmlsys_config_clk MML2_MDP_DLI_ASYNC3_MML>,
				<&mml2_mmlsys_config_clk MML2_MDP_DLI_ASYNC4_MML>,
				<&mml2_mmlsys_config_clk MML2_MDP_DLO_ASYNC0_MML>,
				<&mml2_mmlsys_config_clk MML2_MDP_DLO_ASYNC1_MML>,
				<&mml2_mmlsys_config_clk MML2_MDP_DLO_ASYNC2_MML>,
				<&mml2_mmlsys_config_clk MML2_MDP_DLO_ASYNC3_MML>,
				<&mml2_mmlsys_config_clk MML2_MDP_DLO_ASYNC4_MML>,
				<&mml2_mmlsys_config_clk MML2_MDP_DLO_ASYNC5_MML>,
				<&mml2_mmlsys_config_clk MML2_DISP_DBG_MML>,
				<&mmdvfs_mux MMDVFS_USER_MML>;
			clock-names = "apb_bus", "apb_db",
				"dli0", "dli1", "dli2", "dli3", "dli4",
				"dlo0", "dlo1", "dlo2", "dlo3", "dlo4", "dlo5",

		cmdq_test: cmdq-test@0 {
			compatible = "mediatek,cmdq-test";
			mediatek,gce = <&gce>;
			cmdq-supply = <&gce_m_sec_2>;
			mboxes = <&gce 8 3000 CMDQ_THR_PRIO_1>,
				<&gce 9 3000 CMDQ_THR_PRIO_1>,
				<&gce 28 3000 CMDQ_THR_PRIO_1>,
				<&gce_m_sec_2 9 0 CMDQ_THR_PRIO_1>;
			gce-event-names = "token_user_0";
			gce-events = <&gce CMDQ_SYNC_TOKEN_USER_0>;
			token-user0 = /bits/ 16 <CMDQ_SYNC_TOKEN_USER_0>;
			token-for-ut = /bits/ 16 <CMDQ_SYNC_TOKEN_PREBUILT_MDP_LOCK>;
			token-timeout = /bits/ 16 <CMDQ_SYNC_TOKEN_PREBUILT_MML_LOCK>;
		};

		cmdq_config: cmdq-config@0 {
			gce-core-num = <4>;
			sec-cmdq-enable = <0 0 1 0>;
			cmdq-first-err-disable = <0 1 0 0>;
		};

		mminfra-imax {
			compatible = "mediatek,mminfra-imax";
			reg = <0 0x32900000 0 0x1000>, /* dispsys */
				<0 0x32c00000 0 0x1000>, /* dispsys1 */
				<0 0x3e000000 0 0x1000>, /* mdpsys */
				<0 0x3e000000 0 0x1000>, /* mdpsys1 */
				<0 0x32aa0000 0 0x1000>, /* disp_larb_0 */
				<0 0x32ab0000 0 0x1000>, /* disp_larb_1 */
				<0 0x32da0000 0 0x1000>, /* disp_larb_2 */
				<0 0x32db0000 0 0x1000>, /* disp_larb_3 */
				<0 0x3e1a0000 0 0x1000>, /* mdp_larb_0 */
				<0 0x3e1b0000 0 0x1000>; /* mdp_larb_1 */
			disp-larb0-fake-port = <8>;
			disp-larb1-fake-port = <8>;
			disp-larb2-fake-port = <8>;
			disp-larb3-fake-port = <8>;
			mdp-larb0-fake-port = <8>;
			mdp-larb1-fake-port = <8>;

			mm-sram-base = <0x0f000000>;

			reg-names = "dispsys",
				"dispsys1",
				"mdpsys",
				"mdpsys1",
				"disp_larb_0",
				"disp_larb_1",
				"disp_larb_2",
				"disp_larb_3",
				"mdp_larb_0",
				"mdp_larb_1";

			mtk,smmu-shared = <&mm_smmu_disp>;

			bw-fuzzer = <1>;
			larb-id = <0 1 34 35>;
			port-id = <8 8 8 8>;
			rd-addr-ofs = <0x80 0x100 0x80 0x100>;
			wr-addr-ofs = <0x84 0x104 0x84 0x104>;
			con0-ofs = <0x78 0x98 0x78 0x98>;
			con1-ofs = <0x7c 0x9c 0x7c 0x9c>;
			reset-ofs = <0x74 0x94 0x74 0x94>;
			enable-ofs = <0x70 0x90 0x70 0x90>;
			state-ofs = <0x88 0x108 0x88 0x108>;
			wr-pat = <4 4 4 4>;
			length = <255 255 255 255>;
			burst = <7 7 7 7>;
			dis-rd = <0 0 0 0>;
			dis-wr = <0 0 0 0>;
			latency = <1023 1023 1023 1023>;
			loop = <1 1 1 1>;

			bw-table-latency = <0 16 1023>;
			bw-table-bw = <4100 1800 100>;

			interconnects =
				<&mmqos MASTER_LARB_PORT(MTK_SMMU_PORT_ID(62, 8))
					&mmqos SLAVE_COMMON(1)>,
				<&mmqos MASTER_LARB_PORT(MTK_SMMU_PORT_ID(23, 8))
					&mmqos SLAVE_COMMON(0)>,
				<&mmqos MASTER_LARB_PORT(MTK_SMMU_PORT_ID(31, 8))
					&mmqos SLAVE_COMMON(1)>,
				<&mmqos MASTER_LARB_PORT(MTK_SMMU_PORT_ID(63, 8))
					&mmqos SLAVE_COMMON(0)>;
			interconnect-names = "fake_eng_0", "fake_eng_1", "fake_eng_2", "fake_eng_3";
		};

		sram@100000 {
			compatible = "pkvm,protected-region";
			reg = <0x0 0x00100000 0 0x12000>;
		};

		devapc@14401000 {
			compatible = "mediatek,mt6993-devapc";
			reg = <0 0x14401000 0 0x1000>, /* apinfra_io sys0 pd */
				<0 0x14401000 0 0x1000>, /* apinfra_io sys1 pd */
				<0 0x14400000 0 0x1000>, /* apinfra_io_ctrl pd */

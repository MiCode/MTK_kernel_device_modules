		disp_ovl0_exdma0: disp-ovl0-exdma0@32930000 {
			compatible = "mediatek,disp_ovl0_exdma0",
				"mediatek,mt6993-disp-ovl-exdma";
			clocks = <&ovlsys_config_clk OVL_EXDMA0_DISP>;
			reg = <0 0x32930000 0 0x1000>;
			mtk,smmu-shared = <&mm_smmu_disp>;
			mtk,smmu-shared-sec = <&mm_smmu_svp_disp>;
		};

		disp_ovl0_exdma2: disp-ovl0-exdma2@32950000 {
			compatible = "mediatek,disp_ovl0_exdma2",
				"mediatek,mt6993-disp-ovl-exdma";
			clocks = <&ovlsys_config_clk OVL_EXDMA2_DISP>;
			mediatek,larb = <&smi_larb0 SMMU_L0_P2_OVL_EXDMA2>;
			reg = <0 0x32950000 0 0x1000>;
			mtk,smmu-shared = <&mm_smmu_disp>;
			mtk,smmu-shared-sec = <&mm_smmu_svp_disp>;
			iommus-ovl = <SMMU_L0_P2_OVL_EXDMA2>; // Tf debug tool
			interconnects = <&mmqos MASTER_LARB_PORT(SMMU_L0_P2_OVL_EXDMA2)
					 &mmqos SLAVE_COMMON(1)>,
					<&mmqos MASTER_LARB_PORT(SMMU_L0_P2_OVL_EXDMA2)
					 &mmqos SLAVE_COMMON(1)>,
					<&mmqos MASTER_LARB_PORT(SMMU_L0_P0_OVL_EXDMA2_HDR)
					 &mmqos SLAVE_COMMON(1)>,
					<&mmqos MASTER_LARB_PORT(SMMU_L0_P4_OVL_EXDMA2_HDR_STASH)
					 &mmqos SLAVE_COMMON(1)>,
					<&mmqos MASTER_LARB_PORT(SMMU_L0_P6_OVL_EXDMA2_STASH)
					 &mmqos SLAVE_COMMON(1)>;
			interconnect-names = "DDP_COMPONENT_OVL_EXDMA2_qos",
					     "DDP_COMPONENT_OVL_EXDMA2_hrt_qos",
					     "DDP_COMPONENT_OVL_EXDMA2_hdr_qos",
					     "DDP_COMPONENT_OVL_EXDMA2_hdr_stash_qos",
					     "DDP_COMPONENT_OVL_EXDMA2_stash_qos";
		};

		disp_dbgtp: disp-dbgtp@3ee80000 {
			compatible = "mediatek,disp_dbgtp",
				"mediatek,mt6993-disp-dbgtp";
			reg = <0 0x3ee80000 0 0x1000>;
			interrupts = <GIC_SPI 449 IRQ_TYPE_LEVEL_HIGH 0>;
			clocks = <&disp_vdisp_ao_config_clk VDISP_AO_DISP_DEBUG_TOP_DISP>;
		};


			mediatek,pd-id = <MT6993_SMI_PD_VDE0>;
			smi-user-id = <MTK_SMI_VDEC_CORE>;
		};

		mm_m0_rsiu_regs: smi-mm-m0-rsiu-regs@30b30000 {
			compatible = "mediatek,smi-rsi";

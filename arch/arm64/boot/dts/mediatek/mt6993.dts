						&smi_img_sub_comm0 &smi_img_sub_comm1
						&smi_img_sub_comm2 &smi_img_sub_comm3
						&smi_img_sub_comm4 &smi_img_sub_comm5
						&smi_img_sub_comm6 &smi_cam_sub_comm0

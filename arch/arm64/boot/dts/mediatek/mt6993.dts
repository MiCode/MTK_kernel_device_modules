		scp_i2c1: i2c@1d840000 {
			compatible = "mediatek,mt6991-i2c";
			reg = <0 0x1d840000 0 0x40000>,
					<0 0x1db40000 0 0x20000>;
			interrupts = <GIC_SPI 528 IRQ_TYPE_LEVEL_HIGH 0>;
			clocks = <&scp_i3c_clk SCP_I3C_I2C1_SCP_I2C>,
				<&pericfg_ao_clk PERAO_U_AP_DMA_X32W_BCLK_I2C>;
			clock-names = "main", "dma";
			i2c-clock-info = <0x1da00e10 0x2>;    /* *reg*  *value* */
			clock-div = <1>;
			clk-src-in-hz = <130000000>;
			ch-offset-i2c = <0x20000>;
			ch-offset-dma = <0x10000>;
			i2c-offset-scp = <0x20000>;
			scl-gpio-id = <96>;
			sda-gpio-id = <97>;
			scp-wake-en = <1>;
			scp-gipc-in-set-ap = <0x1df50040>;
			gipc1-setclr-bit-0 = <0x10>;
			vlpcfg-base = <0x1c001000>;
			vlp-scp-sleep = <0x92c 0x1 0x4>;
			vlp-scp-sleep-stat = <0x934 0xf0000>;   /* sleep-stat1 */
			vlp-scp-sleep-stat2 = <0x938 0x3e>;    /* sleep-stat2 */
			mediatek,wake-scp-check-en;
			mediatek,use-slp-stat1-stat2;

				4500 4400 3400
				5000 4900 4800>;
			lvsys-thd-volt-l-size = <2>;
			lvsys-thd-volt-h-size = <2>;
			lvsys-thd-volt-l = <3200 2600
					3200 2600
					3300 2700
					3300 2700>;
			lvsys-thd-volt-h = <3500 2900
					3500 2900
					3600 2900
					3600 2900>;
			lvsys-thd-volt-tb1-l = <3400 3100
					3500 3200
					3800 3600
					4000 3800>;
			lvsys-thd-volt-tb1-h = <3600 3300
					3800 3400
					3900 3700
					4100 3900>;
			lvsys-thd-volt-tb2-l = <3400 3100
					3600 3400
					3800 3600
					3900 3600>;
			lvsys-thd-volt-tb2-h = <3800 3300
					3700 3500
					3900 3700
					4000 3700>;

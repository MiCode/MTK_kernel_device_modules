				<&mmqos MASTER_LARB_PORT(SMMU_L33_P4_DISP_DBI_COUNT0_R)
						&mmqos SLAVE_COMMON(0)>,
				<&mmqos MASTER_LARB_PORT(SMMU_L33_P4_DISP_DBI_COUNT0_R)
						&mmqos SLAVE_COMMON(0)>,
				<&mmqos MASTER_LARB_PORT(SMMU_L33_P8_DISP_DBI_COUNT0_R_STASH)
						&mmqos SLAVE_COMMON(0)>;

		apusys-apummu {
			#address-cells = <2>;
			#size-cells = <2>;
			compatible = "mediatek,rv-apummu-mt6993";
			// dma-ranges = <0x0 0x0 0x0 0x0 0x1 0x0>;
			mtk,iommu-group = <&apu_iommu_group_3>;
			iommus = <&apu_smmu 0xd>;
			smmu-ssid-max = <125>;
		};

		mvpu {
			compatible = "mediatek, mt6993-mvpu";
			core-num = <2>;
			mask = /bits/ 64 <0x0000000fffffffff>;
			mtk,iommu-group = <&apu_iommu_group_2>;
			iommus = <&apu_smmu 0xf>;
		};

		mtk_apu_mem_code: mtk-apu-mem-code {
			#address-cells = <2>;
			#size-cells = <2>;
			compatible = "mediatek, apu_mem_code";
			status = "okay";
			type = <1>;
			mask = /bits/ 64 <0x0000000fffffffff>;
			mtk,iommu-group = <&apu_iommu_group_0>;
			iommus = <&apu_smmu 0xb>;
			pasid-num-bits = <8>;
			mtk,smmu-ssids {
				mtk,smmu-ssid-range = <1 125>;
			};
		};

		mtk_apu_mem_code_coherent: mtk-apu-mem-code-coherent {
			#address-cells = <2>;
			#size-cells = <2>;
			compatible = "mediatek, apu_mem_code_coherent";
			status = "okay";
			type = <4>;
			mask = /bits/ 64 <0x00000003ffffffff>;
			mtk,iommu-group = <&apu_iommu_group_0>;
			iommus = <&apu_smmu 0x14>;
			dma-coherent;
			pasid-num-bits = <8>;
			mtk,smmu-ssids {
				mtk,smmu-ssid-range = <1 125>;
			};
		};
		mtk_apu_mem_data: mtk-apu-mem-data {
			#address-cells = <2>;
			#size-cells = <2>;
			compatible = "mediatek, apu_mem_data";
			status = "okay";
			type = <2>;
			mask = /bits/ 64 <0x0000000fffffffff>;
			mtk,iommu-group = <&apu_iommu_group_1>;
			iommus = <&apu_smmu 0xa>;
			pasid-num-bits = <8>;
			mtk,smmu-ssids {
				mtk,smmu-ssid-range = <1 125>;
			};
		};


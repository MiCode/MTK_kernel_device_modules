			mediatek,larb = <&smi_larb33 SMMU_L33_P0_DISP_WDMA0>;
			mediatek,smi-id = <33>;
			mtk,smmu-shared = <&mm_smmu_disp>;
			mtk,smmu-shared-sec = <&mm_smmu_svp_disp>;
			interconnects =
				<&mmqos MASTER_LARB_PORT(SMMU_L33_P0_DISP_WDMA0)

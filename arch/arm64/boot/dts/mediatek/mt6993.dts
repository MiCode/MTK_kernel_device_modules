		mdla: mdla {
			#address-cells = <2>;
			#size-cells = <2>;
			compatible = "mediatek, mdla-rv";
			core-num = <4>;
			version = <0x69930600>;
			mtk,iommu-group = <&apu_iommu_group_2>;
			iommus = <&apu_smmu 0xe>;
		};

		apusys_aov: apusys-aov {
			compatible = "mediatek,apusys_aov-v3";
			smmu-device = <&apusys_aov_smmu_device>;
			ctrl-size = <0x200000>;
		};

		apusys_aov_smmu_device: apusys-aov-smmu-device {
			compatible = "mediatek,apusys-aov-smmu-device";
			#address-cells = <1>;

/* AUDIO GPIO standardization end */

#include "mediatek/cust_mt6993_msdc.dtsi"
#include "mediatek/trusty.dtsi"
#include "mediatek/cust_mt6993_connfem.dtsi"

&hypervisor {
	status = "okay";
};

&trusty {
	trusty-sapu {
		compatible = "mediatek,trusty-sapu";
		power-version = <2>;
		datamem-type = <2>;
		datamem-size = <0x0 0x0 0x0 0x0>;
		smmu-device = <&secure_apu_smmu_device>;
		status = "okay";
	};
};

&mddriver {
	/* for md pmic voltage setting */
	md-vmodem-supply = <&mt6661_6_buck1>;
	md-vmodem = <815000 815000>;
	md-vsram-supply = <&mt6661_5_buck6>;
	md-vsram = <750000 750000>;
	md-vdigrf-supply = <&mt6661_6_buck3>;
	md-vdigrf = <700000 700000>;

	/* for md rf pmic */
	vsram-digrf-supply = <&mt6661_6_lnc0_8>;
	vrfio12-supply = <&mt6661_6_ln60_5>;
	vrfio18-supply = <&mt6661_6_lnc0_9>;
	vs3-2-supply = <&mt6661_6_buck5>;
	vs2-2-supply = <&mt6661_6_buck6>;
	va10-supply = <&mt6661_6_ln60_7>;
	vrf09-supply = <&mt6661_6_lnc0_s_11>;
	vrf12-supply = <&mt6661_6_lnc0_s_12>;
	vrf18-supply = <&mt6661_6_lnc0_10>;
};

&md_auxadc {
	io-channels = <&mt6661_6_auxadc (ADC_PURES_OPEN_MASK | AUXADC_AGPIO2)>;
};

		camisp: camisp@3a010000 {
			compatible = "mediatek,mt6993-camisp";
			reg =	<0 0x3a010000 0 0x1000>,
				<0 0x3a430000 0 0x1000>,
				<0 0x3a440000 0 0x1000>,
				<0 0x3a0a0000 0 0x800>,
				<0 0x3a0a8000 0 0x30>,
				<0 0x3a0b8000 0 0x48>,
				<0 0x3a0c8000 0 0x48>,
				<0 0x3a0d8000 0 0x48>,
				<0 0x3c828800 0 0x5c>;
			reg-names = "base", "adlwr", "adlrd", "qof_base",
				"dvc_top", "dvc_a", "dvc_b", "dvc_c", "fmon_base";
			mediatek,ccd = <&remoteproc_ccd>;
			mediatek,camisp-vcore = <&camisp_vcore>;
			mtk,smmu-shared = <&mm_smmu_cam>;
			operating-points-v2 = <&opp_table_cam>;
			//power-domains = <&hfrpsys MT6993_POWER_DOMAIN_CAM_MAIN>;
			interrupts = <GIC_SPI 656 IRQ_TYPE_LEVEL_HIGH 0>,
				<GIC_SPI 663 IRQ_TYPE_LEVEL_HIGH 0>,
				<GIC_SPI 619 IRQ_TYPE_LEVEL_HIGH 0>;
			interrupt-names = "dvc", "fmon", "qoftop";
			clocks =
			    <&cam_main_r1a_clk CAM_M_CAM_CAM_MAIN>,
			    <&cam_main_r1a_clk CAM_M_CAM_SUBA_CAM_MAIN>,
			    <&cam_main_r1a_clk CAM_M_CAM_SUBB_CAM_MAIN>,
			    <&cam_main_r1a_clk CAM_M_CAM_SUBC_CAM_MAIN>,
			    <&cam_main_r1a_clk CAM_M_CAM_MRAW_CAM_MAIN>,
			    <&cam_main_r1a_clk CAM_M_CAMTG_CAM_MAIN>,
			    <&cam_main_r1a_clk CAM_M_SENINF_CAM_MAIN>,
			    <&cam_main_r1a_clk CAM_M_CAM_QOF_CON_1_CAM_MAIN>,
			    <&cam_main_r1a_clk CAM_M_CAM_WLA_CON_1_CAM_MAIN>,
			    <&cam_main_r1a_clk CAM_M_CAM_DVC_CON_1_CAM_MAIN>,
			    <&cam_main_r1a_clk CAM_M_CAM_CVFS_CON_1_CAM_MAIN>,
			    <&cksys_mm_clk CKSYS_MM_CAM_SEL>,
			    <&cksys_mm_clk CKSYS_MM_CAMTM_SEL>,
			    <&mmdvfs_mux MMDVFS_USER_CAM>;
			clock-names =
			    "camsys_main_cam",
			    "camsys_main_cam_suba",
			    "camsys_main_cam_subb",
			    "camsys_main_cam_subc",
			    "camsys_main_cam_mraw",
			    "camsys_main_camtg",
			    "camsys_main_seninf",
			    "camsys_main_cam_qof_con_1",
			    "camsys_main_cam_wla_con_1",
			    "camsys_main_cam_dvc_con_1",
			    "camsys_main_cam_cvfs_con_1",
			    "cksys_mm_cam_sel",
			    "cksys_mm_camtm_sel",
			    "mmdvfs_mux";

			nvmem-cells = <&efuse_segment>, <&isp_efuse_data>;
			nvmem-cell-names = "efuse_segment_cell", "isp-efuse-data";
		};

		cam_bwr: cam-bwr@3a00d000 {
			mediatek,camisp-vcore = <&camisp_vcore>;
			compatible = "mediatek,mt6993-cam-bwr";
			reg = <0 0x3a022000 0 0x1c78>;
			reg-names = "bwr_base";
			clocks =
				<&cam_main_r1a_clk CAM_M_CAM_CAM_MAIN>,
				<&cam_main_r1a_clk CAM_M_CAM_BWR_CON_1_CAM_MAIN>;
			clock-names =
				"camsys_main_cam",
				"camsys_main_cam_bwr_con_1";
		};

		cam_raw_a: cam-raw-a@3a700000 {
			compatible = "mediatek,cam-raw";
			reg =	<0 0x3a700000 0 0x8000>,
				<0 0x3a708000 0 0x8000>,
				<0 0x3a710000 0 0x8000>,
				<0 0x3a718000 0 0x8000>,

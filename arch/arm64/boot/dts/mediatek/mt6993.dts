					"inner_base", "inner_base_DMA", "inner_base_SCQ",
					"inner_base_pdp", "inner_base_stg";
			mediatek,camsv-id = <5>;
			mediatek,cammux-id = <5>;
			interrupts = <GIC_SPI 626 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 632 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 638 IRQ_TYPE_LEVEL_HIGH 0>;
			mediatek,larbs = <&smi_larb29>,
							<&smi_larb26>;
			clocks = <&camsys_mraw_clk CAM_MR_LARB29_CAMSV>,
					<&camsys_mraw_clk CAM_MR_LARB26_CAMSV>,
					<&camsys_mraw_clk CAM_MR_CAMSV_TOP_CAMSV>,
					<&camsys_mraw_clk CAM_MR_SENINF_CAMTM_CAMSV>,
					<&camsys_mraw_clk CAM_MR_CAMSV_CAMSV>;
			clock-names = "cam_main_larb29_con",
					"cam_main_larb26_con",
					"cam_main_camsv_top_con",
					"cam_main_seninf_camtm_con",
					"cam_main_camsv_f_con";
			mediatek,smmu-dma-axid =
					<SMMU_L29_P7_CAMSV_TOP_CQI_F>,
					<SMMU_L26_P1_CAMSV_TOP_F0>;
			mmqos-supply = <&mmqos>;
			interconnects =
				<&mmqos MASTER_LARB_PORT(SMMU_L29_P7_CAMSV_TOP_CQI_F)
					&mmqos SLAVE_COMMON(1)>,
				<&mmqos MASTER_LARB_PORT(SMMU_L26_P1_CAMSV_TOP_F0)
					&mmqos SLAVE_COMMON(1)>,
				<&mmqos MASTER_LARB_PORT(SMMU_L26_P3_CAMSV_TOP_F0_STG)
					&mmqos SLAVE_COMMON(1)>;
			interconnect-names =
				"l29_cqi_f",
				"l26_imgo0_f",
				"l26_stg0_f";
		};

		otf_pda: otf-pda@3a660000 {
			#address-cells = <2>;
			#size-cells = <2>;
			compatible = "mediatek,pda";
			reg = <0 0x3a660000 0 0x1000>,
				<0 0x3a668000 0 0x1000>;
			reg-names = "base", "inner_base";
			dma-ranges = <0x0 0x0 0x0 0x0 0x4 0x0>;
			mediatek,pda-id = <0>;
			interrupts = <GIC_SPI 611 IRQ_TYPE_LEVEL_HIGH 0>;
			mtk,smmu-shared = <&mm_smmu_cam>;
			mediatek,larbs = <&smi_larb25>;
			clocks = <&cam_vcore_r1a_clk CAM_V_R1A_G_CAM_VCORE>,
				<&cam_vcore_r1a_clk CAM_V_R1A_TX6_GALS_CAM_VCORE>,
				<&cam_vcore_r1a_clk CAM_V_R1A_TX47_GALS_CAM_VCORE>,
				<&cam_vcore_r1a_clk CAM_V_R1A_SUB_COMM0_CAM_VCORE>,
				<&cam_vcore_r1a_clk CAM_V_R1A_SUB_COMM2_CAM_VCORE>,
				<&cam_vcore_r1a_clk CAM_V_R1A_X46_GALS_CAM_VCORE>,
				<&cam_vcore_r1a_clk CAM_V_R1A_X53_GALS_CAM_VCORE>,
				<&cam_main_r1a_clk CAM_M_CAM_CAM_MAIN>,
				<&cam_main_r1a_clk CAM_M_CAM_CVFS_CON_1_CAM_MAIN>,
				<&cksys_mm_clk CKSYS_MM_CAMTM_SEL>,
				<&camsys_mraw_clk CAM_MR_LARB25_CAMSV>,
				<&camsys_mraw_clk CAM_MR_LARB26_CAMSV>,
				<&camsys_mraw_clk CAM_MR_LARB25_SMI>,
				<&camsys_mraw_clk CAM_MR_LARB26_SMI>,
				<&camsys_mraw_clk CAM_MR_PDA0_PDA>,
				<&camsys_mraw_clk CAM_MR_PDA1_PDA>;
			clock-names = "camsys_vcore_g_cam_vcore",
				"camsys_vcore_tx6_gals",
				"camsys_vcore_tx47_gals",
				"camsys_vcore_sub_comm0",
				"camsys_vcore_sub_comm2",
				"camsys_vcore_x46_gals",
				"camsys_vcore_x53_gals",
				"camsys_main_cam",
				"camsys_main_cam_cvfs_con_1",
				"cksys_mm_camtm_sel",
				"mraw_larb25_camsv",
				"mraw_larb26_camsv",
				"mraw_larb25_smi",
				"mraw_larb26_smi",
				"camsys_mraw_pda0",
				"camsys_mraw_pda1";
			mediatek,smmu-dma-axid =
				<SMMU_L25_P5_PDA_0_RDMA0>,
				<SMMU_L25_P6_PDA_0_RDMA1>,
				<SMMU_L25_P7_PDA_0_RDMA2>,
				<SMMU_L25_P8_PDA_0_RDMA3>,
				<SMMU_L25_P9_PDA_0_RDMA4>,
				<SMMU_L25_P11_PDA_0_WDMA>;
			mediatek,cam-bwr = <&cam_bwr>;
			mmqos-supply = <&mmqos>;
			interconnects =
				<&mmqos MASTER_LARB_PORT(SMMU_L25_P5_PDA_0_RDMA0)
						&mmqos SLAVE_COMMON(1)>,
				<&mmqos MASTER_LARB_PORT(SMMU_L25_P6_PDA_0_RDMA1)
						&mmqos SLAVE_COMMON(1)>,
				<&mmqos MASTER_LARB_PORT(SMMU_L25_P7_PDA_0_RDMA2)
						&mmqos SLAVE_COMMON(1)>,
				<&mmqos MASTER_LARB_PORT(SMMU_L25_P8_PDA_0_RDMA3)
						&mmqos SLAVE_COMMON(1)>,
				<&mmqos MASTER_LARB_PORT(SMMU_L25_P9_PDA_0_RDMA4)
						&mmqos SLAVE_COMMON(1)>,
				<&mmqos MASTER_LARB_PORT(SMMU_L25_P11_PDA_0_WDMA)
						&mmqos SLAVE_COMMON(1)>;
			interconnect-names =
				"l25_pdai_a0",
				"l25_pdai_a1",
				"l25_pdai_a2",
				"l25_pdai_a3",
				"l25_pdai_a4",
				"l25_pdao_a";
		};

		pda: pda@3a670000 {
			#address-cells = <2>;
			#size-cells = <2>;
			compatible = "mediatek,camera-pda";
			reg = <0 0x3a670000 0 0x1000>;
			dma-ranges = <0x0 0x0 0x0 0x0 0x4 0x0>;
			interrupts = <GIC_SPI 612 IRQ_TYPE_LEVEL_HIGH 0>;
			mtk,smmu-shared = <&mm_smmu_cam>;
			mediatek,larbs = <&smi_larb26>;
			mediatek,camisp-vcore = <&camisp_vcore>;
			clocks = <&cam_main_r1a_clk CAM_M_CAM_CAM_MAIN>,
				<&cam_main_r1a_clk CAM_M_CAM_CVFS_CON_1_CAM_MAIN>,
				<&cksys_mm_clk CKSYS_MM_CAMTM_SEL>,
				<&camsys_mraw_clk CAM_MR_LARB25_CAMSV>,
				<&camsys_mraw_clk CAM_MR_LARB26_CAMSV>,
				<&camsys_mraw_clk CAM_MR_LARB25_SMI>,
				<&camsys_mraw_clk CAM_MR_LARB26_SMI>,
				<&camsys_mraw_clk CAM_MR_PDA0_PDA>,
				<&camsys_mraw_clk CAM_MR_PDA1_PDA>;
			clock-names = "camsys_main_cam",
					"camsys_main_cam_cvfs_con_1",
					"cksys_mm_camtm_sel",
					"mraw_larb25_camsv",
					"mraw_larb26_camsv",
					"mraw_larb25_smi",
					"mraw_larb26_smi",
					"camsys_mraw_pda0",
					"camsys_mraw_pda1";
			mediatek,smmu-dma-axid =
					<SMMU_L26_P4_PDA_1_RDMA0>,
					<SMMU_L26_P5_PDA_1_RDMA1>,
					<SMMU_L26_P6_PDA_1_RDMA2>,
					<SMMU_L26_P7_PDA_1_RDMA3>,
					<SMMU_L26_P8_PDA_1_RDMA4>,
					<SMMU_L26_P10_PDA_1_WDMA>;
			mediatek,cam-bwr = <&cam_bwr>;
			mmqos-supply = <&mmqos>;
			interconnects =
				<&mmqos MASTER_LARB_PORT(SMMU_L26_P4_PDA_1_RDMA0)
						&mmqos SLAVE_COMMON(1)>,
				<&mmqos MASTER_LARB_PORT(SMMU_L26_P5_PDA_1_RDMA1)
						&mmqos SLAVE_COMMON(1)>,
				<&mmqos MASTER_LARB_PORT(SMMU_L26_P6_PDA_1_RDMA2)
						&mmqos SLAVE_COMMON(1)>,
				<&mmqos MASTER_LARB_PORT(SMMU_L26_P7_PDA_1_RDMA3)
						&mmqos SLAVE_COMMON(1)>,
				<&mmqos MASTER_LARB_PORT(SMMU_L26_P8_PDA_1_RDMA4)
						&mmqos SLAVE_COMMON(1)>,
				<&mmqos MASTER_LARB_PORT(SMMU_L26_P10_PDA_1_WDMA)
						&mmqos SLAVE_COMMON(1)>;
			interconnect-names = "l26_pdai_b0",
						"l26_pdai_b1",
						"l26_pdai_b2",
						"l26_pdai_b3",
						"l26_pdai_b4",
						"l26_pdao_b";
		};

		/* ATF logger */
		atf_logger: atf-logger {
			compatible = "mediatek,tfa_debug";
		};

		flashlight_core: flashlight-core {
			compatible = "mediatek,flashlight_core";
			low-battery-level = <5>;
			battery-percent-level = <2>;
			battery-oc-level = <5>;
		};

		mtk_composite_v4l2_1: mtk-composite-v4l2-1 {
			compatible = "mediatek,mtk_composite_v4l2_1";
			port@0 {
				flashlight_0: endpoint {
					remote-endpoint = <&fl_core_0>;
				};
			};
			port@1 {
				flashlight_1: endpoint {
					remote-endpoint = <&fl_core_1>;
				};
			};
			port@2 {
				flashlight_2: endpoint {
					remote-endpoint = <&fl_core_2>;
				};
			};
		};

		mtk_composite_v4l2_2: mtk-composite-v4l2-2 {
			compatible = "mediatek,mtk_composite_v4l2_2";
		};

		qos:qos@11bb00 {
			compatible = "mediatek,mt6893-qos";
			reg = <0 0x0011bb00 0 0x100>,
				<0 0x0011b8dc 0 0x224>,
				<0 0x0011b920 0 0x0>,
				<0 0x0011b864 0 0x18>;
		reg-names = "sram", "share_sram", "share_sram_ext", "share_sram_dbg";
			mediatek,enable = <1>;
		};

		cm_mgr: cm-mgr@c100000 {
			compatible = "mediatek,mt6993-cm_mgr";
			reg = <0 0xc100000 0 0x9000>;
			reg-names = "cm_mgr_base";
			interconnects = <&dvfsrc MT6873_MASTER_MCU_1 &dvfsrc MT6873_SLAVE_DDR_EMI>;
			interconnect-names = "cm-perf-bw";
			required-opps = <&dvfsrc_freq_opp0>,
				<&dvfsrc_freq_opp1>,
				<&dvfsrc_freq_opp2>,
				<&dvfsrc_freq_opp3>,
				<&dvfsrc_freq_opp4>,
				<&dvfsrc_freq_opp5>,
				<&dvfsrc_freq_opp6>,
				<&dvfsrc_freq_opp7>,
				<&dvfsrc_freq_opp8>,
				<&dvfsrc_freq_opp9>;
			cm-mgr-enable = <1>;
			cm-mgr-arch = "v1p";
			cm-mgr-num-array = <7>;
			cm-mgr,cp-down  = <100 100 100 100 100 100 100>;
			cm-mgr,cp-up = <100 100 100 100 100 100 100>;
			cm-mgr,dt-down = <0 0 0 0 0 0 0>;
			cm-mgr,dt-up = <0 0 0 0 0 0 0>;
			cm-mgr,vp-down = <100 100 100 100 100 100 100>;
			cm-mgr,vp-up = <100 100 100 100 100 100 100>;

			use-cpu-to-dram-map = "disable";
			use-cpu-to-dram-map-new = "disable";
			cm-mgr-cpu-opp-to-dram = <3 3 9 9 9 9 9 9
						9 9 9 9 9 9 9 9
						9 9 9 9 9 9 9 9
						9 9 9 9 9 9 9 9>;
		   cm-perf-mode-enable = <1>;
		   cm-perf-mode-ceiling-opp = <0>;
		   cm-perf-mode-thd = <5>;
		};

		mtee_svp: mtee-svp {
			compatible = "medaitek,svp";
		};

		drm_wv: drm-wv {
			compatible = "mediatek,drm_wv";
			status = "okay";
		};

		fpsgo: fpsgo {
			compatible = "mediatek,fpsgo";
			cpu-limit = <2>;
			fbt-cpu-mask = <255 128 15 127 240 112>;
		};

		smmu_hyp_vms: smmu-hyp-vms {
			compatible = "mtk,smmu-hyp-vms";
			/* vm-no-map-ranges = <IPA.high IPA.low size.high size.low> */
			vm-no-map-ranges = <0x0 0x10700000 0x0 0x00100000>;
			s2-bypass-sid = <255>;

			linux-vm-0 {
				compatible = "mtk,smmu-vm";
				vmid = <0x0>;
				/* ipa-granule (test or debug only): 1=2M;2=4KB */
				/* ipa-granule = <2>; */
				/* identity-map(IPA=PA) = <IPA.high IPA.low size.high size.low> */
				/* 0 ~ 0x40000000 sram , dram pa max support 0x800000000-1 (35-bit) */
				identity-map = /bits/ 64 <0x80000000 0x780000000>,
					/bits/ 64 <0x880000000 0x40000000>; /* emi slb buffer */
				identity-map-mode = <0x7>; /* 0x7 = rwx */
			};

			protected-vm-1 {
				compatible = "mtk,smmu-vm";
				vmid = <0x1>;
				sid = <2 16 137 138 139 145 147 161 177 209 211>;
				/* identity-map(IPA=PA) = <IPA.high IPA.low size.high size.low> */
				identity-map = /bits/ 64 <0x80000000 0x780000000>,
					/bits/ 64 <0x880000000 0x40000000>; /* emi slb buffer */
				identity-map-mode = <0x1>; /* 0x1 = r */
				identity-map-mblock = "mediatek,me_GPUmputab_PMA";
			};
		};

		mtk-iommu-debug {
			compatible = "mediatek,mt6993-smmu-debug";
		};

		mtk-hwzram {
			compatible = "mediatek,mtk-hwzram";

			reg =
				<0 0x1c004000 0 0xc000>,	/* ZRAM_PM */
				<0 0x14c00000 0 0x1000>,	/* ZRAM_CONFIG */
				<0 0x14c60000 0 0x20000>,	/* ZRAM_SMMU */
				<0 0x14c80000 0 0x10000>,	/* ZRAM_DEC */
				<0 0x14ca0000 0 0x10000>;	/* ZRAM_ENC */

			reg-names =
				"zram_pm",
				"zram_config",
				"zram_smmu",
				"zram_dec",
				"zram_enc";

			/* ESPI: 4147 ~ */
			interrupts =
				<2 51 IRQ_TYPE_LEVEL_HIGH 0>,
				<2 52 IRQ_TYPE_LEVEL_HIGH 0>,
				<2 55 IRQ_TYPE_LEVEL_HIGH 0>,
				<2 56 IRQ_TYPE_LEVEL_HIGH 0>;

			interrupt-names =
				"zram_enc_irq",
				"zram_dec_irq",
				"zram_smmu_tbu_0_irq",
				"zram_smmu_tbu_1_irq";

			/* Clock source */
			clocks = <&cksys_top_clk CKSYS_TOP_ZRAM_SUB_SEL>,
			       <&cksys_top_clk CKSYS_TOP_MAINPLL_D5_D2>,
			       <&cksys_top_clk CKSYS_TOP_MAINPLL_D6>,
			       <&cksys_top_clk CKSYS_TOP_MAINPLL_D5>,
			       <&cksys_top_clk CKSYS_TOP_MAINPLL_D4>,
			       <&cksys_top_clk CKSYS_TOP_MAINPLL_D3>;

			clock-names = "source",
				"gear_3",
				"gear_4",
				"gear_5",
				"gear_6",
				"gear_7";

			/* for clock scaling vcore voting */
			dvfsrc-vcore-supply = <&dvfsrc_vcore>;

			vcore-volts = <575000 600000 650000 725000 825000>;

			/* default gear level */
			default-gear = <6>;

			/* iommus */
			iommus = <&soc_smmu 0x40>;
			mtk,smmu-dma-mode = "disable";
			dma-coherent;
		};

		emi-pctrl {
			compatible = "mediatek,emi-pctrl";
			reg = <0 0x1102c000 0 0x1000>;
		};

		dvm-mi {
			compatible = "mediatek,dvm-mi";
			reg = <0 0x1102a000 0 0x1000>;
		};

		/* smmu mpam */
		soc-smmu-mpam-mon {
			compatible = "mtk,smmu-v3-mpam-mon";
			mtk,smmu = <&soc_smmu>;
		};

		apu-smmu-mpam-mon {
			compatible = "mtk,smmu-v3-mpam-mon";
			mtk,smmu = <&apu_smmu>;
		};

		mm-smmu-mpam-mon {
			compatible = "mtk,smmu-v3-mpam-mon";
			mtk,smmu = <&mm_smmu>;
		};

		gpu-smmu-mpam-mon {
			compatible = "mtk,smmu-v3-mpam-mon";
			mtk,smmu = <&gpu_smmu>;
		};

		mtk-smmu-qos {
			compatible = "mediatek,smmu-qos";
		};

		mtk_smmu_granule: mtk-smmu-granule {
			mtk,gran4k-only = <0>;
		};

		mkp {
			compatible = "mediatek,mkp-drv";
			memory-region = <&mkp_mem>;
		};

		/* dmaheap */
		mtkheap-slc {
			compatible = "mediatek,dmaheap-mtk-slc";
			heap-name = "mtk_slc";
		};

		mtkheap-mm-coherent {
			compatible = "mediatek,dmaheap-mtk-mm-coherent";
			heap-name = "mtk_mm-coherent";
		};

		mtkheap-page-prot {
			compatible = "mediatek,dmaheap-mtk-sec-page";
			heap-name = "mtk_prot_page-uncached";
			trusted-mem-type = <10>;
		};

		mtkheap-region-prot {
			compatible = "mediatek,dmaheap-mtk-sec-region";
			heap-name = "mtk_prot_region";
			trusted-mem-type = <1>;
			region-heap-align-name = "mtk_prot_region-aligned";
			mtk,smmu-shared = <&mm_smmu_cam_protected>;
		};

		mtkheap-page-sapu {
			compatible = "mediatek,dmaheap-mtk-sec-page";
			heap-name = "mtk_sapu_page-uncached";
			trusted-mem-type = <14>;
		};

		mtkheap_page_svp: mtkheap-page-svp {
			compatible = "mediatek,dmaheap-mtk-sec-page";
			heap-name = "mtk_svp_page-uncached";
			trusted-mem-type = <9>;
			status = "disabled";
		};

		mtkheap_page_wfd: mtkheap-page-wfd {
			compatible = "mediatek,dmaheap-mtk-sec-page";
			heap-name = "mtk_wfd_page-uncached";
			trusted-mem-type = <11>;
			status = "disabled";
		};

		mtkheap_region_svp: mtkheap-region-svp {
			compatible = "mediatek,dmaheap-mtk-sec-region";
			heap-name = "mtk_svp_region";
			trusted-mem-type = <0>;
			region-heap-align-name = "mtk_svp_region-aligned";
			mtk,smmu-shared = <&mm_smmu_codec_protected>;
			status = "disabled";
		};

		mtkheap_region_wfd: mtkheap-region-wfd {
			compatible = "mediatek,dmaheap-mtk-sec-region";
			heap-name = "mtk_wfd_region";
			trusted-mem-type = <2>;
			region-heap-align-name = "mtk_wfd_region-aligned";
			mtk,smmu-shared = <&mm_smmu_codec_protected>;
			status = "disabled";
		};

		mtkheap_region_tui: mtkheap-region-tui {
			compatible = "mediatek,dmaheap-mtk-sec-region";
			heap-name = "mtk_tui_region";
			trusted-mem-type = <8>;
			region-heap-align-name = "mtk_tui_region-aligned";
			mtk,smmu-shared = <&mm_smmu_svp_disp>;
			status = "disabled";
		};

		/* dmaheap test */
		mtk_dmabufheap_debug0: dmaheap-test0 {
			compatible = "mediatek, mtk_dmabufheap, iommu0";
			mtk,smmu-shared = <&mm_smmu_disp>;
		};

		mtk_dmabufheap_debug1: dmaheap-test1 {
			compatible = "mediatek, mtk_dmabufheap, iommu1";
			mtk,smmu-shared = <&mm_smmu_svp_disp>;
		};

		mtk_dmabufheap_debug2: dmaheap-test2 {
			compatible = "mediatek, mtk_dmabufheap, coherent";
			mtk,smmu-shared = <&mm_smmu_acp_cam>;
		};

		/* smmu test */
		disp_fake_eng_pwr: disp-fake-eng-pwr {
			clocks = <&disp_vdisp_ao_config_clk VDISP_AO_DISP_DPC_DISP>,
				<&disp_vdisp_ao_config_clk VDISP_AO_DISP_BUS_DISP>,
				<&ovlsys_config_clk OVL_SMI_SUB_COMM0_DISP>,
				<&ovlsys_config_clk OVL_FAKE_ENG0_DISP>,
				<&ovlsys_config_clk OVL_FAKE_ENG1_DISP>;
			clock-names = "CLK_DISP_VCORE",
				"CLK_VDISP_PERI",
				"CLK_OVL0",
				"CLK_OVL0_FAKE_ENG0",
				"CLK_OVL0_FAKE_ENG1";
		};

		smmu-test-ktf1 {
			compatible = "mediatek,mm-smmu-test-ktf1";
			dma-mmap-reg = <0x32900000 0x1000>;
			dma-mmap-offset = <0x70>;
			mtk,smmu-shared = <&mm_smmu_disp>;
			mediatek,larbs-port = <SMMU_L0_P8_OVL_FAKE_ENG0>;
			pwr-handle = <&disp_fake_eng_pwr>;
		};

		smmu-test-ktf2 {
			compatible = "mediatek,mm-smmu-test-ktf2";
			mtk,smmu-shared = <&mm_smmu_svp_disp>;
		};

		smmu-test-ktf3 {
			#address-cells = <1>;
			#size-cells = <1>;
			compatible = "mediatek,mm-smmu-test-ktf3";
			iommus = <&mm_smmu 224>;
			mtk,iommu-dma-range = <0x40000000 0x10000000>;
			mtk,smmu-dma-mode = "bypass";
		};

		smmu-test-ktf4 {
			compatible = "mediatek,mm-smmu-test-ktf4";
			mtk,smmu-dma-mode = "disable";
			iommus = <&mm_smmu 225>;
		};

		smmu-test-ktf5 {
			compatible = "mediatek,mm-coherent-test-ktf";
			mtk,smmu-shared = <&mm_smmu_acp_disp>;
		};

		smmu-test-ktf6 {
			compatible = "mediatek,mm-dynamic-test-ktf";
			dynamic-iommu {
				#address-cells = <1>;
				#size-cells = <1>;
				compatible = "mediatek,mm-dynamic-iommu-ktf";
				iommus = <&mm_smmu 226>;
				mtk,iommu-dma-range = <0x40000000 0x10000000>;
			};
		};

		smmu-test-ktf7 {
			compatible = "mediatek,mm-ssid-test-ktf";
			iommus = <&mm_smmu 227>;
			pasid-num-bits = <8>;
			mtk,smmu-ssids {
				#address-cells = <2>;
				#size-cells = <2>;
				mtk,iommu-dma-range = <0x0 0x40000000 0x0 0x80000000>;
				mtk,smmu-ssid-range = <1 255>;
				smmu-ssid1 {
					#address-cells = <2>;
					#size-cells = <2>;
					ssid = <1>;
					mtk,iommu-dma-range = <0x1 0x10000000 0x0 0x40000000>;
				};
				smmu-ssid2 {
					ssid = <2>;
					mtk,iommu-dma-range = <0x2 0x10000000 0x0 0x40000000>;
				};
				smmu-ssid3 {
					ssid = <3>;
				};
			};
		};


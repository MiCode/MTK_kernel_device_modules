		touch_tui0: touch-tui0 {
			compatible = "mediatek,tui_common";
		};

		pps: pps {
			compatible = "pps-gpio";
		};

		nebula_mbox: nebula-mbox@0 {
			compatible = "grt,ipc-mbox";
			#mbox-cells = <1>;
			status = "disabled";
		};

		pwritg: pwritg {
			compatible = "simple-bus";
			#address-cells = <1>;
			#size-cells = <0>;
			status = "disabled";
		};

		power_service: power-service {
			compatible = "grt,power-service";
			mboxes = <&nebula_mbox 0>, /*channel 0*/
				<&nebula_mbox 1>, /*channel 1*/
				<&nebula_mbox 2>, /*channel 2*/
				<&nebula_mbox 3>, /*channel 3*/
				<&nebula_mbox 4>; /*channel 4*/
			status = "disabled";
		};


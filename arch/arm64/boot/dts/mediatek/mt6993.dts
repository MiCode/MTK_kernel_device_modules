			status = "okay";
			type = <5>;
			mask = /bits/ 64 <0x00000003ffffffff>;
			mtk,iommu-group = <&apu_iommu_group_1>;
			iommus = <&apu_smmu 0x15>;
			dma-coherent;
			pasid-num-bits = <8>;
			mtk,smmu-ssids {

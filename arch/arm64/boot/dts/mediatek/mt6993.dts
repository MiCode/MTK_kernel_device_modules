		};

		disp_postmask0: disp-postmask0@3e3d0000 {
			compatible = "mediatek,disp_postmask0",
						"mediatek,mt6993-disp-postmask";
			reg = <0 0x3e3d0000 0 0x1000>;
			clocks = <&dispsys_config_clk MM0_DISP_POSTMASK0_DISP>;

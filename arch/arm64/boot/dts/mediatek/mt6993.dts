&spmi {
        pmic: mt6661-4@4 {
		mt6661_dynamic_loading_throttling: mtk-dynamic-loading-throttling {
			compatible = "mediatek,mt6661-dynamic_loading_throttling";
			/* charger: mtk_charger_thread */
			mediatek,charger = <&lk_charger>;
			/* 1700~2700mV, one gear per 100mV */
			uvlo-level = <2000>;
			vbb-uvlo-level = <2700>;
			io-channels = <&mt6379_auxadc_1 MT6379_AUXADC_IMP>,
				      <&mt6379_auxadc_1 MT6379_AUXADC_IMIX_R>,
				      <&mt6379_auxadc_1 MT6379_AUXADC_BATSNS>;
			io-channel-names = "pmic_ptim",
					"pmic_imix_r",
					"pmic_batadc";
			bootmode = <&chosen>;
		};
	};
};

&mt6661_4 {
	pmic-lvsys-notify {
		compatible = "mediatek,mt6661-lvsys-notify";
		lvsys-thd-volt-l-size = <2>;
		lvsys-thd-volt-h-size = <2>;
		thd-volts-l = <3400 3100>;
		thd-volts-h = <3500 3200>;
		lv-deb-sel = <0>;
		hv-deb-sel = <3>;
		vio18-switch-reg = <0x53 0x58>;
		io-channels = <&mt6661_6_auxadc AUXADC_VSYSSNS>;
		io-channel-names = "pmic_vsys";
	};
};

/* clear in APU  */
&mt6661_3 {
	mtk-spmi-pmic-debug {
		rgs-npkt-cclp-clr-enable = <0>;
	};
};
#include "mediatek/mt6993-clkitg.dtsi"
#include "mediatek/mt6993-coresight.dtsi"
#include "mediatek/mt6993-disable-unused.dtsi"
#include "mediatek/mt6993-disp-unused.dtsi"

/* WF GPIO start */
&pio {
	wf_rst_off: wf-rst-off {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO250__FUNC_GPIO250>;
			output-low;
		};
	};
	wf_rst_on: wf-rst-on {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO250__FUNC_GPIO250>;
			output-high;
		};
	};
	wf_rst_pta_uart_init: wf-rst-pta-uart-init {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO235__FUNC_GPIO235>;
			input-enable;
			bias-pull-down;
		};
		pins-cmd2-dat {
			pinmux = <PINMUX_GPIO236__FUNC_GPIO236>;
			input-enable;
			bias-pull-down;
		};
	};
	wf_rst_pta_uart_on: wf-rst-pta-uart-on {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO235__FUNC_PTA_TXD0>;
			output-low;
		};
		pins-cmd2-dat {
			pinmux = <PINMUX_GPIO236__FUNC_PTA_RXD0>;
			input-enable;
			bias-pull-down;
		};
	};
	wf_rst_pta_uart_off: wf-rst-pta-uart-off {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO235__FUNC_GPIO235>;
			input-enable;
			bias-pull-down;
		};
		pins-cmd2-dat {
			pinmux = <PINMUX_GPIO236__FUNC_GPIO236>;
			input-enable;
			bias-pull-down;
		};
	};
};
/* WF GPIO end */

/* BT combo GPIO start */
&pio {
	bt_combo_gpio_init: bt-combo-gpio-init {
		/* BT_UTXD, GPIO237 */
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO241__FUNC_GPIO241>;
			input-enable;
			bias-pull-down;
		};
		/* BT_URXD, GPIO238 */
		pins-cmd2-dat {
			pinmux = <PINMUX_GPIO242__FUNC_GPIO242>;
			input-enable;
			bias-pull-down;
		};
	};
	bt_combo_gpio_pre_on: bt-combo-gpio-pre-on {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO241__FUNC_GPIO241>;
			input-enable;
			bias-pull-up;
		};
		pins-cmd2-dat {
			pinmux = <PINMUX_GPIO242__FUNC_GPIO242>;
			input-enable;
			bias-pull-up;
		};
	};
	bt_combo_uart_tx_aux: bt-combo-uart-tx-aux {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO241__FUNC_CONN_UARTHUB_UART_TX>;
		};
	};
	bt_combo_uart_rx_aux: bt-combo-uart-rx-aux {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO242__FUNC_CONN_UARTHUB_UART_RX>;
		};
	};
	bt_rst_on: bt-rst-on {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO249__FUNC_GPIO249>;
			output-high;
		};
	};
	bt_rst_off: bt-rst-off {
		pins-cmd1-dat {
			pinmux = <PINMUX_GPIO249__FUNC_GPIO249>;
			output-low;
		};
	};
};
/* BT combo GPIO end */


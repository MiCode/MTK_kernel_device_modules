			mtk,smmu-shared = <&mm_smmu_codec>;
			//mtk,smmu-shared = <&mm_smmu_hfrp>;
			mediatek,larb = <&smi_larb42>;
			operating-points-v2 = <&opp_table_venc>;
			mmqos-supply = <&mmqos>;
			ports =
				<SMMU_L42_P4_JPGENC_Y_RDMA_C1>,
				<SMMU_L42_P5_JPGENC_C_RDMA_C1>,
				<SMMU_L42_P6_JPGENC_BS_C1>,
				<SMMU_L42_P7_JPGENC_Q_TABLE_C1>;
			interconnects = <&mmqos MASTER_LARB_PORT(SMMU_L42_P4_JPGENC_Y_RDMA_C1)
							&mmqos SLAVE_COMMON(0)>,
						<&mmqos MASTER_LARB_PORT(SMMU_L42_P5_JPGENC_C_RDMA_C1)
							&mmqos SLAVE_COMMON(0)>,
						<&mmqos MASTER_LARB_PORT(SMMU_L42_P7_JPGENC_Q_TABLE_C1)
							&mmqos SLAVE_COMMON(0)>,
						<&mmqos MASTER_LARB_PORT(SMMU_L42_P6_JPGENC_BS_C1)
							&mmqos SLAVE_COMMON(0)>;
			interconnect-names = "path_jpegenc_y_rdma",
					"path_jpegenc_c_rmda",
					"path_jpegenc_q_table",
					"path_jpegenc_bsdma";
			axdomain = <224>;
			clock-set = <832000000>;
			ccf-one-step;
			need-resource-set = <1>;
			mmqos-level;
			yuv422-bw = <2867000>;
			yuv420-bw = <4096000>;
		};


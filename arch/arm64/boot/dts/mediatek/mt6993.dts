/dts-v1/;
#include <dt-bindings/clock/mt6993-clk.h>
#include <dt-bindings/iio/mt635x-auxadc.h>
#include <dt-bindings/interrupt-controller/arm-gic.h>
#include <dt-bindings/interrupt-controller/irq.h>
#include <dt-bindings/leds/common.h>
#include <dt-bindings/memory/mt6993-larb-port.h>
#include <dt-bindings/mmdvfs/mmdvfs-clk-mt6993.h>
#include <dt-bindings/mminfra/mminfra-mt6993.h>
#include <dt-bindings/phy/phy.h>
#include <dt-bindings/pinctrl/mt6993-pinfunc.h>
#include <dt-bindings/reset/ti-syscon.h>
#include <dt-bindings/soc/mediatek,boot-mode.h>
#include <dt-bindings/spmi/spmi.h>
#include <dt-bindings/interconnect/mtk,emi.h>
#include <dt-bindings/memory/mt6993-smi-pd.h>
#include <dt-bindings/memory/mtk-smi-user.h>
#include <dt-bindings/gce/mt6993-gce.h>
#include <dt-bindings/mml/mml-mt6993.h>
#include <dt-bindings/mminfra/mminfra-mt6993.h>
#include <dt-bindings/mfd/mt6379.h>
#include <dt-bindings/iio/adc/mediatek,mt6379_auxadc.h>
#include <dt-bindings/iio/adc/mediatek,mt6379_adc.h>
#include <dt-bindings/power/mt6375-gauge.h>
#include <dt-bindings/power/mtk-charger.h>
#include <dt-bindings/interconnect/mtk,mmqos.h>

/ {
	model = "MT6993";
	compatible = "mediatek,MT6993";
	interrupt-parent = <&gic>;
	#address-cells = <2>;
	#size-cells = <2>;

	aliases {
		i2c0 = &i2c0;
		i2c1 = &i2c1;
		i2c2 = &i2c2;
		i2c3 = &i2c3;
		i2c4 = &i2c4;
		i2c5 = &i2c5;
		i2c6 = &i2c6;
		i2c7 = &i2c7;
		i2c8 = &i2c8;
		i2c9 = &i2c9;
		i2c10 = &i2c10;
		i2c11 = &i2c11;
		i2c12 = &i2c12;
		i2c13 = &i2c13;
		i2c14 = &i2c14;
		scp-i2c1 = &scp_i2c1;
		i3c0 = &i2c0;
		i3c1 = &i2c1;
		i3c2 = &i2c2;
		i3c4 = &i2c4;
		i3c7 = &i2c7;
		i3c8 = &i2c8;
		i3c9 = &i2c9;
		mtksmmu0 = &mm_smmu;
		mtksmmu1 = &apu_smmu;
		mtksmmu2 = &soc_smmu;
		mtksmmu3 = &gpu_smmu;
/*
		//need to maintain to 6993
		dli-async13 = &ovl_dli_async1;
		wdma4 = &disp_wdma4;
		disp-dvo0 = &disp_dvo0;
		dsi0 = &dsi0;
		dsi1 = &dsi1;
		dsi2 = &dsi2;
		y2r0 = &disp_y2r0;
		mdp-rdma0 = &disp_mdp_rdma0;
		mutex0 = &disp1_mutex0;
		wdma10 = &ovl_wdma0;
		wdma11 = &ovl_wdma1;
		wdma12 = &ovl1_wdma0;
		wdma13 = &ovl1_wdma1;
		dp-intf0 = &disp1_dp_intf0;
		dp-intf1 = &disp1_dp_intf1;
		dsc1 = &disp_dsc_wrap1;
		dsc2 = &disp_dsc_wrap2;
		dsc3 = &disp_dsc_wrap3;
*/
		exdma0 = &disp_ovl0_exdma0;
		exdma2 = &disp_ovl0_exdma2;
		disp-dvo1 = &disp_dvo1;
		exdma3 = &disp_ovl0_exdma3;
		exdma4 = &disp_ovl0_exdma4;
		exdma5 = &disp_ovl0_exdma5;
		exdma6 = &disp_ovl0_exdma6;
		exdma7 = &disp_ovl0_exdma7;
		exdma12 = &disp_ovl1_exdma2;
		exdma13 = &disp_ovl1_exdma3;
		exdma14 = &disp_ovl1_exdma4;
		exdma15 = &disp_ovl1_exdma5;
		exdma16 = &disp_ovl1_exdma6;
		exdma17 = &disp_ovl1_exdma7;
		exdma22 = &disp_ovl2_exdma2;
		exdma23 = &disp_ovl2_exdma3;
		exdma24 = &disp_ovl2_exdma4;
		exdma25 = &disp_ovl2_exdma5;
		blender0 = &disp_ovl0_blender0;
		blender1 = &disp_ovl0_blender1;
		blender2 = &disp_ovl0_blender2;
		blender3 = &disp_ovl0_blender3;
		blender4 = &disp_ovl0_blender4;
		blender5 = &disp_ovl0_blender5;
		blender6 = &disp_ovl0_blender6;
		blender7 = &disp_ovl0_blender7;
		blender10 = &disp_ovl1_blender0;
		blender11 = &disp_ovl1_blender1;
		blender12 = &disp_ovl1_blender2;
		blender13 = &disp_ovl1_blender3;
		blender14 = &disp_ovl1_blender4;
		blender15 = &disp_ovl1_blender5;
		blender16 = &disp_ovl1_blender6;
		blender17 = &disp_ovl1_blender7;
		blender20 = &disp_ovl2_blender0;
		blender21 = &disp_ovl2_blender1;
		blender22 = &disp_ovl2_blender2;
		blender23 = &disp_ovl2_blender3;
		outproc0 = &disp_ovl0_outproc0;
		outproc1 = &disp_ovl0_outproc1;
		outproc2 = &disp_ovl0_outproc2;
		outproc3 = &disp_ovl0_outproc3;
		outproc6 = &disp_ovl1_outproc0;
		outproc7 = &disp_ovl1_outproc1;
		outproc8 = &disp_ovl1_outproc2;
		outproc9 = &disp_ovl1_outproc3;
		outproc12 = &disp_ovl2_outproc0;
		outproc13 = &disp_ovl2_outproc1;
		outproc14 = &disp_ovl2_outproc2;
		ovl0-dlo-async12= &ovl0_dlo_async12;
		ovl1-dlo-async12= &ovl1_dlo_async12;
		ovl1-dlo-async14= &ovl1_dlo_async14;
		ovl2-dlo-async12 = &ovl2_dlo_async12;
		dli-async0 = &dli_async0;
		dlo-async0 = &dlo_async0;
		dli-async11 = &dli_async11;
		dli-async12 = &dli_async12;
		dli-async20 = &dli_async20;
		dlo-async16 = &dlo_async16;
		dli-async29 = &dli_async29;
		dlo-async1 = &dlo_async1;
		dlo-async2 = &dlo_async2;
		dlo-async3 = &dlo_async3;
		dlo-async4 = &dlo_async4;
		dli-async21 = &dli_async21;
		dli-async22 = &dli_async22;
		dli-async23 = &dli_async23;
		dli-async24 = &dli_async24;
		dlo-async17 = &dlo_async17;
		dli-async30 = &dli_async30;
		dli-async-b0 = &dli_async0_b;
		dli-async-b2 = &dli_async2_b;
		dlo-async-b0 = &dlo_async0_b;
		dlo-async-b11 = &dlo_async11_b;
		dlo-async-b12 = &dlo_async12_b;
		dli-async-b20 = &dli_async20_b;
		relay5 = &disp_relay5;
		tdshp0 = &disp_tdshp0;
		tdshp4 = &disp_tdshp1;
		color0 = &disp_color0;
		color3 = &disp_color1;
		ccorr0 = &disp_ccorr0;
		ccorr1 = &disp_ccorr1;
		ccorr8 = &disp_ccorr2;
		ccorr9 = &disp_ccorr3;
		c3d0 = &disp_c3d0;
		c3d1 = &disp_c3d1;
		c3d4 = &disp_c3d2;
		c3d5 = &disp_c3d3;
		aal0 = &disp_aal0;
		aal2 = &disp_aal1;
		maal0 = &disp_mdp_aal0;
		maal2 = &disp_mdp_aal1;
		gamma0 = &disp_gamma0;
		gamma4 = &disp_gamma1;
		dither0 = &disp_dither0;
		dither1 = &disp_dither1;
		dither4 = &disp_dither2;
		dither5 = &disp_dither3;
		chist0 = &disp_chist0;
		chist1 = &disp_chist1;
		spr0 = &disp_spr0;
		spr2 = &disp_spr2;
		postalign0 = &disp_postalign0;
		postalign2 = &disp_postalign2;
		oddmr0 = &disp_oddmr0;
		oddmr2 = &disp_oddmr2;
		dbi-count0 = &disp_dbi_count0;
		mdp-rsz0 = &disp_rsz0;
		mdp-rsz7 = &disp_rsz1;
		postmask0 = &disp_postmask0;
		postmask2 = &disp_postmask1;
		mdp-rsz2 = &ovl0_rsz0;
		mdp-rsz4 = &ovl1_rsz0;
		bwm0 = &disp_bwm0;
		dsc0 = &disp_dsc_wrap0;
		dsc1 = &disp_dsc_wrap1;
		dsi0 = &dsi0;
		dsi1 = &dsi1;
		mutex0 = &disp1_mutex0;
		wdma0 = &disp_wdma0;
		wdma1 = &disp_wdma1;
		ovl0-dli-async0 = &ovl_dli_async0;
		mml-mutex0 = &mml1_mutex0;
		mml-mutex1 = &mml2_mutex0;
		mml-wrot0 = &mml2_wrot0;
		mml-wrot1 = &mml2_wrot1;
		merge0 = &disp_merge0;
		splitter0 = &disp1_splitter0;
		splitter1 = &disp1_splitter1;
		gdma0 = &disp_gdma0;
	};

	aov: aov {
		compatible = "mediatek,aov";
		status = "okay";
		op-mode = <1>;
		mediatek,larbs-uisp = <&smi_larb27>;
		scp-dvfs-supply = <&scp_dvfs>;
		vcp-supply = <&vcp>;
		apu-supply = <&apusys_aov>;
		sensor-i2c = <&i2c2 &i2c4 &i2c9>;
		ulposc-support;
		base = <0x1c204000>;
		ver = "v2";
	};

	cache-parity {
		compatible = "mediatek,mt6985-cache-parity";
		ecc-irq-support = <1>;
		arm-dsu-ecc-hwirq = <62>;
		interrupts = <GIC_SPI 0 IRQ_TYPE_LEVEL_HIGH 0>, /* Core 0 Fault IRQ */
			<GIC_SPI 1 IRQ_TYPE_LEVEL_HIGH 0>, /* Core 1 Fault IRQ */
			<GIC_SPI 2 IRQ_TYPE_LEVEL_HIGH 0>, /* Core 2 Fault IRQ */
			<GIC_SPI 3 IRQ_TYPE_LEVEL_HIGH 0>, /* Core 3 Fault IRQ */
			<GIC_SPI 4 IRQ_TYPE_LEVEL_HIGH 0>, /* Core 4 Fault IRQ */
			<GIC_SPI 5 IRQ_TYPE_LEVEL_HIGH 0>, /* Core 5 Fault IRQ */
			<GIC_SPI 6 IRQ_TYPE_LEVEL_HIGH 0>, /* Core 6 Fault IRQ */
			<GIC_SPI 7 IRQ_TYPE_LEVEL_HIGH 0>, /* Core 7 Fault IRQ */
			<GIC_SPI 30 IRQ_TYPE_LEVEL_HIGH 0>; /* DSU Fault IRQ */
	};

	/* chosen */
	chosen: chosen {
		bootargs = "console=tty0 root=/dev/ram \
			    nosoftlockup \
			    8250.nr_uarts=4 \
			    androidboot.hardware=mt6993 \
			    android_arch_task_struct_size=512 \
			    vmalloc=400M swiotlb=noforce \
			    firmware_class.path=/vendor/firmware \
			    cgroup.memory=nosocket,nokmem \
			    disable_dma32=on \
			    transparent_hugepage=never \
			    arm64.nomops \
			    hyp_trace_printk hyp_event=__hyp_printk \
			    kvm-arm.hyp_lm_size_mb=2000 \
			    kvm-arm.protected_prefault=9 \
			    kvm-arm.protected_modules=pkvm_mgmt,pkvm_tmem,pkvm_smmu,pkvm_mkp,\
pkvm_seninf_6993,pkvm_cmdq";
		mkp_panic = "on";
	};

	cpus {
		#address-cells = <1>;
		#size-cells = <0>;

		/*TODO: check cpus node with Chip announcement wiki */
		cpu0: cpu@0 {
			device_type = "cpu";
			reg = <0x0000>;
			performance-domains = <&performance 0>;
			enable-method = "psci";
			cpu-idle-states = <&cpuoff_l &clusteroff_l &mcusysoff_l
						&system_vcore &s2idle>;
			capacity-dmips-mhz = <793>;
		};

		cpu1: cpu@1 {
			device_type = "cpu";
			reg = <0x0100>;
			performance-domains = <&performance 0>;
			enable-method = "psci";
			cpu-idle-states = <&cpuoff_l &clusteroff_l &mcusysoff_l
						&system_vcore &s2idle>;
			capacity-dmips-mhz = <793>;
		};

		cpu2: cpu@2 {
			device_type = "cpu";
			reg = <0x0200>;
			performance-domains = <&performance 0>;
			enable-method = "psci";
			cpu-idle-states = <&cpuoff_l &clusteroff_l &mcusysoff_l
						&system_vcore &s2idle>;
			capacity-dmips-mhz = <793>;
		};

		cpu3: cpu@3 {
			device_type = "cpu";
			reg = <0x0300>;
			performance-domains = <&performance 0>;
			enable-method = "psci";
			cpu-idle-states = <&cpuoff_l &clusteroff_l &mcusysoff_l
						&system_vcore &s2idle>;
			capacity-dmips-mhz = <793>;
		};

		cpu4: cpu@100 {
			device_type = "cpu";
			reg = <0x0400>;
			performance-domains = <&performance 1>;
			enable-method = "psci";
			cpu-idle-states = <&cpuoff_m &clusteroff_m &mcusysoff_m
						&system_vcore &s2idle>;
			capacity-dmips-mhz = <952>;
		};

		cpu5: cpu@101 {
			device_type = "cpu";
			reg = <0x0500>;
			performance-domains = <&performance 1>;
			enable-method = "psci";
			cpu-idle-states = <&cpuoff_m &clusteroff_m &mcusysoff_m
						&system_vcore &s2idle>;
			capacity-dmips-mhz = <952>;
		};

		cpu6: cpu@102 {
			device_type = "cpu";
			reg = <0x0600>;
			performance-domains = <&performance 1>;
			enable-method = "psci";
			cpu-idle-states = <&cpuoff_m &clusteroff_m &mcusysoff_m
						&system_vcore &s2idle>;
			capacity-dmips-mhz = <952>;
		};

		cpu7: cpu@200 {
			device_type = "cpu";
			reg = <0x0700>;
			performance-domains = <&performance 2>;
			enable-method = "psci";
			cpu-idle-states = <&cpuoff_b &clusteroff_b &mcusysoff_b
						&system_vcore &s2idle>;
			capacity-dmips-mhz = <1024>;
		};

		cpu-map {
			cluster0 {
				core0 {
					cpu = <&cpu0>;
				};
				core1 {
					cpu = <&cpu1>;
				};
				core2 {
					cpu = <&cpu2>;
				};
				core3 {
					cpu = <&cpu3>;
				};
			};

			cluster1 {
				core0 {
					cpu = <&cpu4>;
				};
				core1 {
					cpu = <&cpu5>;
				};
				core2 {
					cpu = <&cpu6>;
				};
			};

			cluster2 {
				core0 {
					cpu = <&cpu7>;
				};
			};
		};

		idle-states {
			entry-method = "arm,psci";
			cpuoff_l: cpuoff-l {
				compatible = "arm,idle-state";
				arm,psci-suspend-param = <0x00010000>;
				local-timer-stop;
				entry-latency-us = <97>;
				exit-latency-us = <178>;
				min-residency-us = <9518>;
			};
			cpuoff_m: cpuoff-m {
				compatible = "arm,idle-state";
				arm,psci-suspend-param = <0x00010000>;
				local-timer-stop;
				entry-latency-us = <87>;
				exit-latency-us = <186>;
				min-residency-us = <7390>;
			};
			cpuoff_b: cpuoff-b {
				compatible = "arm,idle-state";
				arm,psci-suspend-param = <0x00010000>;
				local-timer-stop;
				entry-latency-us = <87>;
				exit-latency-us = <189>;
				min-residency-us = <4291>;
			};
			clusteroff_l: clusteroff-l {
				compatible = "arm,idle-state";
				arm,psci-suspend-param = <0x01010001>;
				local-timer-stop;
				entry-latency-us = <250>;
				exit-latency-us = <329>;
				min-residency-us = <9518>;
			};
			clusteroff_m: clusteroff-m {
				compatible = "arm,idle-state";
				arm,psci-suspend-param = <0x01010001>;
				local-timer-stop;
				entry-latency-us = <250>;
				exit-latency-us = <361>;
				min-residency-us = <7390>;
			};
			clusteroff_b: clusteroff-b {
				compatible = "arm,idle-state";
				arm,psci-suspend-param = <0x01010001>;
				local-timer-stop;
				entry-latency-us = <250>;
				exit-latency-us = <353>;
				min-residency-us = <4996>;
			};
			mcusysoff_l: mcusysoff-l {
				compatible = "arm,idle-state";
				arm,psci-suspend-param = <0x02010007>;
				local-timer-stop;
				entry-latency-us = <1472>;
				exit-latency-us = <1916>;
				min-residency-us = <9518>;
			};
			mcusysoff_m: mcusysoff-m {
				compatible = "arm,idle-state";
				arm,psci-suspend-param = <0x02010007>;
				local-timer-stop;
				entry-latency-us = <1456>;
				exit-latency-us = <1930>;
				min-residency-us = <7390>;
			};
			mcusysoff_b: mcusysoff-b {
				compatible = "arm,idle-state";
				arm,psci-suspend-param = <0x02010007>;
				local-timer-stop;
				entry-latency-us = <1440>;
				exit-latency-us = <1821>;
				min-residency-us = <4996>;
			};
			system_vcore: system-vcore {
				compatible = "arm,idle-state";
				arm,psci-suspend-param = <0x020100ff>;
				local-timer-stop;
				entry-latency-us = <940>;
				exit-latency-us = <3500>;
				min-residency-us = <35200>;
			};
			s2idle: s2idle {
				compatible = "arm,idle-state";
				arm,psci-suspend-param = <0x020180ff>;
				local-timer-stop;
				entry-latency-us = <10000>;
				exit-latency-us = <10000>;
				min-residency-us = <4294967295>;
			};
		};
	};

	psci {
		compatible = "arm,psci-1.0";
		method = "smc";
	};

	gic: interrupt-controller@6800000 {
		/*TODO: please check interrupt controller again*/
		compatible = "arm,gic-v3";
		#interrupt-cells = <4>;
		#address-cells = <2>;
		#size-cells = <2>;
		#redistributor-regions = <1>;
		interrupt-parent = <&gic>;
		interrupt-controller;
                reg = <0 0x6800000 0 0x40000>, /* distributor */
	              <0 0x6880000 0 0x200000>; /* redistributor */
		interrupts = <GIC_PPI 9 IRQ_TYPE_LEVEL_HIGH 0>;
		ppi-partitions {
				ppi_cluster0: interrupt-partition-0 {
					affinity = <&cpu0 &cpu1 &cpu2 &cpu3>;
				};
				ppi_cluster1: interrupt-partition-1 {
					affinity = <&cpu4 &cpu5 &cpu6>;
				};
				ppi_cluster2: interrupt-partition-2 {
					affinity = <&cpu7>;
				};
		};
	};

	gic_ram_parity: gic-ram-parity {
		compatible = "mediatek,gic-ram-parity";
		interrupts = <GIC_SPI 159 IRQ_TYPE_EDGE_RISING 0>,
				<GIC_SPI 160 IRQ_TYPE_EDGE_RISING 0>;
		interrupt-names = "fault_handling_interrupt",
				"error_recovery_interrupt";
	};

	/* Trustonic Mobicore SW IRQ number 182 = 32 + 150 */
	mobicore: mobicore {
		compatible = "trustonic,mobicore";
		interrupts = <GIC_SPI 150 IRQ_TYPE_EDGE_RISING 0>;
	};

	/* Microtrust SW IRQ number 151(183 - 32) ~ 152(184 - 32) */
	utos: utos {
		compatible = "microtrust,utos";
		interrupts = <GIC_SPI 151 IRQ_TYPE_EDGE_RISING 0>;
	};

	spmi: spmi@1c01a000 {
		compatible = "mediatek,mt6993-spmi";
		reg = <0 0x1c01a000 0 0x00111c>,
		      <0 0x1c01c000 0 0x000100>,
		      <0 0x1c018000 0 0x00111c>,
		      <0 0x1c01c800 0 0x000100>;
		reg-names = "pmif","spmimst","pmif-p","spmimst-p";
		interrupts-extended = <&pio 272 IRQ_TYPE_LEVEL_HIGH>,
				<&pio 273 IRQ_TYPE_LEVEL_HIGH>,
				<&gic GIC_SPI 423 IRQ_TYPE_LEVEL_HIGH 0>,
				<&gic GIC_SPI 529 IRQ_TYPE_LEVEL_HIGH 0>,
				<&gic GIC_SPI 424 IRQ_TYPE_LEVEL_HIGH 0>,
				<&gic GIC_SPI 530 IRQ_TYPE_LEVEL_HIGH 0>;
		interrupt-names = "rcs_irq","rcs_irq_p","pmif_irq","spmi_nack_irq","pmif_p_irq","spmi_p_nack_irq";
		interrupt-controller;
		#interrupt-cells = <1>;
		irq-event-en = <0xc0000000 0x1 0x0 0x0 0x0>;
		irq-event-en-p = <0xc0000000 0x1 0x0 0x0 0x0>;
		spmi-dev-mask = <0x55a8>;
		#address-cells = <2>;
		#size-cells = <0>;
		hwinf-err-irq-idx = <0x21 0x30>;
		swinf-err-irq-idx = <0x71 0x76>;
		rcs-mask-list = <0x4 0x4>;
	};

	spmi_pmif_mpu: spmi-pmif-mpu@1c01a900 {
		compatible = "mediatek,mt6993-spmi-pmif-mpu";
		// reg = <0 0x1c01a900 0 0x000808>,
		//       <0 0x1c018900 0 0x000808>;
		reg-names = "pmif_mpu", "pmif_p_mpu";
		mediatek,pmic-all-rgn-en = <0x7031e8>;
		mediatek,pmic-all-rgn-en-2 = <0x0>;
		mediatek,pmic-all-rgn-en-p = <0xf5508078>;
		mediatek,pmic-all-rgn-en-p-2 = <0xf7ad06>;
		mediatek,kernel-enable-time = <0x3c>;
		disable = <0>;
	};

	mbraink_v6993: mbraink-plat {
		compatible = "mediatek,mbraink-v6993";
		gauge = <&mtk_gauge>;
		gauge2 = <&mtk_gauge2>;
		ufsnotify = <&ufshci0>;
		vcore-supply = <&mt6667_13_buck1>;
		vsram-supply = <&mt6661_5_buck6>;
		mm-supply = <&mt6667_7_buck3>;
		pmic = <&mt6661_3>;
	};

	pmrc_gip: gip@1c02c000 {
		compatible = "mediatek,mt6993-pmrc-gip";
		reg = <0 0x1c02c000 0 0x000efc>,
			  <0 0x1c500000 0 0x000efc>,
			  <0 0x1c02e000 0 0x000efc>,
			  <0 0x1c502000 0 0x000efc>;
		reg-names = "gip","gip-sec","gip-p","gip-p-sec";
		interrupts-extended = <&gic 2 62 IRQ_TYPE_LEVEL_HIGH 0>,
				<&gic 2 63 IRQ_TYPE_LEVEL_HIGH 0>;
		interrupt-names = "pmrc_gip_irq","pmrc_gip_p_irq";
		gip-irq-event-en = <0x0 0xffffffff 0xf9dc0000 0x3 0xfffc0000 0x3>;
		gip-irq-event-en-p = <0x0 0xffffffff 0xf9dc0000 0x3 0xfffc0000 0x3>;
		#address-cells = <2>;
		#size-cells = <0>;
		hwinf-bytecnt-vio-irq-idx = <0x92 0xa1>;
		hwinf-err-irq-idx = <0x52 0x61>;
		pmic-vio-irq-idx = <0x30 0x3f>;
		req-vio-irq-idx = <0x20 0x2f>;
	};

	timer: timer {
			compatible = "arm,armv8-timer";
			interrupt-parent = <&gic>;
			interrupts = <GIC_PPI 13 IRQ_TYPE_LEVEL_HIGH 0>,
						 <GIC_PPI 14 IRQ_TYPE_LEVEL_HIGH 0>,
						 <GIC_PPI 11 IRQ_TYPE_LEVEL_HIGH 0>,
						 <GIC_PPI 10 IRQ_TYPE_LEVEL_HIGH 0>;
			clock-frequency = <1000000000>;
	};

	pmu_travis: pmu-travis {
		compatible = "arm,cortex-x925-pmu";
		interrupt-parent = <&gic>;
		interrupts = <GIC_PPI 7 IRQ_TYPE_LEVEL_HIGH &ppi_cluster2>;
	};
	pmu_alto: pmu-alto {
		compatible = "arm,cortex-x4-pmu";
		interrupt-parent = <&gic>;
		interrupts = <GIC_PPI 7 IRQ_TYPE_LEVEL_HIGH &ppi_cluster1>;
	};
	pmu_gelas: pmu-gelas {
		compatible = "arm,cortex-a725-pmu";
		interrupt-parent = <&gic>;
		interrupts = <GIC_PPI 7 IRQ_TYPE_LEVEL_HIGH &ppi_cluster0>;
	};

	dsu_pmu_0: dsu-pmu-0 {
		compatible = "arm,dsu-pmu";
		interrupts = <GIC_SPI 35 IRQ_TYPE_LEVEL_HIGH 0>;
		cpus = <&cpu0>, <&cpu1>, <&cpu2>, <&cpu3>,
			<&cpu4>, <&cpu5>, <&cpu6>, <&cpu7>;
	};

	hwrng: hwrng {
		compatible = "arm,sec-rng";
		methods = "smc";
		method-fid = /bits/ 16 <0x26a>;
		quality = /bits/ 16 <900>;
	};

	security_ao: security-ao@1800d000 {
		compatible = "mediatek,security_ao";
		reg = <0 0x1800d000 0 0x1000>;
	};

	google_trusty: google-trusty {
		compatible = "android,google-trusty-ffa-v1";
		google,real-drv = <0>;

		trusty-core {
			compatible = "android,google-trusty-core-v1";
			ranges = <0x0>;
			#address-cells = <0x2>;
			#size-cells = <0x2>;

			virtio {
				compatible = "android,google-trusty-virtio-v1";
			};

			test {
				compatible = "android,google-trusty-test-v1";
			};

			log {
				compatible = "android,google-trusty-log-v1";
			};

			irq {
				compatible = "android,google-trusty-irq-v1";
			};
		};
	};

	ise_lpm: ise-lpm {
		compatible = "mediatek,ise-lpm";
		ise-wakelock = <0>;
		ise-lpm-freerun = <0>;
		ise-lpm-deinit-bypass = <1>;
		ise-lpm-vote-dram = <0>;
		interconnects = <&dvfsrc MT6873_MASTER_ISE &dvfsrc MT6873_SLAVE_DDR_EMI>;
		interconnect-names = "ise-perf-bw";
		required-opps = <&dvfsrc_freq_opp3>;
	};

	ise_trusty: ise-trusty {
		#size-cells = <0x02>;
		#address-cells = <0x02>;
		ranges;
		compatible = "android,ise-trusty-smc-v1";
		mediatek,real-drv = <0>;

		ise-log {
			compatible = "android,ise-trusty-log-v1";
		};

		ise-virtio@10001000 {
			compatible = "android,ise-trusty-virtio-v1";
			reg = <0 0x10001000 0 0x1000>;
			interrupts = <GIC_SPI 917 IRQ_TYPE_LEVEL_HIGH 0>;
			apmcu-offset = <0x000>;
			apmcu-ack = <0x10000>;
		};
	};

	ise_mbox: ise-mbox@18021000 {
		compatible = "mediatek,ise-mbox";
		reg = <0 0x18021000 0 0x1000>;
		mediatek,real-drv = <0>;
	};

	masp: masp@1800e000 {
		compatible = "mediatek,masp";
		reg = <0 0x1800e000 0 0x1000>;
		interrupts = <GIC_SPI 389 IRQ_TYPE_LEVEL_HIGH 0>;
		/* GIC_IRQ ID(sej_axgpt_irq)*/
	};


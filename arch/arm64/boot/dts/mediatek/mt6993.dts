		pcie0: pcie@16910000 {
			device_type = "pci";
			compatible = "mediatek,mt6993-pcie";
			reg = <0 0x16910000 0 0x4000>;
			reg-names = "pcie-mac";
			#address-cells = <3>;
			#size-cells = <2>;
			interrupts = <GIC_SPI 369 IRQ_TYPE_LEVEL_HIGH 0>;
			bus-range = <0x00 0xff>;
			ranges = <0x82000000 0 0x50000000
				  0x0 0x50000000 0 0x8000000>;
			status = "disabled";
			linux,pci-domain = <0>;
			mediatek,peri-reset-dis;
			mediatek,dvfs-req-dis;
			pextpcfg = <&pextp0cfg_ao_clk>;
			vlpcfg = <&vlpcfg_bus>;
			pmrc = <&srclken_rc>;

			clocks = <&pextp0cfg_ao_clk PEXTP0_MAC0_TL_PEXTP>,
				 <&pextp0cfg_ao_clk PEXTP0_MAC0_REF_PEXTP>,
				 <&pextp0cfg_ao_clk PEXTP0_MAC0_AXI_250_PEXTP>,
				 <&pextp0cfg_ao_clk PEXTP0_MAC0_AHB_APB_PEXTP>,
				 <&pextp0cfg_ao_clk PEXTP0_MAC0_PL_P_PEXTP>,
				 <&cksys_top_clk CKSYS_TOP_TL_SEL>,
				 <&ap_pd_clk CLK_PD_PEXTP_MAC0_PEXTP>;
			resets = <&pextp0ao_rst 0>, <&pextp0ao_rst 1>;
			reset-names = "mac", "phy";
			phys = <&pciephy0>;
			phy-names = "pcie-phy";

			#interrupt-cells = <1>;
			interrupt-map-mask = <0 0 0 7>;
			interrupt-map = <0 0 0 1 &pcie_intc0 0>,
					<0 0 0 2 &pcie_intc0 1>,
					<0 0 0 3 &pcie_intc0 2>,
					<0 0 0 4 &pcie_intc0 3>;
			pcie_intc0: interrupt-controller {
				interrupt-controller;
				#address-cells = <0>;
				#interrupt-cells = <1>;
			};
		};

		pcie1: pcie@16940000 {
			device_type = "pci";
			compatible = "mediatek,mt6993-pcie";

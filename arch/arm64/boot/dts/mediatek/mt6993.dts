	charger: charger {
		compatible = "mediatek,charger";
		gauge = <&mtk_gauge>;
		charger = <&mt6379_chg>;
		bc12-psy = <&mt6379_chg>;
		bootmode = <&chosen>;

		algorithm-name = "Basic";
		charger-configuration= <0>;
		alg-new-arbitration;

		/* common */
		battery-cv = <4350000>;
		max-charger-voltage = <6500000>;
		vbus-sw-ovp-voltage = <15000000>;
		min-charger-voltage = <4600000>;

		/* sw jeita */
		enable-vbat-mon = <0>;
		/* enable-sw-jeita; */
		jeita-temp-above-t4-cv = <4240000>;
		jeita-temp-t3-to-t4-cv = <4240000>;
		jeita-temp-t2-to-t3-cv = <4340000>;
		jeita-temp-t1-to-t2-cv = <4240000>;
		jeita-temp-t0-to-t1-cv = <4040000>;
		jeita-temp-below-t0-cv = <4040000>;
		temp-t4-thres = <50>;
		temp-t4-thres-minus-x-degree = <47>;
		temp-t3-thres = <45>;
		temp-t3-thres-minus-x-degree = <39>;
		temp-t2-thres = <10>;
		temp-t2-thres-plus-x-degree = <16>;
		temp-t1-thres = <0>;
		temp-t1-thres-plus-x-degree = <6>;
		temp-t0-thres = <0>;
		temp-t0-thres-plus-x-degree = <0>;
		temp-neg-10-thres = <0>;

		/* battery temperature protection */
		enable-min-charge-temp;
		min-charge-temp = <0>;
		min-charge-temp-plus-x-degree = <6>;
		max-charge-temp = <50>;
		max-charge-temp-minus-x-degree = <47>;

		/* charging current */
		usb-charger-current = <500000>;
		ac-charger-current = <2050000>;
		ac-charger-input-current = <3000000>;
		charging-host-charger-current = <1500000>;

		/* dynamic mivr */
		enable-dynamic-mivr;
		min-charger-voltage-1 = <4400000>;
		min-charger-voltage-2 = <4200000>;
		max-dmivr-charger-current = <1800000>;

		/* fast charging algo support indicator */
		enable-fast-charging-indicator;

		/* enable LK boot volt*/
		enable-boot-volt = <1>;

		/* adapter priority */
		adapter-priority = <1>;
	};

	mml-test {
		compatible = "mediatek,mml-test";
		mediatek,mml = <&mmlsys2_config>;
		mmlsys-config-supply = <&mmlsys2_config>;
	};

	mml-ait {
		compatible = "mediatek,mml-ait";
		mediatek,mml = <&mmlsys2_config>;
	};

	rt-pd-manager {
		compatible = "mediatek,rt-pd-manager";
		nr-port = <1>;
		//en-wd0-port0;
		tcpc-supply = <&mt6379_typec>;
	};

	pd_adapter: pd-adapter {
		compatible = "mediatek,pd_adapter";
		nr-port = <1>;
		force-cv;
		adapter-name = "pd_adapter";
		tcpc-supply = <&mt6379_typec>;
	};

	mtk_ctd: mtk-ctd {
		compatible = "mediatek,mtk_ctd";
		nr-port = <1>;
		chg-name-port0 = "primary_chg";
		bc12-sel-port0 = <MTK_CTD_BY_SUBPMIC>;
		bc12-psy-port0 = <&mt6379_chg>;
		tcpc-supply = <&mt6379_typec>;
		chg-supply = <&mt6379_chg>;
	};

	ufcs_adapter: ufcs-adapter {
		compatible = "mediatek,ufcs-adapter";
		status = "okay";
	};

	rt5133_gpio1: rt5133-gpio1 {
		compatible = "regulator-fixed";
		regulator-name = "rt5133-gpio1";
		regulator-min-microvolt = <2800000>;
		regulator-max-microvolt = <2800000>;
		vin-supply = <&rt5133_ldo1>;
		enable-active-high;
		gpio = <&rt5133 0 0x0>;
	};

	rt5133_gpio2: rt5133-gpio2 {
		compatible = "regulator-fixed";
		regulator-name = "rt5133-gpio2";
		regulator-min-microvolt = <2800000>;
		regulator-max-microvolt = <2800000>;
		vin-supply = <&rt5133_ldo1>;
		enable-active-high;
		gpio = <&rt5133 1 0x0>;
	};

	rt5133_gpio3: rt5133-gpio3 {
		compatible = "regulator-fixed";
		regulator-name = "rt5133-gpio3";
		regulator-min-microvolt = <2800000>;
		regulator-max-microvolt = <2800000>;
		vin-supply = <&rt5133_ldo1>;
		enable-active-high;
		gpio = <&rt5133 2 0x0>;
	};

	hcp: hcp@15001000 {
		compatible = "mediatek,hcp8s_f";
		//dma-ranges = <0x0 0x0 0x0 0x0 0x4 0x0>;
		reg = <0 0x15001000 0 0x4000>;
		mtk,smmu-shared = <&mm_smmu_cam>;
	};

	vmm_ctrl: vmm-ctrl {
		compatible = "mediatek,vmm_notifier_mt6993";
		pd-id = <0>;
		vmm-vcp-supply = <&vcp>;
		vmm-regulator-supply = <&mt6667_7_buck3>;
	};

	imgsys_cmdq: imgsys-cmdq@15002000 {
		compatible = "mediatek,imgsys-cmdq-8s";
		//dma-ranges = <0x0 0x0 0x0 0x0 0x4 0x0>;
		reg = <0 0x15002000 0 0x4000>;
	};

	imgsys_acp: imgsys-acp@15003000 {
		compatible = "mediatek,imgsys-isp8s-acp-mt6993";
		reg = <0 0x15003000 0 0x4000>;
		mtk,smmu-shared = <&mm_smmu_acp_cam>;
		mediatek,imgsys-coherent = "enable"; // enable after acp ready
	};

	imgsys_fw: imgsys-fw@15000000 {
		compatible = "mediatek,imgsys-isp8s-mt6993";
		//dma-ranges = <0x0 0x0 0x0 0x0 0x4 0x0>;
		reg = <0 0x34010000 0 0x4000>, // 0 IMGSYS_TOP
			<0 0x34760000 0 0x10000>, // 1 IMGSYS_TRAW
			<0 0x34050000 0 0x10000>, // 2 IMGSYS_LTRAW
			<0 0x34190000 0 0x10000>, // 3 IMGSYS_DIP
			<0 0x341a0000 0 0x10000>, // 4 IMGSYS_DIP_NR1
			<0 0x341b0000 0 0x20000>, // 5 IMGSYS_DIP_NR2
			<0 0x341d0000 0 0x10000>, // 6 IMGSYS_DIP_CINE
			<0 0x34250000 0 0x10000>, // 7 IMGSYS_PQDIP_A
			<0 0x34540000 0 0x10000>, // 8 IMGSYS_PQDIP_B
			<0 0x34240000 0 0x10000>, // 9 IMGSYS_WPE_EIS
			<0 0x34500000 0 0x10000>, // 10 IMGSYS_WPE_TNR
			<0 0x34640000 0 0x10000>, // 11 IMGSYS_WPE_LITE
			<0 0x34200000 0 0x00100>, // 12 IMGSYS_WPE1_DIP1
			<0 0x34530000 0 0x10000>, // 13 IMGSYS_OMC_TNR
			<0 0x34650000 0 0x10000>, // 14 IMGSYS_OMC_LITE
			<0 0x34550000 0 0x10000>, // 15 IMGSYS_ME
			<0 0x00000000 0 0x01500>, // 16 IMGSYS_ADL_A
			<0 0x00000000 0 0x01500>, // 17 IMGSYS_ADL_B
			<0 0x34500000 0 0x00100>, // 18 IMGSYS_WPE2_DIP1
			<0 0x34600000 0 0x00100>, // 19 IMGSYS_WPE3_DIP1
			<0 0x34100000 0 0x00100>, // 20 IMGSYS_DIP_TOP
			<0 0x34120000 0 0x00100>, // 21 IMGSYS_DIP_TOP_NR
			<0 0x34150000 0 0x00100>, // 22 IMGSYS_DIP_TOP_NR2
			<0 0x34700000 0 0x00100>, // 23 IMGSYS_TRAW_DIP1
			<0 0x34560000 0 0x10000>, // 24 IMGSYS_ME_MMG
			<0 0x34670000 0 0x00200>, // 25 IMGSYS_DFP_TOP
			<0 0x34670600 0 0x00200>, // 26 IMGSYS_DFP_FE
			<0 0x34670800 0 0x00100>, // 27 IMGSYS_DFP_DRZH2N
			<0 0x34670a00 0 0x00200>, // 28 IMGSYS_DFP_FM
			<0 0x34680000 0 0x00200>, // 29 IMGSYS_DFP2_TOP
			<0 0x34680c00 0 0x00300>, // 30 IMGSYS_DFP2_DVGF
			<0 0x34780000 0 0x00150>, // 31 IMGSYS_VCORE
			<0 0x34320000 0 0x10000>, // 32 IMGSYS_MAE
			<0 0x34060000 0 0x01000>, // 33 IMGSYS_ISC
			<0 0x34270000 0 0x00100>, // 34 IMGSYS_WPE_EIS_PQDIP_A
			<0 0x34580000 0 0x00100>, // 35 IMGSYS_WPE_TNR_PQDIP_B
			<0 0x34810000 0 0x00100>, // 36 IMGSYS_MAIN_WPE0
			<0 0x34820000 0 0x00100>, // 37 IMGSYS_MAIN_WPE1
			<0 0x34830000 0 0x00100>, // 38 IMGSYS_MAIN_WPE2
			<0 0x348b0000 0 0x00100>; // 39 IMGSYS_MAIN_OMC_LITE
		interrupts = <GIC_SPI 699 IRQ_TYPE_LEVEL_HIGH 0>;
		mediatek,imgsys-ver = <0>;
		mediatek,hcp = <&hcp>;
		mediatek,imgsys-cmdq = <&imgsys_cmdq>;
		mediatek,imgsys-ddr-en = <4>;
		mtk,smmu-shared = <&mm_smmu_cam>;
		mboxes =
			/* normal thread */
			<&gce_m 0 3000 CMDQ_THR_PRIO_2>,
			<&gce_m 1 3000 CMDQ_THR_PRIO_2>,
			<&gce_m 2 3000 CMDQ_THR_PRIO_2>,
			<&gce_m 3 3000 CMDQ_THR_PRIO_2>,
			<&gce_m 4 3000 CMDQ_THR_PRIO_2>,
			<&gce_m 5 3000 CMDQ_THR_PRIO_2>,
			<&gce_m 6 3000 CMDQ_THR_PRIO_2>,
			<&gce_m 7 3000 CMDQ_THR_PRIO_2>,
			<&gce_m 9 3000 CMDQ_THR_PRIO_2>,
			<&gce_m 12 3000 CMDQ_THR_PRIO_2>,
			<&gce_m 13 3000 CMDQ_THR_PRIO_2>,
			<&gce_m 16 3000 CMDQ_THR_PRIO_2>,
			<&gce_m 17 3000 CMDQ_THR_PRIO_2>,
			<&gce_m 18 3000 CMDQ_THR_PRIO_2>,
			<&gce_m 19 3000 CMDQ_THR_PRIO_2>,
			<&gce_m 20 3000 CMDQ_THR_PRIO_2>,
			<&gce_m 21 3000 CMDQ_THR_PRIO_2>,
			<&gce_m 22 3000 CMDQ_THR_PRIO_2>,
			<&gce_m 23 3000 CMDQ_THR_PRIO_2>,
			<&gce_m 24 3000 CMDQ_THR_PRIO_2>,
			<&gce_m 25 3000 CMDQ_THR_PRIO_2>,
			<&gce_m 26 3000 CMDQ_THR_PRIO_2>,
			<&gce_m 28 3000 CMDQ_THR_PRIO_1>,
			<&gce_m 29 3000 CMDQ_THR_PRIO_1>,
			<&gce_m 31 3000 CMDQ_THR_PRIO_1>,
			/* power thread */
			<&gce_m_2 24 CMDQ_NO_TIMEOUT CMDQ_THR_PRIO_1>,
			<&gce_m_2 25 CMDQ_NO_TIMEOUT CMDQ_THR_PRIO_1>,
			<&gce_m_2 26 CMDQ_NO_TIMEOUT CMDQ_THR_PRIO_1>,
			<&gce_m_2 27 CMDQ_NO_TIMEOUT CMDQ_THR_PRIO_1>,
			<&gce_m_2 28 CMDQ_NO_TIMEOUT CMDQ_THR_PRIO_1>,
			/* qos thread */
			<&gce_m 27 CMDQ_NO_TIMEOUT CMDQ_THR_PRIO_1>,
			/* secure thread */
			<&gce_m_sec 10 CMDQ_NO_TIMEOUT CMDQ_THR_PRIO_2>,
			/* sec mae */
			<&gce_m_sec 11 CMDQ_NO_TIMEOUT CMDQ_THR_PRIO_2>,
			/* slc */
			<&gce_m_sec 8 CMDQ_NO_TIMEOUT CMDQ_THR_PRIO_2>;
			/* thread list end */
		traw-cq-thread0-frame-done =
			/bits/ 16 <CMDQ_EVENT_IMG_TRAW0_CQ_THR_DONE_TRAW0_0>;
		traw-cq-thread1-frame-done =
			/bits/ 16 <CMDQ_EVENT_IMG_TRAW0_CQ_THR_DONE_TRAW0_1>;

&clkitg {
	status = "okay";
	bring-up@0 {
		compatible = "mediatek,clk-bring-up";
		reg = <0x0>;
		clocks =
			<&cksys_reg_clk CLK_CKSYS_REG_MMINFRA_SEL>,
			<&cksys_reg_clk CLK_CKSYS_REG_DPMAIF_MAIN_SEL>,
			<&cksys_reg_clk CLK_CKSYS_REG_VENC_SEL>,
			<&cksys_reg_clk CLK_CKSYS_REG_VDEC_SEL>,
			<&cksys_reg_clk CLK_CKSYS_REG_IMG1_SEL>,
			<&cksys_reg_clk CLK_CKSYS_REG_IPE_SEL>,
			<&cksys_reg_clk CLK_CKSYS_REG_CAM_SEL>,
			<&cksys_reg_clk CLK_CKSYS_REG_CAMTM_SEL>,
			<&cksys_reg_clk CLK_CKSYS_REG_SSR_PKA_SEL>,
			<&cksys_reg_clk CLK_CKSYS_REG_SSR_DMA_SEL>,
			<&cksys_reg_clk CLK_CKSYS_REG_SSR_KDF_SEL>,
			<&cksys_reg_clk CLK_CKSYS_REG_SSR_RNG_SEL>,
			<&cksys_reg_clk CLK_CKSYS_REG_SSR_PQC_SEL>;
	};

	bring-up-venc@2 {
		compatible = "mediatek,clk-bring-up";
		reg = <0x2>;
		clocks =
			<&venc_gcon_clk CLK_VEN1_CKE1_VENC_VENC>,
			<&venc_gcon_clk CLK_VEN1_CKE5_GALS_VENC>;
	};

	bring-up-pdaf@3 {
		compatible = "mediatek,clk-bring-up";
		reg = <0x3>;
		clocks =
			<&camsys_mraw_clk CLK_CAM_MR_PDA0_PDAF>,
			<&camsys_mraw_clk CLK_CAM_MR_PDA1_PDAF>;
	};

	bring-up-smi@4 {
		compatible = "mediatek,clk-bring-up";
		reg = <0x4>;
		clocks =
			<&img_vcore_d1a_clk CLK_IMG_VCORE_SUB0_SMI>,
			<&img_vcore_d1a_clk CLK_IMG_VCORE_SUB1_SMI>,

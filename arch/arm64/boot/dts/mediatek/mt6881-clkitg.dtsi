&clkitg {
	status = "okay";
	bring-up@0 {
		compatible = "mediatek,clk-bring-up";
		reg = <0x0>;
		clocks =
			<&cksys_reg_clk CLK_CKSYS_REG_MMINFRA_SEL>,
			<&cksys_reg_clk CLK_CKSYS_REG_SSR_PKA_SEL>,
			<&cksys_reg_clk CLK_CKSYS_REG_SSR_DMA_SEL>,
			<&cksys_reg_clk CLK_CKSYS_REG_SSR_KDF_SEL>,
			<&cksys_reg_clk CLK_CKSYS_REG_SSR_RNG_SEL>,
			<&cksys_reg_clk CLK_CKSYS_REG_SSR_PQC_SEL>;
	};

	bring-up-mml@15 {
		compatible = "mediatek,clk-bring-up";
		reg = <0x15>;
		clocks =
			<&mdpsys_config_clk CLK_MDP_MUTEX0_MML>,
			<&mdpsys_config_clk CLK_MDP_APB_BUS_MML>,
			<&mdpsys_config_clk CLK_MDP_SMI0_MML>,
			<&mdpsys_config_clk CLK_MDP_RDMA0_MML>,
			<&mdpsys_config_clk CLK_MDP_FG0_MML>,
			<&mdpsys_config_clk CLK_MDP_HDR0_MML>,
			<&mdpsys_config_clk CLK_MDP_AAL0_MML>,
			<&mdpsys_config_clk CLK_MDP_RSZ0_MML>,
			<&mdpsys_config_clk CLK_MDP_TDSHP0_MML>,
			<&mdpsys_config_clk CLK_MDP_COLOR0_MML>,
			<&mdpsys_config_clk CLK_MDP_WROT0_MML>,
			<&mdpsys_config_clk CLK_MDP_FAKE_ENG0_MML>,
			<&mdpsys_config_clk CLK_MDP_DLI_ASYNC0_MML>,
			<&mdpsys_config_clk CLK_MDP_DLI_ASYNC1_MML>,
			<&mdpsys_config_clk CLK_MDP_RDMA1_MML>,
			<&mdpsys_config_clk CLK_MDP_FG1_MML>,
			<&mdpsys_config_clk CLK_MDP_HDR1_MML>,
			<&mdpsys_config_clk CLK_MDP_AAL1_MML>,
			<&mdpsys_config_clk CLK_MDP_RSZ1_MML>,
			<&mdpsys_config_clk CLK_MDP_TDSHP1_MML>,
			<&mdpsys_config_clk CLK_MDP_COLOR1_MML>,
			<&mdpsys_config_clk CLK_MDP_WROT1_MML>,
			<&mdpsys_config_clk CLK_MDP_RSZ2_MML>,
			<&mdpsys_config_clk CLK_MDP_WROT2_MML>,
			<&mdpsys_config_clk CLK_MDP_DLO_ASYNC0_MML>,
			<&mdpsys_config_clk CLK_MDP_RSZ3_MML>,
			<&mdpsys_config_clk CLK_MDP_WROT3_MML>,
			<&mdpsys_config_clk CLK_MDP_DLO_ASYNC1_MML>,
			<&mdpsys_config_clk CLK_MDP_HRE_TOP_MDPSYS_MML>,
			<&mdpsys_config_clk CLK_MDP_FMM_IMG_DL_ASYNC0_MML>,
			<&mdpsys_config_clk CLK_MDP_FMM_IMG_DL_ASYNC1_MML>,
			<&mdpsys_config_clk CLK_MDP_FIMG_IMG_DL_ASYNC0_MML>,
			<&mdpsys_config_clk CLK_MDP_FIMG_IMG_DL_ASYNC1_MML>;
	};

	bring-up-pd-mm-infra-shutdown@25 {
		compatible = "mediatek,scpsys-bring-up";
		reg = <0x25>;
		power-domains = <&scpsys MT6881_POWER_DOMAIN_MM_INFRA_SHUTDOWN>;
	};
};

&disp_dpc {
	vidle-mask = <0x0>;
};

&mipi_tx_config1 {
	status = "okay";
};

&mt6373_vfp {
	regulator-always-on;
};

&disp_merge0 {
	status = "okay";
};

&dsi1 {
	mediatek,dual-dsi-slave;
	status = "okay";
	ports {
		#address-cells = <1>;
		#size-cells = <0>;
		port@1 {
			reg = <1>;
			slave_in: endpoint {
				remote-endpoint = <&master_out>;
			};
		};
	};
};

&dsi1_te {
	interrupt-parent = <&pio>;
	interrupts = <6 1 6 1>;
	status = "okay";
};

&dsi0 {
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;
	turner_42_02_0a_dsc_vdo: panel1@0 {
		compatible = "o88_42_02_0a_dsc_vdo,lcm";
		reg = <0>;
		reset-gpios = <&pio 90 0>;
		mi,esd-err-irq-gpio = <&pio 22 0x2002>;
		mi,esd-err-irq-gpio-second = <&pio 21 0x2002>;
		lane-swap-setting = <1 2 0 3 4 2>;
		pn-swap-setting = <1 1 1 1 1 1>;
		pinctrl-names = "default";
		vcn18io-supply = <&mt6373_vcn18io>;
		hw_en-gpios = <&pio 181 0>;
		bias_enp-gpios = <&pio 187 0>;
		bias_enn-gpios = <&pio 206 0>;
		lcm_id-gpios = <&pio 180 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
		port {
			panel_in: endpoint {
				remote-endpoint = <&dsi_out>;
			};
		};
	};

	ports {
		#address-cells = <1>;
		#size-cells = <0>;
		port@0 {
			reg = <0>;
			dsi_out: endpoint {
				remote-endpoint = <&panel_in>;
			};
		};
		port@1 {
			reg = <1>;
			master_out: endpoint {
				remote-endpoint = <&slave_in>;
			};
		};
	};
};

&pio {

	rptr_enable: rptr-enable {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO28__FUNC_GPIO28>;
			output-high;
		};
	};

	rptr_disable: rptr-disable {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO28__FUNC_GPIO28>;
			output-low;
		};
	};

};

&ssusb {
	mediatek,force-vbus;
	mediatek,clk-mgr;
	mediatek,usb3-drd;
	mediatek,uds = <&usb_dp_selector 19>;
	mediatek,eusb2-cm-l1 = <0x474>;
	maximum-speed = "super-speed";
	maximum-speed-host = <0x05>;
	usb-role-switch;
	status = "okay";
};

&ssusb1 {
	wakeup-source;
	mediatek,clk-mgr;
	mediatek,force-vbus;
	mediatek,eusb2-cm-l1 = <0x474>;
	maximum-speed = "high-speed";
	usb-role-switch;
	status = "okay";
};

&usb_host {
	mediatek,usb-offload = <&usb_offload>;
	status = "okay";
};

&usb_host1 {
	usb2-lpm-disable;
	status = "okay";
};

&mt6379_eusb2_repeater {
	mediatek,vrt-sel = <0>;
	mediatek,intr-ofs = "0";
	mediatek,term-ofs = "0";
	mediatek,equalization = <4>;
	mediatek,rx-sqth = <5>;
	mediatek,discth = <0xf>;
	mediatek,host-vrt-sel = <2>;
	mediatek,host-rx-sqth = <0>;
	mediatek,host-discth = <0xf>;
	mediatek,host-term-ofs = "-3";
	mediatek,host-intr-ofs = "4";
	mediatek,pre-emphasis = <2>;
	status = "okay";
};


&i2c13 {

	nxp_eusb2_repeater_turner: nxp-eusb2-repeater-turner@43 {
		compatible = "mtk,nxp-eusb2-repeater";
		pinctrl-names = "enable", "disable";
		pinctrl-0 = <&rptr_enable>;
		pinctrl-1 = <&rptr_disable>;
		reg = <0x43>;
		#phy-cells = <0>;
		status = "okay";
	};

};

&nxp_eusb2_repeater_turner {
	mediatek,rptr-ouput-swing = <0x4>;
	mediatek,rptr-demphasis = <0x22>;
};

&u2phy1 {
	phy-cells = <1>;
	phys = <&nxp_eusb2_repeater_turner>;
	status = "okay";

};

&u2port1 {

	status = "okay";

};

&pcie0 {
	pinctrl-names = "init", "default", "sleep", "pd";
	pinctrl-0 = <&pcie0_pins_init>;
	pinctrl-1 = <&pcie0_pins_default>;
	pinctrl-2 = <&pcie0_pins_sleep>;
	pinctrl-3 = <&pcie0_pins_pd>;
	max-link-speed = <4>;
	status = "okay";
};

&pcie1 {
	pinctrl-names = "default";
	pinctrl-0 = <&pcie1_pins_default>;
	max-link-speed = <4>;
	status = "disabled";
};

&pciephy0 {
	mediatek,short-reach;
	status = "okay";
};

&pciephy1 {
	status = "disabled";
};

/* PCIe pinmux start */
/* skyhawk use waken to control DFD_EN, PCIe0 don't need to control it */
&pio {
	pcie0_pins_init: pcie0-init {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO241__FUNC_GPIO241>;
			output-low;
		};

		pins-cmd-dat1 {
			pinmux = <PINMUX_GPIO243__FUNC_GPIO243>;
			bias-pull-up;
			input-enable;
		};
	};

	pcie0_pins_default: pcie0-default {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO241__FUNC_PCIE_PERSTN>,
				 <PINMUX_GPIO243__FUNC_PCIE_CLKREQN>;
			bias-pull-up;
		};
	};

	pcie0_pins_sleep: pcie0-sleep {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO241__FUNC_GPIO241>;
			output-low;
		};

		pins-cmd-dat1 {
			pinmux = <PINMUX_GPIO243__FUNC_GPIO243>;
			bias-pull-up;
			input-enable;
		};
	};

	pcie0_pins_pd: pcie0-pd {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO241__FUNC_GPIO241>;
			output-low;
		};

		pins-cmd-dat1 {
			pinmux = <PINMUX_GPIO243__FUNC_GPIO243>;
			bias-pull-down;
			input-enable;
		};
	};

	pcie1_pins_default: pcie1-default {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO145__FUNC_PCIE_WAKEN_1P>,
				 <PINMUX_GPIO146__FUNC_PCIE_PERSTN_1P>,
				 <PINMUX_GPIO147__FUNC_PCIE_CLKREQN_1P>;
			bias-pull-up = <MTK_PUPD_SET_R1R0_01>;
		};
	};
};
/* PCIe pinmux end */

#if 0
/* no need set here, 6686 will control elna automatically */
/* GPS GPIO standardization start */
&pio {
	gps_pins_default: gps_default {
	};
	gps_l1_lna_pins_ol: gps-l1-lna0 {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO12__FUNC_GPIO12>;
			output-low;
		};
	};
	gps_l1_lna_pins_dsp_ctrl: gps-l1-lna1 {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO12__FUNC_GPS_L1_ELNA_EN>;
		};
	};
	gps_l1_lna_pins_oh: gps-l1-lna2 {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO12__FUNC_GPIO12>;
			output-high;
		};
	};
	gps_l5_lna_pins_ol: gps-l5-lna0 {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO13__FUNC_GPIO13>;
			output-low;
		};
	};
	gps_l5_lna_pins_dsp_ctrl: gps-l5-lna1 {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO13__FUNC_GPS_L5_ELNA_EN>;
		};
	};
	gps_l5_lna_pins_oh: gps-l5-lna2 {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO13__FUNC_GPIO13>;
			output-high;
		};
	};
};
&gps {
	pinctrl-names = "default",
		"gps_l1_lna_disable",
		"gps_l1_lna_dsp_ctrl",
		"gps_l1_lna_enable",
		"gps_l5_lna_disable",
		"gps_l5_lna_dsp_ctrl",
		"gps_l5_lna_enable";
	pinctrl-0 = <&gps_pins_default>;
	pinctrl-1 = <&gps_l1_lna_pins_ol>;
	pinctrl-2 = <&gps_l1_lna_pins_dsp_ctrl>;
	pinctrl-3 = <&gps_l1_lna_pins_oh>;
	pinctrl-4 = <&gps_l5_lna_pins_ol>;
	pinctrl-5 = <&gps_l5_lna_pins_dsp_ctrl>;
	pinctrl-6 = <&gps_l5_lna_pins_oh>;
	status = "okay";
};
/* GPS GPIO standardization end */
#endif

/* usb typec mux start */
&pio {

	ps_enable: ps_enable {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO207__FUNC_GPIO207>;
			output-high;
		};
	};

	ps_disable: ps_disable {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO207__FUNC_GPIO207>;
			output-low;
		};
	};

};

&typec_mux_switch {
	orientation-switch;
	mode-switch;
	accessory;
	port {
		ssusb_mux: endpoint {
			remote-endpoint = <&tcpc_typec_usb>;
		};
	};
};

&ps5170 {
	pinctrl-names = "enable", "disable";
	pinctrl-0 = <&ps_enable>;
	pinctrl-1 = <&ps_disable>;
	status = "okay";
};

&usb_dp_selector {
	status = "okay";
};
/* usb typec mux end */

&pio {
	aw86938_irq_active_r:aw86938_irq_active_r {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO5__FUNC_GPIO5>;
			slew-rate = <0>;
			bias-pull-up = <00>;
		};
	};
	aw86938_rst_active_r:aw86938_rst_active_r {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO42__FUNC_GPIO42>;
			slew-rate = <0>;
			bias-pull-up = <00>;
		};
	};
	aw86938_irq_active_l:aw86938_irq_active_l {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO11__FUNC_GPIO11>;
			slew-rate = <0>;
			bias-pull-up = <00>;
		};
	};
	aw86938_rst_active_l:aw86938_rst_active_l {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO41__FUNC_GPIO41>;
			slew-rate = <0>;
			bias-pull-up = <00>;
		};
	};
};

&i2c1 {
    clock-frequency = <400000>;
	status = "ok";
	haptic_hv_r@5B {
		compatible = "awinic,haptic_hv_r";
		reg = <0x5B>;
		#sound-dai-cells = <0>;
		sound-name-prefix = "HAPTIC_SPK_R";
		irq-gpio = <&pio 11 1>;
		reset-gpio = <&pio 41 1>;
		f0_pre = < 1700 >;
		mode = /bits/ 8 < 5 >;
		aw8693x_f0_cali_percent = /bits/ 8 < 15 >;
		aw8693x_gain_bypass = /bits/ 8 < 1 >;
		aw8693x_uvlo_vol_default = /bits/ 8 < 0 >;
		aw8693x_cont_smart_loop = /bits/ 8 < 0 >;
		aw8693x_cont_drv1_lvl = /bits/ 8 < 0x7F >;
		aw8693x_cont_drv2_lvl = /bits/ 8 < 0x38 >;
		aw8693x_cont_lra_vrms = < 1000 >;
		aw8693x_cont_drv1_time = /bits/ 8 < 0x04 >;
		aw8693x_cont_drv2_time = /bits/ 8 < 0x32 >;
		aw8693x_cont_track_margin = /bits/ 8 < 0x0F >;
		aw8693x_cont_brk_gain = /bits/ 8 < 0x08 >;
		aw8693x_cont_brk_time = /bits/ 8 < 0x08 >;
		aw8693x_duration_time = /bits/ 8 < 20 30 60 >;
		aw8693x_d2s_gain = /bits/ 8 < 0x04 >;
		aw8693x_algo_d2s_gain = /bits/ 8 < 0x01 >;
		aw8693x_drv_width = /bits/ 8 < 0x6A >;
		aw8693x_trig_config = /bits/ 8 < 0 0 0 1 0 2 0 0
						 0 0 0 1 0 2 0 0
						 0 0 0 1 0 2 0 0 >;
		aw8693x_bst_vol_default = < 8500 >;
		/* aw8693x_is_enabled_track_en; */
		aw8693x_vib_effect_max = < 197 >; /*vib_effect_max must bigger than vib_effect_id*/
		/* aw8693x_is_enabled_auto_bst; */
		/* aw8693x_is_enabled_one_wire; */
	};
	aw8693xs_codec: haptic_hv_l@5A{
		status = "ok";
		compatible = "awinic,haptic_hv_l";
		reg = <0x5A>;
		#sound-dai-cells = <0>;
		sound-name-prefix = "HAPTIC_SPK";
		f0_pre = < 1700 >;
		mode = /bits/ 8 < 5 >;
		irq-gpio = <&pio 5 1>;
		reset-gpio = <&pio 42 1>;
		/****************** aw8693x **************/
		aw8693x_f0_cali_percent = /bits/ 8 < 15 >;
		aw8693x_gain_bypass = /bits/ 8 < 1 >;
		aw8693x_uvlo_vol_default = /bits/ 8 < 0 >;
		aw8693x_cont_smart_loop = /bits/ 8 < 0 >;
		aw8693x_cont_drv1_lvl = /bits/ 8 < 0x7F >;
		aw8693x_cont_drv2_lvl = /bits/ 8 < 0x38 >;
		aw8693x_cont_drv_width = /bits/ 8 <0x8A>;
		aw8693x_cont_lra_vrms = < 1000 >;
		aw8693x_cont_drv1_time = /bits/ 8 < 0x04 >;
		aw8693x_cont_drv2_time = /bits/ 8 < 0x32 >;
		aw8693x_cont_track_margin = /bits/ 8 < 0x0F >;
		aw8693x_cont_brk_gain = /bits/ 8 < 0x08 >;
		aw8693x_cont_brk_time = /bits/ 8 < 0x08 >;
		aw8693x_duration_time = /bits/ 8 < 20 30 60 >;
		aw8693x_d2s_gain = /bits/ 8 < 0x04 >;
		aw8693x_algo_d2s_gain = /bits/ 8 < 0x01 >;
		aw8693x_drv_width = /bits/ 8 < 0x6A >;
		aw8693x_trig_config = /bits/ 8 < 0 0 0 1 0 2 0 0
						 0 0 0 1 0 2 0 0
						 0 0 0 1 0 2 0 0 >;
		aw8693x_bst_vol_default = < 8500 >;
		/* aw8693x_is_enabled_track_en; */
		aw8693x_vib_effect_max = < 197 >; /*vib_effect_max must bigger than vib_effect_id*/
		/* aw8693x_is_enabled_auto_bst; */
		/* aw8693x_is_enabled_one_wire; */
	};
};

&i2c10 {
	gate_ic: gate_ic@11 {
		compatible = "mediatek,MI_I2C_LCD_BIAS";
		label = "lcd-backlight";
		pwm_config = <0 1 0 0 0>;
		reg = <0x11>;
		id = <10>;
		status = "okay";
	};
};

&i2c0 {
/*
	spk1: speaker_amp@5c {
		compatible = "richtek,rt5512";
		#sound-dai-cells = <0>;
		reg = <0x5c>;
		status = "okay";
		sound-name-prefix = "Left";
	};

	spk2: speaker_amp@5d {
		compatible = "richtek,rt5512";
		#sound-dai-cells = <0>;
		reg = <0x5d>;
		status = "okay";
		sound-name-prefix = "Right";
	};
*/
       clock-frequency = <400000>;
       spk1: speaker_amp@34 {
               status = "okay";
               compatible = "tfa,tfa98xx";
               #sound-dai-cells = <0>;
               reg = <0x34>;
               reset-gpio = <&pio 91 0>;
               reset-polarity=<0>;
               irq-gpio = <&pio 39 0>;
       };

       spk2: speaker_amp@36 {
               status = "okay";
               compatible = "tfa,tfa98xx";
               #sound-dai-cells = <0>;
               reg = <0x36>;
               reset-polarity=<0>;
               irq-gpio = <&pio 94 0>;
       };
};

&sound {
	mediatek,spk-i2s = <25 24>;
	mediatek,speaker-codec {
		sound-dai = <&spk1>, <&spk2>;
	};
};

&odm {
	snd_vir_haptic: snd-vir-haptic {
		compatible = "mediatek,snd-vir-haptic";
	};
};

&mddriver {
	ref-args = "md_disable";
};

#if 0
&pdc {
	pd_vbus_upper_bound = <12000000>;
};

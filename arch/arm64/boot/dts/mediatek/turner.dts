&thermal_zones {
	quiet_therm: quiet_therm {
		polling-delay = <0>; /* milliseconds */
		polling-delay-passive = <0>; /* milliseconds */
		thermal-sensors = <&tboard_thermistor8>;

		trips {
			quiet_therm_crit: quiet-therm-crit {
				temperature = <119000>;
				hysteresis = <2000>;
				type = "passive";
			};
		};
	};
	charger1_therm: charger1_therm {
		polling-delay = <0>; /* milliseconds */
		polling-delay-passive = <0>; /* milliseconds */
		thermal-sensors = <&tboard_thermistor9>;

		trips {
			charger1_therm_crit: charger1-therm-crit {
				temperature = <119000>;
				hysteresis = <2000>;
				type = "passive";
			};
		};
	};
	wifi_therm: wifi_therm {
		polling-delay = <0>; /* milliseconds */
		polling-delay-passive = <0>; /* milliseconds */
		thermal-sensors = <&tboard_thermistor4>;

		trips {
			wifi_therm_crit: wifi-therm-crit {
				temperature = <119000>;
				hysteresis = <2000>;
				type = "passive";
			};
		};
	};
	flash_therm: flash_therm {
		polling-delay = <0>; /* milliseconds */
		polling-delay-passive = <0>; /* milliseconds */
		thermal-sensors = <&tboard_thermistor5>;

		trips {
			flash_therm_crit: flash-therm-crit {
				temperature = <119000>;
				hysteresis = <2000>;
				type = "passive";
			};
		};
	};
	display_therm: display_therm {
		polling-delay = <0>; /* milliseconds */
		polling-delay-passive = <0>; /* milliseconds */
		thermal-sensors = <&tboard_thermistor6>;

		trips {
			display_therm_crit: display-therm-crit {
				temperature = <119000>;
				hysteresis = <2000>;
				type = "passive";
			};
		};
	};
	ScreenPmic_therm: ScreenPmic_therm {
		polling-delay = <0>; /* milliseconds */
		polling-delay-passive = <0>; /* milliseconds */
		thermal-sensors = <&tboard_thermistor7>;

		trips {
			ScreenPmic_therm_crit: ScreenPmic-therm-crit {
				temperature = <119000>;
				hysteresis = <2000>;
				type = "passive";
			};
		};
	};
};

&pio {
	charger_third_pd_phy: charger-third-pd-phy {
 		pins_cmd_dat {
 			pinmux = <PINMUX_GPIO123__FUNC_SCL3>,
  			<PINMUX_GPIO124__FUNC_SDA3>;
 			bias-pull-up = <MTK_PULL_SET_RSEL_111>;
 		};
 	};
};

&pio {
	charger_load_switch: charger-load-switch {
 		pins_cmd_dat {
 			pinmux = <PINMUX_GPIO190__FUNC_SCL4>,
			<PINMUX_GPIO191__FUNC_SDA4>;
 			bias-pull-up = <MTK_PULL_SET_RSEL_101>;
 		};
 	};
};

&pio {
	charger_quick_cp: charger-quick-cp {
 		pins_cmd_dat {
 			pinmux = <PINMUX_GPIO176__FUNC_SCL5>,
			<PINMUX_GPIO177__FUNC_SDA5>;
 			bias-pull-up = <MTK_PULL_SET_RSEL_111>;
 		};
 	};
};


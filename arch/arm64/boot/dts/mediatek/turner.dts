&lk_charger {
	/* charging current */
	usb-charger-current = <500000>;
	ac-charger-current = <1500000>;
	ac-charger-input-current = <2000000>;
	non-std-ac-charger-current = <1500000>;
	charging-host-charger-current = <1500000>;
	ta-ac-charger-current = <1500000>;
	pd-charger-current = <1500000>;
	/* battery temperature protection */
	temp-t4-threshold = <60>;
	temp-t3-threshold = <45>;
	pre-charger-current = <550000>;
	fast-charge-voltage = <3100>;
	max-charger-voltage = <12000000>;
	shutdown-voltage = <3200>;
	boot-battery-voltage = <3400000>;
};


&pd_cp_manager {
		compatible = "pd_cp_manager";
		fv = <4530>;
		fv_ffc = <4580>;
		max_fcc = <12400>;
		max_vbus = <12000>;
		max_ibus = <6200>;
		fcc_low_hyst = <120>;
		fcc_high_hyst = <(-30)>;
		low_tbat = <100>;
		high_tbat = <480>;
		high_vbat = <4400>;
		high_soc = <95>;
		low_fcc = <2000>;
		cv_vbat = <4510>;
		cv_vbat_ffc = <4560>;
		cv_ibat = <2000>;
		min_pdo_vbus = <8000>;
		max_pdo_vbus = <11000>;
		support_pmic_parachg;
		switch1_1_enter = <3100>;
		switch1_1_exit = <4100>;
		switch2_1_enter = <4500>;
		switch2_1_exit = <12500>;
		pdm_ibus_gap = <1600>;
		pdm_bypass_ibus_gap = <2600>;
		adapter_power = <66>;
		fv_hyst = <3>;
};

&strategy_fg{
		compatible = "xiaomi,strategy_fg";
		enable_shutdown_delay;
		normal_shutdown_vbat_1s = <3200>;
		critical_shutdown_vbat_1s = <3250>;
		cool_critical_shutdown_vbat_1s = <3250>;
		old_critical_shutdown_vbat_1s = <3250>;
		report_full_rsoc_1s = <9700>;
		soc_gap_1s = <2>;
		fg_type = <1>;
};

&mtk_gauge{
	DISABLE_MTKBATTERY = <(1)>;
};

&i2c5 {
	clock-frequency = <400000>;
	status = "okay";
	sc8541@6C{
		compatible = "sc,sc8541-standalone";
		reg = <0x6C>;
		pinctrl-names = "charger_quick_cp";
 		pinctrl-0 = <&charger_quick_cp>;
		interrupt-parent = <&pio>;
		interrupts = <76 0>;
		sc8541,intr_gpio = <&pio 27 IRQ_TYPE_EDGE_FALLING>;
		charger_name = "primary_dvchg";
		charger_name_v4_19 = "primary_divider_chg";
		sc,sc8541,vbat-ovp-dis = <0>;
		sc,sc8541,vbat-ovp = <90>; /*3840 + val * 10*/
		sc,sc8541,vbat-ovp-alm-dis = <1>;
		sc,sc8541,vbat-ovp-alm = <70>; /*3840 + val * 10*/
		sc,sc8541,ibat-ocp-dis = <0>;
		sc,sc8541,ibat-ocp  = <127>; /*val * 100*/
		sc,sc8541,ibat-ocp-alm-dis = <1>;
		sc,sc8541,ibat-ocp-alm = <80>; /*val * 100*/
		sc,sc8541,ibus-ucp-dis = <0>;
		sc,sc8541,vbus-in-range-dis = <0>;
		sc,sc8541,vbus-pd-en = <0>;
		sc,sc8541,vbus-ovp = <80>; /*7000 + val * 50*/
		sc,sc8541,vbus-ovp-alm-dis = <1>;
		sc,sc8541,vbus-ovp-alm = <80>; /*7000 + val * 50*/
		sc,sc8541,ibus-ocp-dis = <0>;
		sc,sc8541,ibus-ocp = <21>; /*1000 + val * 250*/
		sc,sc8541,tshut-dis = <1>;
		sc,sc8541,tsbus-flt-dis = <1>;
		sc,sc8541,tsbat-flt-dis = <1>;
		sc,sc8541,tdie-alm = <200>; /*25 + val * 0.5*/
		sc,sc8541,tsbus-flt = <21>;
		sc,sc8541,tsbat-flt = <21>;
		sc,sc8541,vac1-ovp = <3>; /*0:6.5V 1:10.5V 2:12V 3:14V 4:16V 5~7:18V*/
		sc,sc8541,vac2-ovp = <3>; /*0:6.5V 1:10.5V 2:12V 3:14V 4:16V 5~7:18V*/
		sc,sc8541,vac1-pd-en = <0>;
		sc,sc8541,vac2-pd-en = <0>;
		sc,sc8541,fsw-set = <4>; /*0:200KHz 1:300KHz 2:400KHz
				3:500KHz 4:600KHz 5:650KHz 6:700KHz 7:750KHz*/
		sc,sc8541,wd-timeout = <0>; /*0:0.5s 1:1s 2:5s 3:30s*/
		sc,sc8541,wd-timeout-dis = <1>;
		sc,sc8541,ibat-sns-r = <0>; /*0:2mho 1:5mho*/
		sc,sc8541,ss-timeout = <7>; /*0:6.25ms 1:12.5ms 2:25ms 3:50ms
				4:100ms 5:400ms 6:1.5s 7:10s*/
		sc,sc8541,ibus-ucp-fall-dg = <1>;
		sc,sc8541,vout-ovp-dis = <0>;
		sc,sc8541,vout-ovp = <3>; /*4700 + val * 100*/
		sc,sc8541,pmid2out-uvp = <7>; /*50 + val * 25*/
		sc,sc8541,pmid2out-ovp = <7>; /*200 + val * 50*/
		project_vendor = <2>;
	};
};

&i2c4 {
	clock-frequency = <100000>;
	status = "okay";
	sc7601@54 {
		compatible = "sc7601";
		ic_role = <0>;
		reg = <0x54>;
		bat-ovp-threshold = <5500>;
		pre-chg-curr = <100>;
		vfc-chg-volt = <3100>;
		limit-chg-curr = <2950>;
		pinctrl-names = "charger_load_switch";
 		pinctrl-0 = <&charger_load_switch>;
	};
};

&i2c7 {
    clock-frequency = <400000>;
    sc-wireless-charger@38{
        compatible = "sc,sc96231-wireless-charger";
        reg = <0x38>;
		project_vendor = <2>;
		fw_version_index = <0>;
		rx-int = <&pio 213 IRQ_TYPE_EDGE_FALLING>;
		hall-int3 = <&pio 211 IRQ_TYPE_EDGE_FALLING>;
		hall-int4 = <&pio 113 IRQ_TYPE_EDGE_FALLING>;
		hall-int3-s = <&pio 209 IRQ_TYPE_EDGE_FALLING>;
		hall-int4-s = <&pio 112 IRQ_TYPE_EDGE_FALLING>;
		reverse-boost-gpio = <&pio 212 0x0>;
		reverse-txon-gpio = <&pio 1 0x0>;
    };
};

&extcon_usb {
	vdd_boost_5v_en_a = <&pio 128 0x0>;
};

&extcon_usb1 {
	vdd_boost_5v_en_b = <&pio 127 0x0>;
	status = "okay";
};

&pmic_adc {
	vin3_open {
		channel = <AUXADC_VIN3>;
		pures = <ADC_PURES_100K>;
	};
	vin5_open {
		channel = <AUXADC_VIN5>;
		pures = <ADC_PURES_100K>;
	};
};

&mt6379_typec {
	tcpc,en_floatgnd;
	/* 0:16x, 1:128x, 2:512x, 3:1024x */
	wd,wd0_tsleep = <1>;
	/* 0:400us, 1:1ms, 2:2ms, 3:4ms, 4:10ms, 5:40ms, 6:100ms, 7:400ms */
	wd,wd0_tdet = <3>;
	/* example wd0_tsleep = 512x, wd0_tdet = 4ms, wd0 polling time = 512*4ms */

	port {
		tcpc_typec_usb: endpoint {
			remote-endpoint = <&ssusb_mux>;
		};
	};
};

&mtee_svp {
        mtee: MTEE {
                compatible = "mediatek,mtk_svp_on_mtee_support";
        };

        svp: SecureVideoPath {
                compatible = "mediatek,mtk_sec_video_path_support";
        };
};

&mtkheap_page_tee {
        status = "ok";
};

&mtkheap_page_svp {
        status = "ok";
};


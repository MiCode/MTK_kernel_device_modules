/dts-v1/;
/plugin/;
#include <dt-bindings/interrupt-controller/arm-gic.h>
#include <dt-bindings/interrupt-controller/irq.h>
#include <dt-bindings/pinctrl/mt6993-pinfunc.h>
#include <dt-bindings/phy/phy.h>
#include <dt-bindings/iio/mt635x-auxadc.h>
#include <dt-bindings/clock/mt6993-clk.h>
#include <dt-bindings/thermal/thermal.h>
#include <dt-bindings/gpio/gpio.h>
#include "mediatek/xiaomi_yili_mt6993_fingerprint.dtsi"

&chosen {
	bootargs_ext = "log_buf_len=2M";
};

&clkbuf_ctrl {
	compatible = "mediatek,mt8910-clkbuf";
};

&mt6687_clkbuf {
	compatible = "mediatek,mt6687-tb-clkbuf";
};

&android {
	hardware = "mt8910";
};

&ise_lpm {
	ise-wakelock = <0>;
	ise-lpm-freerun = <0>;
	ise-lpm-deinit-bypass = <0>;
	ise-lpm-vote-dram = <0>;
};

&ise_mbox {
	mediatek,real-drv = <0>;
};

&ise_trusty {
	mediatek,real-drv = <0>;
};

&pio {
	mtkfb_pins_lcd_bias_enp1: lcd-bias-enp1-gpio {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO118__FUNC_GPIO118>;
			slew-rate = <1>;
			output-high;
		};
	};
	mtkfb_pins_lcd_bias_enp0: lcd-bias-enp0-gpio {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO118__FUNC_GPIO118>;
			slew-rate = <1>;
			output-low;
		};
	};
	mtkfb_pins_lcd_bias_enn1: lcd-bias-enn1-gpio {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO118__FUNC_GPIO118>;
			slew-rate = <1>;
			output-high;
		};
	};
	mtkfb_pins_lcd_bias_enn0: lcd-bias-enn0-gpio {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO118__FUNC_GPIO118>;
			slew-rate = <1>;
			output-low;
		};
	};
	mtkfb_pins_lcm_rst_out1_gpio: lcm-rst-out1-gpio {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO89__FUNC_GPIO89>;
			slew-rate = <1>;
			output-high;
		};
	};
	mtkfb_pins_lcm_rst_out0_gpio: lcm-rst-out0-gpio {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO89__FUNC_GPIO89>;
			slew-rate = <1>;
			output-low;
		};
	};
	mtkfb_pins_lcm_dsi_te: lcm-dsi-te {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO88__FUNC_DSI_TE>;
		};
	};
	mtkfb_pins_lcm_led_en1: lcm-led-en1-gpio {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO105__FUNC_GPIO105>;
			slew-rate = <1>;
			output-high;
		};
	};
	mtkfb_pins_lcm_led_en0: lcm-led-en0-gpio {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO105__FUNC_GPIO105>;
			slew-rate = <1>;
			output-low;
		};
	};
};

&odm {
	thermal_message: thermal-message {
		board-sensor = "VIRTUAL-SENSOR";
		board-sensor-trip-enable = <1>;
		trip-point-high = <41000>;
		trip-point-low = <40000>;
		sysfs-nodes {
			foreground_app_name {
				mode-flag = <2>;
				data-flag = <0>;
			};
			therm_log_enable {
				mode-flag = <2>;
				data-flag = <1>;
				default = <0>;
			};
			boost_daily_track {
				mode-flag = <2>;
				data-flag = <0>;
			};
			boost_perapp_track {
				mode-flag = <2>;
				data-flag = <0>;
			};
			config_daily_track {
				mode-flag = <2>;
				data-flag = <0>;
			};
		};
	};
};

&mt6661_5_auxadc {
	mt6661-5-vin1-100k-poll {
				channel = <AUXADC_VIN1_POLL>;
				pures = <ADC_PURES_100K>;
				rc-set-time = <1400>;
			};

	mt6661-5-vin3-100k-poll {
				channel = <AUXADC_VIN3_POLL>;
				pures = <ADC_PURES_100K>;
				rc-set-time = <1400>;
			};

	mt6661-5-vin4-100k-poll {
				channel = <AUXADC_VIN4_POLL>;
				pures = <ADC_PURES_100K>;
				rc-set-time = <1400>;
			};

	mt6661-5-vin5-100k-poll {
				channel = <AUXADC_VIN5_POLL>;
				pures = <ADC_PURES_100K>;
				rc-set-time = <1400>;
			};

	mt6661-5-agpio1-100k-poll {
				channel = <AUXADC_AGPIO1_POLL>;
				pures = <ADC_PURES_100K>;
				rc-set-time = <1400>;
			};

	mt6661-5-agpio2-100k-poll {
				channel = <AUXADC_AGPIO2_POLL>;
				pures = <ADC_PURES_100K>;
				rc-set-time = <1400>;
			};

};

&mt6661_6_auxadc {
	mt6661-6-vin1-100k {
				channel = <AUXADC_VIN1>;
				pures = <ADC_PURES_100K>;
				rc-set-time = <1400>;
			};
	mt6661-6-vin2-100k {
				channel = <AUXADC_VIN2>;
				pures = <ADC_PURES_100K>;
				rc-set-time = <1400>;
			};
	mt6661-6-vin3-100k {
				channel = <AUXADC_VIN3>;
				pures = <ADC_PURES_100K>;
				rc-set-time = <1400>;
			};
	mt6661-6-vin4-100k {
				channel = <AUXADC_VIN4>;
				pures = <ADC_PURES_100K>;
				rc-set-time = <1400>;
			};
	mt6661-6-vin5-100k {
				channel = <AUXADC_VIN5>;
				pures = <ADC_PURES_100K>;
				rc-set-time = <1400>;
			};
};

&mtkfb {
	pinctrl-names = "lcd_bias_enp1_gpio", "lcd_bias_enp0_gpio",
		"lcd_bias_enn1_gpio", "lcd_bias_enn0_gpio",
		"lcm_rst_out1_gpio", "lcm_rst_out0_gpio",
		"mode_te_te", "lcm_led_en1_gpio", "lcm_led_en0_gpio",
		"mode_te_te1";
	pinctrl-0 = <&mtkfb_pins_lcd_bias_enp1>;
	pinctrl-1 = <&mtkfb_pins_lcd_bias_enp0>;
	pinctrl-2 = <&mtkfb_pins_lcd_bias_enn1>;
	pinctrl-3 = <&mtkfb_pins_lcd_bias_enn0>;
	pinctrl-4 = <&mtkfb_pins_lcm_rst_out1_gpio>;
	pinctrl-5 = <&mtkfb_pins_lcm_rst_out0_gpio>;
	pinctrl-6 = <&mtkfb_pins_lcm_dsi_te>;
	pinctrl-7 = <&mtkfb_pins_lcm_led_en1>;
	pinctrl-8 = <&mtkfb_pins_lcm_led_en0>;
	status = "okay";
};

&mtk_leds {
	compatible = "mediatek,disp-leds";

	backlight {
		max-brightness = <4095>;
		min-brightness = <1>;
		max-hw-brightness = <2047>;
		led-mode = <4>;
		default-state = "cust_lk_backlight";
		lk_backlight = <326>;
	};
};

&disp_wdma0 {
	mtk,smmu-shared = <&mm_smmu_disp>;
	mtk,smmu-shared-sec = <&mm_smmu_svp_disp>;
};

&dispsys_config {
	pinctrl-names = "mode_te_te";
	pinctrl-0 = <&mtkfb_pins_lcm_dsi_te>;

	helper-name-proj = "MTK_DRM_OPT_VIDLE_MTCMOS_DT_EN",
		"MTK_DRM_OPT_DSI_UNDERRUN_AEE",
		"MTK_DRM_OPT_RES_SWITCH",
		"MTK_DRM_OPT_RES_SWITCH_ON_AP",
		"MTK_DRM_OPT_FRAME_SUBMIT",
		"MTK_DRM_OPT_OVL_WCG_BY_COLOR_MODE";

	helper-value-proj = <1>, /*MTK_DRM_OPT_VIDLE_MTCMOS_DT_EN*/
		<1>, /*MTK_DRM_OPT_DSI_UNDERRUN_AEE*/
		<0>, /*MTK_DRM_OPT_RES_SWITCH*/
		<0>, /*MTK_DRM_OPT_RES_SWITCH_ON_AP*/
		<0>, /*MTK_DRM_OPT_FRAME_SUBMIT*/
		<1>; /*MTK_DRM_OPT_OVL_WCG_BY_COLOR_MODE*/


	clocks =
		<&disp_vdisp_ao_config_clk VDISP_AO_CONFIG_DISP>,
		<&dispsys_config_clk MM0_CONFIG_DISP>,
		<&disp0b_dispsys_config_clk MM0B_CONFIG_DISP>,
		<&ovlsys_config_clk OVLSYS_CONFIG_DISP>,
		<&ovl1_ovlsys_config_clk OVL1_OVLSYS_CONFIG_DISP>,
		<&ovl2_ovlsys_config_clk OVL2_OVLSYS_CONFIG_DISP>,
		<&dispsys1_config_clk MM1_DISP1_CFG_DISP>,
		<&dispsys1_config_clk MM1_DISP1_S_CFG_DISP>,
		<&disp1b_dispsys1_config_clk MM1B_DISP1_CFG_DISP>,
		<&disp1b_dispsys1_config_clk MM1B_DISP1_S_CFG_DISP>,
		<&dispsys_config_clk MM0_DISP_MUTEX0_DISP>,
		<&ovlsys_config_clk OVL_MUTEX0_DISP>,
		<&dispsys1_config_clk MM1_DISP_MUTEX0_DISP>,
		<&dispsys1_config_clk MM1_DISP_DSI0_DISP>,
		<&dispsys1_config_clk MM1_DISP_DSI1_DISP>,
		<&disp0b_dispsys_config_clk MM0B_DISP_MUTEX0_DISP>,
		<&ovl1_ovlsys_config_clk OVL1_OVL_MUTEX0_DISP>,
		<&ovl2_ovlsys_config_clk OVL2_OVL_MUTEX0_DISP>,
		<&disp1b_dispsys1_config_clk MM1B_DISP_MUTEX0_DISP>,
		<&disp_vdisp_ao_config_clk VDISP_AO_DISP_BWR_DISP>,
		<&disp_vdisp_ao_config_clk VDISP_AO_DISP_DEBUG_TOP_DISP>,
		<&dispsys_config_clk MM0_DISP_DBG_DISP>,
		<&disp0b_dispsys_config_clk MM0B_DISP_DBG_DISP>,
		<&ovlsys_config_clk OVL_DISP_DBG_DISP>,
		<&ovl1_ovlsys_config_clk OVL1_DISP_DBG_DISP>,
		<&ovl2_ovlsys_config_clk OVL2_DISP_DBG_DISP>,
		<&dispsys1_config_clk MM1_DISP_DBG_DISP>,
		<&disp1b_dispsys1_config_clk MM1B_DISP_DBG_DISP>;

	operating-points-v2 = <&opp_table_disp>, <&opp_table_disp_b0>;
	status = "okay";
};

&reserved_memory {
	hw_logger_resv_mem: hw-logger-resv-mem {
		compatible = "mediatek,hw-logger-resv-mem";
		size = <0 0x300000>; /* 3M */
		alignment = <0 0x1000>;
	};
};

&disp_dsc_wrap1 {
	status = "okay";
};

&reserved_memory {
	cmdq_reserved_mem: cmdq-resv-memory {
		compatible = "mediatek,cmdq-resv-mem";
		size = <0 0x200000>; /* 2M */
		alignment = <0 0x1000>;
	};
};

&mt6661_4_ldc0_3 {
	regulator-always-on;
};

&disp_merge0 {
	status = "okay";
};

&dp_tx{
	dp-noe = <&pio 42 0>;
	dp-sel = <&pio 43 0>;
	dpauxn-supply = <&mt6661_3_ld20_1>;
};

&gpio_keys {
	status = "okay";
	boost {
		label = "boost";
		linux,code = <183>;
		linux,input-type = <1>;
		gpios = <&pio 18 1>;
		debounce-interval = <30>;
		wakeup-source;
	};
};

&disp_c3d0 {
	auto-flip = <0>;
};

&disp_c3d1 {
	auto-flip = <0>;
};

&disp_c3d2 {
	auto-flip = <0>;
};

&disp_c3d3 {
	auto-flip = <0>;
};


&dsi0 {
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;
	yili_42_02_0a_dsc_vdo: panel1@0 {
		compatible = "p88_42_02_0a_dsc_vdo,lcm";
		reg = <0>;
		reset-gpios = <&pio 89 0>;
		mi,esd-err-irq-gpio = <&pio 8 0x2002>;
		mi,esd-err-irq-gpio-second = <&pio 7 0x2002>;
		lane-swap-setting = <1 2 0 3 4 2>;
		pn-swap-setting = <1 1 1 1 1 1>;
		pinctrl-names = "default";
		dpaux-supply = <&mt6661_4_ldc0_3>;
		dvdd-gpios =  <&pio 104 0>;
		hw_en-gpios = <&pio 105 0>;
		lcm_id-gpios = <&pio 186  (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;

		port {
			panel_in: endpoint {
				remote-endpoint = <&dsi_out>;
			};
		};
	};

	ports {
		#address-cells = <1>;
		#size-cells = <0>;
		port@0 {
			reg = <0>;
			dsi_out: endpoint {
				remote-endpoint = <&panel_in>;
			};
		};
		port@1 {
			reg = <1>;
			master_out: endpoint {
				remote-endpoint = <&slave_in>;
			};
		};
	};
};

&dsi1 {
	mediatek,dual-dsi-slave;
	status = "okay";
	ports {
		#address-cells = <1>;
		#size-cells = <0>;
		port@1 {
			reg = <1>;
			slave_in: endpoint {
				remote-endpoint = <&master_out>;
			};
		};
	};
};

&dsi1_te {
	interrupt-parent = <&pio>;
	interrupts = <6 1 6 1>;
	status = "okay";
};


&i2c5 {
	clock-frequency = <400000>; //400k
	gate_ic: gate_ic@11 {
		compatible = "mediatek,MI_I2C_LCD_BIAS";
		label = "lcd-backlight";
		pwm_config = <0 1 0 0 0>;
		reg = <0x11>;
		id = <5>;
		status = "okay";
	};
};

&pcie0 {
	pinctrl-names = "init", "default", "sleep", "pd";
	pinctrl-0 = <&pcie0_pins_init>;
	pinctrl-1 = <&pcie0_pins_default>;
	pinctrl-2 = <&pcie0_pins_sleep>;
	pinctrl-3 = <&pcie0_pins_pd>;
	max-link-speed = <4>;
	mediatek,suspend-mode-l12;
	status = "okay";
};

&pcie1 {
	pinctrl-names = "default";
	pinctrl-0 = <&pcie1_pins_default>;
	max-link-speed = <4>;
	status = "disabled";
};

&pciephy0 {
	mediatek,short-reach;
	status = "okay";
};

&pciephy1 {
	status = "disabled";
};

/* PCIe pinmux start */
/* skyhawk use waken to control DFD_EN, PCIe0 don't need to control it */
&pio {
	pcie0_pins_init: pcie0-init {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO245__FUNC_GPIO245>;
			output-low;
		};

		pins-cmd-dat1 {
			pinmux = <PINMUX_GPIO247__FUNC_GPIO247>;
			bias-pull-up;
			input-enable;
		};
	};

	pcie0_pins_default: pcie0-default {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO245__FUNC_PCIE_PERSTN>,
				 <PINMUX_GPIO247__FUNC_PCIE_CLKREQN>;
			bias-pull-up;
		};
	};

	pcie0_pins_sleep: pcie0-sleep {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO245__FUNC_GPIO245>;
			output-low;
		};

		pins-cmd-dat1 {
			pinmux = <PINMUX_GPIO247__FUNC_GPIO247>;
			bias-pull-up;
			input-enable;
		};
	};

	pcie0_pins_pd: pcie0-pd {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO245__FUNC_GPIO245>;
			output-low;
		};

		pins-cmd-dat1 {
			pinmux = <PINMUX_GPIO247__FUNC_GPIO247>;
			bias-pull-down;
			input-enable;
		};
	};

	pcie1_pins_default: pcie1-default {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO132__FUNC_PCIE_WAKEN_1P>,
				 <PINMUX_GPIO133__FUNC_PCIE_PERSTN_1P>,
				 <PINMUX_GPIO134__FUNC_PCIE_CLKREQN_1P>;
			bias-pull-up;
		};
	};
};
/* PCIe pinmux end */


&pio {

	rptr_enable: rptr-enable {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO185__FUNC_GPIO185>;
			output-high;
		};
	};

	rptr_disable: rptr-disable {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO185__FUNC_GPIO185>;
			output-low;
		};
	};

};

&ssusb {
	mediatek,force-vbus;
	mediatek,clk-mgr;
	mediatek,usb3-drd;
	mediatek,uds = <&usb_dp_selector 19>;
	mediatek,eusb2-cm-l1 = <0x474>;
	maximum-speed = "super-speed";
	maximum-speed-host = <0x05>;
	usb-role-switch;
	status = "okay";
};

&extcon_usb {
	nr-port = <2>;
	vdd_boost_5v_en_a = <&pio 77 0x0>;
	vdd_boost_5v_en_b = <&pio 76 0x0>;
	pinctrl-names = "enable", "disable";
	pinctrl-0 = <&rptr_enable>;
	pinctrl-1 = <&rptr_disable>;
	tcpc = "type_c_port0";
};


/* usb typec mux start */
&pio {
	ps_enable: ps-enable {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO204__FUNC_GPIO204>;
			output-high;
		};
	};

	ps_disable: ps-disable {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO204__FUNC_GPIO204>;
			output-low;
		};
	};
};

&mipi_tx_config0 {
	status = "okay";
};

&mipi_tx_config1 {
	status = "okay";
};

&mt6379_typec {
	port {
		tcpc_typec_usb: endpoint {
			remote-endpoint = <&ssusb_mux>;
		};
	};
};

&typec_mux_switch {
	orientation-switch;
	mode-switch;
	accessory;
	port {
		ssusb_mux: endpoint {
			remote-endpoint = <&tcpc_typec_usb>;
		};
	};
};

&usb_dp_selector {
	status = "okay";
};
/* usb typec mux end */

/*
 * power-off-time-sec
 *   0      : 8 sec
 *   1      : 11 sec
 *   2      : 2 sec
 *   3      : 5 sec
*/
&mt6661keys {
	pinctrl-names = "kpcol0_mode";
	pinctrl-0 = <&kpcol0_pins_gpio_mode>;
	power-off-time-sec = <1>;

	home2 {
		linux,keycodes = <115>;
		wakeup-source;
	};
};

&pio {
	kpcol0_pins_gpio_mode: gpio-mode {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO40__FUNC_GPIO40>;
			input-enable;
		};
	};
};

&connfem {
	sku {
		hw-names =
			"vc536421_qm45655_ps_yili";	/* [0] QM42655/QM45655, 2G+2A, BT/Wi-Fi AntSwap */

		/***************************************************************
		 * [HW][0] QM42655/QM45655, 2G+2A, BT/Wi-Fi AntSwap
		 **************************************************************/
		hw-0 {
			using-fems =
				<&vc536421>,
				<&qm45655>;

			layout-flag = <0x00000000>;
			layout =
				<&g_wf0_bt0_vc536421>,
				<&g_wf1_bt1_vc536421>,
				<&a_wf0_qm45655>,
				<&a_wf1_qm45655>;

			common {
				flags {
					fe-ant-cnt = [85];
					fe-conn-dpdt-sp3t = [80];
					fe-conn-spdt = [80];
					fe-bt-wf-usage = [80];
					fe-conn-spdt-2 = [80];
				};
			};

			wifi {
				using-states = 
                                	<&vc536421_rxl>,
					<&qm45655_rxl_rxh>;
			};

			bt {
				flags {
					efem-mode = [03]; /* 3:epa_elna, 2:epa, 1:elna, 0:bypass */
					rx-mode = [24]; /* 0x24: G-band RxL */
				};
			};
		};
	};
};

&pio {
	aw86938_irq_active_r:aw86938_irq_active_r {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO19__FUNC_GPIO19>;
			slew-rate = <0>;
			bias-pull-up = <00>;
		};
	};
	aw86938_rst_active_r:aw86938_rst_active_r {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO171__FUNC_GPIO171>;
			slew-rate = <0>;
			bias-pull-up = <00>;
		};
	};
	aw86938_irq_active_l:aw86938_irq_active_l {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO231__FUNC_GPIO231>;
			slew-rate = <0>;
			bias-pull-up = <00>;
		};
	};
	aw86938_rst_active_l:aw86938_rst_active_l {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO49__FUNC_GPIO49>;
			slew-rate = <0>;
			bias-pull-up = <00>;
		};
	};
};

&i2c1 {
    clock-frequency = <400000>;
        status = "ok";
        haptic_hv_r@5B {
                compatible = "awinic,haptic_hv_r";
                reg = <0x5B>;
                #sound-dai-cells = <0>;
                sound-name-prefix = "HAPTIC_SPK_R";
                irq-gpio = <&pio 19 1>;
                reset-gpio = <&pio 171 1>;
                f0_pre = < 1700 >;
                mode = /bits/ 8 < 5 >;
                aw8693x_f0_cali_percent = /bits/ 8 < 15 >;
                aw8693x_gain_bypass = /bits/ 8 < 1 >;
                aw8693x_uvlo_vol_default = /bits/ 8 < 0 >;
                aw8693x_cont_smart_loop = /bits/ 8 < 0 >;
                aw8693x_cont_drv1_lvl = /bits/ 8 < 0x7F >;
                aw8693x_cont_drv2_lvl = /bits/ 8 < 0x38 >;
                aw8693x_cont_lra_vrms = < 1000 >;
                aw8693x_cont_drv1_time = /bits/ 8 < 0x04 >;
                aw8693x_cont_drv2_time = /bits/ 8 < 0x32 >;
                aw8693x_cont_track_margin = /bits/ 8 < 0x0F >;
                aw8693x_cont_brk_gain = /bits/ 8 < 0x08 >;
                aw8693x_cont_brk_time = /bits/ 8 < 0x08 >;
                aw8693x_duration_time = /bits/ 8 < 20 30 60 >;
                aw8693x_d2s_gain = /bits/ 8 < 0x04 >;
                aw8693x_algo_d2s_gain = /bits/ 8 < 0x01 >;
                aw8693x_drv_width = /bits/ 8 < 0x6A >;
                aw8693x_trig_config = /bits/ 8 < 0 0 0 1 0 2 0 0
                                                 0 0 0 1 0 2 0 0
                                                 0 0 0 1 0 2 0 0 >;
                aw8693x_bst_vol_default = < 8500 >;
                /* aw8693x_is_enabled_track_en; */
                aw8693x_vib_effect_max = < 197 >; /*vib_effect_max must bigger than vib_effect_id*/
                /* aw8693x_is_enabled_auto_bst; */
                /* aw8693x_is_enabled_one_wire; */
        };
        aw8693xs_codec: haptic_hv_l@5A{
                status = "ok";
                compatible = "awinic,haptic_hv_l";
                reg = <0x5A>;
                #sound-dai-cells = <0>;
                sound-name-prefix = "HAPTIC_SPK";
                f0_pre = < 1700 >;
                mode = /bits/ 8 < 5 >;
                irq-gpio = <&pio 231 1>;
                reset-gpio = <&pio 49 1>;
                /****************** aw8693x **************/
                aw8693x_f0_cali_percent = /bits/ 8 < 15 >;
                aw8693x_gain_bypass = /bits/ 8 < 1 >;
                aw8693x_uvlo_vol_default = /bits/ 8 < 0 >;
                aw8693x_cont_smart_loop = /bits/ 8 < 0 >;
                aw8693x_cont_drv1_lvl = /bits/ 8 < 0x7F >;
                aw8693x_cont_drv2_lvl = /bits/ 8 < 0x38 >;
                aw8693x_cont_drv_width = /bits/ 8 <0x8A>;
                aw8693x_cont_lra_vrms = < 1000 >;
                aw8693x_cont_drv1_time = /bits/ 8 < 0x04 >;
                aw8693x_cont_drv2_time = /bits/ 8 < 0x32 >;
                aw8693x_cont_track_margin = /bits/ 8 < 0x0F >;
                aw8693x_cont_brk_gain = /bits/ 8 < 0x08 >;
                aw8693x_cont_brk_time = /bits/ 8 < 0x08 >;
                aw8693x_duration_time = /bits/ 8 < 20 30 60 >;
                aw8693x_d2s_gain = /bits/ 8 < 0x04 >;
                aw8693x_algo_d2s_gain = /bits/ 8 < 0x01 >;
                aw8693x_drv_width = /bits/ 8 < 0x6A >;
                aw8693x_trig_config = /bits/ 8 < 0 0 0 1 0 2 0 0
                                                 0 0 0 1 0 2 0 0
                                                 0 0 0 1 0 2 0 0 >;
                aw8693x_bst_vol_default = < 8500 >;
                /* aw8693x_is_enabled_track_en; */
                aw8693x_vib_effect_max = < 197 >; /*vib_effect_max must bigger than vib_effect_id*/
                /* aw8693x_is_enabled_auto_bst; */
                /* aw8693x_is_enabled_one_wire; */
        };
};

&i2c0 {
       clock-frequency = <400000>;
       spk1: speaker_amp@34 {
               status = "okay";
               compatible = "tfa,tfa98xx";
               #sound-dai-cells = <0>;
               reg = <0x34>;
               reset-gpio = <&pio 106 0>;
               reset-polarity=<0>;
               irq-gpio = <&pio 138 0>;
       };
       spk2: speaker_amp@36 {
               status = "okay";
               compatible = "tfa,tfa98xx";
               #sound-dai-cells = <0>;
               reg = <0x36>;
               reset-polarity=<0>;
               irq-gpio = <&pio 107 0>;
       };
};

&sound {
	mediatek,spk-i2s = <25 24>;
	mediatek,speaker-codec {
		sound-dai = <&spk1>, <&spk2>;
	};
};

&mt6661_5_lnc0_10 {
	regulator-always-on;
	regulator-min-microvolt = <1800000>;
	regulator-max-microvolt = <1800000>;
};


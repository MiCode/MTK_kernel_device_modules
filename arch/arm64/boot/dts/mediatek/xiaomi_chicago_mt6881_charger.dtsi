&lk_charger {
	non-std-ac-charger-current = <1000000>;
	ac-charger-current = <1600000>;
	ac-charger-input-current = <2000000>;
	/* battery temperature protection */
	temp-t4-threshold = <58>;
	temp-t3-threshold = <45>;
	temp-t1-threshold = <(-10)>;
	boot-battery-voltage-max = <3650000>;
	boot-battery-voltage = <3200000>;
	pre-charger-current = <700000>;
	boot-voltage-level = <3000 3100 3200 3200 3400>;
	ta-capability-level = <1900 1350 850 500 0>;
	extrem-boot-battery-voltage = <3100000>;
};

&pd_cp_manager {
		compatible = "pd_cp_manager";
		fv = <4492>;
		fv_ffc = <4562>;
		max_fcc = <17600>;
		max_vbus = <20000>;
		max_ibus = <4400>;
		fcc_low_hyst = <150>;
		fcc_high_hyst = <10>;
		low_tbat = <100>;
		high_tbat = <480>;
		high_vbat = <4400>;
		high_soc = <95>;
		low_fcc = <2000>;
		cv_vbat = <4480>;
		cv_vbat_ffc = <4510>;
		cv_ibat = <1200>;
		min_pdo_vbus = <8000>;
		max_pdo_vbus = <21000>;
		mt6375_control_gpio = <&pio 11 0x0>;
		lsw_control_gpio = <&pio 10 0x0>;
		support_4_1_mode;
		support_pmic_parachg;
		switch1_1_enter = <2500>;
		switch1_1_exit = <3700>;
		switch2_1_enter = <4200>;
		switch2_1_exit = <6500>;
		pdm_ibus_gap = <0>;
		pdm_bypass_ibus_gap = <2600>;
		adapter_power = <100>;
		fv_hyst = <9>;
		support_pchg_policy;
};

&mtk_gauge {
	disable-mtkbattery = <(1)>;
	FIXED_BATTERY_TEMPERATURE = <(25)>;
};

&rt_pd_manager {
	en-wd0-port0;
};

&mt6720_typec {
	tcpc,en_floatgnd;
};

&i2c5 {
	hl7603_3@77 {
		compatible = "hl7603_3";
		reg = <0x77>;
		vout_threshold = <3600>;
	};
};

&mt6368_vtp {
		regulator-always-on;
};

&mt6720_div2 {
    status = "disabled";
};


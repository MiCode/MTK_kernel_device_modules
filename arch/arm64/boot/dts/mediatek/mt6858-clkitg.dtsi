&clkitg {
	status = "okay";
	bring-up@0 {
		compatible = "mediatek,clk-bring-up";
		reg = <0x0>;
		clocks =
			<&cksys_reg_clk CLK_TOP_DISP0_SEL>,
			<&cksys_reg_clk CLK_TOP_MMINFRA_SEL>,
			<&cksys_reg_clk CLK_TOP_UART_SEL>,
			<&cksys_reg_clk CLK_TOP_MSDC_MACRO_1P_SEL>,
			<&cksys_reg_clk CLK_TOP_MSDC30_1_SEL>,
			<&cksys_reg_clk CLK_TOP_MSDC30_1_HCLK_SEL>,
			<&cksys_reg_clk CLK_TOP_DISP_PWM_SEL>,
			<&cksys_reg_clk CLK_TOP_USB_TOP_SEL>,
			<&cksys_reg_clk CLK_TOP_USB_XHCI_SEL>,
			<&cksys_reg_clk CLK_TOP_I2C_SEL>,
			<&cksys_reg_clk CLK_TOP_SENINF_SEL>,
			<&cksys_reg_clk CLK_TOP_SENINF1_SEL>,
			<&cksys_reg_clk CLK_TOP_SENINF2_SEL>,
			<&cksys_reg_clk CLK_TOP_DPMAIF_MAIN_SEL>,
			<&cksys_reg_clk CLK_TOP_VENC_SEL>,
			<&cksys_reg_clk CLK_TOP_VDEC_SEL>,
			<&cksys_reg_clk CLK_TOP_DSI_OCC_SEL>,
			<&cksys_reg_clk CLK_TOP_IMG1_SEL>,
			<&cksys_reg_clk CLK_TOP_IPE_SEL>,
			<&cksys_reg_clk CLK_TOP_CAM_SEL>,
			<&cksys_reg_clk CLK_TOP_CAMTM_SEL>,
			<&cksys_reg_clk CLK_TOP_USB_FRMCNT_SEL>,
			<&apmixedsys_clk CLK_APMIXED_UNIVPLL>,
			<&apmixedsys_clk CLK_APMIXED_MSDCPLL>,
			<&apmixedsys_clk CLK_APMIXED_MMPLL>,
			<&apmixedsys_clk CLK_APMIXED_TVDPLL>,
			<&vlp_cksys_top_clk CLK_VLP_TOP_SCP_SEL>,
			<&vlp_cksys_top_clk CLK_VLP_TOP_CAMTG0_SEL>,
			<&vlp_cksys_top_clk CLK_VLP_TOP_CAMTG1_SEL>,
			<&vlp_cksys_top_clk CLK_VLP_TOP_CAMTG2_SEL>,
			<&vlp_cksys_top_clk CLK_VLP_TOP_CAMTG3_SEL>;
	};

	bring-up-disp@1 {
		compatible = "mediatek,clk-bring-up";
		reg = <0x1>;
		clocks =
			<&dispsys_config_clk CLK_MM_DISP_OVL0_2L_DISP>,
			<&dispsys_config_clk CLK_MM_DISP_OVL1_2L_DISP>,
			<&dispsys_config_clk CLK_MM_DISP_OVL2_2L_DISP>,
			<&dispsys_config_clk CLK_MM_DISP_RSZ1_DISP>,
			<&dispsys_config_clk CLK_MM_DISP_RSZ0_DISP>,
			<&dispsys_config_clk CLK_MM_DISP_TDSHP0_DISP>,
			<&dispsys_config_clk CLK_MM_DISP_C3D0_DISP>,
			<&dispsys_config_clk CLK_MM_DISP_COLOR0_DISP>,
			<&dispsys_config_clk CLK_MM_DISP_CCORR0_DISP>,
			<&dispsys_config_clk CLK_MM_DISP_CCORR1_DISP>,
			<&dispsys_config_clk CLK_MM_DISP_AAL0_DISP>,
			<&dispsys_config_clk CLK_MM_DISP_GAMMA0_DISP>,
			<&dispsys_config_clk CLK_MM_DISP_POSTMASK0_DISP>,
			<&dispsys_config_clk CLK_MM_DISP_DITHER0_DISP>,
			<&dispsys_config_clk CLK_MM_DISP_TDSHP1_DISP>,
			<&dispsys_config_clk CLK_MM_DISP_C3D1_DISP>,
			<&dispsys_config_clk CLK_MM_DISP_CCORR2_DISP>,
			<&dispsys_config_clk CLK_MM_DISP_CCORR3_DISP>,
			<&dispsys_config_clk CLK_MM_DISP_GAMMA1_DISP>,
			<&dispsys_config_clk CLK_MM_DISP_DITHER1_DISP>,
			<&dispsys_config_clk CLK_MM_DISP_DSC_WRAP0_DISP>,
			<&dispsys_config_clk CLK_MM_DISP_DSI0_DISP>,
			<&dispsys_config_clk CLK_MM_DISP_WDMA1_DISP>,
			<&dispsys_config_clk CLK_MM_DISP_APB_BUS_DISP>,
			<&dispsys_config_clk CLK_MM_DISP_FAKE_ENG0_DISP>,
			<&dispsys_config_clk CLK_MM_DISP_FAKE_ENG1_DISP>,
			<&dispsys_config_clk CLK_MM_DISP_MUTEX0_DISP>,
			<&dispsys_config_clk CLK_MM_SMI_COMMON_DISP>,
			<&dispsys_config_clk CLK_MM_DSI0_DISP>,
			<&dispsys_config_clk CLK_MM_26M_DISP>;
	};

	bring-up-smi@2 {
		compatible = "mediatek,clk-bring-up";
		reg = <0x2>;
		clocks =
			// CAMSYS_RAWA pre-cg
			// CAMSYS_RAWB pre-cg
			<&camsys_main_clk CLK_CAM_M_CAM_CAM>,
			<&camsys_main_clk CLK_CAM_M_CAMTG_CAM>,
			<&camsys_main_clk CLK_CAM_M_CAM2MM_GALS_CAM>,

			<&imgsys1_clk CLK_IMGSYS1_LARB9_SMI>,
			<&imgsys1_clk CLK_IMGSYS1_LARB10_SMI>,
			<&imgsys2_clk CLK_IMGSYS2_LARB9_SMI>,
			<&ipesys_clk CLK_IPE_LARB20_SMI>,
			<&ipesys_clk CLK_IPE_SMI_SUBCOM_SMI>,
			<&venc_gcon_clk CLK_VEN1_CKE0_LARB_SMI>,
			<&camsys_main_clk CLK_CAM_M_LARB13_SMI>,
			<&camsys_main_clk CLK_CAM_M_LARB14_SMI>,
			<&camsys_rawa_clk CLK_CAM_RA_LARBX_SMI>,
			<&camsys_rawb_clk CLK_CAM_RB_LARBX_SMI>,
			<&dispsys_config_clk CLK_MM_SMI_COMMON_SMI>,
			<&mdpsys_config_clk CLK_MDP_SMI0_SMI>;
	};

	bring-up-cam-dip@3 {
		compatible = "mediatek,clk-bring-up";
		reg = <0x3>;
		clocks =
			<&imgsys1_clk CLK_IMGSYS1_LARB9_CAM_DIP>,
			<&imgsys1_clk CLK_IMGSYS1_DIP_CAM_DIP>;
	};

	bring-up-msdc@4 {
		compatible = "mediatek,clk-bring-up";
		reg = <0x4>;
		clocks =
			<&pericfg_ao_clk CLK_PERAO_P_MSDC1_MSDC>,
			<&pericfg_ao_clk CLK_PERAO_P_MSDC1_H_MSDC>,
			<&pericfg_ao_clk CLK_PERAO_P_MSDC1_MST_F_MSDC>,
			<&pericfg_ao_clk CLK_PERAO_P_MSDC1_SLV_H_MSDC>;
	};

	bring-up-cam@5 {
		compatible = "mediatek,clk-bring-up";
		reg = <0x5>;
		clocks =
			// CAMSYS_RAWA pre-cg
			// CAMSYS_RAWB pre-cg
			<&camsys_main_clk CLK_CAM_M_CAM_CAM>,
			<&camsys_main_clk CLK_CAM_M_CAMTG_CAM>,
			<&camsys_main_clk CLK_CAM_M_CAM2MM_GALS_CAM>,

			<&camsys_main_clk CLK_CAM_M_LARB13_CAM>,
			<&camsys_main_clk CLK_CAM_M_LARB14_CAM>,
			<&camsys_main_clk CLK_CAM_M_SENINF_CAM>,
			<&camsys_main_clk CLK_CAM_M_CAMSV1_CAM>,
			<&camsys_main_clk CLK_CAM_M_CAMSV2_CAM>,
			<&camsys_main_clk CLK_CAM_M_CAMSV3_CAM>,
			<&camsys_rawa_clk CLK_CAM_RA_LARBX_CAM>,
			<&camsys_rawa_clk CLK_CAM_RA_CAM_CAM>,
			<&camsys_rawa_clk CLK_CAM_RA_CAMTG_CAM>,
			<&camsys_rawb_clk CLK_CAM_RB_LARBX_CAM>,
			<&camsys_rawb_clk CLK_CAM_RB_CAM_CAM>,
			<&camsys_rawb_clk CLK_CAM_RB_CAMTG_CAM>;
	};

	bring-up-jpegenc@6 {
		compatible = "mediatek,clk-bring-up";
		reg = <0x6>;
		clocks =
			<&venc_gcon_clk CLK_VEN1_CKE2_JPGENC_JPEGENC>;
	};

	bring-up-venc@7 {
		compatible = "mediatek,clk-bring-up";
		reg = <0x7>;
		clocks =
			<&venc_gcon_clk CLK_VEN1_CKE1_VENC_VENC>,
			<&venc_gcon_clk CLK_VEN1_CKE5_GALS_VENC>;
	};

	bring-up-cam-msf@9 {
		compatible = "mediatek,clk-bring-up";
		reg = <0x9>;
		clocks =
			<&imgsys2_clk CLK_IMGSYS2_LARB9_CAM_MSF>,
			<&imgsys2_clk CLK_IMGSYS2_MFB_CAM_MSF>;

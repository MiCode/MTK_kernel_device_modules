			<&mdpsys_config_clk CLK_MDP_SMI0_MDP>,
			<&mdpsys_config_clk CLK_MDP_RDMA0_MDP>,
			<&mdpsys_config_clk CLK_MDP_FG0_MDP>,
			<&mdpsys_config_clk CLK_MDP_HDR0_MDP>,
			<&mdpsys_config_clk CLK_MDP_AAL0_MDP>,
			<&mdpsys_config_clk CLK_MDP_RSZ0_MDP>,
			<&mdpsys_config_clk CLK_MDP_TDSHP0_MDP>,
			<&mdpsys_config_clk CLK_MDP_COLOR0_MDP>,
			<&mdpsys_config_clk CLK_MDP_WROT0_MDP>,
			<&mdpsys_config_clk CLK_MDP_FAKE_ENG0_MDP>,
			<&mdpsys_config_clk CLK_MDP_DLI_ASYNC0_MDP>,
			<&mdpsys_config_clk CLK_MDP_RSZ2_MDP>,
			<&mdpsys_config_clk CLK_MDP_WROT2_MDP>,
			<&mdpsys_config_clk CLK_MDP_DLO_ASYNC0_MDP>,
			<&mdpsys_config_clk CLK_MDP_FMM_IMG_DL_ASYNC0_MDP>,
			<&mdpsys_config_clk CLK_MDP_FMM_IMG_DL_ASYNC1_MDP>,
			<&mdpsys_config_clk CLK_MDP_FIMG_IMG_DL_ASYNC0_MDP>,
			<&mdpsys_config_clk CLK_MDP_FIMG_IMG_DL_ASYNC1_MDP>;
	};

	bring-up-vdec@f {
		compatible = "mediatek,clk-bring-up";
		reg = <0xf>;
		clocks =
			<&vdec_gcon_base_clk CLK_VDE2_LAT_CKEN_VDEC>,
			<&vdec_gcon_base_clk CLK_VDE2_LAT_ACTIVE_VDEC>,
			<&vdec_gcon_base_clk CLK_VDE2_LAT_CKEN_ENG_VDEC>,
			<&vdec_gcon_base_clk CLK_VDE2_VDEC_CKEN_VDEC>,
			<&vdec_gcon_base_clk CLK_VDE2_VDEC_ACTIVE_VDEC>,
			<&vdec_gcon_base_clk CLK_VDE2_VDEC_CKEN_ENG_VDEC>;

			<&imp_iic_wrap_c_clk CLK_IMPC_I2C3_I2C>,
			<&imp_iic_wrap_c_clk CLK_IMPC_I2C5_I2C>,
			<&imp_iic_wrap_c_clk CLK_IMPC_I2C6_I2C>,

	bring-up-cam-mss@c {
		compatible = "mediatek,clk-bring-up";
		reg = <0xc>;
		clocks =
			<&imgsys2_clk CLK_IMGSYS2_LARB9_CAM_MSS>,
			<&imgsys2_clk CLK_IMGSYS2_MSS_CAM_MSS>;
	};

	bring-up-cam-rsc@d {

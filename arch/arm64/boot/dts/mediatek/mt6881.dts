			<&pericfg_ao_clk CLK_PERICFG_AO_REG_PERI_AUDIO1_AUDIO>,
			<&pericfg_ao_clk CLK_PERICFG_AO_REG_PERI_AUDIO2_AUDIO>,
			<&cksys_reg_clk CLK_CKSYS_REG_APLL1>,
			<&cksys_reg_clk CLK_CKSYS_REG_APLL1_D2>,
			<&cksys_reg_clk CLK_CKSYS_REG_APLL1_D4>,
			<&cksys_reg_clk CLK_CKSYS_REG_APLL2>,
			<&cksys_reg_clk CLK_CKSYS_REG_APLL2_D2>,
			<&cksys_reg_clk CLK_CKSYS_REG_APLL2_D4>,
			<&cksys_reg_clk CLK_CKSYS_REG_APLL_IN1_MCK_SEL>,
			<&cksys_reg_clk CLK_CKSYS_REG_APLL12_CK_DIV_IN1>,
			<&cksys_reg_clk CLK_CKSYS_REG_TCK_26M_MX9>;
		clock-names = "afe_apll1_audio",
			"afe_apll2_audio",
			"afe_apll_tuner1_audio",
			"afe_apll_tuner2_audio",
			"afe_audio_f26m_audio",
			"afe_audio_hopping_audio",
			"afe_dl0_dac_audio",
			"afe_dl0_dac_hires_audio",
			"afe_dl0_predis_audio",
			"afe_dl1_dac_audio",
			"afe_dl1_dac_hires_audio",
			"afe_dl1_predis_audio",
			"afe_ul0_adc_audio",
			"afe_ul0_adc_hires_audio",
			"afe_ul1_adc_audio",
			"afe_ul1_adc_hires_audio",
			"clk_top_aud_1_sel",
			"clk_top_aud_2_sel",
			"clk_top_aud_engen1_sel",
			"clk_top_aud_engen2_sel",
			"clk_top_aud_intbus_sel",
			"clk_top_audio_h_sel",

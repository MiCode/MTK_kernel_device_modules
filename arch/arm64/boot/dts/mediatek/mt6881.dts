		fhctl@1000ce00 {
			//mcupm-supply = <&mcupm>;

			//compatible = "mediatek,mt6881-fhctl";
			reg = <0 0x1000ce00 0 0x200>, //AP FHCTL base
				<0 0x1000c000 0 0xe00>, //APMIX base

				<0 0x0c030100 0 0x030>,//mcupm EN
				<0 0x0c030000 0 0x100>,//mcupm APMIX
				<0 0x0c030500 0 0x030>,
				<0 0x0c030400 0 0x100>,
				<0 0x0c030900 0 0x030>,
				<0 0x0c030800 0 0x100>,
				<0 0x0c034100 0 0x030>,
				<0 0x0c034000 0 0x100>;

			map0 {
				domain = "top0";
				method = "fhctl-ap";
				mainpll {
					fh-id = <0>;
					perms = <0x1e>;
				};
				msdcpll {
					fh-id = <1>;
					perms = <0x1e>;
				};
				mmpll {
					fh-id = <3>;
					perms = <0x1e>;
				};
				tvdpll {
					fh-id = <4>;
					perms = <0x1e>;
				};
			};

			map1 {
				domain = "mcu0";
				method = "fhctl-ap";
				ccipll {
					fh-id = <0>;
				};
			};

			map2 {
				domain = "mcu1";
				method = "fhctl-ap";
				armpll-ll {
					fh-id = <0>;
				};
			};

			map3 {
				domain = "mcu2";
				method = "fhctl-ap";
				armpll-b {
					fh-id = <0>;
				};
			};

			map4 {
				domain = "mcu3";
				method = "fhctl-ap";
				ptppll {
					fh-id = <0>;
				};
			};
		};


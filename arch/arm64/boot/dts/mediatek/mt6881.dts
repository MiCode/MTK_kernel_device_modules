	thermal_zones: thermal-zones {
		soc_max: soc_max {
			polling-delay = <0>; /* milliseconds */
			polling-delay-passive = <0>; /* milliseconds */
			thermal-sensors = <&lvts 0>;

			trips {
				soc_max_crit: so-max-crit {
					temperature = <118500>;
					hysteresis = <2000>;
					type = "critical";
				};
			};
		};
		cpu-little-1-0 {

		i2c12: i2c@11d77000 {
			compatible = "mediatek,mt6991-i2c";
			reg = <0 0x11d77000 0 0x1000>,
				<0 0x11300b80 0 0x80>;
			interrupts = <GIC_SPI 540 IRQ_TYPE_LEVEL_HIGH 0>;
			/* clocks = <&imp_iic_wrap_c_clk CLK_IMPC_I2C12_I2C>, */
			/*	<&pericfg_ao_clk CLK_PERAO_P_DMA_B_I2C>; */

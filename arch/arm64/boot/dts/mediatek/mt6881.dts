			"vow-scp-dmic-dat-off",
			"vow-scp-dmic-dat-on",
		pinctrl-0 = <&aud_dat_mosi0_off>;
		pinctrl-1 = <&aud_dat_mosi0_on>;
		pinctrl-2 = <&aud_dat_mosi1_off>;
		pinctrl-3 = <&aud_dat_mosi1_on>;
		pinctrl-4 = <&aud_dat_mosi2_off>;
		pinctrl-5 = <&aud_dat_mosi2_on>;

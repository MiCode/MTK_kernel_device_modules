		};

		ssusb: usb0@11201000 {
			compatible = "mediatek,mtu3";
			reg = <0 0x11201000 0 0x2e00>,
				<0 0x11203e00 0 0x0100>;
			reg-names = "mac", "ippc";
			vusb33-supply = <&mt6368_vusb>;
			interrupts = <GIC_SPI 512 IRQ_TYPE_LEVEL_HIGH 0>;
			phy-cells = <1>;
			phys = <&u2port0 PHY_TYPE_USB2>;
			clocks = <&clk26m>, <&clk26m>, <&clk26m>;
			clock-names = "sys_ck", "host_ck", "frmcnt_ck";
			#address-cells = <2>;
			#size-cells = <2>;
			ranges;
			dr_mode = "otg";
			maximum-speed = "high-speed";
			mediatek,force-vbus;
			mediatek,clk-mgr;
			usb-role-switch;
			cdp-block;

			port {
				mtu3_drd_switch: endpoint {
					remote-endpoint = <&usb_role>;
				};
			};

			usb_host: xhci0@11200000 {
				compatible = "mediatek,mtk-xhci";
				reg = <0 0x11200000 0 0x1000>;
				reg-names = "mac";
				interrupts = <GIC_SPI 513 IRQ_TYPE_LEVEL_HIGH 0>;
				clocks = <&clk26m>;
				clock-names = "sys_ck";
				status = "okay";
			};
		};

		u2phy: usb-phy0@11f40000 {
			compatible = "mediatek,xsphy", "mediatek,mt6881-xsphy";
			reg = <0 0x11f40000 0 0x400>;
			reg-names = "u2_port_base";
			#address-cells = <2>;
			#size-cells = <2>;
			ranges;

			u2port0: usb2-phy0@11f40000 {
				reg = <0 0x11f40000 0 0x400>;
				clocks = <&clk26m>;
				clock-names = "ref";
				#phy-cells = <1>;
			};
		};

		pcie: pcie@112f0000 {
			device_type = "pci";
			compatible = "mediatek,mt6881-pcie";
			reg = <0 0x112f0000 0 0x4000>;
			reg-names = "pcie-mac";
			#address-cells = <3>;
			#size-cells = <2>;
			interrupts = <GIC_SPI 800 IRQ_TYPE_LEVEL_HIGH 0>;
			bus-range = <0x00 0xff>;
			ranges = <0x82000000 0 0x30000000
				  0x0 0x30000000 0 0x10000000>;
			status = "disabled";
			linux,pci-domain = <0>;
			mediatek,peri-reset-dis;
			mediatek,dvfs-req-dis;

			phys = <&pciephy>;
			phy-names = "pcie-phy";

			#interrupt-cells = <1>;
			interrupt-map-mask = <0 0 0 7>;
			interrupt-map = <0 0 0 1 &pcie_intc 0>,
					<0 0 0 2 &pcie_intc 1>,
					<0 0 0 3 &pcie_intc 2>,
					<0 0 0 4 &pcie_intc 3>;
			pcie_intc: interrupt-controller {
				interrupt-controller;
				#address-cells = <0>;
				#interrupt-cells = <1>;
			};
		};

		pciephy: phy@11100000 {
			compatible = "mediatek,mt6881-pcie-phy";
			#phy-cells = <0>;
			reg = <0 0x11100000 0 0x10000>;
			reg-names = "sif";
			status = "disabled";
		};

		gpueb: gpueb@3d000000 {
			compatible = "mediatek,gpueb";
			gpueb-support = <0>;
			ghpm-support = <0>;
			gpueb-logger-support = <0>;
			gpu-mpu-support = <0>;
			gpu-mpu-data-size = <0xc00>;
			mbox-count = <1>;
			mbox-size = <160>; /* 160 slot * 4 = 640 byte */
			slot-size = <4>;   /* 1 slot = 4 bytes */
			ts-mbox = <0>; /* mbox for timersync */

			/* id, mbox, send_size */
			send-table =
				<0 0 4>,
				<1 0 8>,
				<2 0 3>,
				<3 0 6>,
				<4 0 9>,
				<5 0 4>,
				<6 0 6>,
				<7 0 6>,
				<8 0 1>,
				<9 0 4>,
				<10 0 3>;
			send-name-table =
				"IPI_ID_FAST_DVFS_EVENT",
				"IPI_ID_GPUFREQ",
				"IPI_ID_SLEEP",
				"IPI_ID_TIMER",
				"IPI_ID_FHCTL",
				"IPI_ID_CCF",
				"IPI_ID_GPUMPU",
				"IPI_ID_FAST_DVFS",
				"CH_IPIR_C_MET", /* = IPIS_C_MET on gpueb side */
				"CH_IPIS_C_MET", /* = IPIR_C_MET on gpueb side */
				"IPI_ID_BRISKET";

			/* id, mbox, recv_size, recv_opt, cb_ctx_opt */
			recv-table =
				<0 0 4 0 0>,
				<1 0 8 1 1>,
				<2 0 1 0 1>,
				<3 0 1 0 1>,
				<4 0 1 1 1>,
				<5 0 4 1 1>,
				<6 0 1 1 1>,
				<7 0 6 1 1>,
				<8 0 4 0 1>,
				<9 0 1 1 1>,
				<10 0 3 1 1>;
			recv-name-table =
				"IPI_ID_FAST_DVFS_EVENT",
				"IPI_ID_GPUFREQ",
				"IPI_ID_SLEEP",
				"IPI_ID_TIMER",
				"IPI_ID_FHCTL",
				"IPI_ID_CCF",
				"IPI_ID_GPUMPU",
				"IPI_ID_FAST_DVFS",
				"CH_IPIR_C_MET", /* = IPIS_C_MET on gpueb side */
				"CH_IPIS_C_MET", /* = IPIR_C_MET on gpueb side */
				"IPI_ID_BRISKET";

			reg =
				<0 0x3d000000 0 0x40000>,
				<0 0x3d03fd00 0 0x80>,
				<0 0x3d140100 0 0x200>,
				<0 0x3d120000 0 0x100>,
				<0 0x3d130000 0 0x200>,
				<0 0x3d03fd80 0 0x280>,
				<0 0x3d170008 0 0x4>,
				<0 0x3d170004 0 0x4>,
				<0 0x3d170074 0 0x4>,
				<0 0x3d170000 0 0x4>,
				<0 0x3d170078 0 0x4>,
				<0 0x1c001eb4 0 0x4>;
			reg-names =
				"gpueb_base",
				"gpueb_gpr_base",
				"gpueb_cfgreg_base",
				"gpueb_intc_base",
				"gpueb_dma_base",
				"mbox0_base",
				"mbox0_init", /* dummy input for mtk_mbox_probe */
				"mbox0_set",
				"mbox0_clr",
				"mbox0_send",
				"mbox0_recv",
				"mfg0_pwr_con";

			interrupts = <GIC_SPI 401 IRQ_TYPE_LEVEL_HIGH 0>;
			interrupt-names = "mbox0";
			mbox-attr = <0x0>;

			gpueb-mem-table =
				<0 0x4000>,   /* 16KB */
				<1 0x180000>; /* 1.5MB */

			gpueb-mem-name-table =
				"MEM_ID_GPUFREQ", /* GPUFREQ */
				"MEM_ID_LOG";     /* LOGGER */

			gpueb-diagnosis-mode = <0>;
		};

		gpufreq: gpufreq@3a500000 {
			compatible = "mediatek,gpufreq";
			reg =
				<0 0x3a500000 0 0x10000>, /* MFG_TOP_CONFIG */
				<0 0x3d1a0000 0 0x10000>, /* MFG_GPUEB_BUS_DBG_TRACKER */
				<0 0x3d800000 0 0x10000>, /* MFG_RPC */
				<0 0x3d810000 0 0x400>,   /* MFG_PLL_TOP_P0 */
				<0 0x3d810400 0 0x400>,   /* MFG_PLL_TOP_P1 */
				<0 0x3d860000 0 0x10000>, /* MFG_VCORE_AO_CFG */
				<0 0x3d910000 0 0x10000>, /* MFG_VCORE_BUS_DBG_TRACKER */
				<0 0x10023000 0 0x100>,   /* INFRA_AO_DEBUG */
				<0 0x1002b000 0 0x100>,   /* INFRA_AO1_DEBUG */
				<0 0x10042000 0 0x100>,   /* EMI_NAO_DBG_CTRL */
				<0 0x1021c000 0 0x1000>,  /* NTH_EMICFG */
				<0 0x1025f000 0 0x500>,   /* EMI_M6_XPU_SOC_SSC */
				<0 0x10270000 0 0x300>,   /* EMICFG_AO */
				<0 0x10276000 0 0x100>,   /* EMICFG_PD_BCRM */
				<0 0x1030c000 0 0x500>,   /* EMI_M7_XPU_SOC_SSC */
				<0 0x1c001000 0 0x1000>;  /* SLEEP */
			reg-name =
				"mfg_top_config",
				"mfg_gpueb_bus_trk",
				"mfg_rpc",
				"mfg_pll_top_p0",
				"mfg_pll_top_p1",
				"mfg_vcore_ao_cfg",
				"mfg_vcore_bus_trk",
				"infra_ao_debug",
				"infra_ao1_debug",
				"emi_nao_dbg_ctrl",
				"nth_emicfg",
				"emi_m6_xpu_soc_ssc",
				"emicfg_ao",
				"emicfg_pd_bcrm",
				"emi_m7_xpu_soc_ssc",
				"sleep";
			interrupts =
				<GIC_SPI 402 IRQ_TYPE_LEVEL_HIGH 0>;
			interrupt-names =
				"BUS_TRACKER";
			gpufreq-wrapper-supply = <&gpufreq_wrapper>;
		};

		extcon_usb: extcon-usb {
			compatible = "mediatek,extcon-usb";
			vbus-supply = <&mt6720_otg_vbus>;
			vbus-voltage = <5000000>;
			vbus-current = <1800000>;
			charger = <&mt6720_chg>;
			tcpc = "type_c_port0";
			mediatek,bypss-typec-sink = <1>;
			mediatek,u2;
			port {
				usb_role: endpoint {
					remote-endpoint = <&mtu3_drd_switch>;
				};
			};
		};

		usb_meta: usb-meta {
			compatible = "mediatek,usb-meta";
			udc = <&ssusb>;
		};

		u3fpgaphy: u3fpgaphy {
			compatible = "mediatek,fpga-u3phy";
			mediatek,ippc = <0x11203e00>;
			#address-cells = <2>;
			#size-cells = <2>;
			fpga-i2c-physical-base = <0x11d70000>;
			fpga-i2c-clock = <0x11d78e00 0x1>;
			status = "disabled";

			u3fpgaport0: u3fpgaport0 {
				chip-id = <0xa60931a>;
				port = <0>;
				pclk_phase = <23>;
				#phy-cells = <1>;
			};
		};

		mrdump_ext_rst: mrdump_ext_rst {
			compatible = "mediatek, mrdump_ext_rst-eint";
			mode = "IRQ";
			status = "okay";
		};


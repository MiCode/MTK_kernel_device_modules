#include <dt-bindings/power/mt6375-gauge.h>

/ {
	model = "MT6881";
	compatible = "mediatek,MT6881";
	interrupt-parent = <&gic>;
	#address-cells = <2>;
	#size-cells = <2>;

	aliases {
		i2c0 = &i2c0;
		i2c1 = &i2c1;
		i2c2 = &i2c2;
		i2c3 = &i2c3;
		i2c4 = &i2c4;
		i2c5 = &i2c5;
		i2c6 = &i2c6;
		i2c7 = &i2c7;
		i2c8 = &i2c8;
		i2c9 = &i2c9;
		i2c10 = &i2c10;
		i2c11 = &i2c11;
		i2c12 = &i2c12;
		i3c0 = &i2c0;
		i3c2 = &i2c2;
		i3c4 = &i2c4;
		i3c7 = &i2c7;
		i3c8 = &i2c8;
		i3c9 = &i2c9;
		i3c11 = &i2c11;
		ovl3 = &disp_ovl0_2l;
		ovl4 = &disp_ovl1_2l;
		ovl5 = &disp_ovl2_2l;
		ovl6 = &disp_ovl3_2l;
		dsi0 = &dsi0;
		mutex0 = &disp_mutex0;
#if 0
		wdma1 = &disp_wdma1;
		rsz0 = &disp_rsz0;
		rsz4 = &disp_rsz1;
		postmask0 = &disp_postmask0;
		dsc0 = &disp_dsc_wrap0;
#endif
	};

	clkbuf_ctrl: clkbuf-ctrl {
		//pmic-supply = <&mt6685_mfd>;
		//compatible = "mediatek,mt6881-clkbuf";
		//pmic = <&mt6685_clkbuf>;
		srclken-rc = <&srclken_rc>;
		//pmif = <&spmi>;
	};

	/* chosen */
	chosen: chosen {
		bootargs = "console=tty0 root=/dev/ram \
			    8250.nr_uarts=3 \
			    nosoftlockup \
			    loglevel=8 \
			    androidboot.hardware=mt6881 \
			    cgroup.memory=nosocket,nokmem \
			    disable_dma32=on \
			    transparent_hugepage=never \
			    arm64.nomops arm64.nomte \
			    initcall_debug=1 \
			    vmalloc=400M swiotlb=noforce cma=64M \
			    firmware_class.path=/vendor/firmware \
			    kvm-arm.mode=none \
			    initcall_debug=1";
	};


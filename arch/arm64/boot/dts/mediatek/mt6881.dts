				<&ufscfg_ao_clk CLK_UFSAO_UNIPRO_TX_SYM_UFS>,
				<&ufscfg_ao_clk CLK_UFSAO_UNIPRO_RX_SYM0_UFS>,
				<&ufscfg_ao_clk CLK_UFSAO_UNIPRO_RX_SYM1_UFS>,

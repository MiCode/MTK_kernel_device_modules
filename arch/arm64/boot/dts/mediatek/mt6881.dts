			sda-gpio-id = <140>;
		};

		i2c10: i2c@11d75000 {
			compatible = "mediatek,mt6991-i2c";
			reg = <0 0x11d75000 0 0x1000>,
				<0 0x11300a80 0 0x80>;
			interrupts = <GIC_SPI 538 IRQ_TYPE_LEVEL_HIGH 0>;
			/* clocks = <&imp_iic_wrap_c_clk CLK_IMPC_I2C10_I2C>, */
			/*	<&pericfg_ao_clk CLK_PERAO_P_DMA_B_I2C>; */

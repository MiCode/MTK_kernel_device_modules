		i2c9: i2c@11d74000 {
			compatible = "mediatek,mt6991-i2c";
			reg = <0 0x11d74000 0 0x1000>,
				<0 0x11300980 0 0x100>;
			interrupts = <GIC_SPI 537 IRQ_TYPE_LEVEL_HIGH 0>;

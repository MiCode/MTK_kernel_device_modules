	psci {
		compatible = "arm,psci-1.0";
		method = "smc";
	};

	mcupm: mcupm {
		compatible = "mediatek,mcupms_v0";
		#address-cells = <2>;
		#size-cells = <2>;
		ranges;

		mcupm-mst-mbox@c070000 {
			device_type = "mcupm_mbox";
			enabled = <1>;
			reg = <0 0x0c0df600 0 0xa00>,
					<0 0x0c072004 0 0x4>,
					<0 0x0c072018 0 0x4>,
					<0 0x0c072000 0 0x4>,
					<0 0x0c072010 0 0x4>;

			reg-names = "mbox_base",
						"mbox_set",
						"mbox_clr",
						"mbox_send",
						"mbox_recv";

			interrupts = <GIC_SPI 48 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 49 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 50 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 51 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 52 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 53 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 54 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 55 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 56 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 57 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 58 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 59 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 60 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 61 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 62 IRQ_TYPE_LEVEL_HIGH 0>,
						<GIC_SPI 63 IRQ_TYPE_LEVEL_HIGH 0>;

			interrupt-names = "mbox0",
						  "mbox1",
						  "mbox2",
						  "mbox3",
						  "mbox4",
						  "mbox5",
						  "mbox6",
						  "mbox7",
						  "mbox8",
						  "mbox9",
						  "mbox10",
						  "mbox11",
						  "mbox12",
						  "mbox13",
						  "mbox14",
						  "mbox15";

			/* chan_id, pin_id, send_size, offset */
			send-table =
				<0 0 4 0>, /* PLATFORM */
				<1 1 4 0>,
				<2 2 9 0>,
				<3 3 3 0>,
				<4 4 3 0>,
				<5 5 1 0>,
				<6 6 4 0>,
				<7 7 4 0>,
				<8 8 4 0>,
				<9 9 4 0>,
				<10 10 4 0>,
				<11 11 4 0>,
				<12 12 4 0>,
				<13 13 4 0>,
				<14 14 4 0>,
				<15 15 4 0>;

			/* chan_id, pin_id, recv_size, recv_opt, cb_ctx_opt, offset */
			recv-table =
				<0 0 1 0 0 20>, /* PLATFORM */
				<1 1 4 0 0 20>,
				<2 2 1 0 0 20>,
				<3 3 1 0 0 20>,
				<4 4 1 0 0 20>,
				<5 5 4 0 0 20>,
				<6 6 1 1 0 20>,
				<7 7 1 0 0 20>,
				<8 8 1 0 0 20>,
				<9 9 4 0 0 20>,
				<10 10 1 0 0 20>,
				<11 11 1 0 0 20>,
				<12 12 1 0 0 20>,
				<13 13 1 0 0 20>,
				<14 14 1 0 0 20>,
				<15 15 1 0 0 20>;
		};
	};

	logstore: logstore {
		enabled = <1>;
		pmic-register = <0xa0d>;

		/*
		 * If not specified, the default size is 3M:
		 * - 2M for logstore
		 * - 1M for mrdump
		 *
		 * Version is calculated as:
		 *   C_LOG_STORE_EXPDB_SIZE(preloader) + 1M(bootprof) + 1M(mrdump)
		 *
		 * Ensure that the version value is less than MRDUMP_CONFIG_EXPDB_OFFSET_LIMIT.
		 *
		 * To modify the version value, make sure to update
		 * C_LOG_STORE_EXPDB_SIZE in mt6881/print.h accordingly.
		 */
		version = "12582912"; // Equivalent to 12MB
	};

	gic: interrupt-controller@c400000 {
		/*TODO: please check interrupt controller again*/
		compatible = "arm,gic-v3";
		#interrupt-cells = <4>;
		#address-cells = <2>;
		#size-cells = <2>;
		#redistributor-regions = <1>;
		interrupt-parent = <&gic>;
		interrupt-controller;
		 reg = <0 0x0c400000 0 0x40000>, /* distributor */
			<0 0xc440000 0 0x200000>; /* redistributor */
		interrupts = <GIC_PPI 9 IRQ_TYPE_LEVEL_HIGH 0>;
	};

	memory@40000000 {
		device_type = "memory";
		reg = <0 0x40000000 0 0x40000000>;
	};

	rt-pd-manager {
		compatible = "mediatek,rt-pd-manager";
		nr-port = <1>;
		//en-wd0-port0;
		tcpc-supply = <&mt6720_typec>;
	};

	pd_adapter: pd-adapter {
		compatible = "mediatek,pd_adapter";
		nr-port = <1>;
		force-cv;
		adapter-name = "pd_adapter";
		tcpc-supply = <&mt6720_typec>;
	};

	ufcs_adapter: ufcs-adapter {
	      compatible = "mediatek,ufcs-adapter";
	      force-cv;
	      status = "okay";
	};

	mtk_ctd: mtk-ctd {
		compatible = "mediatek,mtk_ctd";
		nr-port = <1>;
		chg-name-port0 = "primary_chg";
		bc12-sel-port0 = <MTK_CTD_BY_SUBPMIC>;
		bc12-psy-port0 = <&mt6720_chg>;
		tcpc-supply = <&mt6720_typec>;
		chg-supply = <&mt6720_chg>;
	};

	subpmic_pmu_eint: subpmic-pmu-eint {

	};

	odm: odm {
		compatible = "simple-bus";
		/* reserved for overlay by odm */
	};

	reserved_memory: reserved-memory {
		/*TODO: add reserved memory node here*/
		#address-cells = <2>;
		#size-cells = <2>;
		ranges;

		dpmaif_resv_cache_mem: ccci-dpmaif-cache-memory {
			compatible = "mediatek,dpmaif-resv-cache-mem";
			size = <0 0x00190000>; /* 1638400 Bytes for 1rxq */
			alignment = <0 0x10000>;
			alloc-ranges = <0 0x40000000 0 0xf0000000>;
		};

		dpmaif_resv_nocache_mem: ccci-dpmaif-nocache-memory {
			compatible = "mediatek,dpmaif-resv-nocache-mem";
			no-map;
			size = <0 0x0050000>; /* 327680 Bytes */
			alignment = <0 0x10000>;
			alloc-ranges = <0 0x40000000 0 0xf0000000>;
		};
	};

	clk_ao: clk-ao {
		compatible = "simple-bus";
		#address-cells = <1>;
		#size-cells = <0>;
	};

	clkitg: clkitg {
		compatible = "simple-bus";
		#address-cells = <1>;
		#size-cells = <0>;
	};

	disable_unused: disable-unused {
		compatible = "simple-bus";
		#address-cells = <1>;
		#size-cells = <0>;
	};

	clkchk {
		//compatible = "mediatek,mt6881-clkchk";
		//interrupts = <GIC_SPI 395 IRQ_TYPE_LEVEL_HIGH 0>;
		//interrupt-names = "hwv_irq";
	};

	pdchk {
		//compatible = "mediatek,mt6881-pdchk";
		//interrupts = <GIC_SPI 395 IRQ_TYPE_LEVEL_HIGH 0>;
		//interrupt-names = "hwv_irq";
	};
	clocks {
		//compatible = "clk-ftrace";
		clk26m: clk26m {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <26000000>;
		};
		clk13m: clk13m {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <13000000>;
		};
		ulposc: ulposc {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <260000000>;
		};
	};

	buspll_pll_ctrl_clk: syscon@c030000 {
		compatible = "mediatek,mt6881-buspll_pll_ctrl", "syscon";
		reg = <0 0xc030000 0 0x0400>;
		#clock-cells = <1>;
	};

	armpll_ll_pll_ctrl_clk: syscon@c030400 {
		compatible = "mediatek,mt6881-armpll_ll_pll_ctrl", "syscon";
		reg = <0 0xc030400 0 0x0400>;
		#clock-cells = <1>;
	};

	armpll_bl_pll_ctrl_clk: syscon@c030800 {
		compatible = "mediatek,mt6881-armpll_bl_pll_ctrl", "syscon";
		reg = <0 0xc030800 0 0x1000>;
		#clock-cells = <1>;
	};

	ptppll_pll_ctrl_clk: syscon@c034000 {
		compatible = "mediatek,mt6881-ptppll_pll_ctrl", "syscon";
		reg = <0 0xc034000 0 0x1000>;

			clock-names = "main", "dma";
			i2c-clock-info = <0x11e05e00 0x8>;    /* *reg*  *value* */
			clock-div = <1>;
			scl-gpio-id = <131>;
			sda-gpio-id = <132>;
		};

		i2c6: i2c@11e04000 {
			compatible = "mediatek,mt6991-i2c";
			reg = <0 0x11e04000 0 0x1000>,
				<0 0x11300700 0 0x80>;
			interrupts = <GIC_SPI 534 IRQ_TYPE_LEVEL_HIGH 0>;
			/* clocks = <&imp_iic_wrap_c_clk CLK_IMPC_I2C6_I2C>, */

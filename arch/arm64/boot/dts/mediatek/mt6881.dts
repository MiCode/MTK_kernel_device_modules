		mem_mapped_timer: mem-mapped-timer@1cd30000 {
			#address-cells = <2>;
			#size-cells = <2>;
			ranges;
			compatible = "arm,armv7-timer-mem";
			reg = <0 0x1cd30000 0 0x1000>; //CNT_CTL_BSE
			clock-frequency = <1000000000>;
			frame@1cd40000 {
				frame-number = <0>;
				interrupts = <GIC_SPI 377 IRQ_TYPE_LEVEL_HIGH 0>, // phys irq
					     <GIC_SPI 777 IRQ_TYPE_LEVEL_HIGH 0>; // virt irq
				reg = <0 0x1cd40000 0 0x1000>; //CNT_BSE_0
			};
		};

		watchdog: watchdog@1c00a000 {
			compatible = "mediatek,mt6881-wdt",
				     "mediatek,mt6589-wdt",
				     "syscon", "simple-mfd";
			reg = <0 0x1c00a000 0 0x1000>;
			/* Temp disable WDT for SB */
			apwdten = <0>;
			reboot-mode {
				compatible = "syscon-reboot-mode";
				offset = <0x24>;
				mask = <0xf>;
				mode-charger = <BOOT_CHARGER>;
				mode-recovery = <BOOT_RECOVERY>;
				mode-bootloader = <BOOT_BOOTLOADER>;
				mode-dm-verity-dev-corrupt = <BOOT_DM_VERITY>;
				mode-kpoc = <BOOT_KPOC>;
				mode-ddr-reserve = <BOOT_DDR_RSVD>;
				mode-meta = <BOOT_META>;
				mode-rpmbpk = <BOOT_RPMBPK>;
			};
		};


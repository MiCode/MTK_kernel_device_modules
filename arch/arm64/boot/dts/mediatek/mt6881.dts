			<&afe_clk CLK_AFE_APLL_TUNER2_AUDIO>,
			<&afe_clk CLK_AFE_AUDIO_F26M_AUDIO>,
			<&afe_clk CLK_AFE_AUDIO_HOPPING_AUDIO>,
			<&afe_clk CLK_AFE_DL0_DAC_AUDIO>,
			<&afe_clk CLK_AFE_DL0_DAC_HIRES_AUDIO>,

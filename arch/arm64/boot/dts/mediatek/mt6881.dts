	traw_dip1_clk: syscon@15700000 {
		compatible = "mediatek,mt6881-traw_dip1", "syscon";
		reg = <0 0x15700000 0 0x1000>;
		#clock-cells = <1>;
	};

	traw_cap_dip1_clk: syscon@15740000 {
		compatible = "mediatek,mt6881-traw_cap_dip1", "syscon";
		reg = <0 0x15740000 0 0x1000>;
		#clock-cells = <1>;
	};

	img_vcore_d1a_clk: syscon@15780000 {
		compatible = "mediatek,mt6881-img_vcore_d1a", "syscon";
		reg = <0 0x15780000 0 0x1000>;
		#clock-cells = <1>;
	};

	vdec_gcon_base_clk: syscon@1602f000 {
		compatible = "mediatek,mt6881-vdecsys", "syscon";
		reg = <0 0x1602f000 0 0x1000>;
		#clock-cells = <1>;
	};

	venc_gcon_clk: syscon@17000000 {
		compatible = "mediatek,mt6881-vencsys", "syscon";
		reg = <0 0x17000000 0 0x1000>;
		#clock-cells = <1>;
	};

	scpsys: power-controller@1c001000 {
		compatible = "mediatek,mt6881-scpsys", "syscon";
		reg = <0 0x1c001000 0 0x1000>;
		#power-domain-cells = <1>;
		//genpd pre-clk settings comment for bringup AO
		//clocks = <&cksys_reg_clk CLK_CKSYS_REG_AUD_INTBUS_SEL>,
		//	<&cksys_reg_clk CLK_CKSYS_REG_DISP0_SEL>,
		//	<&cksys_reg_clk CLK_CKSYS_REG_MMINFRA_SEL>,
		//	<&cksys_reg_clk CLK_CKSYS_REG_MMUP_SEL>,
		//	<&cksys_reg_clk CLK_CKSYS_REG_IMG1_SEL>,
		//	<&cksys_reg_clk CLK_CKSYS_REG_VDEC_SEL>,
		//	<&cksys_reg_clk CLK_CKSYS_REG_VENC_SEL>,
		//	<&cksys_reg_clk CLK_CKSYS_REG_IPE_SEL>,
		//	<&cksys_reg_clk CLK_CKSYS_REG_CAM_SEL>,
		//	<&dispsys_config_clk CLK_MM_SMI_COMMON_GENPD>,
		//	<&mdpsys_config_clk CLK_MDP_SMI0_GENPD>;
		//clock-names = "audio_0",
		//	"dis0_0",
		//	"mm_infra_0",
		//	"mm_proc_0",
		//	"img1_0",
		//	"vde0_0",
		//	"ven0_0",
		//	"ipe_0",
		//	"cam_0",
		//	"dis0-0",
		//	"dis0_lp-0";
		//genpd buck for isp-vcore and cam-vcore comment for bringup AO
		//isp-vcore-supply = <&mt6363_vbuck1>
		//cam-vcore-supply = <&mt6363_vbuck1>

		infra-infracfg-ao-reg-bus = <&infra_infracfg_ao_reg_clk>;
		vlpcfg-reg-bus = <&vlpcfg_reg_bus>;
	};

	vlpcfg_reg_bus: syscon@1c00c000 {
		compatible = "mediatek,mt6881-vlpcfg_reg_bus", "syscon";
		reg = <0 0x1c00c000 0 0x1000>;
	};

	vlp_cksys_top_clk: syscon@1c012000 {
		compatible = "mediatek,mt6881-vlp_cksys_top", "syscon";
		reg = <0 0x1c012000 0 0x1000>;
		#clock-cells = <1>;
	};

	cam_main_r1a_clk: syscon@1a010000 {
		compatible = "mediatek,mt6881-cam_main_r1a", "syscon";
		reg = <0 0x1a010000 0 0x1000>;
		#clock-cells = <1>;
	};

	camsys_mraw_clk: syscon@1a680000 {
		compatible = "mediatek,mt6881-camsys_mraw", "syscon";
		reg = <0 0x1a680000 0 0x1000>;
		#clock-cells = <1>;
	};

	camsys_rawa_clk: syscon@1a7d0000 {
		compatible = "mediatek,mt6881-camsys_rawa", "syscon";
		reg = <0 0x1a7d0000 0 0x1000>;
		#clock-cells = <1>;
	};

	camsys_rmsa_clk: syscon@1a7f0000 {
		compatible = "mediatek,mt6881-camsys_rmsa", "syscon";
		reg = <0 0x1a7f0000 0 0x1000>;
		#clock-cells = <1>;
	};

	camsys_yuva_clk: syscon@1a810000 {
		compatible = "mediatek,mt6881-camsys_yuva", "syscon";
		reg = <0 0x1a810000 0 0x1000>;
		#clock-cells = <1>;
	};

	camsys_rawb_clk: syscon@1a9d0000 {
		compatible = "mediatek,mt6881-camsys_rawb", "syscon";
		reg = <0 0x1a9d0000 0 0x1000>;
		#clock-cells = <1>;
	};

	camsys_rmsb_clk: syscon@1a9f0000 {
		compatible = "mediatek,mt6881-camsys_rmsb", "syscon";
		reg = <0 0x1a9f0000 0 0x1000>;
		#clock-cells = <1>;
	};

	camsys_yuvb_clk: syscon@1aa10000 {
		compatible = "mediatek,mt6881-camsys_yuvb", "syscon";
		reg = <0 0x1aa10000 0 0x1000>;
		#clock-cells = <1>;
	};

	cam_vcore_r1a_clk: syscon@1b80d000 {
		compatible = "mediatek,mt6881-cam_vcore_r1a", "syscon";
		reg = <0 0x1b80d000 0 0x1000>;
		#clock-cells = <1>;
	};

	mminfra_config_clk: syscon@1e800000 {
		compatible = "mediatek,mt6881-mminfra_config", "syscon";
		reg = <0 0x1e800000 0 0x1000>;
		#clock-cells = <1>;
	};

	mdpsys_config_clk: syscon@1f000000 {
		compatible = "mediatek,mt6881-mdpsys", "syscon";
		reg = <0 0x1f000000 0 0x1000>;
		#clock-cells = <1>;
	};

	qos:qos@11bb00 {
		compatible = "mediatek,mt6893-qos";
			reg = <0 0x0011bb00 0 0x100>,
			<0 0x0011b9c0 0 0x140>,
			<0 0x0011b920 0 0xa0>;
			reg-names = "sram", "share_sram", "share_sram_ext";
		mediatek,enable = <0>;
	};

	timer: timer {
		compatible = "arm,armv8-timer";
		interrupt-parent = <&gic>;
		interrupts = <GIC_PPI 13 IRQ_TYPE_LEVEL_HIGH 0>,
			     <GIC_PPI 14 IRQ_TYPE_LEVEL_HIGH 0>,
			     <GIC_PPI 11 IRQ_TYPE_LEVEL_HIGH 0>,
			     <GIC_PPI 10 IRQ_TYPE_LEVEL_HIGH 0>;
		clock-frequency = <1000000000>;
	};
	cpuhvfs: cpuhvfs@c0de750 {
		compatible = "mediatek,cpufreq-hybrid";
		reg = <0 0x0c0de750 0 0xc00>,
			<0 0x0c0dd350 0 0x1400>,
			<0 0x0c0db350 0 0x800>,
			<0 0x0c0df290 0 0xc0>;

		reg-names = "USRAM", "CSRAM", "ESRAM";
		cslog-range =  <0x03d0>, <0x0fa0>;
		tbl-off = <4>, <76>, <148>;

		/* pll mcucfg */
		mcucfg-ver = <0>;
		apmixedsys = <&cpu_pll>;
		clk-div-base = <&cpu_mcucfg>;
		pll-con = <0x20c>, <0x21c>, <0x23c>;
		clk-div = <0xa2a0>, <0xa2a4>, <0xa2e0>;

		/* regulator */
		proc1-supply = <&mt6368_vbuck1>;  //L
		proc2-supply = <&mt6319_6_vbuck1>; //B
		proc3-supply = <&mt6368_vbuck1>;  //DSU

		/* leakage info */
		// nvmem-cells = <&lkginfo>;
		// nvmem-cell-names = "lkginfo";
	};

	eas_info: eas-info {
		compatible = "mediatek,eas-info";
		csram-base = <0x0c0dd350>;
	};


	efuse: efuse@11c10000 {
		compatible = "mediatek,devinfo";
		#address-cells = <1>;
		#size-cells = <1>;

		efuse_segment: segment@78 {
			reg = <0x78 0x4>;
		};

		lvts_e_data1: data1@1ac {
			reg = <0x1ac 0x34>;
		};

		lvts_e_data2: data2@140 {
			reg = <0x140 0x18>;
		};
	};

	wifi: wifi@18000000 {
		compatible = "mediatek,wifi";
		reg = <0 0x18000000 0 0x700000>;
		interrupts = <GIC_SPI 612 IRQ_TYPE_LEVEL_HIGH 0>,
				<GIC_SPI 820 IRQ_TYPE_LEVEL_HIGH 0>;
		emi-addr = <0>;
		emi-size = <0x1400000>;
		emi-alignment = <0x1000000>;
		emi-max-addr = <0xc0000000>;
	};


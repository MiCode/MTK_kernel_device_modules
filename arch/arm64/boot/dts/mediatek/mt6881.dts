/dts-v1/;
#include <dt-bindings/clock/mt6881-clk.h>
#include <dt-bindings/power/mt6881-power.h>
#include <dt-bindings/interrupt-controller/arm-gic.h>
#include <dt-bindings/interrupt-controller/irq.h>
#include <dt-bindings/phy/phy.h>
#include <dt-bindings/pinctrl/mt6858-pinfunc.h>
#include <dt-bindings/gce/mt6881-gce.h>
#include <dt-bindings/soc/mediatek,boot-mode.h>
#include <dt-bindings/memory/mt6881-larb-port.h>


/ {
	model = "MT6881";
	compatible = "mediatek,MT6881";
	interrupt-parent = <&gic>;
	#address-cells = <2>;
	#size-cells = <2>;

	aliases {
		i2c0 = &i2c0;
		i2c1 = &i2c1;
		i2c2 = &i2c2;
		i2c3 = &i2c3;
		i2c4 = &i2c4;
		i2c5 = &i2c5;
		i2c6 = &i2c6;
		i2c7 = &i2c7;
		i2c8 = &i2c8;
		i2c9 = &i2c9;
		i2c10 = &i2c10;
		i2c11 = &i2c11;
		i2c12 = &i2c12;
		ovl3 = &disp_ovl0_2l;
		ovl4 = &disp_ovl1_2l;
		ovl5 = &disp_ovl2_2l;
		ovl6 = &disp_ovl3_2l;
		dsi0 = &dsi0;
		mutex0 = &disp_mutex0;
#if 0
		wdma1 = &disp_wdma1;
		rsz0 = &disp_rsz0;
		rsz4 = &disp_rsz1;
		postmask0 = &disp_postmask0;
		dsc0 = &disp_dsc_wrap0;
#endif
	};

	/* chosen */
	chosen: chosen {
		bootargs = "console=tty0 root=/dev/ram \
			    8250.nr_uarts=4 \
			    nosoftlockup \
			    loglevel=8 \
			    androidboot.hardware=mt6881 \
			    initcall_debug=1 \
			    vmalloc=400M swiotlb=noforce cma=64M \
			    firmware_class.path=/vendor/firmware \
			    kvm-arm.mode=none \
			    initcall_debug=1";
	};


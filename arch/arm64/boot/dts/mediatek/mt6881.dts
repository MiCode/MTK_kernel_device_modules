			compatible = "mediatek,pericfg";
			reg = <0 0x10003000 0 0x1000>;
		};

		gpio: gpio@10005000 {
			compatible = "mediatek,gpio";
			reg = <0 0x10005000 0 0x1000>;
		};

		pio: pinctrl {
			compatible = "mediatek,mt6881-pinctrl";
			reg = <0 0x10005000 0 0x1000>,
				<0 0x11b00000 0 0x1000>,
				<0 0x11b10000 0 0x1000>,
				<0 0x11b20000 0 0x1000>,
				<0 0x11c00000 0 0x1000>,
				<0 0x11d40000 0 0x1000>,
				<0 0x11d60000 0 0x1000>,
				<0 0x11e20000 0 0x1000>,
				<0 0x11ec0000 0 0x1000>,
				<0 0x11f30000 0 0x1000>;
			reg-names = "gpio",
				"iocfg_bl",
				"iocfg_bl1",
				"iocfg_bm",
				"iocfg_rm",
				"iocfg_br",
				"iocfg_br1",
				"iocfg_lm",
				"iocfg_rt",
				"iocfg_lt";
			gpio-controller;
			#gpio-cells = <2>;
			gpio-ranges = <&pio 0 0 199>;
			interrupt-controller;
			#interrupt-cells = <2>;
			mediatek,eint = <&eint>;
		};

		eint: apirq@11ce0000 {
			compatible = "mediatek,mt6983-eint";
			reg = <0 0x11ce0000 0 0x1000>,
					<0 0x11de0000 0 0x1000>,
					<0 0x11e60000 0 0x1000>,
					<0 0x1c01e000 0 0x1000>;
			reg-name = "eint-e", "eint-s", "eint-w", "eint-c";
			interrupts = <GIC_SPI 367 IRQ_TYPE_LEVEL_HIGH 0>;
			mediatek,instance-num = <4>;
			mediatek,total-pin-number = <217>;
			mediatek,pins = <0 1 0 1>,<1 2 0 1>,<2 2 1 1>,<3 2 2 1>,
					<4 2 3 1>,<5 2 4 1>,<6 1 1 1>,<7 1 2 1>,
					<8 1 3 1>,<9 1 4 1>,<10 1 5 1>,<11 1 6 1>,
					<12 1 7 1>,<13 1 8 1>,<14 1 9 1>,<15 1 10 1>,
					<16 1 11 1>,<17 1 12 1>,<18 1 13 1>,<19 1 14 1>,
					<20 2 5 1>,<21 2 6 1>,<22 2 7 1>,<23 2 8 1>,
					<24 2 9 1>,<25 2 10 1>,<26 2 11 1>,<27 2 12 1>,
					<28 2 13 1>,<29 2 14 1>,<30 2 15 1>,<31 2 16 1>,
					<32 2 17 1>,<33 2 18 1>,<34 2 19 1>,<35 2 20 1>,
					<36 0 0 1>,<37 0 1 1>,<38 0 2 1>,<39 0 3 1>,
					<40 0 4 1>,<41 0 5 1>,<42 0 6 1>,<43 0 7 1>,
					<44 0 8 1>,<45 0 9 1>,<46 0 10 1>,<47 0 11 1>,
					<48 0 12 1>,<49 0 13 1>,<50 0 14 1>,<51 0 15 1>,
					<52 0 16 0>,<53 1 15 1>,<54 1 16 0>,<55 1 17 0>,
					<56 1 18 0>,<57 1 19 0>,<58 1 20 0>,<59 1 21 0>,
					<60 1 22 0>,<61 1 23 0>,<62 1 24 0>,<63 1 25 0>,
					<64 1 26 0>,<65 1 27 0>,<66 1 28 0>,<67 0 17 0>,
					<68 1 29 0>,<69 0 18 0>,<70 1 30 0>,<71 1 31 0>,
					<72 1 32 0>,<73 1 33 0>,<74 1 34 0>,<75 0 19 0>,
					<76 0 20 0>,<77 0 21 0>,<78 0 22 0>,<79 0 23 0>,
					<80 0 24 0>,<81 0 25 0>,<82 0 26 0>,<83 0 27 0>,
					<84 0 28 0>,<85 0 29 0>,<86 0 30 0>,<87 0 31 0>,
					<88 0 32 0>,<89 0 33 0>,<90 0 34 0>,<91 0 35 0>,
					<92 0 36 0>,<93 0 37 0>,<94 0 38 0>,<95 0 39 0>,
					<96 0 40 0>,<97 0 41 0>,<98 0 42 0>,<99 0 43 0>,
					<100 0 44 0>,<101 0 45 0>,<102 0 46 0>,<103 0 47 0>,
					<104 0 48 0>,<105 0 49 0>,<106 0 50 0>,<107 0 51 0>,
					<108 0 52 0>,<109 0 53 0>,<110 0 54 0>,<111 0 55 0>,

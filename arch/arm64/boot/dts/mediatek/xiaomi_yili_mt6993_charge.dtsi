#include <dt-bindings/power/mtk-charger.h>

&pio {
	status = "okay";
	charger_third_pd_phy: charger-third-pd-phy {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO183__FUNC_GPIO183>;
			bias-pull-up;
			input-enable;
		};
	};
	charger_load_switch: charger-load-switch {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO70__FUNC_SCL3>,
			<PINMUX_GPIO71__FUNC_SDA3>;
			bias-pull-up = <MTK_PULL_SET_RSEL_101>;
		};
	};
};

/* charger start */
&rt_pd_manager {
	nr-port = <2>;
	en-wd0-port0;
};

&pd_adapter {
	nr-port = <2>;
};

&mt6379_typec {
	nr-port = <2>;
	tcpc,en_floatgnd;
	/* 0:16x, 1:128x, 2:512x, 3:1024x */
	wd,wd0_tsleep = <1>;
	/* 0:400us, 1:1ms, 2:2ms, 3:4ms, 4:10ms, 5:40ms, 6:100ms, 7:400ms */
	wd,wd0_tdet = <3>;
	/* example wd0_tsleep = 512x, wd0_tdet = 4ms, wd0 polling time = 512*4ms */
	pd-data {
		pd,source-pdo-data = <0x00019064>;
	};
};

&mtk_ctd {
	nr-port = <2>;
	chg-name-port1 = "primary_chg";
	bc12-sel-port1 = <MTK_CTD_BY_SUBPMIC>;
	bc12-psy-port1 = <&mt6379_chg>;
};

&i2c3 {
	clock-frequency = <100000>;
	status = "okay";
	sc7601@54 {
		compatible = "sc7601";
		ic_role = <0>;
		reg = <0x54>;
		bat-ovp-threshold = <5500>;
		pre-chg-curr = <100>;
		vfc-chg-volt = <3100>;
		limit-chg-curr = <2950>;
		pinctrl-names = "charger_load_switch";
		pinctrl-0 = <&charger_load_switch>;
	};
};

&i2c6 {
	status = "okay";
	clock-frequency = <100000>;
	sc2201@72 {
		compatible = "sc,sc2201";
		reg = <0x72>;
		sc2201,intr-gpio = <&pio 183 IRQ_TYPE_EDGE_FALLING>;
		sc2201,reset-gpio = <&pio 182 0x1>;
		sc,sc2201,wd_timeout = <0>;
		sc,sc2201,dpdm_en = <0>;
		pinctrl-names = "charger_third_pd_phy";
		pinctrl-0 = <&charger_third_pd_phy>;
		phys = <&u2port0 PHY_TYPE_USB2>;
		phy-names = "usb2-phy";
		usb = <&ssusb>;
	};

	sc2150-driver@4e{
		compatible = "southchip,sc2150";
		reg = <0x4e>;
		status = "okay";
		sc-tcpc,name = "type_c_port1"; /* tcpc_device's name */
		sc-tcpc,role_def = <5>; /* 0: Unknown, 1: SNK, 2: SRC */
					/* 3: DRP, 4: Try.SRC, 5: Try.SNK */
		sc-tcpc,rp_level = <1>; /* 0: Default, 1: 1.5, 2: 3.0 */
		sc-tcpc,vconn_supply  = <1>;  /* 0: Never, 1: Always, */
					      /* 2: EMarkOnly, 3: StartOnly */
		sc-tcpc,notifier_supply_num = <2>;
		sc2150,intr-gpio = <&pio 184 IRQ_TYPE_EDGE_FALLING>;
		cid_detin_b = <&pio 23 IRQ_TYPE_EDGE_BOTH>;
		typecidb-supply = <&mt6661_3_ln60_5>;

		pd-data {
			pd,vid = <0x2717>;
			pd,pid = <0x209e>;
			pd,source-cap-ext = /bits/ 8 <0x17 0x27 0x9e 0x20
								0x00 0x00 0x00 0x00
								0x00 0x00 0x00 0x00
								0x00 0x00 0x00 0x00
								0x00 0x00 0x00 0x00
								0x00 0x00 0x01 0x05
								0x00>;
			pd,sink-cap-ext = /bits/ 8 <0x17 0x27 0x9e 0x20
								0x00 0x00 0x00 0x00
								0x01 0x00 0x00 0x00
								0x00 0x00 0x00 0x00
								0x01 0x00 0x00 0x00
								0x00 0x00 0x00 0x00>;
			pd,mfrs = "SouthChip";

			/*
			 *	VSAFE5V = 0, MAX_POWER = 1, CUSTOM = 2,
			 *	MAX_POWER_LV = 0x21, MAX_POWER_LVIC = 0x31
			 *	MAX_POWER_HV = 0x41, MAX_POWER_HVIC = 0x51
			 */
			pd,charging_policy= <0x31>;

			/*
			 * Fixed 5V, 500 mA <0x00019032>
			 * Fixed 5V, 1A <0x00019064>
			 * Fixed 5V, 2A <0x000190c8>
			 * Fixed 5V, 3A <0x0001912c>
			 * Fixed 9V, 500 mA <0x0002d032>
			 * Fixed 9V, 1A <0x0002d064>
			 * Fixed 9V, 2A <0x0002d0c8>
			 * Fixed 9V, 3A <0x0002d12c>
			 * Variable 5-9V, 1A <0x8642d064>
			 * Variable 5-9V, 2A <0x8642d0c8>
			 * Variable 5-9V, 3A <0x8642d12c>
			 * PPS 3V~5.9V, 3A <0xC0761E3C>
			 */
			pd,source-pdo-size = <1>;
			/* Fixed 5V,1A */
			pd,source-pdo-data = <0x36019064>;
			pd,sink-pdo-size = <1>;
			pd,sink-pdo-data = <0x260190c8>;
			/*0110 1110 0011 0010
			 * No DP, host + device
			 *	pd,id-vdo-size = <6>;
			 *	pd,id-vdo-data = <0xd1402717 0x0 0x17110000
						  0x61000000 0x0 0x41000000>;
			 * With DP
			 *	pd,id-vdo-size = <6>;
			 *	pd,id-vdo-data = <0xd54029cf 0x0 0x17110000
						  0x61000000 0x0 0x41000000>;
			 */

			pd,id-vdo-size = <4>;
			pd,id-vdo-data = <0x81402717 0x0 0x209e0200 0x41000000>;

			bat,nr = <1>;
			pd,country_nr = <0>;

			bat-info0 {
				bat,vid = <0x2717>;
				bat,pid = <0x209e>;
				bat,mfrs = "bat1";
				bat,design_cap = <3000>;
			};

		};
		dpm_caps {
			local_dr_power;
			local_dr_data;
			//local_ext_power;
			local_usb_comm;
			//local_usb_suspend;
			//local_high_cap;
			//local_give_back;
			local_no_suspend;
			local_vconn_supply;

			//attempt_discover_cable_dfp;
			//attempt_enter_dp_mode;
			attempt_discover_cable;
			attempt_discover_id;
			attempt_discover_svid;

			/* 0: disable, 1: prefer_snk, 2: prefer_src */
			pr_check = <0>;
			//pr_reject_as_source;
			//pr_reject_as_sink;
			//pr_check_gp_source;
			//pr_check_gp_sink;

			/* 0: disable, 1: prefer_ufp, 2: prefer_dfp */
			dr_check = <0>;
			//dr_reject_as_dfp;
			dr_reject_as_ufp;
		};
		displayport {
			/* connection type = "both", "ufp_d", "dfp_d" */
			1st_connection = "dfp_d";
			2nd_connection = "dfp_d";
			signal,dp_v13;
			//signal,dp_gen2;
			//usbr20_not_used;
			typec,receptacle;
			ufp_d {
				//pin_assignment,mode_a;
				//pin_assignment,mode_b;
				//pin_assignment,mode_c;
				//pin_assignment,mode_d;
				//pin_assignment,mode_e;
			};
			dfp_d {
				//pin_assignment,mode_a;
				//pin_assignment,mode_b;
				pin_assignment,mode_c;
				pin_assignment,mode_d;
				pin_assignment,mode_e;
				//pin_assignment,mode_f;
			};
		};
	};
};

&i2c8 {
	status = "ok";
	hl7603@76 {
		compatible = "hl7603_1";
		reg = <0x76>;
		vout_threshold = <4800>;
	};
};

&i2c9 {
	clock-frequency = <400000>;
	status = "okay";
	bq28z610@55 {
		compatible = "bq28z610-master";
		reg = <0x55>;
		enable_shutdown_delay;
		max_chg_power_120w;
		normal_shutdown_vbat_1s = <3200>;
		critical_shutdown_vbat_1s = <3250>;
		cool_critical_shutdown_vbat_1s = <3250>;
		old_critical_shutdown_vbat_1s = <3250>;
		report_full_rsoc_1s = <9500>;
		soc_gap_1s = <2>;
		ic_role = <0>;
		batt1_ctrl_gpio = <&pio 79 0x0>;
		batt2_ctrl_gpio = <&pio 78 0x0>;
		fgvio28-supply = <&mt6661_4_ldc0_3>;
		/*pinctrl-names = "slave_connect_cfg";*/
		/*pinctrl-0 = <&slave_connect_cfg>;*/
		soc_decimal_rate = <
			0  38
			10 35
			20 33
			30 33
			40 33
			50 33
			60 33
			70 30
			80 25
			90 20
			95 10 >;
		fg-type = <1>;
	};
};

&i2c10 {
	clock-frequency = <400000>;
	status = "okay";
	bq28z610@55 {
		compatible = "bq28z610-slave";
		reg = <0x55>;
		enable_shutdown_delay;
		max_chg_power_120w;
		normal_shutdown_vbat_1s = <3200>;
		critical_shutdown_vbat_1s = <2960>;
		cool_critical_shutdown_vbat_1s = <2940>;
		old_critical_shutdown_vbat_1s = <2940>;
		report_full_rsoc_1s = <9500>;
		soc_gap_1s = <2>;
		ic_role = <1>;
		batt1_ctrl_gpio = <&pio 79 0x0>;
		batt2_ctrl_gpio = <&pio 78 0x0>;
		fgvio28-supply = <&mt6661_4_ldc0_3>;
		/*pinctrl-names = "slave_connect_cfg";*/
		/*pinctrl-0 = <&slave_connect_cfg>;*/
		soc_decimal_rate = <
			0  38
			10 35
			20 33
			30 33
			40 33
			50 33
			60 33
			70 30
			80 25
			90 20
			95 10 >;
		fg-type = <1>;
	};
};

&i2c11 {
	status = "okay";
	clock-frequency = <400000>;
	scl-gpio-id = <160>;
	sda-gpio-id = <161>;
	sc96231@38{
		compatible = "sc,sc96231-wireless-charger";
		reg = <0x38>;
		project_vendor = <2>;
		fw_version_index = <0>;
		reverse-boost-gpio = <&pio 210 0x0>;
		reverse-txon-gpio = <&pio 211 0x0>;
		rx-int = <&pio 230 IRQ_TYPE_EDGE_FALLING>;
		hall3-int = <&pio 48 IRQ_TYPE_EDGE_FALLING>;
		hall4-int = <&pio 1 IRQ_TYPE_EDGE_FALLING>;
		hall3-s-int = <&pio 14 IRQ_TYPE_EDGE_FALLING>;
		hall4-s-int = <&pio 50 IRQ_TYPE_EDGE_FALLING>;
	};
};

&charger {
	max_charger_voltage = <12000000>;
	/* charging current */
	usb_charger_current = <500000>;
	ac_charger_current = <1600000>;
	ac_charger_input_current = <1600000>;
	charging_host_charger_current = <900000>;
	step_fallback_hyst = <25>;
	step_forward_hyst = <0>;
	jeita_fallback_hyst = <10>;
	jeita_forward_hyst = <10>;
	mt6661_moscon1_control;
	mt6661_moscon2_control;
	pmic_ffc_forbid;
	en_floatgnd;
	smart_snschg_v2_support;
	pd2_input_current = <1700000>;
	min_charger_voltage_1 = <4200000>;
	min_charger_voltage_2 = <4500000>;
	sbu_uart_en = <&pio 24 0x0>;
	ffc_low_tbat = <180>;
	ffc_medium_tbat = <300>;
	ffc_warm_tbat = <350>;
	ffc_little_high_tbat = <400>;
	ffc_high_tbat = <480>;
	ffc_high_soc = <95>;
	adapter_power = <66>;
	support_quick_revchg;

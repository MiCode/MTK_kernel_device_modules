				4144	4343	10300
				4344	4393	8400
				4394	4523	8400
				4524	4560	7168>;
	flip_step_chg_cfg_1_cycle = <3000	4143	6900
				4144	4343	5600
				4344	4393	4455
				4394	4523	4455
				4524	4560	3564>;
	iterm_ffc_1_cycle = <940>;
	iterm_ffc_little_warm_1_cycle = <940>;
	iterm_ffc_warm_1_cycle = <1437>;
	iterm_ffc_hot_1_cycle = <1437>;

	slave_batt_iterm_ffc_1_cycle = <930>;

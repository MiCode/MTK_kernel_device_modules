		0x2B01 0x0000A819 100 1 11000 4500    // 酷泰科140W-AD1404U or 米家户外1000pro
		0x2B01 0x0000A819 55  1 11000 3500    // 小米充电宝-PB2050ZM
		0x12D1 0x00000000 94  1 11000 3500    // 华为90W-200450CP0
		0x2B01 0x00005B15 120 1 11000 4500    // P03MI

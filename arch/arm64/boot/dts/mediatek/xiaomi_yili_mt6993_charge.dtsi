	normal_cutoff_margin_mv = <10>;
	step_normal_chg;
	support_pchg_policy;
	support_low_ibat_switch_buck;

	/* low power charger termination adjust parameter*/
	support-lp-chgr-term-adjust;
	lp-chgr-vterm-drop = <10>;
	lp-chgr-iterm = <150>;

	/* CN battery paremeter */
	fv = <4530>;
	fv_normal = <4510>;
	fv_normal_warm = <4510>;  /* 35 - 40C */
	fv_normal_high = <4510>;  /* 40 - 48C */
	fv_ffc = <4560>;
	iterm = <240>;
	iterm_warm = <240>;
	slave_batt_iterm = <238>;
	slave_batt_iterm_warm = <238>;

	jeita_fcc_cfg = <(-100)	30	4150	897	897
			31	80	4150	1792	1792
			81	130	4150	4481	4481
			131	180	4150	7168	7168
			181	470	4150	12400	12400
			471	600	4090	4481	4481>;
	jeita_fv_cfg = <(-100)	30	4530
			31	80	4530
			81	130	4530
			131	180	4530
			181	470	4560
			471	600	4090>;

	flip_jeita_fcc_cfg = <(-100)	30	4150	446	446
			31	80	4150	891	891
			81	130	4150	2228	2228
			131	180	4150	3564	3564
			181	470	4150	6900	6900
			471	600	4090	2228	2228>;
	flip_jeita_fv_cfg = <(-100)	30	4530
			31	80	4530
			81	130	4530
			131	180	4530
			181	470	4560
			471	600	4090>;

	/* 1-100cls */

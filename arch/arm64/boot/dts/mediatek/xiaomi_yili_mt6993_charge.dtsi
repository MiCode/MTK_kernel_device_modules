				4121	4320	9740
				4321	4400	7912
				4401	4500	7912
				4501	4540	6810>;
	flip_step_chg_cfg_100_cycle = <3000	4120	6900
				4120	4320	5320
				4321	4400	4232
				4401	4500	4232
				4501	4540	3386>;

	/* 300-800cls */

	&thermal_zones {
		conn_therm2: conn_therm2 {
			polling-delay = <0>; /* milliseconds */
			polling-delay-passive = <0>; /* milliseconds */
			thermal-sensors = <&tboard_thermistor4>;

			trips {
				conn_therm2_crit: conn-therm2-crit {
					temperature = <118800>;
					hysteresis = <2000>;
					type = "passive";
				};
			};
		};
		display_therm: display_therm {
			polling-delay = <0>; /* milliseconds */
			polling-delay-passive = <0>; /* milliseconds */
			thermal-sensors = <&tboard_thermistor5>;

			trips {

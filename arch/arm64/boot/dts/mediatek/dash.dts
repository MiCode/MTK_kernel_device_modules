/* svp start */
&mtee_svp {
	mtee: MTEE {
		compatible = "mediatek,mtk_svp_on_mtee_support";
	};
	svp: SecureVideoPath {
		compatible = "mediatek,mtk_sec_video_path_support";
	};
};
&mtkheap_page_tee {
	status = "ok";
};
&mtkheap_page_svp {
	status = "ok";
};
/* svp end */

#include <dash/cust.dtsi>
#include "mediatek/cust_k6991v2_connfem.dtsi"

#include "mediatek/bat_setting/mt6991p_battery_prop.dtsi"

&mtk_gauge {
	DISABLE_MTKBATTERY = <(1)>;
	FIXED_BATTERY_TEMPERATURE = <25>;

	temperature-t0 = <(50)>;
	/* Battery temperature T0 */
	temperature-t1 = <(25)>;
	/* Battery temperature T1 */
	temperature-t2 = <(10)>;
	/* Battery temperature T2 */
	temperature-t3 = <(0)>;
	/* Battery temperature T3 */
	temperature-t4 = <(-10)>;
	/* Battery temperature T4 */
	temperature-t5 = <(-20)>;
	/* Battery temperature T5 */
	active-table = <(6)>;
	#include "mediatek/dash_mt6991s_battery_table.dtsi"
};

#include "mediatek/xiaomi_dash_mt6991_touch.dtsi"
#include "mediatek/dash_mt6991_camera_v4l2.dtsi"
#include "mediatek/xiaomi_dash_mt6991_fingerprint.dtsi"
/*End of this file, DO NOT ADD ANYTHING HERE*/

&pio {
	/* Foursemi Haptic start */
	foursemi_gpio_reset: foursemi_reset_reset {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO42__FUNC_GPIO42>;
			drive-strength = <2>;
			bias-disable;
			output-low;
		};
	};
	foursemi_gpio_reset_output_high: foursemi_reset_active {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO42__FUNC_GPIO42>;
			drive-strength = <2>;
			bias-disable;
			output-high;
		};
	};
	foursemi_gpio_int: foursemi_interrupt_active {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO5__FUNC_GPIO5>;
			drive-strength = <2>;
			bias-pull-up;
			input-enable;
		};
	};

	/* SI Haptic start */
	sih_reset_low: sih_reset_reset {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO42__FUNC_GPIO42>;
			drive-strength = <2>;
			bias-disable;
			output-low;
		};
	};
	sih_reset_high: sih_reset_active {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO42__FUNC_GPIO42>;
			drive-strength = <2>;
			bias-disable;
			output-high;
		};
	};
	sih_interrupt: sih_interrupt_active {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO5__FUNC_GPIO5>;
			drive-strength = <2>;
			bias-pull-up;
			input-enable;
		};
	};
};

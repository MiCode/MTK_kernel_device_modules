#include <dt-bindings/clock/mt6991-clk.h>
#include <dt-bindings/interrupt-controller/arm-gic.h>
#include <dt-bindings/interrupt-controller/irq.h>
#include <dt-bindings/phy/phy.h>
#include <dt-bindings/pinctrl/mt6991-pinfunc.h>
#include <dt-bindings/power/mt6991-power.h>
#include "mediatek/dash-mt6991-common.dtsi"
#include <dt-bindings/iio/mt635x-auxadc.h>
#include <dt-bindings/thermal/thermal.h>
#include <dt-bindings/gce/mt6991-gce.h>
#include "mediatek/dash-sensor-common.dtsi"
#include "mediatek/cust_mt6991_nfc_nxp_dash.dtsi"
#include "mediatek/xiaomi_dash_t1_chip.dtsi"

&chosen {
bootargs_ext = "cpufreq.default_governor=conservative \
		rcu_nocbs=0-7";
bootargs_ext_fac = "cpufreq.default_governor=conservative \
		rcu_nocbs=0-7";
};

&mtk_leds {
	compatible = "mediatek,disp-leds";
	backlight {
		max-brightness = <16383>;
		min-brightness = <1>;
		max-hw-brightness = <16383>;
		led_mode = <4>;
		default-state = "FifteenPercent";
	};
};

&odm {
	thermal_message: thermal-message {
		board-sensor = "VIRTUAL-SENSOR";
	};
};

&mmqos {
	r-hrt-ostdl = <2>;
};

&mt6373_adc {
	vin1-open {
		channel = <AUXADC_VIN1>;
		pures = <ADC_PURES_100K>;
	};
	vin2-open {
		channel = <AUXADC_VIN2>;
		pures = <ADC_PURES_100K>;
	};
	vin4-open {
		channel = <AUXADC_VIN4>;
		pures = <ADC_PURES_100K>;
	};
	vin5-open {
		channel = <AUXADC_VIN5>;
		pures = <ADC_PURES_100K>;
	};
};

&ise_mbox {
	mediatek,real-drv = <0>;
};

&ise_lpm {
	ise-wakelock = <0>;
	ise-lpm-freerun = <0>;
	ise-lpm-deinit-bypass = <0>;
	power-domains = <&scpsys MT6991_POWER_DOMAIN_SSR>;
};

&ise_trusty {
	mediatek,real-drv = <0>;
};

&pmic_adc {
	vin3_100k {
		channel = <AUXADC_VIN3>;
		pures = <ADC_PURES_100K>;
	};
	vin4_open {
		channel = <AUXADC_VIN4>;
		pures = <ADC_PURES_100K>;
	};
	vin6_100k {
		channel = <AUXADC_VIN6>;
		pures = <ADC_PURES_100K>;
	};
	vin7_100k {
		channel = <AUXADC_VIN7>;
		pures = <ADC_PURES_100K>;
	};
};

&rt5133
{
	status = "disabled";
};
&rt5133_gpio1
{
	status = "disabled";
};
&rt5133_gpio2
{
	status = "disabled";
};
&rt5133_gpio3
{
	status = "disabled";
};
&rt6160_bob
{
	status = "disabled";
};
&pio {
	mtkfb_pins_lcd_bias_enp1: lcd-bias-enp1-gpio {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO103__FUNC_GPIO103>;
			slew-rate = <1>;
			output-high;
		};
	};

	mtkfb_pins_lcd_bias_enp0: lcd-bias-enp0-gpio {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO103__FUNC_GPIO103>;
			slew-rate = <1>;
			output-low;
		};
	};

	mtkfb_pins_lcd_bias_enn1: lcd-bias-enn1-gpio {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO103__FUNC_GPIO103>;
			slew-rate = <1>;
			output-high;
		};
	};

	mtkfb_pins_lcd_bias_enn0: lcd-bias-enn0-gpio {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO103__FUNC_GPIO103>;
			slew-rate = <1>;
			output-low;
		};
	};

	mtkfb_pins_lcm_rst_out1_gpio: lcm-rst-out1-gpio {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO90__FUNC_GPIO90>;
			slew-rate = <1>;
			output-high;
		};
	};

	mtkfb_pins_lcm_rst_out0_gpio: lcm-rst-out0-gpio {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO90__FUNC_GPIO90>;
			slew-rate = <1>;
			output-low;
		};
	};
	mtkfb_pins_lcm_dsi_te: lcm-dsi-te {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO89__FUNC_DSI_TE>;
		};
	};

	mtkfb_pins_lcm_led_en1: lcm-led-en1-gpio {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO174__FUNC_GPIO174>;
			slew-rate = <1>;
			output-high;
		};
	};

	mtkfb_pins_lcm_led_en0: lcm-led-en0-gpio {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO174__FUNC_GPIO174>;
			slew-rate = <1>;
			output-low;
		};
	};

	mtkfb_pins_lcm_dsi1_te: lcm-dsi1-te {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO6__FUNC_DSI1_TE>;
		};
	};
};

&mtkfb {
	pinctrl-names = "lcd_bias_enp1_gpio", "lcd_bias_enp0_gpio",
		"lcd_bias_enn1_gpio", "lcd_bias_enn0_gpio",
		"lcm_rst_out1_gpio", "lcm_rst_out0_gpio",
		"mode_te_te", "lcm_led_en1_gpio", "lcm_led_en0_gpio",
		"mode_te_te1";
	pinctrl-0 = <&mtkfb_pins_lcd_bias_enp1>;
	pinctrl-1 = <&mtkfb_pins_lcd_bias_enp0>;
	pinctrl-2 = <&mtkfb_pins_lcd_bias_enn1>;
	pinctrl-3 = <&mtkfb_pins_lcd_bias_enn0>;
	pinctrl-4 = <&mtkfb_pins_lcm_rst_out1_gpio>;
	pinctrl-5 = <&mtkfb_pins_lcm_rst_out0_gpio>;
	pinctrl-6 = <&mtkfb_pins_lcm_dsi_te>;
	pinctrl-7 = <&mtkfb_pins_lcm_led_en1>;
	pinctrl-8 = <&mtkfb_pins_lcm_led_en0>;
	pinctrl-9 = <&mtkfb_pins_lcm_dsi1_te>;

	status = "okay";
};

&dispsys_config {
	pinctrl-names = "mode_te_te", "mode_te_te1";
	pinctrl-0 = <&mtkfb_pins_lcm_dsi_te>;
	pinctrl-1 = <&mtkfb_pins_lcm_dsi1_te>;

	status = "okay";
//	enable-discrete-path = <1>;
//	bypass-pc-path = <0>;

	helper-name-proj = "MTK_DRM_OPT_IDLEMGR_DISABLE_ROUTINE_IRQ",
		"MTK_DRM_OPT_MML_DL_SUB_CFG_CLINET",
		"MTK_DRM_OPT_OVL_WCG",
		"MTK_DRM_OPT_OVL_WCG_BY_COLOR_MODE",
		"MTK_DRM_OPT_DSI_UNDERRUN_AEE";

	helper-value-proj = <1>, /*MTK_DRM_OPT_IDLEMGR_DISABLE_ROUTINE_IRQ*/
		<1>, /*MTK_DRM_OPT_MML_DL_SUB_CFG_CLINET*/
		<1>, /*MTK_DRM_OPT_OVL_WCG*/
		<1>, /*MTK_DRM_OPT_OVL_WCG_BY_COLOR_MODE*/
		<1>; /*MTK_DRM_OPT_DSI_UNDERRUN_AEE*/
};

&disp_dpc {
	vidle-mask = <0x0>;
};

&mipi_tx_config1 {
//	status = "okay";
};

&dsi1 {
//	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;
	init-panel-off;
	panel1@0 {
		compatible = "truly,td4330,cmd";
		reg = <0>;
		pm-enable-gpios = <&pio 215 0>;
		reset-gpios = <&pio 5 0>;
		swap-from-dts;
		lane-swap-setting = <1 2 0 3 4 2>;
		pn-swap-setting = <1 1 1 1 1 1>;
		gate-ic = <4831>;
		pinctrl-names = "default";
		port {
			panel1_in: endpoint {
				remote-endpoint = <&dsi1_out>;
			};
		};
	};
	panel2@1 {
		compatible = "jdi,nt36672e,vdo,120hz";
		reg = <1>;
		pm-enable-gpios = <&pio 215 0>;
		reset-gpios = <&pio 5 0>;
		gate-ic = <4831>;
		pinctrl-names = "default";
		port {
			panel2_in: endpoint {
				remote-endpoint = <&dsi1_out2>;
			};
		};
	};
	panel3@2 {
		compatible = "jdi,nt36672e,cphy,vdo";
		reg = <2>;
		pm-enable-gpios = <&pio 215 0>;
		reset-gpios = <&pio 5 0>;
		gate-ic = <4831>;
		pinctrl-names = "default";
		port {
			panel3_in: endpoint {
				remote-endpoint = <&dsi1_out3>;
			};
		};
	};
	panel4@3 {
		compatible = "jdi,nt36672e,vdo,60hz";
		reg = <3>;
		pm-enable-gpios = <&pio 215 0>;
		reset-gpios = <&pio 5 0>;
		gate-ic = <4831>;
		pinctrl-names = "default";
		port {
			panel4_in: endpoint {
				remote-endpoint = <&dsi1_out4>;
			};
		};
	};
	ports {
		port {
			dsi1_out: endpoint@0 {
				remote-endpoint = <&panel1_in>;
			};

			dsi1_out2: endpoint@1 {
				remote-endpoint = <&panel2_in>;
			};

			dsi1_out3: endpoint@2 {
				remote-endpoint = <&panel3_in>;
			};

			dsi1_out4: endpoint@3 {
				remote-endpoint = <&panel4_in>;
			};
		};
	};
};

&dsi1_te {
	interrupt-parent = <&pio>;
	interrupts = <6 1 6 1>;
	status = "okay";
};

&dsi0 {
	switch-spr = <1>;
	spr-ip-type = <0>;
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;
	dash_42_02_0a_dsc_vdo:panel1@0 {
		compatible = "p10u_42_02_0a_dsc_vdo,lcm";
		reg = <0>;
		//pm-enable-gpios = <&pio 174 0>;
		reset-gpios = <&pio 90 0>;
		mi,esd-err-irq-gpio = <&pio 6 0x2002>;
		res-switch = <2>;
		//gate-ic = <4831>;
		pinctrl-names = "default";
		vcn18io-supply = <&mt6373_vcn18io>;
		vibr-supply = <&mt6373_vibr>;
		//vbuck8-supply = <&mt6373_vbuck8>;
		amoled-dvdd-supply = <&mt6363_vcn13>;
		port {
			panel_in1: endpoint {
				remote-endpoint = <&dsi_out>;
			};
		};
	};

	dash_36_02_0b_dsc_vdo:panel2@1 {
		compatible = "p10u_36_02_0b_dsc_vdo,lcm";
		reg = <1>;
		//pm-enable-gpios = <&pio 174 0>;
		reset-gpios = <&pio 90 0>;
		mi,esd-err-irq-gpio = <&pio 6 0x2002>;
		res-switch = <2>;
		//gate-ic = <4831>;
		pinctrl-names = "default";
		vcn18io-supply = <&mt6373_vcn18io>;
		vibr-supply = <&mt6373_vibr>;
		//vbuck8-supply = <&mt6373_vbuck8>;
		amoled-dvdd-supply = <&mt6363_vcn13>;
		port {
			panel_in2: endpoint {
				remote-endpoint = <&dsi_out2>;
			};
		};
	};

	ports {
		port {
			dsi_out: endpoint {
				remote-endpoint = <&panel_in1>;
			};
			dsi_out2: endpoint2 {
				remote-endpoint = <&panel_in2>;
			};
		};
	};
};

&pio {
	rptr_enable: rptr-enable {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO72__FUNC_GPIO72>;
			output-high;
		};
	};

	rptr_disable: rptr-disable {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO72__FUNC_GPIO72>;
			output-low;
		};
	};
};

&ssusb {
	mediatek,force-vbus;
	mediatek,clk-mgr;
	mediatek,usb3-drd;
	mediatek,uds = <&usb_dp_selector 19>;
	mediatek,eusb2-cm-l1 = <0x474>;
	usb-role-switch;
	status = "okay";
};

&usb_host {
	mediatek,usb-offload = <&usb_offload>;
	status = "okay";
};

&mt6379_eusb2_repeater {
	status = "okay";
	mediatek,param-override-seq =
	<
		0x1 0x6 /*mediatek,discth = <0xf>;*/
		0x2 0x4 /*mediatek,equalization = <0x4>;*/
		0x3 0x4 /*mediatek,vrt-sel = <0x2>;*/
		0x4 0x5 /*mediatek,pre-emphasis = <0x5>;*/
		0x5 0x5 /*mediatek,rx-sqth = <0x0>;*/
		0x6 0x0 /*mediatek,term-ofs = "4";*/
		0x7 0x0 /*mediatek,intr-ofs = "2";*/
	>;

	mediatek,param-override-seq-factory =
	<
		0x1 0x6 /*mediatek,discth = <0xf>;*/
		0x2 0x4 /*mediatek,equalization = <0x4>;*/
		0x3 0x4 /*mediatek,vrt-sel = <0x2>;*/
		0x4 0x5 /*mediatek,pre-emphasis = <0x5>;*/
		0x5 0x5 /*mediatek,rx-sqth = <0x0>;*/
		0x6 0x0 /*mediatek,term-ofs = "4";*/
		0x7 0x0 /*mediatek,intr-ofs = "2";*/
	>;

	mediatek,param-override-seq-carwith =
	<
		0x1 0x6 /*mediatek,discth = <0xf>;*/
		0x2 0x4 /*mediatek,equalization = <0x4>;*/
		0x3 0x4 /*mediatek,vrt-sel = <0x2>;*/
		0x4 0x5 /*mediatek,pre-emphasis = <0x5>;*/
		0x5 0x1 /*mediatek,rx-sqth = <0x0>;*/
		0x6 0x5 /*mediatek,term-ofs = "4";*/
		0x7 0x0 /*mediatek,intr-ofs = "2";*/
	>;


	mediatek,host-param-override-seq =
	<
		0x1 0x7 /*mediatek,discth = <0xf>;*/
		0x2 0x4 /*mediatek,equalization = <0x4>;*/
		0x3 0x4 /*mediatek,vrt-sel = <0x2>;*/
		0x4 0x4 /*mediatek,pre-emphasis = <0x5>;*/
		0x5 0x0 /*mediatek,rx-sqth = <0x0>;*/
		0x6 0x0 /*mediatek,term-ofs = "4";*/
		0x7 0x0 /*mediatek,intr-ofs = "2";*/
	>;

	mediatek,host-param-override-seq-factory =
	<
		0x1 0x6 /*mediatek,discth = <0xf>;*/
		0x2 0x4 /*mediatek,equalization = <0x4>;*/
		0x3 0x1 /*mediatek,vrt-sel = <0x2>;*/
		0x4 0x4 /*mediatek,pre-emphasis = <0x5>;*/
		0x5 0x5 /*mediatek,rx-sqth = <0x0>;*/
		0x6 0x0 /*mediatek,term-ofs = "4";*/
		0x7 0x0 /*mediatek,intr-ofs = "2";*/
	>;

	mediatek,host-param-override-seq-storage =
	<
		0x1 0xe /*mediatek,discth = <0xf>;*/
		0x2 0x4 /*mediatek,equalization = <0x4>;*/
		0x3 0x4 /*mediatek,vrt-sel = <0x2>;*/
		0x4 0x4 /*mediatek,pre-emphasis = <0x5>;*/
		0x5 0x0 /*mediatek,rx-sqth = <0x0>;*/
		0x6 0x0 /*mediatek,term-ofs = "4";*/
		0x7 0x0 /*mediatek,intr-ofs = "2";*/
	>;

};

&nxp_eusb2_repeater {
	pinctrl-names = "enable", "disable";
	pinctrl-0 = <&rptr_enable>;
	pinctrl-1 = <&rptr_disable>;
	status = "okay";
};

&pcie0 {
	pinctrl-names = "init", "default", "sleep", "pd";
	pinctrl-0 = <&pcie0_pins_init>;
	pinctrl-1 = <&pcie0_pins_default>;
	pinctrl-2 = <&pcie0_pins_sleep>;
	pinctrl-3 = <&pcie0_pins_pd>;
	max-link-speed = <3>;
	status = "okay";
};

&pcie1 {
	pinctrl-names = "default";
	pinctrl-0 = <&pcie1_pins_default>;
	max-link-speed = <4>;
	status = "disabled";
};

&pciephy0 {
	status = "okay";
};

&pciephy1 {
	status = "disabled";
};

/* PCIe pinmux start and falcon not use waken */
&pio {
	pcie0_pins_init: pcie0-init {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO241__FUNC_GPIO241>;
			output-low;
		};

		pins-cmd-dat1 {
			pinmux = <PINMUX_GPIO243__FUNC_GPIO243>;
			bias-pull-up;
			input-enable;
		};

		pins-cmd-dat2 {
			pinmux = <PINMUX_GPIO242__FUNC_GPIO242>;
			bias-pull-down;
			input-enable;
		};
	};

	pcie0_pins_default: pcie0-default {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO241__FUNC_PCIE_PERSTN>,
				 <PINMUX_GPIO243__FUNC_PCIE_CLKREQN>;
			bias-pull-up;
		};

		pins-cmd-dat1 {
			pinmux = <PINMUX_GPIO242__FUNC_GPIO242>;
			bias-pull-down;
			input-enable;
		};
	};

	pcie0_pins_sleep: pcie0-sleep {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO241__FUNC_GPIO241>;
			output-low;
		};

		pins-cmd-dat1 {
			pinmux = <PINMUX_GPIO243__FUNC_GPIO243>;
			bias-pull-up;
			input-enable;
		};

		pins-cmd-dat2 {
			pinmux = <PINMUX_GPIO242__FUNC_GPIO242>;
			bias-pull-down;
			input-enable;
		};
	};

	pcie0_pins_pd: pcie0-pd {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO241__FUNC_GPIO241>;
			output-low;
		};

		pins-cmd-dat1 {
			pinmux = <PINMUX_GPIO243__FUNC_GPIO243>,
				 <PINMUX_GPIO242__FUNC_GPIO242>;
			bias-pull-down;
			input-enable;
		};
	};

	pcie1_pins_default: pcie1-default {
		pins-cmd-dat {
			pinmux = <PINMUX_GPIO145__FUNC_PCIE_WAKEN_1P>,
				 <PINMUX_GPIO146__FUNC_PCIE_PERSTN_1P>,
				 <PINMUX_GPIO147__FUNC_PCIE_CLKREQN_1P>;
			bias-pull-up = <MTK_PUPD_SET_R1R0_01>;
		};
	};
};
/* PCIe pinmux end */

&snd_audio_dsp {
	swdsp-smartpa-process-enable = <0x5>;
	mtk-dsp-call-final = <0x5 0xe 0x13 0x12 0x18000>;
};

&adspsys {
	adsp-rsv-ipidma-a = <0x104000>;
};

